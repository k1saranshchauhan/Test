"use client";
import React, { useEffect, useState } from "react";
import { useFormik } from "formik";
import {
  Grid,
  Button,
  TextField,
  Autocomplete,
  Divider,
  Box,
  Typography,
  CircularProgress,
  Tooltip,
} from "@mui/material";
import * as Yup from "yup";
import { CustomAutoComplete } from "@/src/components/superadmin/CustomAutoComplete";
import MainFormHeader from "@/src/components/DashboardUI/MainFormHeader";
import apiClient from "@/utils/apiClient";
import { useDispatch, useSelector } from "react-redux";
import { setError, setSuccess } from "@/store/slices/errorSlice";
import { oomfFrameworkId } from "@/src/constants/unified/frameworkConstants";


const PrayasIntegration = () => {
  const dispatch = useDispatch();
  const [questionnaireList, setQuestionnaireList] = useState([]);
  const [quarterList, setQuarterList] = useState([]);
  const [responseData, setResponseData] = useState([]);
  const userData = useSelector((state) => state.config.userData);
  
      //utility for latest entry
  function getLatestEntry(data, key = "created_at") {
    if (!Array.isArray(data) || data.length === 0) return null;

    return data.reduce((latest, current) => {
      return new Date(current[key]) > new Date(latest[key]) ? current : latest;
    });
  }


  const formik = useFormik({
    initialValues: {
      questionnaire: "",
      quarter: "",
    },
    validationSchema: Yup.object().shape({
      questionnaire: Yup.array().min(1, "Questionnaire is Required"),
      quarter: Yup.array().min(1, "Quarter is Required"),
    }),
    onSubmit: async (values) => {
      const payload = {
        questionnaireId:
          values?.questionnaire?.id || "",
        datadate:
          values?.quarter?.label || "",
      };
      try {
        const res = await apiClient.post(
          "/api/dgqi/prayasIntegration/pushdata",
          payload
        );
        setResponseData(res?.data)
      } catch (error) {
        console.error("API Error:", error);
      }
    },
  });
  //API calls
      const fetchQuestionnaire = async () => {
      try {
        const res = await apiClient.get(
          "/api/dgqi/questionnaires/published-questionnaires",
        );
        const data = res.data.data || [];
        // const latestByCreated = getLatestEntry(data, "created_at");
        // setSelectedQuestionnaire({
        //   id: latestByCreated?.id,
        //   name: latestByCreated?.title,
        //   financialYear: latestByCreated?.financial_year,
        // });
        setQuestionnaireList(
          data.map((item) => ({
            id: item.id,
            name: item.title,
            financialYear: item?.financial_year,
          })),
        );
      } catch (error) {
        setQuestionnaireList([]);
        console.error("Failed to fetch published questionnaires:", error);
      }
    };  
    const fetchQuarter = async () => {
      try {
        const res = await apiClient.get(
          "/api/dgqi/prayasIntegration/quarters",
        );
        const data = res.data.data || [];
        setQuarterList(
          data.map((item) => ({
            id: item.id,
            name: item.title,
          })),
        );
      } catch (error) {
        setQuarterList([]);
        console.error("Failed to fetch quarter:", error);
      }
    }; 
    useEffect(()=>{
        fetchQuestionnaire();
    },[]) 

      useEffect(()=>{
        fetchQuarter();
    },[formik?.values?.questionnaire]) 


  return (
    <>
      <Box marginTop={2} padding={3}>
        <form onSubmit={formik.handleSubmit}>
          <MainFormHeader title="Prayas Integration" />
          <Divider sx={{ marginTop: 2, mb: 5 }} />
          <Grid container spacing={2}>
            <Grid size={{ xs: 12, sm: 6 }}>
              <CustomAutoComplete
                name="questionnaire"
                options={questionnaireList || []}
                label="Questionnaire"
                formik={formik}
                required
                selectAll={false}
                multiple={false}
              />
            </Grid>

            <Grid size={{ xs: 12, sm: 6 }}>
              <Tooltip
                title={
                  !formik?.values?.questionnaire?.length
                    ? "Select Questionnaire first"
                    : ""
                }
                placement="top"
                arrow
              >
                <div>
                  <CustomAutoComplete
                    name="quarter"
                    options={quarterList || []}
                    label="Quarter"
                    formik={formik}
                    required
                    readOnly={!formik?.values?.questionnaire?.length}
                    selectAll={false}
                multiple={false}
                  />
                </div>
              </Tooltip>
            </Grid>
          </Grid>
          <Grid container spacing={2}>
            <Grid size={{ xs: 12, sm: 6 }}>
              <Button
                type="submit"
                fullWidth
                variant="contained"
                color="primary"
                sx={{ mt: 3 }}
              >
                Submit
              </Button>
            </Grid>
            <Grid size={{ xs: 12, sm: 6 }}>
              <Button
                type="reset"
                fullWidth
                variant="outlined"
                color="inherit"
                sx={{ mt: 3 }}
                onClick={() => {
                  formik.resetForm();
                }}
              >
                Clear
              </Button>
            </Grid>
          </Grid>
        </form>
        <Box sx={{ mt: 6 }}>
          {!responseData ? (
            <Box sx={{ display: "flex", justifyContent: "center", mt: 8 }}>
              <CircularProgress color="primary" />
            </Box>
          ) : responseData?.length === 0 ? (
            <Box
              sx={{
                textAlign: "center",
                mt: 8,
                color: "#6c757d",
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
              }}
            >
              <Typography variant="h6" gutterBottom>
                Please select the values to submit
              </Typography>
              {/* <Typography variant="body2">
                No data available for the selected filters.
              </Typography> */}
            </Box>
          ) : (
            <Box
              sx={{
                textAlign: "center",
                mt: 8,
                color: "#6c757d",
                display: "flex",
                flexDirection: "column",
                alignItems: "center",
              }}
            >
              <Typography variant="h6" gutterBottom>
                Data sent successfully
              </Typography>
            </Box>
          )}
        </Box>
      </Box>
    </>
  );
};

export default PrayasIntegration;
