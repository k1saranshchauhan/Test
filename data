import React from "react";
import {
  Table,
  TableBody,
  TableCell,
  TableContainer,
  TableHead,
  TableRow,
  Paper,
  Typography,
  Box,
  styled,
} from "@mui/material";

// Deep professional color palette
const THEME_COLOR = "#45154F";
const BORDER_COLOR = "#632a6d";

const StyledHeaderCell = styled(TableCell)(({ theme }) => ({
  backgroundColor: THEME_COLOR,
  color: theme.palette.common.white,
  fontWeight: "bold",
  textAlign: "center",
  border: `1px solid ${BORDER_COLOR}`,
  padding: "12px 8px",
  fontSize: "0.9rem",
}));

const getComplianceColor = (value) => {
  const num = parseFloat(value);
  if (isNaN(num)) return "transparent";
  if (num >= 80) return "#90ee90"; // Light Green
  if (num >= 50) return "#fff9c4"; // Light Yellow
  return "#f8bbd0"; // Light Red/Pink
};

const TableComponent = ({ data }) => {
  if (!data || data.length === 0) return null;

  return (
    <Box sx={{ p: 3, backgroundColor: "#fdfdfd" }}>
      <TableContainer 
        component={Paper} 
        sx={{ 
          boxShadow: "0px 4px 20px rgba(0,0,0,0.1)", 
          borderRadius: "8px",
          border: "1px solid #ccc" 
        }}
      >
        <Table size="small" sx={{ minWidth: 1000 }}>
          <TableHead>
            <TableRow>
              <StyledHeaderCell rowSpan={2}>Ministry Name</StyledHeaderCell>
              <StyledHeaderCell rowSpan={2}>Department Name</StyledHeaderCell>
              <StyledHeaderCell rowSpan={2}>Scheme Name</StyledHeaderCell>
              <StyledHeaderCell colSpan={2}>Output Indicators</StyledHeaderCell>
              <StyledHeaderCell colSpan={2}>Outcome Indicators</StyledHeaderCell>
            </TableRow>
            <TableRow>
              <StyledHeaderCell sx={{ borderTop: `1px solid ${BORDER_COLOR}` }}>Total</StyledHeaderCell>
              <StyledHeaderCell sx={{ borderTop: `1px solid ${BORDER_COLOR}` }}>Compliance (%)</StyledHeaderCell>
              <StyledHeaderCell sx={{ borderTop: `1px solid ${BORDER_COLOR}` }}>Total</StyledHeaderCell>
              <StyledHeaderCell sx={{ borderTop: `1px solid ${BORDER_COLOR}` }}>Compliance (%)</StyledHeaderCell>
            </TableRow>
          </TableHead>

          <TableBody>
            {data.map((ministry, mIdx) => {
              // Calculate total rows for this Ministry
              const ministryRowSpan = ministry.departments.reduce((acc, dept) =>
                acc + dept.schemes.reduce((sAcc, s) => sAcc + Object.keys(s.years).length, 0), 0
              );

              return ministry.departments.map((dept, dIdx) => {
                // Calculate total rows for this Department
                const deptRowSpan = dept.schemes.reduce((acc, s) => acc + Object.keys(s.years).length, 0);

                return dept.schemes.map((scheme, sIdx) => {
                  const years = Object.keys(scheme.years);

                  return years.map((year, yIdx) => {
                    const yearData = scheme.years[year].overall;
                    const isFirstMin = dIdx === 0 && sIdx === 0 && yIdx === 0;
                    const isFirstDept = sIdx === 0 && yIdx === 0;
                    const isFirstScheme = yIdx === 0;

                    return (
                      <TableRow key={`${mIdx}-${dIdx}-${sIdx}-${yIdx}`} hover>
                        {/* Ministry Column - Vertically Centered */}
                        {isFirstMin && (
                          <TableCell 
                            rowSpan={ministryRowSpan} 
                            sx={{ 
                              verticalAlign: "middle", 
                              textAlign: "center",
                              fontWeight: "bold",
                              color: "#1a237e",
                              borderRight: "1px solid #ccc",
                              backgroundColor: "#fcfcfc",
                              width: "180px"
                            }}
                          >
                            {mIdx + 1}. {ministry.name}
                          </TableCell>
                        )}

                        {/* Department Column - Vertically Centered */}
                        {isFirstDept && (
                          <TableCell 
                            rowSpan={deptRowSpan} 
                            sx={{ 
                              verticalAlign: "middle", 
                              textAlign: "center",
                              fontWeight: "600",
                              borderRight: "1px solid #ccc",
                              width: "180px"
                            }}
                          >
                            {mIdx + 1}.{dIdx + 1} {dept.name}
                          </TableCell>
                        )}

                        {/* Scheme Column */}
                        {isFirstScheme && (
                          <TableCell 
                            rowSpan={years.length} 
                            sx={{ 
                              verticalAlign: "middle", 
                              borderRight: "1px solid #ccc",
                              color: "#45154F",
                              fontWeight: "500"
                            }}
                          >
                            {scheme.name}
                          </TableCell>
                        )}

                        {/* Output Data */}
                        <TableCell align="center" sx={{ borderRight: "1px solid #eee" }}>
                          {yearData.output.total}
                        </TableCell>
                        <TableCell 
                          align="center" 
                          sx={{ 
                            fontWeight: "bold",
                            borderRight: "1px solid #eee",
                            backgroundColor: getComplianceColor(yearData.output.compliance) 
                          }}
                        >
                          {yearData.output.compliance}%
                        </TableCell>

                        {/* Outcome Data */}
                        <TableCell align="center" sx={{ borderRight: "1px solid #eee" }}>
                          {yearData.outcome.total}
                        </TableCell>
                        <TableCell 
                          align="center" 
                          sx={{ 
                            fontWeight: "bold",
                            backgroundColor: getComplianceColor(yearData.outcome.compliance) 
                          }}
                        >
                          {yearData.outcome.compliance}%
                        </TableCell>
                      </TableRow>
                    );
                  });
                });
              });
            })}
          </TableBody>
        </Table>
      </TableContainer>
    </Box>
  );
};

export default TableComponent;
