const renderChangedTable = (changedValues) => {
  // Flatten nested keys for easier label mapping
  const flattenChangedValues = (obj, prefix = "") => {
    return Object.keys(obj).reduce((acc, key) => {
      const val = obj[key];
      const newKey = prefix ? `${prefix}.${key}` : key;

      if (val && typeof val === "object" && val.hasOwnProperty("oldValue") && val.hasOwnProperty("newValue")) {
        acc[newKey] = val;
      } else if (val && typeof val === "object" && !Array.isArray(val)) {
        acc = { ...acc, ...flattenChangedValues(val, newKey) };
      }
      return acc;
    }, {});
  };

  const flatValues = flattenChangedValues(changedValues);
  const keys = Object.keys(flatValues);

  if (!keys.length) return <Typography>No changes detected.</Typography>;

  return (
    <Box mb={2}>
      <Typography
        variant="subtitle1"
        fontWeight="bold"
        gutterBottom
        sx={{ color: HEADER_BG }}
      >
        Highlighted Changes
      </Typography>

      <Table size="small">
        <TableHead>
          <TableRow sx={{ backgroundColor: HEADER_BG }}>
            <TableCell sx={{ color: HEADER_TEXT }}>Field</TableCell>
            <TableCell sx={{ color: HEADER_TEXT }}>Old Value</TableCell>
            <TableCell sx={{ color: HEADER_TEXT }}>New Value</TableCell>
          </TableRow>
        </TableHead>

        <TableBody>
          {keys.map((k, i) => {
            const oldVal = formatDateIfNeeded(k, flatValues[k]?.oldValue);
            const newVal = formatDateIfNeeded(k, flatValues[k]?.newValue);

            return (
              <TableRow key={i}>
                {/* Use labelConfig via getLabel */}
                <TableCell>{getLabel(k)}</TableCell>

                <TableCell>
                  {renderCellValue(
                    k.toLowerCase().includes("status")
                      ? formatStatus(oldVal)
                      : oldVal,
                    k
                  )}
                </TableCell>

                <TableCell>
                  {renderCellValue(
                    k.toLowerCase().includes("status")
                      ? formatStatus(newVal)
                      : newVal,
                    k
                  )}
                </TableCell>
              </TableRow>
            );
          })}
        </TableBody>
      </Table>
    </Box>
  );
};
