"use client";

import React, { useEffect, useState } from "react";
import {
  Box,
  TextField,
  Paper,
} from "@mui/material";
import { DataGrid, GridToolbar } from "@mui/x-data-grid";
import { DndContext, closestCenter, PointerSensor, useSensor, useSensors } from "@dnd-kit/core";
import { arrayMove, SortableContext, verticalListSortingStrategy, useSortable } from "@dnd-kit/sortable";
import { CSS } from "@dnd-kit/utilities";
import dayjs from "dayjs";

/**
 * SortableRow wraps a row for DnD
 */
const SortableRow = ({ id, children }) => {
  const { attributes, listeners, setNodeRef, transform, transition } = useSortable({ id });
  const style = {
    transform: CSS.Transform.toString(transform),
    transition,
    marginBottom: 4,
  };
  return (
    <div ref={setNodeRef} style={style} {...attributes} {...listeners}>
      {children}
    </div>
  );
};

const AdvancedDataGrid = ({
  data = [],
  columns = [],
  rowIdField = "id",
  enableReorder = false,
  searchPlaceholder = "Search...",
  onSelectionChange,
  checkboxSelection = false,
}) => {
  const [searchText, setSearchText] = useState("");
  const [filteredData, setFilteredData] = useState(data);
  const [gridData, setGridData] = useState(data);
  const [selectionModel, setSelectionModel] = useState([]);

  useEffect(() => {
    setGridData(data);
    setFilteredData(data);
  }, [data]);

  // 🔍 Filtering logic
  useEffect(() => {
    const trimmedSearch = (searchText || "").trim().toLowerCase();
    if (!trimmedSearch) {
      setFilteredData(gridData);
      return;
    }

    const ignoredKeys = ["id", "uuid", "raw"];
    const searchObject = (obj) => {
      if (!obj || typeof obj !== "object") return false;
      const shallowMatch = Object.entries(obj).some(([key, val]) => {
        if (ignoredKeys.includes(key.toLowerCase()) || val == null) return false;

        if (key === "is_active" && typeof val === "boolean") {
          const statusText = val ? "active" : "inactive";
          return statusText.startsWith(trimmedSearch);
        }

        if (typeof val === "string" && /^\d{4}-\d{2}-\d{2}T/.test(val)) {
          const formattedDate = dayjs(val).format("DD-MMM-YYYY").toLowerCase();
          return formattedDate.includes(trimmedSearch);
        }

        if (typeof val === "string" || typeof val === "number") {
          return val.toString().toLowerCase().includes(trimmedSearch);
        }

        return false;
      });

      if (shallowMatch) return true;

      return Object.entries(obj).some(([key, val]) => {
        if (ignoredKeys.includes(key.toLowerCase()) || val == null) return false;
        if (typeof val === "object") {
          if (Array.isArray(val)) return val.some((item) => searchObject(item));
          else return searchObject(val);
        }
        return false;
      });
    };

    const filtered = gridData.filter((item) => searchObject(item));
    setFilteredData(filtered);
  }, [searchText, gridData]);

  // DnD sensors
  const sensors = useSensors(useSensor(PointerSensor));

  const handleDragEnd = (event) => {
    const { active, over } = event;
    if (active.id !== over.id) {
      const oldIndex = filteredData.findIndex((row) => row[rowIdField] === active.id);
      const newIndex = filteredData.findIndex((row) => row[rowIdField] === over.id);
      const newData = arrayMove(filteredData, oldIndex, newIndex);
      setFilteredData(newData);
      setGridData(newData);
    }
  };

  // Selection callback
  useEffect(() => {
    if (onSelectionChange) onSelectionChange(selectionModel);
  }, [selectionModel]);

  return (
    <Paper elevation={0}>
      <Box mb={1}>
        <TextField
          size="small"
          fullWidth
          placeholder={searchPlaceholder}
          value={searchText}
          onChange={(e) => setSearchText(e.target.value)}
        />
      </Box>

      {enableReorder ? (
        <DndContext sensors={sensors} collisionDetection={closestCenter} onDragEnd={handleDragEnd}>
          <SortableContext items={filteredData.map((r) => r[rowIdField])} strategy={verticalListSortingStrategy}>
            {filteredData.map((row) => (
              <SortableRow key={row[rowIdField]} id={row[rowIdField]}>
                <DataGrid
                  autoHeight
                  rows={[row]}
                  columns={columns}
                  getRowId={(r) => r[rowIdField]}
                  checkboxSelection={checkboxSelection}
                  onRowSelectionModelChange={(ids) => setSelectionModel(ids)}
                  rowSelectionModel={selectionModel}
                  hideFooter
                />
              </SortableRow>
            ))}
          </SortableContext>
        </DndContext>
      ) : (
        <DataGrid
          autoHeight
          rows={filteredData}
          columns={columns}
          getRowId={(r) => r[rowIdField]}
          checkboxSelection={checkboxSelection}
          onRowSelectionModelChange={(ids) => setSelectionModel(ids)}
          rowSelectionModel={selectionModel}
          components={{ Toolbar: GridToolbar }}
        />
      )}
    </Paper>
  );
};

export default AdvancedDataGrid;
