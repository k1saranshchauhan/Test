import React, { useEffect, useMemo, useState } from "react";
import {
  Box,
  Button,
  Tooltip,
  Typography,
  Paper,
  CircularProgress,
} from "@mui/material";
import { DataGrid } from "@mui/x-data-grid";
import MergeIcon from "@mui/icons-material/CallMerge";
import RefreshIcon from "@mui/icons-material/Refresh";
import SupportingDocumentsRepeater from "./SupportingDocumentsRepeater"; // adjust path
import apiClient from "@/utils/apiClient";

const FILE_SERVER_URL = `${process.env.NEXT_PUBLIC_API_BASE_URL}api/public/download-file/`;

const DocumentMergePage = () => {
  const [rows, setRows] = useState([]);
  const [loading, setLoading] = useState(false);
  const [selectionModel, setSelectionModel] = useState([]);
  const [uploading, setUploading] = useState(false);

  const fetchDocuments = async () => {
    setLoading(true);
    try {
      const res = await apiClient.get(
        `api/document/get-folder-documents/3`
      );

      const filtered = (res?.result || [])
        .filter((doc) => doc.document_name?.toLowerCase().endsWith(".docx"))
        .map((doc) => ({
          id: doc.document_id,
          title: doc.document_title,
          fileName: doc.document_name,
          uploadedAt: doc.uploaded_at,
          uploadedBy: `${doc.first_name || ""} ${doc.last_name || ""}`,
          downloadId: doc.download_id,
        }));

      setRows(filtered);
    } catch (err) {
      console.error("Fetch failed", err);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchDocuments();
  }, []);

  const handleMerge = async () => {
    try {
      setUploading(true);
      await apiClient.post("api/merge-document", {
        documentIds: selectionModel,
      });

      alert("Documents merged successfully");
      setSelectionModel([]);
    } catch (err) {
      console.error("Merge failed", err);
      alert("Merge failed");
    } finally {
      setUploading(false);
    }
  };

  const columns = useMemo(
    () => [
      {
        field: "title",
        headerName: "Title",
        flex: 1,
      },
      {
        field: "fileName",
        headerName: "File Name",
        flex: 1,
      },
      {
        field: "uploadedBy",
        headerName: "Uploaded By",
        flex: 1,
      },
      {
        field: "uploadedAt",
        headerName: "Uploaded At",
        flex: 1,
        valueFormatter: (params) =>
          new Date(params.value).toLocaleString("en-IN"),
      },
      {
        field: "download",
        headerName: "Download",
        renderCell: (params) => (
          <a
            href={`${FILE_SERVER_URL}${params.row.downloadId}`}
            target="_blank"
            rel="noopener noreferrer"
          >
            View
          </a>
        ),
      },
    ],
    []
  );

  return (
    <Box p={3}>
      <Typography variant="h5" fontWeight={600} mb={2}>
        Document Management & Merge
      </Typography>

      {/* Upload Section */}
      <Paper sx={{ p: 2, mb: 3 }} elevation={3}>
        <Typography variant="h6" mb={1}>
          Upload Documents
        </Typography>

        <SupportingDocumentsRepeater
          isViewing={false}
          supportingName="Upload Supporting Documents"
          handleJsonDataChange={() => () => {}}
          uploadMultipleFiles={async (files, titles, descriptions) => {
            // mock wrapper for your existing API
            const formData = new FormData();
            files.forEach((file, i) => {
              formData.append("files", file);
              formData.append("titles", titles[i]);
              formData.append("descriptions", descriptions[i]);
            });

            const res = await apiClient.post(
              "api/document/upload-multiple",
              formData
            );

            fetchDocuments();
            return res?.data || [];
          }}
        />
      </Paper>

      {/* Data Grid Section */}
      <Paper sx={{ p: 2 }} elevation={3}>
        <Box display="flex" justifyContent="space-between" mb={2}>
          <Typography variant="h6">Available DOCX Documents</Typography>

          <Box display="flex" gap={1}>
            <Button
              variant="outlined"
              startIcon={<RefreshIcon />}
              onClick={fetchDocuments}
            >
              Refresh
            </Button>

            <Tooltip
              title={
                selectionModel.length < 2
                  ? "Select at least 2 documents to merge"
                  : "Merge selected documents"
              }
            >
              <span>
                <Button
                  variant="contained"
                  startIcon={
                    uploading ? <CircularProgress size={18} /> : <MergeIcon />
                  }
                  disabled={selectionModel.length < 2 || uploading}
                  onClick={handleMerge}
                >
                  Merge Documents
                </Button>
              </span>
            </Tooltip>
          </Box>
        </Box>

        <div style={{ height: 500, width: "100%" }}>
          <DataGrid
            rows={rows}
            columns={columns}
            checkboxSelection
            disableRowSelectionOnClick
            onRowSelectionModelChange={(newSelection) =>
              setSelectionModel(newSelection)
            }
            rowSelectionModel={selectionModel}
            loading={loading}
            pageSizeOptions={[5, 10, 20]}
          />
        </div>
      </Paper>
    </Box>
  );
};

export default DocumentMergePage;
