import React, { useEffect, useState } from "react";
import {
  Box,
  Button,
  Typography,
  Tooltip,
  Card,
  CardContent,
} from "@mui/material";
import { DataGrid } from "@mui/x-data-grid";
import apiClient from "@/utils/apiClient";
import SupportingDocumentsRepeater from "@/src/components/superadmin/SupportingDocsRepeater";

const DocumentMergePage = () => {
  const [documents, setDocuments] = useState([]);
  const [loading, setLoading] = useState(false);
  const [selectionModel, setSelectionModel] = useState([]);

  // ✅ IMPORTANT: Correct structure based on your reference
  const [uploadState, setUploadState] = useState({
    uploadedFiles: [],
  });

  useEffect(() => {
    fetchDocuments();
  }, []);

  const fetchDocuments = async () => {
    setLoading(true);
    try {
      const res = await apiClient.get(
        "api/document/get-folder-documents/3"
      );

      if (res?.data?.success) {
        const filteredDocs = res?.data?.result.filter((doc) =>
          doc.document_name?.toLowerCase().endsWith(".docx")
        );

        setDocuments(filteredDocs);
      }
    } catch (err) {
      console.error("Error fetching documents", err);
    } finally {
      setLoading(false);
    }
  };

  // ✅ SAME upload function pattern as your dialog
  const uploadMultipleFiles = async (files, titles = [], description) => {
    const formData = new FormData();

    files.forEach((file, idx) => {
      formData.append("files", file);
      formData.append("titles[]", titles[idx] || file.name);
    });

    formData.append("reference_type", "document");
    formData.append("remarks", description);

    try {
      const res = await apiClient.post(
        "api/document/upload-files",
        formData
      );

      return res.data.files;
    } catch (err) {
      console.error("Upload failed", err);
      return [];
    }
  };

  const handleMerge = async () => {
    try {
      await apiClient.post("api/merge-document", {
        documentIds: selectionModel,
      });

      alert("Documents merged successfully");
      setSelectionModel([]);
    } catch (err) {
      console.error("Merge failed", err);
    }
  };

  const columns = [
    {
      field: "document_title",
      headerName: "Title",
      flex: 1,
    },
    {
      field: "document_name",
      headerName: "File Name",
      flex: 1.5,
    },
    {
      field: "uploaded_by",
      headerName: "Uploaded By",
      flex: 1,
    //   valueGetter: (params) =>
    //     `${params.row.first_name || ""} ${params.row.last_name || ""}`,
    },
    {
      field: "uploaded_at",
      headerName: "Uploaded At",
      flex: 1,
    //   valueGetter: (params) =>
    //     new Date(params.row.uploaded_at).toLocaleString(),
    },
  ];

  return (
    <Box p={3}>
      <Typography variant="h5" fontWeight="bold" mb={2}>
        Document Merge
      </Typography>

      {/* ✅ CORRECT SupportingDocumentsRepeater USAGE */}
      <Card sx={{ mb: 3 }}>
        <CardContent>
          <Typography variant="h6" mb={2}>
            Upload Documents
          </Typography>

          <SupportingDocumentsRepeater
            initialDocuments={uploadState.uploadedFiles || []}
            handleJsonDataChange={(fieldName) => (e) => {
              if (fieldName === "supportingDocuments") {
                setUploadState((prev) => ({
                  ...prev,
                  uploadedFiles: e.target.value,
                }));
              }
            }}
            uploadMultipleFiles={uploadMultipleFiles}
          />
        </CardContent>
      </Card>

      {/* Data Grid */}
      <Card>
        <CardContent>
          <Box
            display="flex"
            justifyContent="space-between"
            alignItems="center"
            mb={2}
          >
            <Typography variant="h6">Available DOCX Documents</Typography>

            <Tooltip title="Select at least 2 documents to merge">
              <span>
                <Button
                  variant="contained"
                  disabled={selectionModel.length < 2}
                  onClick={handleMerge}
                >
                  Merge Documents
                </Button>
              </span>
            </Tooltip>
          </Box>

          <DataGrid
            rows={documents}
            columns={columns}
            getRowId={(row) => row.document_id}
            checkboxSelection
            loading={loading}
            autoHeight
            onRowSelectionModelChange={(ids) =>
              setSelectionModel(ids)
            }
            rowSelectionModel={selectionModel}
          />
        </CardContent>
      </Card>
    </Box>
  );
};

export default DocumentMergePage;
