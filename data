"use client";
import React, { useState, useEffect } from "react";
import {
  Autocomplete,
  TextField,
  FormControl,
  Box,
  Button,
  CircularProgress,
  Tooltip,
  Paper,
  Divider,
  Grid,
} from "@mui/material";
import DownloadIcon from "@mui/icons-material/FileDownload";
import { useFormik } from "formik";
import * as Yup from "yup";

import apiClient from "@/utils/apiClient";
import MainFormHeader from "@/src/components/DashboardUI/MainFormHeader";
import { oomfFrameworkId } from "@/src/constants/unified/frameworkConstants";
import { filterByFramework } from "@/utils/niti/filterByFramework";
import { useFilteredFrameworkAccess } from "@/utils/niti/useFilteredFrameworkAccess";
import { useDispatch, useSelector } from "react-redux";
import { startLoader, stopLoader } from "@/store/slices/errorSlice";

const ReportComponent = () => {
  const dispatch = useDispatch();
  const userData = useSelector((state) => state.config.userData);

  const [financialYearList, setFinancialYearList] = useState([]);
  const [loadingYears, setLoadingYears] = useState(false);
  const [exportLoading, setExportLoading] = useState(false);

  const [ministryList, setMinistryList] = useState([]);
  const [departmentList, setDepartmentList] = useState([]);
  const [schemeTypeList, setSchemeTypeList] = useState([]);
  const [schemeList, setSchemeList] = useState([]);

  const { userMinistryIds, userDepartmentIds, userSchemeIds } =
    useFilteredFrameworkAccess({
      userPermittedMinistryIds: userData?.userRelationships[0]?.ministryIds,
      userPermittedDepartmentIds: userData?.userRelationships[0]?.departmentIds,
      userPermittedSchemeIds: userData?.userRelationships[0]?.schemeIds,
      frameworkId: oomfFrameworkId,
    });

  const getCurrentFinancialYear = () => {
    const today = new Date();
    const year = today.getFullYear();
    const month = today.getMonth() + 1;
    return month >= 4 ? `${year}-${year + 1}` : `${year - 1}-${year}`;
  };

  const formik = useFormik({
    initialValues: {
      financialYear: "",
      ministry: [],
      department: [],
      schemeType: [],
      scheme: [],
    },
    validationSchema: Yup.object({
      financialYear: Yup.string().required("Financial Year is required"),
    }),
    onSubmit: async (values) => {
      setExportLoading(true);
      try {
        const response = await apiClient.post(
          "api/oomf/report/oomf-workflow-financial-document",
          {
            financialYear: [values.financialYear],
            ministryIds: values.ministry.map((m) => m.id),
            departmentIds: values.department.map((d) => d.id),
            schemeTypeIds: values.schemeType.map((s) => s.id),
            schemeIds: values.scheme.map((s) => s.id),
          },
          { responseType: "blob" }
        );

        const blob = new Blob([response.data], {
          type: "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        });

        const url = window.URL.createObjectURL(blob);
        const link = document.createElement("a");
        link.href = url;

        let filename = "OOMF_Report_" + values.financialYear + ".docx";
        const contentDisposition = response.headers["content-disposition"];

        if (contentDisposition) {
          const match = contentDisposition.match(/filename="?([^"]+)"?/);
          if (match) filename = match[1];
        }

        link.setAttribute("download", filename);
        document.body.appendChild(link);
        link.click();
        link.remove();
        window.URL.revokeObjectURL(url);
      } catch (err) {
        console.error(err);
        alert("Download failed");
      } finally {
        setExportLoading(false);
      }
    },
  });

  // ---------------- Fetch Financial Years ----------------
  const fetchFinancialYearList = async () => {
    setLoadingYears(true);
    try {
      const response = await apiClient.post(
        "api/oomf/submissions/get-scheme-filters",
        { isSubScheme: false }
      );

      const { filters } = response?.data || {};
      const currentFY = getCurrentFinancialYear();

      const filtered = filters?.financialYears
        ?.map((item, i) => ({
          id: i,
          label: item.name,
        }))
        ?.filter(
          (fy) =>
            parseInt(fy.label.split("-")[0]) <=
            parseInt(currentFY.split("-")[0])
        );

      setFinancialYearList(filtered || []);

      // auto select current FY
      formik.setFieldValue("financialYear", currentFY);
    } catch (err) {
      console.error(err);
    } finally {
      setLoadingYears(false);
    }
  };

  // ---------------- Fetch Ministry ----------------
  const fetchMinistryList = async () => {
    try {
      const res = await apiClient.post("api/dynamic-model-details/data", {
        modelName: "ministry",
        filters: userMinistryIds?.length
          ? {
              where: {
                id: { in: userMinistryIds },
                status: true,
              },
            }
          : {},
      });

      const formatted = res?.data?.data?.map((m) => ({
        id: m.id,
        label: m.name,
      }));

      setMinistryList(formatted || []);
    } catch (err) {
      console.error(err);
    }
  };

  // ---------------- Fetch Scheme Types ----------------
  const fetchSchemeType = async () => {
    try {
      const res = await apiClient.post(
        "api/master/schemeType/by-framework",
        { associatedFrameworks: [oomfFrameworkId] }
      );

      setSchemeTypeList(
        res?.data?.data?.map((s) => ({
          id: s.id,
          label: s.name,
        })) || []
      );
    } catch (err) {
      console.error(err);
    }
  };

  // ---------------- Departments ----------------
  useEffect(() => {
    const fetchDept = async () => {
      if (!formik.values.ministry.length) {
        setDepartmentList([]);
        return;
      }

      formik.setFieldValue("department", []);

      const res = await apiClient.post(
        "api/master/get-departments-for-ministry",
        {
          ministryIds: formik.values.ministry.map((m) => m.id),
        }
      );

      const filtered = res?.data?.data
        ?.filter((d) => userDepartmentIds?.includes(d.id))
        ?.map((d) => ({
          id: d.id,
          label: d.name,
        }));

      setDepartmentList(filtered || []);
    };

    fetchDept();
  }, [formik.values.ministry]);

  // ---------------- Schemes ----------------
  useEffect(() => {
    const fetchSchemes = async () => {
      if (!formik.values.department.length) {
        setSchemeList([]);
        return;
      }

      formik.setFieldValue("scheme", []);

      const res = await apiClient.post(
        "api/master/get-all-schemes-for-departments",
        {
          departmentIds: formik.values.department.map((d) => d.id),
          schemeTypeIds: formik.values.schemeType.map((s) => s.id),
        }
      );

      const filtered = res?.data?.data
        ?.filter((s) => userSchemeIds?.includes(s.id))
        ?.map((s) => ({
          id: s.id,
          label: s.name,
        }));

      setSchemeList(filtered || []);
    };

    fetchSchemes();
  }, [formik.values.department, formik.values.schemeType]);

  useEffect(() => {
    fetchFinancialYearList();
    fetchMinistryList();
    fetchSchemeType();
  }, []);

  return (
    <Box sx={{ mt: 4, px: 2 }}>
      <MainFormHeader title="Outcome Budget Report" />
      <Divider sx={{ my: 2 }} />

      <form onSubmit={formik.handleSubmit}>
        <Paper sx={{ p: 3 }}>
          <Grid container spacing={2}>
            {/* Financial Year */}
            <Grid item xs={12} md={6}>
              <Autocomplete
                options={financialYearList}
                getOptionLabel={(o) => o.label || ""}
                value={
                  financialYearList.find(
                    (f) => f.label === formik.values.financialYear
                  ) || null
                }
                onChange={(e, val) =>
                  formik.setFieldValue("financialYear", val?.label || "")
                }
                renderInput={(params) => (
                  <TextField
                    {...params}
                    label="Financial Year"
                    error={
                      formik.touched.financialYear &&
                      Boolean(formik.errors.financialYear)
                    }
                    helperText={
                      formik.touched.financialYear &&
                      formik.errors.financialYear
                    }
                  />
                )}
              />
            </Grid>

            {/* Ministry */}
            <Grid item xs={12} md={6}>
              <Autocomplete
                multiple
                options={filterByFramework(ministryList, oomfFrameworkId) || []}
                getOptionLabel={(o) => o.label}
                value={formik.values.ministry}
                onChange={(e, val) =>
                  formik.setFieldValue("ministry", val)
                }
                renderInput={(params) => (
                  <TextField {...params} label="Ministry" />
                )}
              />
            </Grid>

            {/* Department */}
            <Grid item xs={12} md={6}>
              <Autocomplete
                multiple
                options={departmentList}
                getOptionLabel={(o) => o.label}
                value={formik.values.department}
                onChange={(e, val) =>
                  formik.setFieldValue("department", val)
                }
                renderInput={(params) => (
                  <TextField {...params} label="Department" />
                )}
                disabled={!formik.values.ministry.length}
              />
            </Grid>

            {/* Scheme Type */}
            <Grid item xs={12} md={6}>
              <Autocomplete
                multiple
                options={schemeTypeList}
                getOptionLabel={(o) => o.label}
                value={formik.values.schemeType}
                onChange={(e, val) =>
                  formik.setFieldValue("schemeType", val)
                }
                renderInput={(params) => (
                  <TextField {...params} label="Scheme Type" />
                )}
              />
            </Grid>

            {/* Scheme */}
            <Grid item xs={12}>
              <Autocomplete
                multiple
                options={schemeList}
                getOptionLabel={(o) => o.label}
                value={formik.values.scheme}
                onChange={(e, val) =>
                  formik.setFieldValue("scheme", val)
                }
                renderInput={(params) => (
                  <TextField {...params} label="Scheme" />
                )}
                disabled={!formik.values.department.length}
              />
            </Grid>
          </Grid>

          {/* Export Button */}
          <Box mt={3}>
            <Tooltip title="Export report">
              <span>
                <Button
                  type="submit"
                  variant="contained"
                  startIcon={
                    exportLoading ? (
                      <CircularProgress size={20} />
                    ) : (
                      <DownloadIcon />
                    )
                  }
                  disabled={exportLoading}
                >
                  {exportLoading ? "Exporting..." : "Export as Word"}
                </Button>
              </span>
            </Tooltip>
          </Box>
        </Paper>
      </form>
    </Box>
  );
};

export default ReportComponent;
