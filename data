import React, { useState, useEffect } from "react";
import {
  Autocomplete,
  TextField,
  FormControl,
  Typography,
  Box,
  Button,
  CircularProgress,
  Tooltip,
  Paper,
  Divider,
} from "@mui/material";
import DownloadIcon from "@mui/icons-material/FileDownload";
import apiClient from "@/utils/apiClient";
import MainFormHeader from "@/src/components/DashboardUI/MainFormHeader";
import { oomfFrameworkId } from "@/src/constants/unified/frameworkConstants";
import {
  filterByFramework,
  filterSchemesByFramework,
} from "@/utils/niti/filterByFramework";
import { useFilteredFrameworkAccess } from "@/utils/niti/useFilteredFrameworkAccess";
import { startLoader, stopLoader } from "@/store/slices/errorSlice";
import { useDispatch, useSelector } from "react-redux";

const ReportComponent = () => {
  const getCurrentFinancialYear = () => {
    const today = new Date();
    const year = today.getFullYear();
    const month = today.getMonth() + 1;
    return month >= 4 ? `${year}-${year + 1}` : `${year - 1}-${year}`;
  };
  
  const [financialYear, setFinancialYear] = useState(getCurrentFinancialYear());
  const [financialYearList, setFinancialYearList] = useState([]);
  const [loadingYears, setLoadingYears] = useState(false);
  const [exportLoading, setExportLoading] = useState(false);
  const userData = useSelector((state) => state.config.userData);
  const [ministryList, setMinistryList] = useState([]);
  const [departmentList, setDepartmentList] = useState([]);
  const [schemeTypeList, setSchemeTypeList] = useState([]);
  const [schemeList, setSchemeList] = useState([]);
  const dispatch = useDispatch();
  const { userMinistryIds, userDepartmentIds, userSchemeIds } =
      useFilteredFrameworkAccess({
        userPermittedMinistryIds: userData?.userRelationships[0]?.ministryIds,
        userPermittedDepartmentIds: userData?.userRelationships[0]?.departmentIds,
        userPermittedSchemeIds: userData?.userRelationships[0]?.schemeIds,
        frameworkId: oomfFrameworkId,
      });

  const fetchFinancialYearList = async () => {
    setLoadingYears(true);
    try {
      const response = await apiClient.post(
        "api/oomf/submissions/get-scheme-filters",
        { isSubScheme: false },
      );

      const { filters } = response?.data || {};
      const formattedData = filters?.financialYears?.map((item, index) => ({
        id: index + 1,
        name: item?.name,
      }));
      // setFinancialYearList(formattedData || []);
      // Get current financial year
      const currentFY = getCurrentFinancialYear();

      // Filter out any future financial years
      const filteredData = formattedData.filter((fy) => {
        // Compare first year of FY string
        const fyStartYear = parseInt(fy.name.split("-")[0], 10);
        const currentStartYear = parseInt(currentFY.split("-")[0], 10);
        return fyStartYear <= currentStartYear;
      });

      setFinancialYearList(filteredData);
    } catch (error) {
      console.error("Failed to fetch financialYear list:", error);
      setFinancialYearList([]);
    } finally {
      setLoadingYears(false);
    }
  };

  useEffect(() => {
    fetchFinancialYearList();
  }, []);

  const handleExport = async () => {
    if (!financialYear) return;
    setExportLoading(true);

    try {
      const response = await apiClient.post(
        "api/oomf/report/oomf-workflow-financial-document",
        { financialYear: [financialYear] },
        { responseType: "blob", headers: { "Content-Type": "application/json" } }
      );

      const blob = new Blob([response.data], {
        type: "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      });

      const url = window.URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;

      const contentDisposition = response.headers["content-disposition"];
      // let filename = `OOMF_Report_${financialYear}.docx`;
      // if (contentDisposition) {
      //   const filenameMatch = contentDisposition.match(/filename="?(.+)"?/);
      //   if (filenameMatch && filenameMatch[1]) filename = filenameMatch[1];
      // }
      let filename = "OOMF_Report_" + financialYear + ".docx"; // default filename

      if (contentDisposition) {
        // Try to match RFC 5987 style first (filename*)
        const filenameStarMatch = contentDisposition.match(
          /filename\*\s*=\s*UTF-8''(.+?)(?:;|$)/i,
        );
        if (filenameStarMatch && filenameStarMatch[1]) {
          filename = decodeURIComponent(filenameStarMatch[1].trim());
        } else {
          // Fallback to regular filename
          const filenameMatch = contentDisposition.match(
            /filename="?([^";]+)"?/i,
          );
          if (filenameMatch && filenameMatch[1]) {
            filename = filenameMatch[1].trim();
          }
        }

        // Remove any trailing underscores or spaces added by proxies
        filename = filename.replace(/_+$/, "");
      }

      link.setAttribute("download", filename);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      window.URL.revokeObjectURL(url);
    } catch (err) {
      console.error("Export failed:", err);
      alert("Failed to download report. Please try again.");
    } finally {
      setExportLoading(false);
    }
  };

  return (
    <Box sx={{ mt: 4, mx: "auto",px:2 }}>
      <MainFormHeader title="Outcome Budget Report" />
      <Divider sx={{ my: 2 }} />

      {/* Toolbar card */}
      <Paper
        elevation={3}
        sx={{
          p: 3,
          display: "flex",
          alignItems: "center",
          justifyContent: "space-between",
          mb: 4,
          flexWrap: "wrap",
          gap: 2,
        }}
      >
        {/* Financial Year Selector */}
        <FormControl sx={{ minWidth: 250, flex: 1 }}>
          <Autocomplete
            options={financialYearList}
            getOptionLabel={(option) => option.name || ""}
            value={
              financialYearList.find((fy) => fy.name === financialYear) || null
            }
            onChange={(event, newValue) => {
              setFinancialYear(newValue ? newValue.name : "");
            }}
            renderInput={(params) => (
              <TextField
                {...params}
                label="Financial Year"
                variant="outlined"
                disabled={loadingYears}
              />
            )}
            disableClearable
          />
        </FormControl>

        {/* Export Button */}
        <Tooltip
          title={
            financialYear
              ? "Export report"
              : "Select a financial year first"
          }
        >
          <span>
            <Button
              variant="contained"
              color="primary"
              startIcon={
                exportLoading ? (
                  <CircularProgress size={20} color="inherit" />
                ) : (
                  <DownloadIcon />
                )
              }
              onClick={handleExport}
              disabled={!financialYear || exportLoading}
              sx={{ height: 56 }}
            >
              {exportLoading ? "Exporting..." : "Export as Word"}
            </Button>
          </span>
        </Tooltip>
      </Paper>

      {/* Optional info text */}
      {/* <Typography variant="body2" color="textSecondary">
        Select a financial year and click "Export as Word" to download the Outcome Budget report.
      </Typography> */}
    </Box>
  );
};

export default ReportComponent;
