const flattenChangedValues = (obj, prefix = "") => {
  const result = {};

  Object.keys(obj).forEach((key) => {
    const val = obj[key];
    const newKey = prefix ? `${prefix}.${key}` : key;

    // If this object has oldValue/newValue
    if (val && val.hasOwnProperty("oldValue") && val.hasOwnProperty("newValue")) {
      // Check if oldValue/newValue are objects themselves
      const isOldObj = val.oldValue && typeof val.oldValue === "object" && !Array.isArray(val.oldValue);
      const isNewObj = val.newValue && typeof val.newValue === "object" && !Array.isArray(val.newValue);

      if (isOldObj || isNewObj) {
        // Recursively flatten nested oldValue/newValue objects
        const nestedOld = isOldObj ? flattenChangedValues(val.oldValue, newKey + ".oldValue") : {};
        const nestedNew = isNewObj ? flattenChangedValues(val.newValue, newKey + ".newValue") : {};
        Object.assign(result, nestedOld, nestedNew);
      } else {
        result[newKey] = val;
      }
    } else if (val && typeof val === "object" && !Array.isArray(val)) {
      // Recursively flatten other nested objects
      Object.assign(result, flattenChangedValues(val, newKey));
    }
  });

  return result;
};




const renderChangedTable = (changedValues) => {
  if (!changedValues || Object.keys(changedValues).length === 0) {
    return <Typography>No changes detected.</Typography>;
  }

  // Flatten nested changedValues for easier label mapping
  const flattenChangedValues = (obj, prefix = "") => {
    const result = {};

    Object.keys(obj).forEach((key) => {
      const val = obj[key];
      const newKey = prefix ? `${prefix}.${key}` : key;

      // If object has oldValue and newValue
      if (val && val.hasOwnProperty("oldValue") && val.hasOwnProperty("newValue")) {
        const isOldObj =
          val.oldValue &&
          typeof val.oldValue === "object" &&
          !Array.isArray(val.oldValue) &&
          Object.keys(val.oldValue).length > 0;
        const isNewObj =
          val.newValue &&
          typeof val.newValue === "object" &&
          !Array.isArray(val.newValue) &&
          Object.keys(val.newValue).length > 0;

        if (isOldObj || isNewObj) {
          // Recursively flatten nested oldValue/newValue
          const nestedOld = isOldObj ? flattenChangedValues(val.oldValue, newKey + ".oldValue") : {};
          const nestedNew = isNewObj ? flattenChangedValues(val.newValue, newKey + ".newValue") : {};
          Object.assign(result, nestedOld, nestedNew);
        } else {
          result[newKey] = val;
        }
      } else if (val && typeof val === "object" && !Array.isArray(val)) {
        // Recursively flatten other objects
        Object.assign(result, flattenChangedValues(val, newKey));
      }
    });

    return result;
  };

  const flatValues = flattenChangedValues(changedValues);
  const keys = Object.keys(flatValues);

  if (!keys.length) return <Typography>No changes detected.</Typography>;

  return (
    <Box mb={2}>
      <Typography
        variant="subtitle1"
        fontWeight="bold"
        gutterBottom
        sx={{ color: HEADER_BG }}
      >
        Highlighted Changes
      </Typography>

      <Table size="small">
        <TableHead>
          <TableRow sx={{ backgroundColor: HEADER_BG }}>
            <TableCell sx={{ color: HEADER_TEXT }}>Field</TableCell>
            <TableCell sx={{ color: HEADER_TEXT }}>Old Value</TableCell>
            <TableCell sx={{ color: HEADER_TEXT }}>New Value</TableCell>
          </TableRow>
        </TableHead>

        <TableBody>
          {keys.map((k, i) => {
            const oldVal = formatDateIfNeeded(k, flatValues[k]?.oldValue);
            const newVal = formatDateIfNeeded(k, flatValues[k]?.newValue);

            return (
              <TableRow key={i}>
                <TableCell>{getLabel(k)}</TableCell>

                <TableCell>
                  {renderCellValue(
                    k.toLowerCase().includes("status")
                      ? formatStatus(oldVal)
                      : oldVal,
                    k
                  )}
                </TableCell>

                <TableCell>
                  {renderCellValue(
                    k.toLowerCase().includes("status")
                      ? formatStatus(newVal)
                      : newVal,
                    k
                  )}
                </TableCell>
              </TableRow>
            );
          })}
        </TableBody>
      </Table>
    </Box>
  );
};
