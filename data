import React from "react";
import {
  Table,
  TableBody,
  TableCell,
  TableContainer,
  TableHead,
  TableRow,
  Paper,
  Typography,
  Box,
  styled,
} from "@mui/material";

// Deep purple theme for a professional "Government/Report" look
const THEME_COLOR = "#45154F";
const BORDER_COLOR = "#632a6d";

const StyledHeaderCell = styled(TableCell)(({ theme }) => ({
  backgroundColor: THEME_COLOR,
  color: theme.palette.common.white,
  fontWeight: "bold",
  textAlign: "center",
  border: `1px solid ${BORDER_COLOR}`,
  fontSize: "0.875rem",
}));

const getComplianceColor = (value) => {
  const num = parseFloat(value);
  if (isNaN(num)) return "transparent";
  if (num >= 80) return "#e8f5e9"; // Very soft green
  if (num >= 50) return "#fff9c4"; // Soft yellow
  return "#fce4ec"; // Soft red
};

const TableComponent = ({ data }) => {
  if (!data) return null;

  return (
    <Box sx={{ p: 3, backgroundColor: "#fafafa", minHeight: "100vh" }}>
      {data.map((ministry, mIdx) => {
        // Calculate RowSpans
        const ministryRowSpan = ministry.departments.reduce((acc, dept) =>
          acc + dept.schemes.reduce((sAcc, s) => sAcc + Object.keys(s.years).length, 0), 0
        );

        return (
          <Box key={mIdx} sx={{ mb: 8 }}>
            {/* Ministry Heading */}
            <Typography variant="h5" sx={{ color: "#1a237e", fontWeight: "bold", mb: 2 }}>
              {mIdx + 1}. {ministry.name}
            </Typography>

            <TableContainer 
              component={Paper} 
              sx={{ boxShadow: "0px 10px 30px rgba(0,0,0,0.08)", borderRadius: "12px", overflow: "hidden" }}
            >
              <Table stickyHeader size="small">
                <TableHead>
                  <TableRow>
                    <StyledHeaderCell rowSpan={2}>Department</StyledHeaderCell>
                    <StyledHeaderCell rowSpan={2}>Scheme Name</StyledHeaderCell>
                    <StyledHeaderCell rowSpan={2}>FY</StyledHeaderCell>
                    <StyledHeaderCell colSpan={2}>Output Indicators</StyledHeaderCell>
                    <StyledHeaderCell colSpan={2}>Outcome Indicators</StyledHeaderCell>
                  </TableRow>
                  <TableRow>
                    <StyledHeaderCell sx={{ top: '37px' }}>Total</StyledHeaderCell>
                    <StyledHeaderCell sx={{ top: '37px' }}>Compliance (%)</StyledHeaderCell>
                    <StyledHeaderCell sx={{ top: '37px' }}>Total</StyledHeaderCell>
                    <StyledHeaderCell sx={{ top: '37px' }}>Compliance (%)</StyledHeaderCell>
                  </TableRow>
                </TableHead>

                <TableBody>
                  {ministry.departments.map((dept, dIdx) => {
                    const deptRowSpan = dept.schemes.reduce((acc, s) => acc + Object.keys(s.years).length, 0);

                    return dept.schemes.map((scheme, sIdx) => {
                      const years = Object.keys(scheme.years);

                      return years.map((year, yIdx) => {
                        const yearData = scheme.years[year].overall;
                        const isFirstDept = sIdx === 0 && yIdx === 0;
                        const isFirstScheme = yIdx === 0;

                        return (
                          <TableRow key={`${mIdx}-${dIdx}-${sIdx}-${yIdx}`} hover>
                            {/* Department Column - Merged */}
                            {isFirstDept && (
                              <TableCell 
                                rowSpan={deptRowSpan} 
                                sx={{ verticalAlign: 'top', fontWeight: 600, bgcolor: '#fcfcfc', borderRight: '1px solid #eee' }}
                              >
                                {mIdx + 1}.{dIdx + 1} {dept.name}
                              </TableCell>
                            )}

                            {/* Scheme Column - Merged */}
                            {isFirstScheme && (
                              <TableCell rowSpan={years.length} sx={{ fontWeight: 500, borderRight: '1px solid #eee' }}>
                                {scheme.name}
                              </TableCell>
                            )}

                            {/* Year Column */}
                            <TableCell align="center" sx={{ fontWeight: 'bold', color: '#666' }}>
                              {year}
                            </TableCell>

                            {/* Output Metrics */}
                            <TableCell align="center">{yearData.output.total}</TableCell>
                            <TableCell 
                              align="center" 
                              sx={{ 
                                fontWeight: 'bold', 
                                backgroundColor: getComplianceColor(yearData.output.compliance) 
                              }}
                            >
                              {yearData.output.compliance}%
                            </TableCell>

                            {/* Outcome Metrics */}
                            <TableCell align="center">{yearData.outcome.total}</TableCell>
                            <TableCell 
                              align="center" 
                              sx={{ 
                                fontWeight: 'bold', 
                                backgroundColor: getComplianceColor(yearData.outcome.compliance) 
                              }}
                            >
                              {yearData.outcome.compliance}%
                            </TableCell>
                          </TableRow>
                        );
                      });
                    });
                  })}
                </TableBody>
              </Table>
            </TableContainer>
          </Box>
        );
      })}
    </Box>
  );
};

export default TableComponent;
