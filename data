import { Autocomplete, Checkbox, Chip, TextField } from "@mui/material";
import CheckBoxOutlineBlankIcon from "@mui/icons-material/CheckBoxOutlineBlankOutlined";
import CheckBoxIcon from "@mui/icons-material/CheckBoxOutlined";
import React from "react";

export const CustomAutoComplete = ({
  name,
  options,
  label,
  placeholder = "",
  selectAll = false,
  multiple = true,
  readOnly = false,
  required = false,
  size = "small",
  limitTags = 1,
  onChange,
  formik,
  ...props
}) => {
  if (formik === null || formik === undefined) return;
  const { values, setFieldValue, errors, touched } = formik;

  const selectAllOption = { id: "0", label: "Select All" };
  const mergedOptions =
    multiple && selectAll ? [selectAllOption, ...options] : options;

  const value = values[name] || (multiple ? [] : null);

  const isOptionSelected = (option, valueList) =>
    valueList?.some((val) => val.id === option.id);

  const handleChange = (e, selected) => {
    if (selectAll && multiple) {
      const isSelectAllChosen = selected.some(
        (opt) => opt.id === selectAllOption.id
      );

      const wasAlreadyAllSelected =
        value?.length === options.length &&
        value.every((v) => options.some((o) => o.id === v.id));

      // If Select All clicked again (toggle off)
      if (isSelectAllChosen && wasAlreadyAllSelected) {
        setFieldValue(name, []);
        onChange?.(e, []);
        return;
      }

      // If Select All newly selected (toggle on)
      if (isSelectAllChosen && !wasAlreadyAllSelected) {
        setFieldValue(name, options);
        onChange?.(e, options);
        return;
      }

      // Filter out "Select All" if it's among selected values
      const filtered = selected.filter((opt) => opt.id !== selectAllOption.id);
      setFieldValue(name, filtered);
      onChange?.(e, filtered);
      return;
    }

    const newValue = multiple ? selected : selected || null;
    setFieldValue(name, newValue);
    onChange?.(e, newValue);
  };

  return (
    <Autocomplete
      {...props}
      multiple={multiple}
      options={mergedOptions}
      value={value}
      getOptionLabel={(option) => option?.label || ""}
      isOptionEqualToValue={(option, val) => option.id === val.id}
      disabled={readOnly}
      fullWidth
      sx={{ mt: 2 }}
      size={size}
      limitTags={multiple ? limitTags : undefined}
      disableCloseOnSelect={multiple}
      onChange={handleChange}
      renderOption={(props, option) => {
        const { key, ...rest } = props;
        return (
          <li key={option?.id} {...rest}>
            {multiple && !readOnly && (
              <Checkbox
                icon={<CheckBoxOutlineBlankIcon fontSize="small" />}
                checkedIcon={<CheckBoxIcon fontSize="small" />}
                checked={isOptionSelected(option, value || [])}
                sx={{ mr: 1 }}
              />
            )}
            {option.label}
          </li>
        );
      }}
      renderTags={
        multiple
          ? (value, getTagProps) =>
              value.map((option, index) => {
                const { key, ...rest } = getTagProps({ index });
                return <Chip key={index} label={option.label} {...rest} />;
              })
          : undefined
      }
      renderInput={(params) => (
        <TextField
          {...params}
          // label={label}
          label={
            <span>
              {label}
              {required && <span style={{ color: "red" }}> *</span>}
            </span>
          }
          fullWidth
          placeholder={placeholder}
          // required={required}
          error={Boolean(touched?.[name] && errors?.[name])}
          helperText={touched?.[name] && errors?.[name]}
          sx={{ backgroundColor: "#fff", borderRadius: "10px" }}
        />
      )}
    />
  );
};
