"use client";

import React, { useState, useMemo } from "react";
import {
  Box,
  TextField,
  Paper,
  InputAdornment,
  IconButton,
  Typography,
  Tooltip,
} from "@mui/material";
import { 
  DataGrid, 
  GridToolbarContainer, 
  GridToolbarExport, 
  GridToolbarColumnsButton,
  GridToolbarFilterButton 
} from "@mui/x-data-grid";
import { Search, Clear, Reorder, Inventory } from "@mui/icons-material";

/**
 * Custom Toolbar for a cleaner look
 */
const CustomToolbar = () => (
  <GridToolbarContainer sx={{ p: 1, gap: 1 }}>
    <GridToolbarColumnsButton />
    <GridToolbarFilterButton />
    <GridToolbarExport />
  </GridToolbarContainer>
);

const AdvancedDataGrid = ({
  data = [],
  columns = [],
  rowIdField = "id",
  enableReorder = false,
  searchPlaceholder = "Search records...",
  onSelectionChange,
  checkboxSelection = false,
}) => {
  const [searchText, setSearchText] = useState("");
  const [selectionModel, setSelectionModel] = useState([]);

  // 1. Optimized Search Logic
  const filteredRows = useMemo(() => {
    const term = searchText.toLowerCase().trim();
    if (!term) return data;

    return data.filter((row) => {
      return Object.values(row).some((value) => {
        if (value === null || value === undefined) return false;
        return String(value).toLowerCase().includes(term);
      });
    });
  }, [data, searchText]);

  // 2. Add a Drag Handle Column if reordering is enabled
  const finalColumns = useMemo(() => {
    if (!enableReorder) return columns;
    return [
      {
        field: "reorder",
        headerName: "",
        width: 50,
        sortable: false,
        filterable: false,
        disableColumnMenu: true,
        renderCell: () => (
          <Tooltip title="Drag to reorder (Feature requires backend sequence)">
            <Reorder sx={{ cursor: "grab", color: "action.active", mt: 1.5 }} />
          </Tooltip>
        ),
      },
      ...columns,
    ];
  }, [columns, enableReorder]);

  // 3. Custom Empty State UI
  const NoRowsOverlay = () => (
    <Box sx={{ display: 'flex', flexDirection: 'column', alignItems: 'center', justifyContent: 'center', height: '100%' }}>
      <Inventory sx={{ fontSize: 40, color: 'divider', mb: 1 }} />
      <Typography variant="body2" color="text.secondary">No records found</Typography>
    </Box>
  );

  return (
    <Paper 
      elevation={0} 
      variant="outlined" 
      sx={{ 
        width: "100%", 
        borderRadius: 2,
        overflow: "hidden",
        border: "1px solid",
        borderColor: "divider"
      }}
    >
      {/* Search Header */}
      <Box sx={{ p: 2, borderBottom: "1px solid", borderColor: "divider", bgcolor: "grey.50" }}>
        <TextField
          size="small"
          fullWidth
          variant="outlined"
          placeholder={searchPlaceholder}
          value={searchText}
          onChange={(e) => setSearchText(e.target.value)}
          InputProps={{
            startAdornment: (
              <InputAdornment position="start">
                <Search fontSize="small" color="action" />
              </InputAdornment>
            ),
            endAdornment: searchText && (
              <InputAdornment position="end">
                <IconButton size="small" onClick={() => setSearchText("")}>
                  <Clear fontSize="small" />
                </IconButton>
              </InputAdornment>
            ),
          }}
          sx={{ bgcolor: "white" }}
        />
      </Box>

      {/* Main Grid */}
      <Box sx={{ height: 500, width: "100%" }}>
        <DataGrid
          rows={filteredRows}
          columns={finalColumns}
          getRowId={(row) => row[rowIdField]}
          checkboxSelection={checkboxSelection}
          onRowSelectionModelChange={(newSelection) => {
            setSelectionModel(newSelection);
            if (onSelectionChange) onSelectionChange(newSelection);
          }}
          rowSelectionModel={selectionModel}
          disableRowSelectionOnClick
          pageSizeOptions={[5, 10, 25, 50]}
          initialState={{
            pagination: { paginationModel: { pageSize: 10 } },
          }}
          slots={{
            toolbar: CustomToolbar,
            noRowsOverlay: NoRowsOverlay,
          }}
          sx={{
            border: "none",
            "& .MuiDataGrid-columnHeaders": {
              bgcolor: "grey.50",
              color: "text.primary",
              fontWeight: "bold",
            },
            "& .MuiDataGrid-cell:focus": {
              outline: "none",
            },
            "& .MuiDataGrid-row:hover": {
              bgcolor: "action.hover",
            },
          }}
        />
      </Box>
    </Paper>
  );
};

export default AdvancedDataGrid;
