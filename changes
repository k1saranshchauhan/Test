export default function OomfFormRefactored({
  data,
  initialPlan,
  isReadOnly,
  type,
  moto,
  isPostBudget,
  draftId,
}) {
  const userData = useSelector((state) => state.config.userData);
  const userMinistryIds = userData?.userRelationships[0]?.ministryIds;
  const userDepartmentIds = userData?.userRelationships[0]?.departmentIds;
  const userSchemeIds = userData?.userRelationships[0]?.schemeIds;
  const [dialogOpen, setDialogOpen] = useState(false);
  const [hasChecked, setHasChecked] = useState(false);
  const [openRemarkModal, setOpenRemarkModal] = useState(false);
  const [currentField, setCurrentField] = useState(null);

  const [footnote, setFootnote] = useState("");
  const [footnoteContext, setFootnoteContext] = useState({});
  const [footnoteIndicatorType, setFootnoteIndicatorType] = useState({});
  const [filtersComplete, setFiltersCompleted] = useState(false);
  const [alertDialogOpen, setAlertDialogOpen] = useState(false);
  const [previousSubmissionId, setPreviousSubmissionId] = useState(null);
  const [footnoteValue, setFootnoteValue] = useState("");
  const [openForwardDialog, setOpenForwardDialog] = useState(false);

  const {
    mappedPrivileges,
    hasAddAccess,
    hasEditAccess,
    hasViewAccess,
    refresh,
  } = usePrivileges(SECTION_KEY.OUTPUT_OUTCOME_STATEMENT_WITH_INDICATOR);
  const searchParams = useSearchParams();

  const handleDialogOpen = ({
    field,
    sectionIndex,
    indicatorIndex,
    defaultValue = "",
  }) => {
    setFootnoteContext({ field, sectionIndex, indicatorIndex });
    setFootnoteValue(defaultValue);
    setDialogOpen(true);
  };

  const handleDialogClose = () => {
    setDialogOpen(false);
  };

  const handleFootnoteSave = () => {
    const valueToSave = footnoteValue;

    if (!footnoteContext) return;

    const { field, sectionIndex, indicatorIndex } = footnoteContext;

    // Indicator footnotes
    if (footnoteContext?.field === "indicatorName") {
      handleIndicatorChange(
        footnoteContext.sectionIndex,
        footnoteContext.indicatorIndex,
        "footNoteIndicatorName",
        valueToSave,
      );
    } else if (footnoteContext?.field === "indicatorTarget") {
      handleIndicatorChange(
        footnoteContext.sectionIndex,
        footnoteContext.indicatorIndex,
        "footNoteIndicatorTarget",
        valueToSave,
      );
    }
    // Output/Outcome footnotes
    else if (field === "Output" || field === "Outcome") {
      setSectionsByType((prev) => {
        const updatedSections = [...(prev[field] || [])];
        while (updatedSections.length <= sectionIndex) updatedSections.push({});
        updatedSections[sectionIndex] = {
          ...updatedSections[sectionIndex],
          footNote: valueToSave,
        };
        return { ...prev, [field]: updatedSections };
      });
    }

    handleDialogClose();
  };

  const router = useRouter();
  // const { id } = router.query;
  const token = searchParams.get("tk");
  const decrypted = token ? decryptData(token) : null;
  const id = decrypted?.id;

  const [initialDraft, setInitialDraft] = useState(true);
  const [financialYear, setFinancialYear] = useState(() =>
    initialDraft ? getNextFinancialYear() : "",
  );

  // Master selections
  const [selectedMinistry, setSelectedMinistry] = useState(null);
  const [selectedDepartment, setSelectedDepartment] = useState(null);
  const [selectedSchemeType, setSelectedSchemeType] = useState(null);
  const [financialOutlay, setFinancialOutlay] = useState(0);
  const [selectedScheme, setSelectedScheme] = useState(null);
  const [selectedState, setSelectedState] = useState(null);
  const [selectedDistrict, setSelectedDistrict] = useState([]);

  const [selectedSubScheme, setSelectedSubScheme] = useState(null);
  const [isSubScheme, setIsSubScheme] = useState(false);

  // Master data lists
  const [dummyMinistries, setDummyMinistries] = useState([]);
  const [dummyDepartments, setDummyDepartments] = useState([]);
  const [dummySchemeTypes, setDummySchemeTypes] = useState([]);
  const [dummySchemes, setDummySchemes] = useState([]);
  const [dummyIndicatorTypes, setDummyIndicatorTypes] = useState([]);
  const [dummyMeasurementTypes, setDummyMeasurementTypes] = useState([]);
  const [dummyUnits, setDummyUnits] = useState([]);
  const [dummyScales, setDummyScales] = useState([]);
  const [dummyStates, setDummyStates] = useState([]);
  const [dummyDistrict, setDummyDistrict] = useState([]);
  const [dummyMeasurementArea, setDummyMeasurementArea] = useState([]);
  const [dummyIndicatorRise, setDummyIndicatorRise] = useState([]);
  const [dummySdg, setDummySdg] = useState([]);
  const [dummyPeriod, setDummyPeriod] = useState([]);
  const [dummyCategoty, setDummyCategoty] = useState([]);
  const [dummyIndicator, setDummyIndicator] = useState([]);
  const [originalDummyIndicator, setOriginalDummyIndicator] = useState([]);
  const [dummyFrequencies, setDummyFrequencies] = useState([]);
  const [originalOutputOutcomes, setOriginalOutputOutcome] = useState([]);
  const [dummySubSchemes, setDummySubSchemes] = useState([]);
  const [outputResponse, setOutputResponse] = useState({});
  const [outcomeResponse, setOutcomeResponse] = useState({});

  // Pre filled data
  const [prefillData, setPrefillData] = useState(null);
  const [errorRatioOrRange, setErrorRatioOrRange] = useState({});
  const [helperText, setHelperText] = useState({});
  const inputRefs = useRef({});
  const [fieldErrors, setFieldErrors] = useState({});
  const subRoleIds = [
    ...new Set(
      userData?.privileges?.flatMap(
        (item) => item.accessRights?.oomfSubRoles?.map((role) => role.id) || [],
      ) || [],
    ),
  ];

  // Handle change for all types
  const handleChange = (e, sIdx, iIdx, unitType, fieldName, extra = {}) => {
    // Extract the raw value; in some custom calls (Autocomplete blur) we synthesize the event
    const raw = e?.target?.value ?? "";
    // Keep trimmed for consistency, but don't block typing anywhere
    const value = typeof raw === "string" ? raw.trim() : raw;

    let error = "";

    // Run regex validation ONLY for targets with these unit types
    if (fieldName === "targets") {
      if (unitType === 10) {
        const ratioRegex = /^\d+:\d+$/; // e.g., "3:4"
        if (value && !ratioRegex.test(value)) {
          error = "Enter a valid ratio (e.g., 3:4)";
        }
      } else if (unitType === 9) {
        const rangeRegex = /^\d+-\d+$/; // e.g., "2-5"
        if (value && !rangeRegex.test(value)) {
          error = "Enter a valid range (e.g., 2-5)";
        }
      }
    }

    const fieldKey =
      fieldName === "targets"
        ? `${currentType}_${sIdx}_${iIdx}_${fieldName}_${extra.targetKey}`
        : `${currentType}_${sIdx}_${iIdx}_${fieldName}`;

    // Update UI field errors (regex-style validation errors)
    setFieldErrors((prev) => {
      const newErrors = { ...prev };
      if (error) {
        newErrors[fieldKey] = error;
      } else {
        delete newErrors[fieldKey];
      }
      return newErrors;
    });

    // Forward to your reducer; IMPORTANT: this preserves extra.strict for validation logic there
    handleIndicatorChange(sIdx, iIdx, fieldName, value, extra);
  };
  const resetForm = () => {
    setPrefillData(null);
    setSelectedMinistry(null);
    setSelectedDepartment(null);
    setSelectedSchemeType(null);
    setSelectedScheme(null);
    setSelectedSubScheme(null);
    setFinancialOutlay(0);
    setSectionsByType({
      Outcome: [createNewSection()],
      Output: [createNewSection()],
    });
    setInitialDraft(true);
  };

  const handleSubmissionCheck = async (filters = {}) => {
    dispatch(startLoader());
    try {
      if (id) {
        return;
      }
      const res = await apiClient.post(
        `/api/oomf/submissions/check-submission`,
        filters,
      );
      const previousData = res?.data?.data;
      if (previousData?.isPresent) {
        setPrefillData(previousData?.data?.form_values);
        setPreviousSubmissionId(previousData?.data?.id);
        setAlertDialogOpen(true);
      }
    } catch (err) {
      dispatch(setError(err.message));
    } finally {
      dispatch(stopLoader());
    }
  };

  const fetchOutputOutcome = async (sectionId) => {
    if (moto !== "edit") return;
    if (!sectionId) return;
    const res = await apiClient.get(`api/master/output-outcome/${sectionId}`);
    return res?.data?.data;
  };

  useEffect(() => {
    if (!data) {
      resetForm();
      return;
    }

    setPrefillData(data);
    setInitialDraft(false);
  }, [data]);

  const dispatch = useDispatch();

  // Pre-fill data useEffect
  useEffect(() => {
    if (
      initialDraft ||
      !prefillData ||
      !dummyMinistries.length ||
      !dummySchemeTypes.length ||
      !dummyIndicatorTypes.length ||
      !dummyMeasurementTypes.length ||
      !dummyUnits.length ||
      !dummyScales.length ||
      !dummyMeasurementArea.length ||
      !dummyIndicatorRise ||
      !dummySdg ||
      !dummyPeriod.length ||
      !dummyCategoty.length ||
      !dummyFrequencies.length
    )
      return;
    setFinancialYear(prefillData.financialYear);
    setSelectedMinistry(prefillData.ministryId);
    setSelectedSchemeType(prefillData.schemeTypeId);
  }, [prefillData, dummyMinistries, dummySchemeTypes]);

  useEffect(() => {
    if (initialDraft || !prefillData) return;
    setSelectedDepartment(prefillData.departmentId);
  }, [initialDraft, prefillData]);

  // Set scheme when scheme list is ready
  useEffect(() => {
    if (initialDraft || !prefillData) return;
    setSelectedScheme(prefillData.schemeId);
    setFinancialOutlay(prefillData.financialOutlay);
  }, [initialDraft, prefillData]);

  useEffect(() => {
    if (initialDraft || !prefillData || !dummySubSchemes.length) return;
    setSelectedSubScheme(prefillData.subSchemeId);
  }, [initialDraft, prefillData, dummySubSchemes]);

  // Set indicator sections when everything is ready
  useEffect(() => {
    if (!prefillData) return;

    const indicatorTypesReady =
      dummyIndicatorTypes.length &&
      dummyMeasurementTypes.length &&
      dummyUnits.length &&
      dummyScales.length &&
      dummyMeasurementArea.length &&
      dummyIndicatorRise.length &&
      dummySdg.length &&
      dummyFrequencies.length &&
      dummyPeriod.length &&
      dummyCategoty.length;

    if (!indicatorTypesReady) return;

    const buildSections = async () => {
      const mappedSections = {};

      for (const item of prefillData.indicatorData) {
        const typeName = item.indicatorType.name;

        mappedSections[typeName] = await Promise.all(
          item.sections.map(async (sec) => {
            let latestSectionName = sec.name;

            // ✅ Fetch latest output–outcome name
            if (sec?.name) {
              try {
                const res = await fetchOutputOutcome(sec.id); // sec.name = id
                latestSectionName = res?.name || sec.name;
              } catch (err) {
                console.error("Failed to fetch output-outcome", err);
              }
            }

            return {
              ...sec,
              name: latestSectionName, // ✅ APPLY updated name
              indicators: sec.indicators.map((ind) => ({
                ...ind,
                measurementType: ind.measurementType?.id ?? "",
                unit: ind.unit?.id ?? "",
                scale: ind.scale?.id ?? "",
                measurementArea: ind.measurementArea?.id ?? "",
                indicatorRise: ind.indicatorRise?.id ?? "",
                sdg: ind.sdg?.id ?? "",
                frequency: ind.frequency?.id ?? "",
                period: ind.period?.id ?? "",
                applicableCategory: ind.applicableCategory?.id ?? "",
                indicator: ind.indicator?.id ?? "",
              })),
            };
          }),
        );
      }

      setSectionsByType(mappedSections);
    };

    buildSections();
  }, [
    prefillData,
    dummyIndicatorTypes,
    dummyMeasurementTypes,
    dummyUnits,
    dummyScales,
    dummyMeasurementArea,
    dummyIndicatorRise,
    dummySdg,
    dummyFrequencies,
    dummyPeriod,
    dummyCategoty,
  ]);

  // Fetch dynamic departments when ministry changes
  useEffect(() => {
    if (!selectedMinistry) return;

    async function getData() {
      dispatch(startLoader());
      try {
        const payload = {
          ministryIds: [selectedMinistry?.id],
        };
        const res = await apiClient.post(
          `/api/master/get-departments-for-ministry`,
          payload,
        );
        const departmentsData = res?.data?.data?.map((item) => ({
          id: item?.id,
          name: item?.name,
          associatedFramework: item?.jsonData?.associatedFramework,
        }));
        setDummyDepartments(departmentsData);
      } catch (err) {
        dispatch(setError(err.message));
      } finally {
        dispatch(stopLoader());
      }
    }

    if (selectedMinistry?.id) getData();
  }, [selectedMinistry]);

  useEffect(() => {
    async function getDistrictsByState() {
      try {
        const payload = {
          stateIds: [selectedState?.id],
        };
        const res = await apiClient.post(
          `/api/master/get-district-for-state`,
          payload,
        );
        const districtsData = res?.data?.data;
        const formattedData = districtsData?.map((district) => ({
          id: district?.id,
          name: district?.district_name,
        }));
        setDummyDistrict(formattedData);
      } catch (err) {
        dispatch(setError(err.message));
      }
    }
    if (selectedState?.id) {
      getDistrictsByState();
    }
  }, [selectedState]);

  // Fetch schemes when department changes
  // useEffect(() => {
  //   if (!selectedDepartment || !selectedSchemeType) return;

  //   async function getData() {
  //     try {
  //       const appSubSchemeFilterData = await apiClient.get(
  //         "api/master/schemes-subscheme-dropdown-application-submission"
  //       );

  //       const responseData = appSubSchemeFilterData?.data?.data || [];

  //       // Unique schemeIds
  //       const schemeIds = [
  //         ...new Set(responseData.map((item) => item.schemeId)),
  //       ];

  //       // Unique subSchemeIds (flattened)
  //       const subSchemeIds = [
  //         ...new Set(responseData.flatMap((item) => item.subSchemeIds || [])),
  //       ];

  //       const payload = {
  //         id: selectedDepartment?.id,
  //         schemeTypeId: selectedSchemeType?.id,
  //         financialYear: financialYear,
  //       };
  //       const res = await apiClient.post(`api/master/get-schemes`, payload);
  //       const schemesData = res.data?.data?.map((item) => ({
  //         ...item,
  //         id: item?.id,
  //         name: item?.name,
  //         associatedFramework:
  //           item?.jsonData?.schemeFinancialYearWiseBudgetDetails?.map(
  //             (item) => item?.associatedFrameworks
  //           ),
  //       }));
  //       setDummySchemes(schemesData);
  //     } catch (err) {
  //       dispatch(
  //         setError(
  //           err?.response?.data?.message || err.message || "Unknown error"
  //         )
  //       );
  //     }
  //   }

  //   if (
  //     selectedDepartment !== null &&
  //     selectedSchemeType !== null &&
  //     financialYear
  //   )
  //     getData();
  // }, [selectedDepartment, selectedSchemeType, financialYear]);

  useEffect(() => {
    if (!selectedDepartment || !selectedSchemeType || !financialYear) return;

    async function getData() {
      dispatch(startLoader());
      try {
        // 1️⃣ Fetch application submission data
        const appSubSchemeFilterData = await apiClient.get(
          "api/master/schemes-subscheme-dropdown-application-submission",
        );
        const responseData = appSubSchemeFilterData?.data?.data || [];

        // Map: schemeId -> Set(subSchemeIds submitted)
        const schemeToSubSchemeMap = new Map();
        responseData.forEach((item) => {
          schemeToSubSchemeMap.set(
            item.schemeId,
            new Set(item.subSchemeIds || []),
          );
        });

        // 2️⃣ Fetch all schemes
        const payload = {
          id: selectedDepartment?.id,
          schemeTypeId: selectedSchemeType?.id,
          financialYear: financialYear,
        };
        const res = await apiClient.post(`api/master/get-schemes`, payload);

        const schemesData =
          res.data?.data?.map((item) => ({
            ...item,
            id: item?.id,
            name: item?.name,
            subSchemes: item?.subSchemes || [],
            associatedFramework:
              item?.jsonData?.schemeFinancialYearWiseBudgetDetails?.map(
                (i) => i?.associatedFrameworks,
              ),
          })) || [];

        // 🚨 EDIT,VIEW,DRAFT MODE → DO NOT FILTER
        if (id && ["edit", "view", "draft"].includes(moto)) {
          setDummySchemes(schemesData);
          return;
        }

        const allSchemeIds = schemesData.map((s) => s.id);

        // 3️⃣ Fetch subschemes in bulk
        const bulkSubSchemesRes = await apiClient.post(
          "/api/master/get-subscheme-ids-by-scheme-bulk",
          { schemeIds: allSchemeIds },
        );

        const schemeToAllSubSchemesMap = new Map();
        (bulkSubSchemesRes?.data?.data || []).forEach((item) => {
          schemeToAllSubSchemesMap.set(item.schemeId, item.subSchemeIds || []);
        });

        // 4️⃣ FILTER SCHEMES (Create mode only)
        const filteredSchemes = schemesData.filter((scheme) => {
          const schemeId = scheme.id;

          const submittedSubSchemes =
            schemeToSubSchemeMap.get(schemeId) || new Set();

          const allSubSchemeIds = schemeToAllSubSchemesMap.get(schemeId) || [];

          if (isSubScheme) {
            if (allSubSchemeIds.length === 0) return false;

            return allSubSchemeIds.some(
              (subId) => !submittedSubSchemes.has(subId),
            );
          } else {
            return !schemeToSubSchemeMap.has(schemeId);
          }
        });

        // 5️⃣ Update dropdown
        setDummySchemes(filteredSchemes);
      } catch (err) {
        dispatch(
          setError(
            err?.response?.data?.message || err.message || "Unknown error",
          ),
        );
      } finally {
        dispatch(stopLoader());
      }
    }

    getData();
  }, [selectedDepartment, selectedSchemeType, financialYear, id]);

  // Initial fetch of all master data
  useEffect(() => {
    async function fetchMasters() {
      try {
        const res = await apiClient.get("api/master/all-oomf-masters");
        const {
          ministries,
          schemeTypes,
          indicatorTypes,
          measurementTypes,
          units,
          scales,
          states,
          districts,
          measurementAreas,
          indicatorRises,
          sdg,
          frequencies,
          periods,
          categories,
        } = res.data.data;
        setDummyMinistries(
          ministries?.map((item) => ({
            id: item?.id,
            name: item?.name,
            associatedFramework: item?.jsonData?.associatedFramework,
          })),
        );
        setDummyIndicatorTypes(indicatorTypes);
        setDummyMeasurementTypes(measurementTypes);
        setDummyUnits(units);
        setDummyScales(scales);
        setDummyStates(
          states.map((item) => ({
            id: item?.id,
            name: item?.state_name,
          })),
        );
        setDummyDistrict(
          districts.map((item) => ({
            id: item?.id,
            name: item?.district_name,
          })),
        );
        setDummyMeasurementArea(measurementAreas);
        setDummyIndicatorRise(indicatorRises);
        setDummySdg(sdg);
        setDummyFrequencies(frequencies);
        setDummyPeriod(periods);
        setDummyCategoty(categories);
      } catch (err) {
        dispatch(setError(err.message));
      }
    }
    async function fetchIndicators() {
      const payload = {
        ministryIds: userMinistryIds,
        departmentIds: userDepartmentIds,
        schemeIds: userSchemeIds,
      };
      const response = await apiClient.post(
        "api/master/get-all-indicators",
        payload,
      );
      const { data: res } = response?.data || [];
      // setDummyIndicator(res);
      setOriginalDummyIndicator(res);
    }

    fetchMasters();
    fetchIndicators();
  }, []);

  // Fetch schemeType by framework
  useEffect(() => {
    const fetchSchemeTypeByFramework = async () => {
      dispatch(startLoader());
      try {
        const response = await apiClient.post(
          `api/master/schemeType/by-framework`,
          {
            associatedFrameworks: [oomfFrameworkId],
          },
        );

        const { data } = response?.data || {};
        if (Array.isArray(data)) {
          const formattedData = data?.map((item) => ({
            id: item?.id,
            name: item?.name,
          }));
          setDummySchemeTypes(formattedData);
        }
      } catch (error) {
        console.error("Failed to fetch scheme-type list:", error);
      } finally {
        dispatch(stopLoader());
      }
    };
    fetchSchemeTypeByFramework();
  }, []);

  // Fetch sub-schemes when scheme changes
  // useEffect(() => {
  //   if (!selectedScheme || !isSubScheme) return;

  //   async function getSubSchemes() {
  //     try {
  //       const payload = {
  //         schemeIds: [selectedScheme?.id],
  //         // financialYear: financialYear,
  //       };
  //       const res = await apiClient.post(
  //         // `/api/master/get-sub-schemes`,
  //         `/api/master/get-subschemes-for-schemes`,
  //         payload
  //       );
  //       const subSchemesData = res.data?.data?.map((item) => ({
  //         id: item?.id,
  //         name: item?.name,
  //       }));
  //       setDummySubSchemes(subSchemesData);
  //     } catch (err) {
  //       dispatch(setError(err.message));
  //     }
  //   }

  //   if (selectedScheme !== null && financialYear) getSubSchemes();
  // }, [selectedScheme, financialYear, isSubScheme]);

  useEffect(() => {
    if (!selectedScheme || !isSubScheme || !financialYear) return;

    async function getSubSchemes() {
      try {
        // 1️⃣ Fetch submitted subscheme data
        const appSubSchemeFilterData = await apiClient.get(
          "api/master/schemes-subscheme-dropdown-application-submission",
        );

        const responseData = appSubSchemeFilterData?.data?.data || [];

        // schemeId -> Set(subSchemeIds already submitted)
        const schemeToSubSchemeMap = new Map();
        responseData.forEach((item) => {
          schemeToSubSchemeMap.set(
            item.schemeId,
            new Set(item.subSchemeIds || []),
          );
        });

        // 2️⃣ Fetch all subschemes with actual names
        const payload = { schemeIds: [selectedScheme.id], financialYear };
        const res = await apiClient.post(
          "/api/master/get-subschemes-for-schemes",
          payload,
        );
        const allSubSchemes = res.data?.data || [];

        // 🔑 Build lookup: subSchemeId -> subSchemeName
        const subSchemeNameMap = new Map(
          allSubSchemes.map((item) => [item.id, item.name]),
        );

        // 3️⃣ Fetch all subscheme IDs for the scheme
        const bulkSubSchemesRes = await apiClient.post(
          "/api/master/get-subscheme-ids-by-scheme-bulk",
          { schemeIds: [selectedScheme.id] },
        );

        const allSubSchemeIds =
          bulkSubSchemesRes?.data?.data?.[0]?.subSchemeIds || [];

        // 🚨 EDIT / VIEW / DRAFT → NO FILTER
        if (id && ["edit", "view", "draft"].includes(moto)) {
          setDummySubSchemes(
            allSubSchemeIds.map((subId) => ({
              id: subId,
              name: subSchemeNameMap.get(subId) || "",
            })),
          );
          return;
        }

        // 4️⃣ CREATE FLOW → filter already submitted subschemes
        const submittedSubSchemes =
          schemeToSubSchemeMap.get(selectedScheme.id) || new Set();

        const filteredSubSchemes = allSubSchemeIds
          .filter((subId) => !submittedSubSchemes.has(subId))
          .map((subId) => ({
            id: subId,
            name: subSchemeNameMap.get(subId) || "",
          }));

        // 5️⃣ Update dropdown
        setDummySubSchemes(filteredSubSchemes);
      } catch (err) {
        dispatch(
          setError(
            err?.response?.data?.message || err.message || "Unknown error",
          ),
        );
      } finally {
        dispatch(stopLoader());
      }
    }

    getSubSchemes();
  }, [selectedScheme, financialYear, isSubScheme]);

