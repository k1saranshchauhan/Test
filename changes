"use client";
import React, { useEffect, useState } from "react";
import { useFormik } from "formik";
import {
  Grid,
  Button,
  Divider,
  Box,
  Typography,
  CircularProgress,
  Tooltip,
} from "@mui/material";
import * as Yup from "yup";
import { CustomAutoComplete } from "@/src/components/superadmin/CustomAutoComplete";
import MainFormHeader from "@/src/components/DashboardUI/MainFormHeader";
import apiClient from "@/utils/apiClient";

const PrayasIntegration = () => {
  const [questionnaireList, setQuestionnaireList] = useState([]);
  const [quarterList, setQuarterList] = useState([]);
  const [responseData, setResponseData] = useState(null);

  // 🔥 New states
  const [quarterError, setQuarterError] = useState("");
  const [isQuarterValid, setIsQuarterValid] = useState(true);
  const [loadingQuarter, setLoadingQuarter] = useState(false);

  // ---------------- Formik ----------------
  const formik = useFormik({
    initialValues: {
      questionnaire: null,
      quarter: null,
    },
    validationSchema: Yup.object({
      questionnaire: Yup.object().required("Questionnaire is Required"),
      quarter: Yup.object().required("Quarter is Required"),
    }),
    onSubmit: async (values) => {
      const payload = {
        questionnaireId: values?.questionnaire?.id,
        datadate: values?.quarter?.label,
      };

      try {
        const res = await apiClient.post(
          "/api/dgqi/prayasIntegration/pushdata",
          payload
        );
        setResponseData(res?.data);
      } catch (error) {
        console.error("API Error:", error);
      }
    },
  });

  // ---------------- Fetch Questionnaire ----------------
  const fetchQuestionnaire = async () => {
    try {
      const res = await apiClient.get(
        "/api/dgqi/questionnaires/published-questionnaires"
      );

      const data = res.data.data || [];

      setQuestionnaireList(
        data.map((item) => ({
          id: item.id,
          label: item.title,
        }))
      );
    } catch (error) {
      setQuestionnaireList([]);
      console.error(error);
    }
  };

  // ---------------- Fetch Quarter (ONLY AFTER QUESTIONNAIRE) ----------------
  useEffect(() => {
    const fetchQuarter = async () => {
      if (!formik.values.questionnaire) return;

      setLoadingQuarter(true);
      setQuarterError("");
      setIsQuarterValid(true);
      setQuarterList([]);
      formik.setFieldValue("quarter", null);

      try {
        const res = await apiClient.get(
          "/api/dgqi/prayasIntegration/quarters",
          {
            params: {
              questionnaireId: formik.values.questionnaire.id,
            },
          }
        );

        // ❗ Important case
        if (!res?.data?.success) {
          setIsQuarterValid(false);
          setQuarterError(res?.data?.message);
          return;
        }

        const data = res.data.data || [];

        setQuarterList(
          data.map((item) => ({
            id: item.id,
            label: item.title,
          }))
        );
      } catch (error) {
        console.error(error);
        setIsQuarterValid(false);
        setQuarterError("Failed to fetch quarter");
      } finally {
        setLoadingQuarter(false);
      }
    };

    fetchQuarter();
  }, [formik.values.questionnaire]);

  useEffect(() => {
    fetchQuestionnaire();
  }, []);

  return (
    <Box mt={2} p={3}>
      <form onSubmit={formik.handleSubmit}>
        <MainFormHeader title="Prayas Integration" />
        <Divider sx={{ mt: 2, mb: 5 }} />

        <Grid container spacing={2}>
          {/* Questionnaire */}
          <Grid size={{ xs: 12, sm: 6 }}>
            <CustomAutoComplete
              name="questionnaire"
              options={questionnaireList}
              label="Questionnaire"
              formik={formik}
              required
              multiple={false}
              selectAll={false}
            />
          </Grid>

          {/* Quarter */}
          <Grid size={{ xs: 12, sm: 6 }}>
            <Tooltip
              title={
                !formik.values.questionnaire
                  ? "Select Questionnaire first"
                  : loadingQuarter
                  ? "Loading quarters..."
                  : !isQuarterValid
                  ? quarterError
                  : ""
              }
              arrow
            >
              <div>
                <CustomAutoComplete
                  name="quarter"
                  options={quarterList}
                  label="Quarter"
                  formik={formik}
                  required
                  multiple={false}
                  selectAll={false}
                  readOnly={
                    !formik.values.questionnaire ||
                    loadingQuarter ||
                    !isQuarterValid
                  }
                />
              </div>
            </Tooltip>
          </Grid>
        </Grid>

        {/* ❗ Error Message */}
        {!isQuarterValid && (
          <Box mt={2}>
            <Typography color="error" variant="body2">
              {quarterError}
            </Typography>
          </Box>
        )}

        {/* Buttons */}
        <Grid container spacing={2}>
          <Grid size={{ xs: 12, sm: 6 }}>
            <Tooltip
              title={!isQuarterValid ? quarterError : ""}
              arrow
            >
              <span>
                <Button
                  type="submit"
                  fullWidth
                  variant="contained"
                  sx={{ mt: 3 }}
                  disabled={!isQuarterValid}
                >
                  Submit
                </Button>
              </span>
            </Tooltip>
          </Grid>

          <Grid size={{ xs: 12, sm: 6 }}>
            <Button
              type="reset"
              fullWidth
              variant="outlined"
              sx={{ mt: 3 }}
              onClick={() => {
                formik.resetForm();
                setQuarterList([]);
                setQuarterError("");
                setIsQuarterValid(true);
                setResponseData(null);
              }}
            >
              Clear
            </Button>
          </Grid>
        </Grid>
      </form>

      {/* Response Section */}
      <Box sx={{ mt: 6 }}>
        {responseData === null ? (
          <Typography align="center" color="textSecondary">
            Please select values and submit
          </Typography>
        ) : responseData?.length === 0 ? (
          <Typography align="center" color="textSecondary">
            No data available
          </Typography>
        ) : (
          <Typography align="center" color="green">
            Data sent successfully
          </Typography>
        )}
      </Box>
    </Box>
  );
};

export default PrayasIntegration;
