"use client";

import React, { useState, useEffect, useMemo, useCallback } from "react";
import {
  Box,
  TextField,
  Paper,
  InputAdornment,
  IconButton,
  Typography,
  Stack,
  Divider,
  Card,
  CardContent,
} from "@mui/material";
import { DataGrid, GridToolbarContainer, GridToolbarExport } from "@mui/x-data-grid";
import { Search, Clear, DragIndicator, Storage } from "@mui/icons-material";
import { DragDropContext, Droppable, Draggable } from "@hello-pangea/dnd";

/**
 * 1. Define Toolbar outside to prevent re-render loops
 */
const CustomToolbar = () => (
  <GridToolbarContainer sx={{ p: 1, borderBottom: "1px solid", borderColor: "divider" }}>
    <GridToolbarExport />
  </GridToolbarContainer>
);

const AdvancedDataGrid = ({
  data = [],
  columns = [],
  rowIdField = "id",
  enableReorder = true,
  searchPlaceholder = "Search records...",
  onSelectionChange,
  checkboxSelection = true,
}) => {
  const [searchText, setSearchText] = useState("");
  const [gridRows, setGridRows] = useState([]);

  // Sync rows whenever the prop data changes
  useEffect(() => {
    if (data) {
      setGridRows(data);
    }
  }, [data]);

  // 2. High-Performance Search Logic
  const filteredRows = useMemo(() => {
    const term = searchText.toLowerCase().trim();
    if (!term) return gridRows;

    return gridRows.filter((row) =>
      Object.values(row).some(
        (val) => val !== null && val !== undefined && String(val).toLowerCase().includes(term)
      )
    );
  }, [gridRows, searchText]);

  // 3. Drag and Drop Handler
  const onDragEnd = useCallback((result) => {
    if (!result.destination) return;

    const reordered = Array.from(gridRows);
    const [movedItem] = reordered.splice(result.source.index, 1);
    reordered.splice(result.destination.index, 0, movedItem);

    setGridRows(reordered);
  }, [gridRows]);

  // 4. Column Definitions (adding Drag Handle)
  const finalColumns = useMemo(() => {
    const baseColumns = columns.map((col) => ({
      ...col,
      flex: col.flex || 1,
      minWidth: col.width || 120,
    }));

    if (enableReorder) {
      return [
        {
          field: "drag_handle",
          headerName: "",
          width: 50,
          sortable: false,
          filterable: false,
          disableColumnMenu: true,
          renderCell: () => (
            <Box sx={{ display: "flex", alignItems: "center", height: "100%" }}>
              <DragIndicator sx={{ color: "action.disabled", cursor: "grab" }} />
            </Box>
          ),
        },
        ...baseColumns,
      ];
    }
    return baseColumns;
  }, [columns, enableReorder]);

  return (
    <Card variant="outlined" sx={{ borderRadius: 2, boxShadow: "0 2px 10px rgba(0,0,0,0.05)" }}>
      <CardContent sx={{ p: 0, "&:last-child": { pb: 0 } }}>
        <Stack spacing={0}>
          {/* Header Section styled like your reference code */}
          <Box sx={{ p: 2, bgcolor: "background.paper" }}>
            <Stack direction={{ xs: "column", sm: "row" }} spacing={2} alignItems="center">
              <Stack direction="row" spacing={1} alignItems="center" sx={{ flexGrow: 1 }}>
                <Storage color="primary" />
                <Typography variant="h6" fontWeight="600">
                  Data Management
                </Typography>
              </Stack>

              <TextField
                size="small"
                variant="outlined"
                placeholder={searchPlaceholder}
                value={searchText}
                onChange={(e) => setSearchText(e.target.value)}
                sx={{ width: { xs: "100%", sm: 300 }, bgcolor: "white" }}
                InputProps={{
                  startAdornment: (
                    <InputAdornment position="start">
                      <Search fontSize="small" color="action" />
                    </InputAdornment>
                  ),
                  endAdornment: searchText && (
                    <IconButton size="small" onClick={() => setSearchText("")}>
                      <Clear fontSize="small" />
                    </IconButton>
                  ),
                }}
              />
            </Stack>
          </Box>

          <Divider />

          {/* Grid Section */}
          <Box sx={{ height: 500, width: "100%" }}>
            <DragDropContext onDragEnd={onDragEnd}>
              <Droppable droppableId="datagrid-droppable">
                {(provided) => (
                  <div {...provided.droppableProps} ref={provided.innerRef} style={{ height: "100%" }}>
                    <DataGrid
                      rows={filteredRows}
                      columns={finalColumns}
                      getRowId={(row) => row[rowIdField]}
                      checkboxSelection={checkboxSelection}
                      onRowSelectionModelChange={(ids) => onSelectionChange?.(ids)}
                      disableRowSelectionOnClick
                      slots={{ toolbar: CustomToolbar }}
                      sx={{
                        border: "none",
                        "& .MuiDataGrid-columnHeaders": {
                          bgcolor: "grey.50",
                          color: "text.primary",
                          fontWeight: "bold",
                        },
                        "& .MuiDataGrid-cell:focus": {
                          outline: "none",
                        },
                        "& .MuiDataGrid-row:hover": {
                          bgcolor: "action.hover",
                        },
                      }}
                    />
                    {provided.placeholder}
                  </div>
                )}
              </Droppable>
            </DragDropContext>
          </Box>
        </Stack>
      </CardContent>
    </Card>
  );
};

export default AdvancedDataGrid;
