async function generateDynamicReport(
  financialYears = [],
  submissionIds = [],
  ministryIds = [],
  departmentIds = [],
  schemeIds = [],
  measurementAreaIds = []
) {
  try {
    // 🔹 Build dynamic where condition
    const whereConditions = {
      AND: [
        { form_values: { not: null } },
        ...(financialYears.length
          ? [
              {
                OR: financialYears.map((fy) => ({
                  form_values: {
                    path: ["financialYear"],
                    equals: fy,
                  },
                })),
              },
            ]
          : []),
        ...(submissionIds.length ? [{ id: { in: submissionIds } }] : []),
      ],
    };

    // 🔹 Fetch submissions
    const submissions = await prisma.applicationSubmission.findMany({
      where: whereConditions,
    });

    if (!submissions.length) {
      return { status: false, message: "No submissions found", result: [] };
    }

    // 🔹 Fetch mapping data for each submission
    const results = await Promise.all(
      submissions.map(async (submission) => {
        const mapping = await prisma.outputOutcomeMapping.findUnique({
          where: { submission_id: submission.id },
        });

        return {
          id: submission.id,
          form_values: safeJSON(submission.form_values),
          links: safeJSON(mapping ? mapping.mappingData : {}),
        };
      })
    );

    // 🔹 Apply filters
    const filteredResults = results.filter((res) => {
      const fv = res.form_values;

      if (ministryIds.length && !ministryIds.includes(fv.ministryId?.id))
        return false;

      if (departmentIds.length && !departmentIds.includes(fv.departmentId?.id))
        return false;

      if (schemeIds.length && !schemeIds.includes(fv.schemeId?.id))
        return false;

      if (measurementAreaIds.length) {
        const hasMatchingArea = fv.indicatorData?.some((ind) =>
          ind.sections?.some((sec) =>
            sec.indicators?.some(
              (indicator) =>
                indicator.measurementArea &&
                measurementAreaIds.includes(indicator.measurementArea.id)
            )
          )
        );
        if (!hasMatchingArea) return false;
      }

      return true;
    });

    if (!filteredResults.length) {
      return {
        status: false,
        message: "No submissions matched given filters",
        result: [],
      };
    }

    // 🔹 Normalize indicator data
    const prunedResults = filteredResults.map((res) => {
      const fv = res.form_values;

      const indicatorData =
        fv.indicatorData?.map((ind) => ({
          indicatorType: ind.indicatorType || "N/A",
          sections:
            ind.sections?.map((sec) => ({
              ...sec,
              indicators:
                measurementAreaIds.length > 0
                  ? sec.indicators?.filter(
                      (indicator) =>
                        indicator.measurementArea &&
                        measurementAreaIds.includes(
                          indicator.measurementArea.id
                        )
                    ) || []
                  : sec.indicators || [],
            })) || [],
        })) || [];

      return {
        ...res,
        form_values: { ...fv, indicatorData },
      };
    });

    // 🔹 Collect department IDs
    const allDepartmentIds = [
      ...new Set(
        prunedResults
          .map((r) => r.form_values?.departmentId?.id)
          .filter(Boolean)
      ),
    ];

    // 🔹 Fetch departments and demand numbers
    const departmentsData = await prisma.departments.findMany({
      where: { id: { in: allDepartmentIds } },
      select: { id: true, jsonData: true },
    });

    const departmentDemandMap = {};
    departmentsData.forEach((dept) => {
      const json = safeJSON(dept.jsonData);
      departmentDemandMap[dept.id] = json?.demandNo
        ? Number(json.demandNo)
        : null;
    });

    // 🔹 Build hierarchical structure
    const ministriesMap = {};

    for (const res of prunedResults) {
      const fv = res.form_values;

      const ministry = {
        id: fv.ministryId?.id || 0,
        name: fv.ministryId?.name || "Unknown Ministry",
      };

      const deptId = fv.departmentId?.id || 0;
      const department = {
        id: deptId,
        name: fv.departmentId?.name || "Unknown Department",
        demandNumber: departmentDemandMap[deptId] || null,
      };

      const schemeId = fv.schemeId?.id || 0;
      const subSchemeId = fv.subSchemeId?.id || null;

      // Initialize Ministry
      if (!ministriesMap[ministry.id]) {
        ministriesMap[ministry.id] = { ...ministry, departments: {} };
      }

      // Initialize Department
      if (!ministriesMap[ministry.id].departments[deptId]) {
        ministriesMap[ministry.id].departments[deptId] = {
          ...department,
          schemes: {},
        };
      }

      const schemesMap = ministriesMap[ministry.id].departments[deptId].schemes;

      // If it's a sub-scheme submission
      if (subSchemeId) {
        // Ensure parent scheme exists
        if (!schemesMap[schemeId]) {
          schemesMap[schemeId] = {
            id: schemeId,
            name: fv.schemeId?.name || "Unknown Scheme",
            form_values: null, // parent may come later
            links: {},
            subSchemes: [],
          };
        }

        // Add sub-scheme
        const subSchemeObj = {
          id: subSchemeId,
          name: fv.subSchemeId?.name || "Unknown Sub-Scheme",
          form_values: fv,
          links: res.links,
        };

        // Prevent duplicates
        if (
          !schemesMap[schemeId].subSchemes.some((s) => s.id === subSchemeObj.id)
        ) {
          schemesMap[schemeId].subSchemes.push(subSchemeObj);
        }
      } else {
        // Scheme-level submission
        if (!schemesMap[schemeId]) {
          schemesMap[schemeId] = {
            id: schemeId,
            name: fv.schemeId?.name || "Unknown Scheme",
            form_values: fv,
            links: res.links,
            subSchemes: [],
          };
        } else {
          // Update parent scheme data if not already populated
          if (!schemesMap[schemeId].form_values) {
            schemesMap[schemeId].form_values = fv;
            schemesMap[schemeId].links = res.links;
          }
        }
      }
    }

    // 🔹 Convert to final array format
    const ministries = Object.values(ministriesMap).map((ministry) => ({
      id: ministry.id,
      name: ministry.name,
      departments: Object.values(ministry.departments).map((dept) => ({
        id: dept.id,
        name: dept.name,
        demandNumber: dept.demandNumber,
        schemes: Object.values(dept.schemes),
      })),
    }));

    return {
      status: true,
      message: "Dynamic report generated successfully.",
      result: ministries,
    };
  } catch (error) {
    console.error("Service Error (generateDynamicReport):", error);
    throw error;
  }
}
