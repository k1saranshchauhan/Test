        id: item?.id,
        label: item?.name,
      }));
    setOrgTypesList(finalOrgTypes);
  };

  useEffect(() => {
    fetchOrgTypes();
  }, []);
  useEffect(() => {
    const fetchData = async () => {
      try {
        if (!editId) return; // No editId → skip

        let response;

        // 🟢 Decide which API to call based on status
        if (status === "Draft") {
          response = await apiClient.get(`/api/draft/get-draft/${editId}`);
        } else {
          response = await apiClient.get(`/api/alert/get-alert/${editId}`);
        }

        const { data } = response?.data || {};
        if (!data) return;

        // 🧩 Draft data has metaData JSON inside
        const editData = status === "Draft" ? data.metaData : data;

        // 🧠 Derive recipients in a uniform structure
        const recipientDetails =
          status === "Draft"
            ? editData?.user_ids
            : Array.from(
                new Map(
                  (editData?.alert_logs || []).map((log) => {
                    const user = log?.user || {};
                    return [
                      user?.id,
                      {
                        id: user?.id || null,
                        label: user?.email || "",
                      },
                    ];
                  }),
                ).values(),
              );

        // 🪄 Normalize field names (for consistency between Draft & Alert)
        const normalizedData = {
          ...editData,
          alertType:
            editData?.alertType || editData?.type
              ? {
                  label:
                    editData?.type === "EMAIL" ? "Email Alert" : editData?.type,
                  value: editData?.type,
                }
              : null,
          targetModule: editData?.targetModule || editData?.targetModules,
          ministry: editData?.ministry || editData?.ministry_ids,
          department: editData?.department || editData?.dept_ids,
          orgTypes: editData.orgTypeDetails || [],
          recepients: recipientDetails, // ✅ unified recipient data
          startDate: editData?.startDate,
          endDate: editData?.endDate,
          frequencyPattern:
            editData?.frequencyPattern?.frequencyPattern ||
            editData?.frequencyPattern ||
            {},
          content: editData?.content,
          specificCondition: editData?.specificCondition || "",
        };

        handleEditFormPopulation(normalizedData);
