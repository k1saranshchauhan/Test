// 🔹 Common reusable Actions column

const getMasterCondition = (rowData, urlModal) => {
  if (!rowData || !urlModal) return true; // default allow

  // Define a mapping between modal types and their respective flags
  const editabilityMap = {
    user: "isEditableUser",
    role: "isEditableRole",
  };

  // Get the relevant key based on the current modal
  const key = editabilityMap[urlModal?.toLowerCase()];

  // If key doesn’t exist in map → default allow editing
  if (!key) return true;
  // Return value of the matched key, or default to true
  return rowData[key] !== false;
};

const getActionsColumn = ({
  hasAddAccess,
  hasEditAccess,
  hasViewAccess,
  handleEdit,
  handleViewAuditTrail,
  setIsViewing,
  setSchemeData,
  urlModal,
}) => ({
  field: "actions",
  headerName: "Actions",
  // flex: 0.5,
  // minWidth: 200,
  width: 150,
  sortable: false,
  filterable: false,
  headerAlign: "left",
  align: "left",
  renderCell: (params) => {
    const key = getMasterCondition(params.row, urlModal);
    return (
      <Stack direction="row" spacing={1}>
        {hasEditAccess && key && (
          <IconButton
            onClick={() => {
              handleEdit(params.row);
              setIsViewing(false);
            }}
            color="primary"
            size="small"
          >
            <EditIcon />
          </IconButton>
        )}
        {hasViewAccess && (
          <IconButton
            onClick={() => {
              handleEdit(params.row);
              setIsViewing(true);
            }}
            color="primary"
            size="small"
          >
            <RemoveRedEyeOutlined />
          </IconButton>
        )}
        {/* <Tooltip title="View Audit Trail">
        <IconButton
          onClick={() => handleViewAuditTrail(params.row)}
          color="primary"
          size="small"
        >
          <HistoryIcon />
        </IconButton>
      </Tooltip> */}
        {urlModal === "schemes" && hasAddAccess && (
          <Tooltip title="Add Scheme Budget Details">
            <IconButton
              onClick={() => setSchemeData(params.row)}
              color="primary"
              size="small"
            >
              <PlaylistAddIcon sx={{ fontSize: "32px" }} />
            </IconButton>
          </Tooltip>
        )}
      </Stack>
    );
  },
});

const applyCustomLogic = (columns) =>
  columns.map((col) => ({
    ...col,
    filterOperators: dataGridFilterOperators, // Your custom logic here
  }));
