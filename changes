"use client";

import React, { useEffect, useState, useMemo } from "react";
import {
  Box,
  TextField,
  Typography,
  Paper,
} from "@mui/material";
import { DataGrid, GridToolbar } from "@mui/x-data-grid";
import { DragDropContext, Droppable, Draggable } from "react-beautiful-dnd";
import dayjs from "dayjs";

/**
 * AdvancedDataGrid
 * Props:
 *  - data: array of objects
 *  - columns: DataGrid columns
 *  - rowIdField: field name to use as row ID (default "id")
 *  - enableReorder: boolean, allow drag & drop reordering
 *  - searchPlaceholder: string
 *  - onSelectionChange: callback for selected rows
 */
const AdvancedDataGrid = ({
  data = [],
  columns = [],
  rowIdField = "id",
  enableReorder = false,
  searchPlaceholder = "Search...",
  onSelectionChange,
  checkboxSelection = false,
}) => {
  const [searchText, setSearchText] = useState("");
  const [filteredData, setFilteredData] = useState(data);
  const [gridData, setGridData] = useState(data);
  const [selectionModel, setSelectionModel] = useState([]);

  useEffect(() => {
    setGridData(data);
    setFilteredData(data);
  }, [data]);

  // 🔍 Filtering
  useEffect(() => {
    const trimmedSearch = (searchText || "").trim().toLowerCase();
    if (!trimmedSearch) {
      setFilteredData(gridData);
      return;
    }

    const ignoredKeys = ["id", "uuid", "raw"];

    const searchObject = (obj) => {
      if (!obj || typeof obj !== "object") return false;

      // Shallow search
      const shallowMatch = Object.entries(obj).some(([key, val]) => {
        if (ignoredKeys.includes(key.toLowerCase()) || val == null) return false;

        // Boolean
        if (key === "is_active" && typeof val === "boolean") {
          const statusText = val ? "active" : "inactive";
          return statusText.startsWith(trimmedSearch);
        }

        // ISO date strings
        if (typeof val === "string" && /^\d{4}-\d{2}-\d{2}T/.test(val)) {
          const formattedDate = dayjs(val).format("DD-MMM-YYYY").toLowerCase();
          return formattedDate.includes(trimmedSearch);
        }

        // string or number
        if (typeof val === "string" || typeof val === "number") {
          return val.toString().toLowerCase().includes(trimmedSearch);
        }

        return false;
      });

      if (shallowMatch) return true;

      // Deep recursive
      return Object.entries(obj).some(([key, val]) => {
        if (ignoredKeys.includes(key.toLowerCase()) || val == null) return false;
        if (typeof val === "object") {
          if (Array.isArray(val)) return val.some((item) => searchObject(item));
          else return searchObject(val);
        }
        return false;
      });
    };

    const filtered = gridData.filter((item) => searchObject(item));
    setFilteredData(filtered);
  }, [searchText, gridData]);

  // 🔀 Drag & drop reordering
  const handleDragEnd = (result) => {
    if (!result.destination) return;
    const newData = Array.from(filteredData);
    const [removed] = newData.splice(result.source.index, 1);
    newData.splice(result.destination.index, 0, removed);
    setFilteredData(newData);
    setGridData(newData); // persist reordered data
  };

  // Selection callback
  useEffect(() => {
    if (onSelectionChange) onSelectionChange(selectionModel);
  }, [selectionModel]);

  return (
    <Paper elevation={0}>
      <Box mb={1}>
        <TextField
          size="small"
          fullWidth
          placeholder={searchPlaceholder}
          value={searchText}
          onChange={(e) => setSearchText(e.target.value)}
        />
      </Box>

      {enableReorder ? (
        <DragDropContext onDragEnd={handleDragEnd}>
          <Droppable droppableId="droppable-grid">
            {(provided) => (
              <div {...provided.droppableProps} ref={provided.innerRef}>
                {filteredData.map((row, index) => (
                  <Draggable
                    key={row[rowIdField]}
                    draggableId={row[rowIdField].toString()}
                    index={index}
                  >
                    {(provided, snapshot) => (
                      <div
                        ref={provided.innerRef}
                        {...provided.draggableProps}
                        {...provided.dragHandleProps}
                        style={{
                          marginBottom: 4,
                          ...provided.draggableProps.style,
                        }}
                      >
                        <DataGrid
                          autoHeight
                          rows={[row]}
                          columns={columns}
                          getRowId={(r) => r[rowIdField]}
                          checkboxSelection={checkboxSelection}
                          onRowSelectionModelChange={(ids) =>
                            setSelectionModel(ids)
                          }
                          rowSelectionModel={selectionModel}
                          hideFooter
                        />
                      </div>
                    )}
                  </Draggable>
                ))}
                {provided.placeholder}
              </div>
            )}
          </Droppable>
        </DragDropContext>
      ) : (
        <DataGrid
          autoHeight
          rows={filteredData}
          columns={columns}
          getRowId={(r) => r[rowIdField]}
          checkboxSelection={checkboxSelection}
          onRowSelectionModelChange={(ids) =>
            setSelectionModel(ids)
          }
          rowSelectionModel={selectionModel}
          components={{ Toolbar: GridToolbar }}
        />
      )}
    </Paper>
  );
};

export default AdvancedDataGrid;
