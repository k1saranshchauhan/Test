            filteredData = filteredData.filter((dept) =>
              allowedDepartmentIds.includes(dept?.id),
            );
          }

          // ---------------------------------------------------------
          // 🔥 3. Filter departments based on selected targetModule
          // ---------------------------------------------------------

          const selectedModules = formik?.values?.targetModule;

          if (selectedModules) {
            // keep ids only
