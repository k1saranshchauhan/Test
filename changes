"use client";

import React, { useState, useMemo, useEffect } from "react";
import {
  Box,
  TextField,
  Paper,
  InputAdornment,
  IconButton,
  Chip,
  Stack,
  Divider,
} from "@mui/material";
import {
  DataGrid,
  GridToolbarContainer,
} from "@mui/x-data-grid";
import {
  Search,
  Clear,
  KeyboardArrowUp,
  KeyboardArrowDown,
} from "@mui/icons-material";
import StraightIcon from '@mui/icons-material/Straight';
import SouthIcon from '@mui/icons-material/South';
import NorthIcon from '@mui/icons-material/North';

const AdvancedDataGrid = ({
  data = [],
  columns = [],
  rowIdField = "id",
  enableReorder = false,
  searchPlaceholder = "Search records...",
  onSelectionChange,
  onOrderChange, // <--- prop to sync with parent
  checkboxSelection = true,
  loading=false,
}) => {
  const [searchText, setSearchText] = useState("");
  const [tableData, setTableData] = useState(data);

  useEffect(() => {
    setTableData(data);
  }, [data]);

  const filteredRows = useMemo(() => {
    const term = searchText.toLowerCase().trim();
    if (!term) return tableData;

    return tableData.filter((row) => {
      return Object.values(row).some((val) => {
        if (val === null || val === undefined) return false;
        return JSON.stringify(val).toLowerCase().includes(term);
      });
    });
  }, [tableData, searchText]);

  const handleMove = (index, direction) => {
    const newData = [...tableData];
    const targetIndex = direction === "up" ? index - 1 : index + 1;
    if (targetIndex < 0 || targetIndex >= newData.length) return;

    // Swap items
    [newData[index], newData[targetIndex]] = [newData[targetIndex], newData[index]];
    
    setTableData(newData);
    
    // Notify parent immediately so the payload stays in sync
    if (onOrderChange) {
      onOrderChange(newData);
    }
  };

  const finalColumns = useMemo(() => {
    const baseCols = columns.map((col) => ({
      ...col,
    }));

    if (enableReorder) {
      return [
        {
          field: "reorder_actions",
          headerName: "Order",
          width: 100,
          sortable: false,
          renderCell: (params) => {
            const index = tableData?.findIndex((r) => r[rowIdField] === params.id);
            return (
              <Stack direction="row" sx={{mt:1.4}}>
                <IconButton 
                  size="small" 
                  disabled={index === 0} 
                  onClick={() => handleMove(index, "up")}
                >
                  <NorthIcon fontSize="small" color="primary"  sx={{fontWeight:600}}/>
                </IconButton>
                <IconButton 
                  size="small" 
                  disabled={index === tableData.length - 1} 
                  onClick={() => handleMove(index, "down")}
                >
                  <SouthIcon fontSize="small" color="primary" sx={{fontWeight:600}}/>
                </IconButton>
              </Stack>
            );
          },
        },
        ...baseCols,
      ];
    }
    return baseCols;
  }, [columns, enableReorder, tableData]);

  return (
    <Paper
      elevation={3}
      sx={{ borderRadius: 2, overflow: "hidden", border: "1px solid #eee" }}
    >
      <Box sx={{ p: 2, bgcolor: "background.paper" }}>
        <TextField
          size="small"
          placeholder={searchPlaceholder}
          value={searchText}
          onChange={(e) => setSearchText(e.target.value)}
          sx={{ width: 300 }}
          InputProps={{
            startAdornment: (
              <InputAdornment position="start">
                <Search color="action" />
              </InputAdornment>
            ),
            endAdornment: searchText && (
              <IconButton size="small" onClick={() => setSearchText("")}>
                <Clear fontSize="small" />
              </IconButton>
            ),
          }}
        />
      </Box>
      <Divider />
      <Box sx={{ height: 500, width: "100%", px: 1 }}>
        <DataGrid
          rows={filteredRows}
          columns={finalColumns}
          getRowId={(row) => row[rowIdField]}
          checkboxSelection={checkboxSelection}
          onRowSelectionModelChange={(ids) => onSelectionChange?.(ids)}
          disableRowSelectionOnClick
          disableColumnFilter
          pageSizeOptions={[10, 20, 30, 40, 50, 100]}
          initialState={{
            pagination: {
              paginationModel: { pageSize: 10, page: 0 }, //replaces pageSize
            },
          }}
          pagination
          slots={{
            toolbar: () => (
              <GridToolbarContainer sx={{ p: 1 }}>
                <Box sx={{ flexGrow: 1 }} />
              </GridToolbarContainer>
            ),
          }}
          localeText={{
            columnMenuSortAsc: "Sort as A to Z",
            columnMenuSortDesc: "Sort as Z to A",
          }}
          loading={loading}
          sx={{
            border: "none",
            "& .MuiDataGrid-columnHeader": {
              bgcolor: "grey.50",
              fontWeight: "bold",
            },
            // --- TARGET THE HEADER CHECKBOX HERE ---
            "& .MuiDataGrid-columnHeaderCheckbox .MuiCheckbox-root": {
              color: "#fff", // Default color
              "&.Mui-checked": {
                color: "#fff", // Color when checked (e.g., Purple/Red/etc)
              },
            },
            // --- TARGET ROW CHECKBOXES (Optional) ---
            "& .MuiDataGrid-cellCheckbox .MuiCheckbox-root": {
              color: "primary.light",
            },
            "& .MuiDataGrid-row:hover": {
              bgcolor: "primary.lighter",
              cursor: "pointer",
            },
            "& .MuiDataGrid-cell": {
              borderColor: "grey.100",
            },
          }}
        />
      </Box>
    </Paper>
  );
};

export default AdvancedDataGrid;
