          const formattedData = filteredData.map((item) => ({
            id: item?.id,
            label: item?.name,
          }));

          setDepartmentNames(formattedData);
        }
      } catch (error) {
        console.error("Failed to fetch department names:", error);
        setDepartmentNames([]);
      } finally {
        dispatch(setLoader(false));
      }
