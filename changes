  function generateMDThemeChartConfig(apiResponse, Highcharts) {
    if (!apiResponse) return {};

    // Step 1. Sort departments - those with theme_scores first
    const sortedData = [...apiResponse].sort((a, b) => {
      const aHasScores =
        Array.isArray(a.theme_scores) && a.theme_scores.length > 0;
      const bHasScores =
        Array.isArray(b.theme_scores) && b.theme_scores.length > 0;
      if (aHasScores === bHasScores) return 0;
      return aHasScores ? -1 : 1; // non-empty theme_scores first
    });

    // Step 2: Build department -> ministry + theme totals
    const departmentThemeTotals = {};
    const departmentMinistryMap = {};

    sortedData.forEach((item) => {
      const ministry = item.ministry_name?.trim();
      const department = item.department_name?.trim();
      if (!ministry || !department) return;

      departmentMinistryMap[department] = ministry;

      if (!departmentThemeTotals[department])
        departmentThemeTotals[department] = {};

      (item.theme_scores || []).forEach((theme) => {
        if (!theme.theme_name) return;
        if (!departmentThemeTotals[department][theme.theme_name])
          departmentThemeTotals[department][theme.theme_name] = {
            total: 0,
            count: 0,
          };
        departmentThemeTotals[department][theme.theme_name].total +=
          theme.avg_score;
        departmentThemeTotals[department][theme.theme_name].count += 1;
      });
    });

    // Step 3: Use the sorted department order
    const departments = sortedData
      .map((item) => item.department_name?.trim())
      .filter(Boolean);

    // Step 4: Collect all unique themes
    const themeSet = new Set();
    Object.values(departmentThemeTotals).forEach((themeMap) =>
      Object.keys(themeMap).forEach((theme) => themeSet.add(theme)),
    );
    const themes = Array.from(themeSet);

    // Step 5: Build series
    const series = themes.map((themeName, idx) => {
      const data = departments.map((dept) => {
        const obj = departmentThemeTotals[dept]?.[themeName];
        return {
          y: obj ? parseFloat((obj.total / obj.count)?.toFixed(2)) : null,
          department: dept,
          ministry: departmentMinistryMap[dept],
        };
      });

      return {
        name: themeName,
        data,
        color:
          Highcharts.getOptions().colors[
            idx % Highcharts.getOptions().colors.length
          ],
      };
    });

    // Step 6: Chart config
    return {
      chart: {
        type: "column",
        backgroundColor: "transparent",
        zoomType: "x",
        panning: true,
        panKey: "shift",
      },
      title: { text: null },
      subtitle: {
        text: "Click and drag to zoom in. Hold Shift and Click/Drag to move the chart.",
        align: "center",
        style: { fontSize: "12px", color: "#666" },
      },
      xAxis: {
        categories: departments, //  sorted order applied
        crosshair: true,
        min: 0,
        max: departments.length > 3 ? 2 : departments.length - 1,
        scrollbar: { enabled: departments.length > 3 },
        labels: { rotation: 0, style: { fontSize: "11px" } },
      },
      yAxis: {
        min: 0,
        tickInterval: 0.5,
        title: { text: "Score" },
        gridLineColor: "#eee",
        maxPadding: 0.2,
      },
      tooltip: {
        shared: true,
        useHTML: true,
        pointFormatter: function () {
          if (this.y === null) return "";
          return `
<span style="color:${this.color}">●</span>
<b>${this.series.name}</b> Score: <b>${this.y?.toFixed(2)}</b><br/>
        `;
        },
        footerFormat: "Click to view more details",
      },
      plotOptions: {
        column: {
          grouping: true,
          borderWidth: 0,
          pointPadding: 0.1,
          groupPadding: 0.1,
          minPointLength: 0,
          dataLabels: {
            enabled: true,
            format: "{point.y:.2f}",
            style: { fontWeight: "bold" },
          },
          // point: {
          //   events: {
          //     click: function () {
          //       const clickedDepartment = this.department;
          //       const clickedMinistry = this.ministry;

          //       const departmentData = apiResponse.find(
          //         (d) => d.department_name?.trim() === clickedDepartment,
          //       );

          //       if (!departmentData) return;

          //       // Add unique ID for DataGrid
          //       const row = {
          //         id: departmentData.department_id || Math.random(),
          //         ministryName: clickedMinistry,
          //         departmentName: clickedDepartment,
          //       };

          //       (departmentData.theme_scores || []).forEach((theme) => {
          //         if (theme.theme_name) row[theme.theme_name] = theme.avg_score;
          //       });

          //       setColsData(generateMDThemeChartColumns(themes));
          //       setRowData([row]);
          //       setOpen(true);
          //     },
          //   },
          // },
          point: {
            events: {
              click: function () {
                const clickedDepartment = this.department;
                const clickedMinistry = this.ministry;

                const departmentData = apiResponse.find(
                  (d) => d.department_name?.trim() === clickedDepartment,
                );

                if (!departmentData) return;

                // Add unique ID for DataGrid
                const row = {
                  id: departmentData.department_id || Math.random(),
                  ministryName: clickedMinistry,
                  departmentName: clickedDepartment,
                };

                (departmentData.theme_scores || []).forEach((theme) => {
                  if (theme.theme_name) {
                    const value = Number(theme.avg_score);
                    row[theme.theme_name] = Number.isFinite(value)
                      ? Number(value?.toFixed(2))
                      : 0;
                  }
                });

                setColsData(generateMDThemeChartColumns(themes));
                setRowData([row]);
                setOpen(true);
              },
            },
          },
        },
      },
      exporting: {
        buttons: {
          contextButton: {
            menuItems: [
              "viewFullscreen",
              "printChart",
              "separator",
              "downloadPNG",
              "downloadJPEG",
              // "downloadPDF",
              "downloadSVG",
              "downloadCSV",
              "downloadXLS",
              "viewData",
            ],
          },
        },
        csv: {
          columnHeaderFormatter: function (item) {
            if (item && item.isXAxis) {
              return "M/D";
            }
            return item?.name;
          },
        },
      },
      legend: {
        align: "center",
        verticalAlign: "bottom",
        itemStyle: { fontWeight: "500", color: "#333" },
      },
      series,
    };
  }
