import {
  Dialog,
  DialogTitle,
  DialogContent,
  DialogActions,
  Button,
} from "@mui/material";
import { useEffect, useState } from "react";
import { useDispatch } from "react-redux";
import { setError, startLoader, stopLoader } from "@/store/slices/errorSlice";
import apiClient from "@/utils/apiClient";
import IndividualBulkForwardStepper from "../IndividualBulkForwardStepper";
import IndividualBulkForwardStepperForCreater from "../IndividualBulkForwardStepperForCreater";
import TelegramIcon from "@mui/icons-material/Telegram";

export default function IndividualBulkForwardDialog({
  open,
  onClose,
  submissionId,
  mode,
  isCreator = false,
  type = "",
  canForward,
  selectedRow,
}) {
  const dispatch = useDispatch();
  const [isValidated, setIsValidated] = useState(false);
  const [successDialogParams, setSuccessDialogParams] = useState(null);

  // ---------- Frequency validation helper ----------
  const isEmptyFrequency = (freq) => {
    if (!freq) return true;
    if (typeof freq === "object" && Object.keys(freq).length === 0) return true;
    if (Array.isArray(freq) && freq.length === 0) return true;
    if (typeof freq === "string" && freq.trim() === "") return true;
    return false;
  };

  // ---------- Targets validation helper ----------
  const isEmptyTargets = (targets) => {
    if (!targets) return true;
    if (typeof targets === "object" && Object.keys(targets).length === 0)
      return true;
    if (Array.isArray(targets) && targets.length === 0) return true;
    if (typeof targets === "string" && targets.trim() === "") return true;
    return false;
  };

  // ---------- Validate frequency and targets ----------
  const validateFrequencyAndTargets = (data) => {
    if (!data?.form_values?.indicatorData)
      return { valid: false, message: "No indicator data found." };

    for (const item of data.form_values.indicatorData) {
      for (const section of item.sections || []) {
        for (const ind of section.indicators || []) {
          // Frequency validation
          if (isEmptyFrequency(ind.frequency)) {
            return {
              valid: false,
              message:
                "Please select the frequency for all indicators in the framework before forwarding.",
            };
          }

          // Targets validation
          if (isEmptyTargets(ind.targets)) {
            return {
              valid: false,
              message:
                "Please fill the frequency value for all indicators in the framework before forwarding.",
            };
          }
        }
      }
    }

    return { valid: true, message: "Validation passed." };
  };

  // ---------- Fetch & validate on open ----------
  useEffect(() => {
    if (!open || !submissionId) return;

    const fetchAndValidate = async () => {
      dispatch(startLoader());
      try {
        const res = await apiClient.get(
          `api/oomf/submissions/applicationDetailsById/${submissionId}`,
        );
        const data = res.data?.data;
        const successParams = {
          ministry: data?.form_values?.ministryId?.name,
          department: data?.form_values?.departmentId?.name,
          scheme: data?.form_values?.schemeId?.name,
        };
        setSuccessDialogParams(successParams);
        if (type === "addFrequency") {
          const validationResult = validateFrequencyAndTargets(data);
          setIsValidated(validationResult.valid);

          if (!validationResult.valid) {
            dispatch(setError(validationResult.message));
            onClose();
          }
        }
      } catch (err) {
        dispatch(setError("Failed to validate submission data."));
        onClose();
      } finally {
        dispatch(stopLoader());
      }
    };

    fetchAndValidate();
  }, [open, submissionId, type, dispatch, onClose]);

  return (
    <Dialog open={open} onClose={onClose} fullWidth maxWidth="lg">
      <DialogTitle sx={{ backgroundColor: "#45154f", color: "#fff" }}>
        <TelegramIcon /> Make individual framework ready for Bulk forward
      </DialogTitle>

      <DialogContent dividers>
        {type === "addFrequency" && !isValidated ? (
          <div>Validating frequency...</div>
        ) : isCreator ? (
          <IndividualBulkForwardStepperForCreater
            submissionId={submissionId}
            successDialogParams={successDialogParams}
          />
        ) : (
          <IndividualBulkForwardStepper
            mode={mode}
            canForward={canForward}
            submissionId={submissionId}
            successDialogParams={successDialogParams}
            documents={selectedRow?.documents}
          />
        )}
      </DialogContent>

      <DialogActions>
        <Button onClick={onClose} variant="contained">
          Cancel
        </Button>
      </DialogActions>
    </Dialog>
  );
}
