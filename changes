<TextField
              disabled={isReadOnly}
              inputRef={(el) => {
                if (el)
                  inputRefs.current[
                    `${sectionIndex}_${indicatorIndex}_preTarget`
                  ] = el;
              }}
              fullWidth
              label={
                <>
                  Target Value{" "}
                  <span
                    style={{
                      color: "red",
                      display: moto === "draft" ? "none" : "inline",
                    }}
                  >
                    *
                  </span>
                </>
              }
              type={
                indicator?.unit === 10 || indicator?.unit === 9
                  ? "text"
                  : "number"
              }
              value={indicator.preTarget ?? ""}
              onChange={(e) =>
                handleChange(
                  e,
                  sectionIndex,
                  indicatorIndex,
                  indicator?.unit,
                  "preTarget",
                )
              }
              error={
                !!fieldErrors[`${sectionIndex}_${indicatorIndex}_preTarget`]
              }
              helperText={
                fieldErrors[`${sectionIndex}_${indicatorIndex}_preTarget`]
              }
              sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
              InputProps={{
                endAdornment: (
                  <>
                    <InputAdornment position="end">
                      <Tooltip
                        title={
                          isReadOnly
                            ? "View Footnote"
                            : "Add a footnote for this Target"
                        }
                      >
                        <IconButton
                          onClick={() =>
                            handleDialogOpen({
                              field: "indicatorTarget",
                              sectionIndex,
                              indicatorIndex,
                              defaultValue:
                                section.indicators[indicatorIndex]
                                  ?.footNoteIndicatorTarget || "",
                            })
                          }
                        >
                          <DescriptionIcon sx={{ color: primaryColor }} />
                        </IconButton>
                      </Tooltip>
                    </InputAdornment>
                  </>
                ),
              }}
            />
