const STORAGE_KEY = "individual_bulk_forward_drafts";

export const getIndividualBulkForwardDrafts = () => {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? JSON.parse(raw) : {};
  } catch (err) {
    console.error("Failed to parse individual bulk forward drafts", err);
    return {};
  }
};

export const saveIndividualBulkForwardDraft = (submissionId, data) => {
  try {
    const drafts = getIndividualBulkForwardDrafts();
    drafts[submissionId] = {
      ...(drafts[submissionId] || {}),
      ...data,
    };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(drafts));
    return drafts;
  } catch (err) {
    console.error("Failed to save individual bulk forward draft", err);
    return {};
  }
};

export const getIndividualBulkForwardDraftById = (submissionId) => {
  const drafts = getIndividualBulkForwardDrafts();
  return drafts?.[submissionId] || null;
};

export const removeIndividualBulkForwardDraft = (submissionId) => {
  try {
    const drafts = getIndividualBulkForwardDrafts();
    delete drafts[submissionId];
    localStorage.setItem(STORAGE_KEY, JSON.stringify(drafts));
    return drafts;
  } catch (err) {
    console.error("Failed to remove draft", err);
    return {};
  }
};

export const clearIndividualBulkForwardDrafts = () => {
  localStorage.removeItem(STORAGE_KEY);
};

/* -------------------------------
   Generic helpers
-------------------------------- */
export const isNonEmptyText = (value = "") => {
  return typeof value === "string" && value.trim() !== "";
};

export const hasDocuments = (docs = []) => {
  return (
    Array.isArray(docs) &&
    docs.some(
      (doc) =>
        doc &&
        (
          doc.uploadedFile ||
          doc.id ||
          doc.filePath ||
          doc.fileName ||
          doc.name
        )
    )
  );
};

/* -------------------------------
   Draft validation
-------------------------------- */
export const validateCreatorDraft = ({ uploadedFiles = [], remarks = "" }) => {
  const errors = [];

  if (!hasDocuments(uploadedFiles)) {
    errors.push("Framework attachment is required.");
  }

  if (!isNonEmptyText(remarks)) {
    errors.push("Remarks are required.");
  }

  return {
    isValid: errors.length === 0,
    errors,
  };
};

export const validateNonCreatorDraft = ({
  revisedFrameworkFiles = [],
  hindiFiles = [],
  snippetFiles = [],
  remarks = "",
  uniqueFlag = "No",
}) => {
  const errors = [];

  if (!hasDocuments(revisedFrameworkFiles)) {
    errors.push("Revised Framework is required.");
  }

  if (uniqueFlag === "No") {
    if (!hasDocuments(hindiFiles)) {
      errors.push("Hindi Document is required.");
    }

    if (!hasDocuments(snippetFiles)) {
      errors.push("Snippet of e file is required.");
    }

    if (!isNonEmptyText(remarks)) {
      errors.push("Remarks are required.");
    }
  }

  return {
    isValid: errors.length === 0,
    errors,
  };
};

/* -------------------------------
   Row-level validation
   (draft OR prepopulated row data)
-------------------------------- */
export const validateRowForBulkForward = (row) => {
  const submissionId = row?.submissionId;
  const drafts = getIndividualBulkForwardDrafts();
  const draft = drafts?.[submissionId];

  // 1. If draft exists, validate from draft
  if (draft) {
    if (draft?.isCreator) {
      return validateCreatorDraft({
        uploadedFiles: draft?.documents || [],
        remarks: draft?.remarks || "",
      });
    }

    const docs = draft?.documents || [];

    return validateNonCreatorDraft({
      revisedFrameworkFiles: docs.filter(
        (doc) => doc?.name === "Revised framework" || doc?.name === "Framework"
      ),
      hindiFiles: docs.filter((doc) => doc?.name === "Hindi Document"),
      snippetFiles: docs.filter((doc) => doc?.name === "Snippet of e file "),
      remarks: draft?.remarks || "",
      uniqueFlag: row?.uniqueFlag || "No",
    });
  }

  // 2. Otherwise validate from backend/prepopulated row documents
  const docs = row?.documents || [];
  const remarks = row?.remarks || row?.fromRemarks || "";

  const isCreator = Number(row?.permission?.orderIndex) === 1;

  if (isCreator) {
    return validateCreatorDraft({
      uploadedFiles: docs.filter(
        (doc) => doc?.name === "Framework" || doc?.name === "Revised framework"
      ),
      remarks,
    });
  }

  return validateNonCreatorDraft({
    revisedFrameworkFiles: docs.filter(
      (doc) => doc?.name === "Revised framework" || doc?.name === "Framework"
    ),
    hindiFiles: docs.filter((doc) => doc?.name === "Hindi Document"),
    snippetFiles: docs.filter((doc) => doc?.name === "Snippet of e file "),
    remarks,
    uniqueFlag: row?.uniqueFlag || "No",
  });
};

/* -------------------------------
   Bulk-level validation
-------------------------------- */
export const areAllSelectedRecordsValidated = (rows = []) => {
  if (!rows?.length) return false;

  return rows.every((row) => validateRowForBulkForward(row).isValid);
};

export const getValidationSummaryForRows = (rows = []) => {
  return rows.map((row) => {
    const validation = validateRowForBulkForward(row);

    return {
      submissionId: row?.submissionId,
      isValid: validation.isValid,
      errors: validation.errors,
    };
  });
};

/* -------------------------------
   Final payload
-------------------------------- */
export const buildBulkForwardIndividualPayload = ({
  selectedRows = [],
  orgTypeId,
  subRoleId,
  createdBy,
}) => {
  const drafts = getIndividualBulkForwardDrafts();

  const validSubmissionIds = [];
  const fromDocumentIds = {};
  const fromRemarks = {};

  selectedRows?.forEach((row) => {
    const id = row?.submissionId;
    const draft = drafts?.[id];

    // If user has overridden and saved draft, use that
    if (draft?.payload) {
      validSubmissionIds.push(Number(id));
      fromDocumentIds[id] = draft?.payload?.fromDocumentIds || [];
      fromRemarks[id] = draft?.payload?.fromRemarks || "";
      return;
    }
    // Otherwise fallback to backend/prepopulated row data
    const docs = row?.documents || [];
    const remarks = row?.remarks || row?.fromRemarks || "";

    validSubmissionIds.push(Number(id));
    fromDocumentIds[id] = docs;
    fromRemarks[id] = remarks;
  });

  return {
    submissionIds: validSubmissionIds,
    orgTypeId,
    subRoleId,
    fromRemarks,
    fromDocumentIds,
    createdBy,
  };
};
