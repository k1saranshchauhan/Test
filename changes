import React, { useMemo } from "react";
import {
  Box,
  Typography,
  Paper,
  TableContainer,
  Table,
  TableHead,
  TableRow,
  TableCell,
  TableBody,
} from "@mui/material";

const ProgressTable = ({ data }) => {
  if (!data?.data) return null;

  const reportData = data.data;
  const years = Object.keys(reportData).sort();

  // 1. Grouping Logic: Ministry -> Department -> Scheme
  const hierarchy = useMemo(() => {
    const tree = {};

    years.forEach((year) => {
      reportData[year].forEach((schemeEntry) => {
        const minName = schemeEntry.ministryId?.name || "Unknown Ministry";
        const deptName = schemeEntry.departmentId?.name || "Unknown Department";
        const schemeName = schemeEntry.schemeId?.name || "Unknown Scheme";

        if (!tree[minName]) tree[minName] = {};
        if (!tree[minName][deptName]) tree[minName][deptName] = {};
        if (!tree[minName][deptName][schemeName]) {
          tree[minName][deptName][schemeName] = {
            indicatorRows: {},
            financialInfo: {}, // To store BE/AE per year
          };
        }

        // Store Financial Outlay for the Header
        tree[minName][deptName][schemeName].financialInfo[year] = {
          be: schemeEntry.financialOutlay || 0,
          ae: schemeEntry.actualExpenditure || 0,
        };

        // Process Indicators
        schemeEntry.indicatorData.forEach((typeGroup) => {
          typeGroup.sections.forEach((section) => {
            section.indicators.forEach((ind) => {
              const rowKey = `${typeGroup.indicatorType.name}-${section.name}-${ind.indicator.name}`;
              if (!tree[minName][deptName][schemeName].indicatorRows[rowKey]) {
                tree[minName][deptName][schemeName].indicatorRows[rowKey] = {
                  type: typeGroup.indicatorType.name,
                  statement: section.name,
                  indicatorName: ind.indicator.name,
                  unit: ind.unit?.name || "nos.",
                  period: ind.period?.name || "Duration",
                  yearlyValues: {},
                };
              }
              tree[minName][deptName][schemeName].indicatorRows[rowKey].yearlyValues[year] = {
                target: ind.target,
                progress: ind.progress,
              };
            });
          });
        });
      });
    });
    return tree;
  }, [reportData, years]);

  return (
    <Box sx={{ p: 3, backgroundColor: "#f9f9f9" }}>
      {Object.entries(hierarchy).map(([minName, departments]) => (
        <Box key={minName} sx={{ mb: 4 }}>
          {/* Ministry Level */}
          <Typography variant="h4" sx={{ color: "#2c3e50", fontWeight: "bold", mb: 1 }}>
            {minName}
          </Typography>

          {Object.entries(departments).map(([deptName, schemes]) => (
            <Box key={deptName} sx={{ ml: 3, mb: 3 }}>
              {/* Department Level */}
              <Typography variant="h5" sx={{ color: "#34495e", fontWeight: "600", mb: 1 }}>
                {deptName}
              </Typography>

              {Object.entries(schemes).map(([schemeName, schemeContent]) => (
                <Box key={schemeName} sx={{ ml: 3, mb: 5 }}>
                  {/* Scheme Title */}
                  <Typography variant="h6" sx={{ color: "#45154F", fontWeight: "bold", mb: 2 }}>
                    Scheme: {schemeName}
                  </Typography>

                  <TableContainer component={Paper} sx={{ boxShadow: 3 }}>
                    <Table size="small" sx={{ border: "1px solid #ccc" }}>
                      <TableHead>
                        {/* Row 1: Year Headers with BE/AE */}
                        <TableRow sx={{ backgroundColor: "#45154F" }}>
                          <TableCell rowSpan={3} sx={{ color: "#fff", fontWeight: "bold", border: "1px solid #632a6d" }}>Indicator Type</TableCell>
                          <TableCell rowSpan={3} sx={{ color: "#fff", fontWeight: "bold", border: "1px solid #632a6d" }}>Indicator Statement</TableCell>
                          <TableCell rowSpan={3} sx={{ color: "#fff", fontWeight: "bold", border: "1px solid #632a6d" }}>Indicator</TableCell>
                          <TableCell rowSpan={3} sx={{ color: "#fff", fontWeight: "bold", border: "1px solid #632a6d" }}>Unit</TableCell>
                          <TableCell rowSpan={3} sx={{ color: "#fff", fontWeight: "bold", border: "1px solid #632a6d" }}>Period Attribute</TableCell>
                          
                          {years.map((year) => {
                            const fin = schemeContent.financialInfo[year] || { be: 0, ae: 0 };
                            return (
                              <TableCell key={year} colSpan={2} align="center" sx={{ color: "#fff", border: "1px solid #632a6d" }}>
                                <Typography variant="caption" sx={{ display: "block", fontWeight: "bold" }}>{year}</Typography>
                                <Typography variant="caption" sx={{ fontSize: "0.7rem" }}>
                                  BE: {fin.be}, AE: {fin.ae}
                                </Typography>
                              </TableCell>
                            );
                          })}
                          <TableCell colSpan={2} align="center" sx={{ color: "#fff", fontWeight: "bold", border: "1px solid #632a6d", backgroundColor: "#2e0e35" }}>
                            Cumulative
                          </TableCell>
                        </TableRow>

                        {/* Row 2: Labels */}
                        <TableRow sx={{ backgroundColor: "#45154F" }}>
                          {[...years, "Total"].map((item) => (
                            <React.Fragment key={item}>
                              <TableCell align="center" sx={{ color: "#fff", fontSize: "0.8rem", border: "1px solid #632a6d" }}>Target</TableCell>
                              <TableCell align="center" sx={{ color: "#fff", fontSize: "0.8rem", border: "1px solid #632a6d" }}>Progress</TableCell>
                            </React.Fragment>
                          ))}
                        </TableRow>
                      </TableHead>

                      <TableBody>
                        {Object.values(schemeContent.indicatorRows).map((row, rIdx) => {
                          let cumTarget = 0;
                          let cumProgress = 0;

                          return (
                            <TableRow key={rIdx} sx={{ "&:nth-of-type(even)": { backgroundColor: "#f2f2f2" } }}>
                              <TableCell sx={{ border: "1px solid #ddd" }}>{row.type}</TableCell>
                              <TableCell sx={{ border: "1px solid #ddd", fontSize: "0.85rem" }}>{row.statement}</TableCell>
                              <TableCell sx={{ border: "1px solid #ddd" }}>{row.indicatorName}</TableCell>
                              <TableCell sx={{ border: "1px solid #ddd" }}>{row.unit}</TableCell>
                              <TableCell sx={{ border: "1px solid #ddd" }}>{row.period}</TableCell>

                              {years.map((year) => {
                                const val = row.yearlyValues[year] || { target: "-", progress: "-" };
                                if (typeof val.target === "number") cumTarget += val.target;
                                if (typeof val.progress === "number") cumProgress += val.progress;
                                return (
                                  <React.Fragment key={year}>
                                    <TableCell align="center" sx={{ border: "1px solid #ddd" }}>{val.target}</TableCell>
                                    <TableCell align="center" sx={{ border: "1px solid #ddd" }}>{val.progress}</TableCell>
                                  </React.Fragment>
                                );
                              })}

                              <TableCell align="center" sx={{ border: "1px solid #ddd", fontWeight: "bold", backgroundColor: "#fffde7" }}>{cumTarget || "-"}</TableCell>
                              <TableCell align="center" sx={{ border: "1px solid #ddd", fontWeight: "bold", backgroundColor: "#fffde7" }}>{cumProgress || "-"}</TableCell>
                            </TableRow>
                          );
                        })}
                      </TableBody>
                    </Table>
                  </TableContainer>
                </Box>
              ))}
            </Box>
          ))}
        </Box>
      ))}
    </Box>
  );
};

export default ProgressTable;
