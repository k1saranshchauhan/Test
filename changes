"use client";

import React, { useEffect, useState, useMemo } from "react";
import {
  Box,
  Button,
  Typography,
  Tooltip,
  Card,
  CardContent,
  Stack,
} from "@mui/material";
import { CloudUpload, MergeType, Add } from "@mui/icons-material";
import apiClient from "@/utils/apiClient";
import EnhancedSupportingDocumentsRepeater from "./EnhancedSupportingDocRepeater";
import AdvancedDataGrid from "./AdvancedDataGrid";
import DynamicDialog from "./DynamicDialog";

const DocumentMergePage = () => {
  const [documents, setDocuments] = useState([]); // This stores the current order
  const [selectionModel, setSelectionModel] = useState([]);
  const [isUploadDialogOpen, setIsUploadDialogOpen] = useState(false);

  useEffect(() => {
    fetchDocuments();
  }, []);

  const fetchDocuments = async () => {
    try {
      const res = await apiClient.get("api/document/get-folder-documents/3");
      if (res?.data?.success) {
        const filteredDocs = res.data.result.filter((doc) =>
          doc.document_name?.toLowerCase().endsWith(".docx")
        );
        setDocuments(filteredDocs);
      }
    } catch (err) {
      console.error(err);
    }
  };

  // Professional upload handler for the dialog
  const uploadMultipleFiles = async (files, titles = [], description) => {
    const formData = new FormData();
    files.forEach((file, idx) => {
      formData.append("files", file);
      formData.append("titles[]", titles[idx] || file.name);
    });
    formData.append("reference_type", "document");
    formData.append("remarks", description);

    try {
      const res = await apiClient.post("api/document/upload-files", formData);
      fetchDocuments(); // Refresh list after upload
      setIsUploadDialogOpen(false); // Close dialog
      return res.data.files;
    } catch (err) {
      console.error("Upload failed", err);
      return [];
    }
  };

  const handleMerge = async () => {
    if (selectionModel.length < 2) return;

    // Construct the payload based on the CURRENT order in the 'documents' state
    // We only include documents that are currently selected
    const orderedPayload = documents
      .filter((doc) => selectionModel.includes(doc.document_id))
      .map((doc, index) => ({
        [index + 1]: doc.document_id,
      }));

    try {
      await apiClient.post("api/merge-document", { 
        documentIds: selectionModel,
        order: orderedPayload 
      });
      alert("Documents merged successfully");
      setSelectionModel([]);
      fetchDocuments();
    } catch (err) {
      console.error(err);
    }
  };

  const columns = [
    { field: "document_title", headerName: "Title", flex: 1 },
    { field: "document_name", headerName: "File Name", flex: 1.5 },
    { field: "uploaded_by", headerName: "Uploaded By", flex: 1 },
    { field: "uploaded_at", headerName: "Uploaded At", flex: 1 },
  ];

  return (
    <Box p={3}>
      <Stack direction="row" justifyContent="space-between" alignItems="center" mb={3}>
        <Box>
          <Typography variant="h5" fontWeight="bold">
            Document Management
          </Typography>
          <Typography variant="body2" color="text.secondary">
            Upload, reorder, and merge your .docx files
          </Typography>
        </Box>
        
        <Button
          variant="outlined"
          startIcon={<CloudUpload />}
          onClick={() => setIsUploadDialogOpen(true)}
          sx={{ borderRadius: 2 }}
        >
          Import New Documents
        </Button>
      </Stack>

      <Card elevation={3} sx={{ borderRadius: 2 }}>
        <CardContent>
          <Box display="flex" justifyContent="space-between" alignItems="center" mb={2}>
            <Typography variant="h6" sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
              <MergeType color="primary" /> Merge Sequence
            </Typography>
            
            <Tooltip title={selectionModel.length < 2 ? "Select at least 2 documents" : "Generate merged document"}>
              <span>
                <Button
                  variant="contained"
                  color="primary"
                  disabled={selectionModel.length < 2}
                  onClick={handleMerge}
                  sx={{ borderRadius: 2, px: 4 }}
                >
                  Merge Selected ({selectionModel.length})
                </Button>
              </span>
            </Tooltip>
          </Box>

          <AdvancedDataGrid
            data={documents}
            columns={columns}
            rowIdField="document_id"
            enableReorder={true}
            checkboxSelection={true}
            onSelectionChange={setSelectionModel}
            // Passing setDocuments allows the Grid to update the order in this parent state
            onRowsOrderChange={setDocuments} 
          />
        </CardContent>
      </Card>

      {/* Professional Upload Dialog */}
      <DynamicDialog
        open={isUploadDialogOpen}
        onClose={() => setIsUploadDialogOpen(false)}
        title="Document Import Wizard"
        maxWidth="md"
      >
        <EnhancedSupportingDocumentsRepeater
          onUploadComplete={() => {
             // Handled inside uploadMultipleFiles, but kept for compatibility
          }}
          uploadMultipleFiles={uploadMultipleFiles}
        />
      </DynamicDialog>
    </Box>
  );
};

export default DocumentMergePage;
