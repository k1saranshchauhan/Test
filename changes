      if (status === "Draft") {
        payload.draftId = Number(editId);
        payload.updatedBy = userData?.id;
      } else {
        payload.id = Number(editId);
        payload.updatedBy = userData?.id;
      }
    }

    try {
      dispatch(setLoader(true));
      const response = await apiClient.post(
        "/api/alert/create-or-update-alert",
        payload,
      );

      const { data, message } = response?.data;
      dispatch(setSuccess(message));
      setHandleSubmitClicked(false);
      router.push("/superadmin/alertManagement/view-alerts");
      // Optionally reset form or show toast/snackbar
    } catch (error) {
      console.error("Failed to create alert:", error);
      // Optionally show error toast/snackbar
    } finally {
      setIsAlertCancelled(false);
      dispatch(setLoader(false));
    }
