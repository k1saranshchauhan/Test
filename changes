  const userMinistries = userData?.userRelationships?.[0]?.ministryIds;
  const userDepartments = userData?.userRelationships?.[0]?.departmentIds;
  const userSchemes = userData?.userRelationships?.[0]?.schemeIds;
  const [privilegesReady, setPrivilegesReady] = useState(false);
