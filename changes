import React, { useEffect, useState } from "react";
import { Box, Typography, Button, TextField } from "@mui/material";
import SingleUpload from "./SingleUpload";
import apiClient from "@/utils/apiClient";
import { useDispatch, useSelector } from "react-redux";
import { setError, setSuccess } from "@/store/slices/errorSlice";
import { setOomfWorkflowDocuments } from "@/store/slices/configSlice";
import { validateNonCreatorDraft } from "@/utils/oomf/individualBulkForwardDraft";

const IndividualBulkForwardStepper = ({
  mode,
  canForward,
  submissionId,
  uniqueFlag = "No",
  successDialogParams,
  documents,
  remarks: initialRemarks = "",
  onClose,
  draftData,
  onSaveDraft,
}) => {
  const dispatch = useDispatch();

  const [revisedFrameworkData, setRevisedFrameworkData] = useState({
    uploadedFiles: [],
  });
  const [hindiDocumentData, setHindiDocumentData] = useState({
    uploadedFiles: [],
  });
  const [snippetFileData, setSnippetFileData] = useState({
    uploadedFiles: [],
  });
  const [remarks, setRemarks] = useState("");

  const userData = useSelector((state) => state.config.userData);
  const isReadOnly = mode === "view";

  const uniqueRoleIds = [
    ...new Set(
      userData?.privileges?.flatMap((item) =>
        item.frameworkId === 3 && Array.isArray(item.accessRights?.oomfSubRoles)
          ? item.accessRights.oomfSubRoles.map((role) => role.id)
          : [],
      ),
    ),
  ];

  useEffect(() => {
    if (uniqueFlag === "Yes") {
      dispatch(setOomfWorkflowDocuments([]));
    }
  }, [dispatch, uniqueFlag]);

  useEffect(() => {
    if (!submissionId) return;

    // 1st priority = reviewed in-memory draft
    if (draftData) {
      const savedDocs = draftData?.documents || [];

      setRevisedFrameworkData({
        uploadedFiles: savedDocs.filter(
          (doc) => doc.name === "Revised framework" || doc.name === "Framework",
        ),
      });

      setHindiDocumentData({
        uploadedFiles: savedDocs.filter(
          (doc) => doc.name === "Hindi Document",
        ),
      });

      setSnippetFileData({
        uploadedFiles: savedDocs.filter(
          (doc) => doc.name === "Snippet of e file ",
        ),
      });

      setRemarks(draftData?.remarks || "");
      return;
    }

    // 2nd priority = backend / row data
    if (mode === "edit" || mode === "view") {
      const backendDocs = documents || [];

      setRevisedFrameworkData({
        uploadedFiles: backendDocs.filter(
          (doc) => doc.name === "Revised framework" || doc.name === "Framework",
        ),
      });

      setHindiDocumentData({
        uploadedFiles: backendDocs.filter(
          (doc) => doc.name === "Hindi Document",
        ),
      });

      setSnippetFileData({
        uploadedFiles: backendDocs.filter(
          (doc) => doc.name === "Snippet of e file ",
        ),
      });

      setRemarks(initialRemarks || "");
    }
  }, [submissionId, documents, mode, initialRemarks, draftData]);

  const uploadMultipleFiles = async (files, titles = [], docDescription) => {
    const formData = new FormData();

    files.forEach((file) => {
      formData.append("files", file);
      const title = file.name.replace(/[^a-zA-Z0-9]/g, "_");
      formData.append("titles[]", title);
    });

    formData.append("reference_type", "oomf");
    formData.append("user_id", userData?.id);
    formData.append("remarks", docDescription);

    try {
      const response = await apiClient.post(
        "api/document/upload-files",
        formData,
      );
      return response.data.files;
    } catch (err) {
      console.error("Upload failed:", err);
      return [];
    }
  };

  const handleSaveDraft = async () => {
    try {
      const validation = validateNonCreatorDraft({
        revisedFrameworkFiles: revisedFrameworkData?.uploadedFiles || [],
        hindiFiles: hindiDocumentData?.uploadedFiles || [],
        snippetFiles: snippetFileData?.uploadedFiles || [],
        remarks,
        uniqueFlag,
      });

      if (!validation.isValid) {
        dispatch(setError(validation.errors[0]));
        return;
      }

      const allDocumentIds = [
        ...(revisedFrameworkData.uploadedFiles || []),
        ...(hindiDocumentData.uploadedFiles || []),
        ...(snippetFileData.uploadedFiles || []),
      ];

      const validationPayload = {
        orgTypeId: userData?.OrganizationType?.id,
        subRoleIds: uniqueRoleIds,
        submissionId: Number(submissionId),
      };

      const validateUserPrivileges = await apiClient.post(
        `/api/oomf/step/validate-submission`,
        validationPayload,
      );

      if (!validateUserPrivileges?.data?.data?.valid) {
        dispatch(setError("No action found for this role!"));
        return;
      }

      const draftPayload = {
        orgTypeId: userData?.OrganizationType?.id,
        subRoleId: validateUserPrivileges?.data?.data?.latestStep?.subRoleId,
        submissionId: Number(submissionId),
        fromRemarks: remarks,
        fromDocumentIds: allDocumentIds,
        createdBy: userData?.id,
      };

      onSaveDraft?.(submissionId, {
        submissionId: Number(submissionId),
        isCreator: false,
        type: "workflow",
        documents: allDocumentIds,
        remarks,
        isValid: validation.isValid,
        errors: validation.errors,
        payload: draftPayload,
      });

      dispatch(setSuccess("Record saved successfully for Bulk Forward."));
      onClose();
    } catch (error) {
      dispatch(setError("Failed to save record."));
    }
  };

  return (
    <>
      <Box sx={{ mt: 3 }}>
        <Box
          sx={{
            backgroundColor: "#FFF3CD",
            border: "1px solid #FFEEBA",
            padding: "12px 16px",
            borderRadius: "6px",
            mb: 2,
          }}
        >
          <Typography sx={{ color: "#856404", fontSize: "14px" }}>
            <strong>Note:</strong> When making individual framework ready for
            Bulk forward, the documents and remarks previously uploaded for
            individual schemes will be replaced by the documents and remarks
            submitted here.
          </Typography>
        </Box>
      </Box>

      {(mode === "edit" || (mode === "view" && canForward)) && (
        <Box sx={{ mt: 3 }}>
          <Box
            sx={{
              color: "#fff",
              backgroundColor: "#45154f",
              borderRadius: "5px",
              p: "8px 20px 8px 20px",
            }}
          >
            <Typography variant="h6">
              Mandatory Attachments <span style={{ color: "#E43636" }}>*</span>
            </Typography>
          </Box>

          <Box
            sx={{
              border: "1px solid lightgray",
              borderRadius: "5px",
              px: 3,
              pt: 2,
              pb: 1,
              mt: 2,
            }}
          >
            <Box sx={{ mt: 2 }}>
              <SingleUpload
                key={`revised-${submissionId}-${draftData?.updatedAt || 0}`}
                initialDocuments={revisedFrameworkData.uploadedFiles || []}
                handleJsonDataChange={(fieldName) => (e) => {
                  if (fieldName === "supportingDocuments") {
                    setRevisedFrameworkData((prev) => ({
                      ...prev,
                      uploadedFiles: e.target.value,
                    }));
                  }
                }}
                uploadMultipleFiles={uploadMultipleFiles}
                documentName={
                  uniqueFlag === "No" ? "Revised framework" : "Framework"
                }
                deleteFunctionality={false}
                isViewing={isReadOnly}
              />
            </Box>

            {uniqueFlag === "No" && (
              <Box sx={{ mt: 2 }}>
                <SingleUpload
                  key={`hindi-${submissionId}-${draftData?.updatedAt || 0}`}
                  initialDocuments={hindiDocumentData.uploadedFiles || []}
                  handleJsonDataChange={(fieldName) => (e) => {
                    if (fieldName === "supportingDocuments") {
                      setHindiDocumentData((prev) => ({
                        ...prev,
                        uploadedFiles: e.target.value,
                      }));
                    }
                  }}
                  uploadMultipleFiles={uploadMultipleFiles}
                  documentName="Hindi Document"
                  isViewing={isReadOnly}
                  deleteFunctionality={false}
                />
              </Box>
            )}

            {uniqueFlag === "No" && (
              <Box sx={{ mt: 2 }}>
                <SingleUpload
                  key={`snippet-${submissionId}-${draftData?.updatedAt || 0}`}
                  initialDocuments={snippetFileData.uploadedFiles || []}
                  handleJsonDataChange={(fieldName) => (e) => {
                    if (fieldName === "supportingDocuments") {
                      setSnippetFileData((prev) => ({
                        ...prev,
                        uploadedFiles: e.target.value,
                      }));
                    }
                  }}
                  uploadMultipleFiles={uploadMultipleFiles}
                  documentName="Snippet of e file "
                  isViewing={isReadOnly}
                  deleteFunctionality={false}
                />
              </Box>
            )}
          </Box>

          {uniqueFlag === "No" && (
            <Box sx={{ mt: 2 }}>
              <Box
                sx={{
                  color: "#fff",
                  backgroundColor: "#45154f",
                  borderRadius: "5px",
                  p: "8px 20px 8px 20px",
                }}
              >
                <Typography variant="h6">
                  Remarks <span style={{ color: "#E43636" }}>*</span>
                </Typography>
              </Box>

              <Box position="relative">
                <TextField
                  required
                  disabled={
                    !(mode === "edit" || (mode === "view" && canForward))
                  }
                  placeholder="Kindly add Remarks"
                  multiline
                  minRows={3}
                  fullWidth
                  variant="outlined"
                  value={remarks}
                  onChange={(e) => {
                    const value = e.target.value;
                    if (value.length <= 1000) {
                      setRemarks(value);
                    }
                  }}
                  sx={{ mt: 1 }}
                  inputProps={{
                    style: { paddingBottom: "25px" },
                    pattern: "[a-zA-Z0-9\\-_,.() ]*",
                    onInput: (e) => {
                      e.target.value = e.target.value.replace(
                        /[^a-zA-Z0-9\-_,.() ]/g,
                        "",
                      );
                    },
                  }}
                />

                <Box
                  sx={{
                    position: "absolute",
                    bottom: 4,
                    right: 8,
                    fontSize: "11px",
                    color: "#666",
                  }}
                >
                  {remarks?.length}/1000
                </Box>
              </Box>
            </Box>
          )}

          <Box textAlign="right" mt={3}>
            <Button
              variant="contained"
              size="large"
              color="success"
              onClick={handleSaveDraft}
            >
              Save
            </Button>
          </Box>
        </Box>
      )}
    </>
  );
};

export default IndividualBulkForwardStepper;
