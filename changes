import apiClient from "@/utils/apiClient";
import {
  Autocomplete,
  Box,
  Checkbox,
  FormControl,
  FormControlLabel,
  FormLabel,
  InputLabel,
  ListItemText,
  MenuItem,
  Select,
  Grid,
  TextField,
  Switch,
  Tooltip,
  Typography,
  FormHelperText,
  Accordion,
  AccordionSummary,
  AccordionDetails,
  Button,
} from "@mui/material";
import ExpandMoreIcon from "@mui/icons-material/ExpandMore";
import { useEffect, useState } from "react";
import { useDispatch, useSelector } from "react-redux";
import {
  filterByFramework,
  filterSchemesByFramework,
} from "@/utils/niti/filterByFramework";
import { oomfFrameworkId } from "@/src/constants/unified/frameworkConstants";

const Indicator = ({ modalState }) => {
  const {
    jsonData,
    handleJsonDataChange,
    ministryNames,
    selectedDepartmentId,
    allOomfMastersData,
    newRow,
    isViewing,
    handleSwitchChange,
    handleNewChange,
    errors = {},
    indicatorList,
    setIndicatorList,
  } = modalState;
  const [departmentList, setDepartmentList] = useState([]);
  const [schemeTypes, setSchemeTypes] = useState([]);
  const [schemeList, setSchemeList] = useState([]);
  const [subSchemeList, setSubSchemeList] = useState([]);
  const [isSubScheme, setIsSubScheme] = useState(false);
  const userData = useSelector((state) => state.config.userData);
  const userMinistryIds = userData?.userRelationships[0]?.ministryIds;
  const userDepartmentIds = userData?.userRelationships[0]?.departmentIds;
  const userSchemeIds = userData?.userRelationships[0]?.schemeIds;

  // Auto-enable Is Sub-scheme switch if jsonData.subScheme exists
  useEffect(() => {
    if (jsonData?.subScheme) {
      setIsSubScheme(true);
    } else {
      setIsSubScheme(false);
    }
  }, [jsonData?.subScheme]);

  useEffect(() => {
    const fetchDepartmentNames = async () => {
      const selectedType = jsonData?.ministry;
      if (!selectedType) {
        setDepartmentList([]);
        return;
      }

      const ministryIds = selectedType ? [selectedType.id] : [];

      try {
        const response = await apiClient.post(
          `api/master/get-departments-for-ministry`,
          { ministryIds },
        );

        const { data } = response?.data || {};
        if (Array.isArray(data)) {
          const filteredData = data?.filter((item) =>
            userDepartmentIds?.includes(item?.id),
          );

          const formattedData = filteredData?.map((item) => ({
            id: item?.id,
            name: item?.name,
            associatedFramework: item?.jsonData?.associatedFramework,
          }));

          setDepartmentList(formattedData);
        }
      } catch (error) {
        console.error("Failed to fetch department list:", error);
        setDepartmentList([]);
      }
    };
    fetchDepartmentNames();
  }, [jsonData?.ministry]);

  useEffect(() => {
    if (!jsonData?.department || !jsonData?.schemeType) return;
    async function getData() {
      try {
        const payload = {
          id: jsonData?.department?.id,
          schemeTypeId: jsonData?.schemeType?.id,
          financialYear: "",
        };
        const res = await apiClient.post(`/api/master/get-active-schemes`, payload);
        const schemesData = res.data?.data;
        setSchemeList(
          schemesData
            ?.filter((item) => userSchemeIds?.includes(item?.id))
            ?.map((item) => ({
              id: item.id,
              name: item.name,
              associatedFramework:
                item?.jsonData?.schemeFinancialYearWiseBudgetDetails?.map(
                  (item) => item?.associatedFrameworks,
                ),
            })),
        );
      } catch (err) {
        console.log(err.message);
      }
    }

    if (jsonData?.department !== null && jsonData?.schemeType !== null)
      getData();
  }, [jsonData?.department, jsonData?.schemeType]);

  useEffect(() => {
    const fetchSubSchemeList = async () => {
      const selectedType = jsonData?.scheme;
      if (!selectedType) {
        setSubSchemeList([]);
        return;
      }

      const schemeIds = [selectedType.id];

      try {
        const response = await apiClient.post(
          `api/master/get-subschemes-for-schemes`,
          { schemeIds },
        );

        const { data } = response?.data || {};
        if (Array.isArray(data)) {
          const formattedData = data?.map((item) => ({
            id: item?.id,
            name: item?.name,
          }));
          setSubSchemeList(formattedData);
        }
      } catch (error) {
        console.error("Failed to fetch scheme list:", error);
        setSubSchemeList([]);
      }
    };
    fetchSubSchemeList();
  }, [jsonData?.scheme]);

  useEffect(() => {
    const fetchSchemeTypeByFramework = async () => {
      try {
        const response = await apiClient.post(
          `api/master/schemeType/by-framework`,
          {
            associatedFrameworks: [oomfFrameworkId],
          },
        );

        const { data } = response?.data || {};
        if (Array.isArray(data)) {
          const formattedData = data?.map((item) => ({
            id: item?.id,
            name: item?.name,
          }));
          setSchemeTypes(formattedData);
        }
      } catch (error) {
        console.error("Failed to fetch scheme-type list:", error);
        setSchemeTypes([]);
      }
    };
    fetchSchemeTypeByFramework();
  }, [jsonData?.ministry]);

  // Auto-select Ministry when only ONE is available
  useEffect(() => {
    const filteredMinistries =
      filterByFramework(
        ministryNames?.filter((m) => userMinistryIds?.includes(m?.id)),
        oomfFrameworkId,
      ) || [];

    if (filteredMinistries.length === 1 && !jsonData?.ministry) {
      handleJsonDataChange("ministry")({
        target: { value: filteredMinistries[0] },
      });
    }
  }, [ministryNames, jsonData?.ministry]);
  // Auto-select Department when only ONE exists for the selected ministry
  useEffect(() => {
    const filteredDepartments =
      filterByFramework(departmentList, oomfFrameworkId) || [];

    if (
      jsonData?.ministry &&
      filteredDepartments.length === 1 &&
      !jsonData?.department
    ) {
      handleJsonDataChange("department")({
        target: { value: filteredDepartments[0] },
      });
    }
  }, [departmentList, jsonData?.ministry, jsonData?.department]);

  return (
    <>
      <Grid container spacing={2}>
        <Grid size={{ xs: 12, sm: 6 }}>
          <FormControl fullWidth required>
            <Autocomplete
              disabled={isViewing}
              options={
                filterByFramework(
                  ministryNames?.filter((m) =>
                    userMinistryIds?.includes(m?.id),
                  ),
                  oomfFrameworkId,
                ) || []
              }
              value={jsonData?.ministry || null}
              getOptionLabel={(option) => option.name}
              isOptionEqualToValue={(option, value) => option.id === value.id}
              onChange={(event, newValue) => {
                handleJsonDataChange("ministry")({
                  target: { value: newValue },
                });
              // ✅ ensure department resets cleanly
              setDepartmentList([]);  
              handleJsonDataChange("department")({ target: { value: null } });
              // Reset schemeType when department changes
              handleJsonDataChange("schemeType")({
                target: { value: null },
              });
              // Reset scheme when schemeType changes
              handleJsonDataChange("scheme")({
                target: { value: null },
              }); 
              }}
              renderOption={(props, option) => {
                const { key, ...rest } = props;
                return (
                  <li key={key} {...rest}>
                    {option.name}
                  </li>
                );
              }}
              renderInput={(params) => {
                const { key, ...rest } = params;
                return (
                  <TextField
                    key={key}
                    {...rest}
                    label="Ministry"
                    placeholder="Select Ministry"
                    required
                    error={Boolean(errors?.ministry)}
                    helperText={errors?.ministry || ""}
                  />
                );
              }}
            />
          </FormControl>
        </Grid>
        <Grid size={{ xs: 12, sm: 6 }}>
          <FormControl fullWidth required>
            <Tooltip
              title={
                !jsonData?.ministry ? "Please select a Ministry first" : ""
              }
              arrow
              placement="top"
            >
              <span>
                <Autocomplete
                  disabled={isViewing || !jsonData?.ministry}
                  options={
                    filterByFramework(departmentList, oomfFrameworkId) || []
                  }
                  value={jsonData?.department || null}
                  getOptionLabel={(option) => option.name}
                  isOptionEqualToValue={(option, value) =>
                    option.id === value.id
                  }
                  onChange={(event, newValue) => {
                    handleJsonDataChange("department")({
                      target: { value: newValue },
                    });
                    // Reset schemeType when department changes
                    handleJsonDataChange("schemeType")({
                      target: { value: null },
                    });
                    // Reset scheme when schemeType changes
                    handleJsonDataChange("scheme")({
                      target: { value: null },
                    }); 
                  }}
                  renderOption={(props, option) => {
                    const { key, ...rest } = props;
                    return (
                      <li key={key} {...rest}>
                        {option.name}
                      </li>
                    );
                  }}
                  renderInput={(params) => (
                    <TextField
                      {...params}
                      label="Department"
                      placeholder="Select Department"
                      required
                      error={Boolean(errors?.department)}
                      helperText={errors?.department || ""}
                    />
                  )}
                />
              </span>
            </Tooltip>
          </FormControl>
        </Grid>
        <Grid size={{ xs: 12, sm: 6 }}>
          <Tooltip
            title={
              // selectedDepartmentId?.length <= 0
              !jsonData?.department ? "Please select a Department first" : ""
            }
            arrow
            placement="top"
          >
            <span>
              <Autocomplete
                disabled={isViewing || !jsonData?.department}
                options={schemeTypes?.map((item) => ({
                  id: item.id,
                  name: item.name,
                }))}
                value={jsonData?.schemeType || null}
                getOptionLabel={(option) => option?.name || ""}
                isOptionEqualToValue={(option, value) => option.id === value.id}
                onChange={(event, newValue) => {
                  handleJsonDataChange("schemeType")({
                    target: { value: newValue },
                  });
                  // Reset scheme when schemeType changes
                  handleJsonDataChange("scheme")({
                    target: { value: null },
                  });
                }}
                renderOption={(props, option) => {
                  const { key, ...rest } = props;
                  return (
                    <li key={key} {...rest}>
                      {option.name}
                    </li>
                  );
                }}
                renderInput={(params) => (
                  <TextField
                    {...params}
                    label="Scheme Type"
                    placeholder="Select Scheme Type"
                    required
                    error={Boolean(errors?.schemeType)}
                    helperText={errors?.schemeType || ""}
                  />
                )}
              />
            </span>
          </Tooltip>
        </Grid>

        <Grid size={{ xs: 12, sm: 6 }}>
          <Tooltip
            title={
              !jsonData?.department
                ? "Please select a Department first"
                : !jsonData?.schemeType?.name
                  ? "Please select a Scheme Type first"
                  : ""
            }
            arrow
            placement="top"
          >
            <span>
              <Autocomplete
                disabled={
                  isViewing ||
                  !jsonData?.department ||
                  !jsonData?.schemeType?.name
                }
                options={
                  filterSchemesByFramework(schemeList, oomfFrameworkId) || []
                }
                value={jsonData?.scheme || null}
                getOptionLabel={(option) => option.name}
                isOptionEqualToValue={(option, value) => option.id === value.id}
                onChange={(event, newValue) => {
                  handleJsonDataChange("scheme")({
                    target: { value: newValue },
                  });
                  handleNewChange("parentId")({
                    target: { value: newValue ? Number(newValue.id) : null },
                  });
                  // Reset sub-scheme & disable toggle when scheme changes
                  setIsSubScheme(false);
                  handleJsonDataChange("subScheme")({
                    target: { value: null },
                  });
                }}
                renderOption={(props, option) => {
                  const { key, ...rest } = props;
                  return (
                    <li key={key} {...rest}>
                      {option.name}
                    </li>
                  );
                }}
                renderInput={(params) => (
                  <TextField
                    {...params}
                    label="Scheme"
                    placeholder="Select Scheme"
                    required
                    error={Boolean(errors?.scheme)}
                    helperText={errors?.scheme || ""}
                  />
                )}
              />
            </span>
          </Tooltip>
        </Grid>
        <Grid size={{ xs: 12, sm: 6 }}>
          <Tooltip
            title={
              !jsonData?.scheme?.name
                ? "Please select a scheme first to enable this option"
                : ""
            }
            arrow
          >
            <span>
              <FormControlLabel
                control={
                  <Switch
                    checked={isSubScheme}
                    onChange={(e) => {
                      setIsSubScheme(e.target.checked);
                      handleJsonDataChange("isSubScheme")({
                        target: { value: e.target.checked },
                      });
                      if (!e.target.checked && subSchemeList.length > 0) {
                        handleJsonDataChange("subScheme")({
                          target: { value: null },
                        });
                      }
                    }}
                    disabled={isViewing || !jsonData?.scheme?.name}
                  />
                }
                label="Is Sub-scheme"
              />
            </span>
          </Tooltip>
        </Grid>
        <Grid size={{ xs: 12, sm: 6 }}>
          {isSubScheme && (
            <>
              {subSchemeList?.length > 0 ? (
                <Autocomplete
                  options={subSchemeList}
                  value={jsonData?.subScheme || null}
                  getOptionLabel={(option) => option.name}
                  isOptionEqualToValue={(option, value) =>
                    option.id === value.id
                  }
                  onChange={(event, newValue) => {
                    handleJsonDataChange("subScheme")({
                      target: { value: newValue },
                    });
                    handleNewChange("parentScheme")({
                      target: { value: jsonData?.scheme?.id || "" },
                    });
                  }}
                  renderInput={(params) => (
                    <TextField
                      {...params}
                      label="Sub-scheme"
                      placeholder="Select Sub-scheme"
                      required={isSubScheme} // mandatory only if switch is on
                      error={Boolean(errors?.subScheme) && isSubScheme} // optional: only show error if switch is on
                      helperText={isSubScheme ? errors?.subScheme || "" : ""}
                    />
                  )}
                />
              ) : (
                <Typography color="error" sx={{ mt: 1, fontWeight: 600 }}>
                  No sub-scheme exists
                </Typography>
              )}
            </>
          )}
        </Grid>

        {/* Indicators Section */}
        <Grid size={12}>
          <Typography variant="h6" sx={{ mt: 2, mb: 1 }}>
            Indicators
          </Typography>
          {indicatorList.map((indicator, index) => (
            <Accordion key={index} sx={{ mb: 2 }}>
              <AccordionSummary
                expandIcon={<ExpandMoreIcon />}
                aria-controls={`indicator-${index}-content`}
                id={`indicator-${index}-header`}
              >
                <Typography>
                  Indicator {index + 1}: {indicator.indicatorName || "New Indicator"}
                </Typography>
              </AccordionSummary>
              <AccordionDetails>
                <Grid container spacing={2}>
                  <Grid size={{ xs: 12, sm: 6 }}>
                    <Autocomplete
                      disabled={isViewing}
                      options={[
                        { label: "Output", value: "output" },
                        { label: "Outcome", value: "outcome" },
                      ]}
                      value={
                        indicator.indicatorType
                          ? {
                              value: indicator.indicatorType,
                              label: indicator.indicatorType.charAt(0).toUpperCase() + indicator.indicatorType.slice(1),
                            }
                          : null
                      }
                      getOptionLabel={(option) => option.label}
                      isOptionEqualToValue={(option, value) => option.value === value.value}
                      onChange={(event, newValue) => {
                        const updatedIndicators = [...indicatorList];
                        updatedIndicators[index].indicatorType = newValue ? newValue.value.toLowerCase() : "";
                        setIndicatorList(updatedIndicators);
                      }}
                      renderInput={(params) => (
                        <TextField
                          {...params}
                          label="Indicator Type"
                          placeholder="Select Indicator Type"
                          required
                          error={Boolean(errors?.[`indicatorList[${index}].indicatorType`])}
                          helperText={errors?.[`indicatorList[${index}].indicatorType`] || ""}
                        />
                      )}
                    />
                  </Grid>
                  <Grid size={{ xs: 12, sm: 6 }}>
                    <TextField
                      fullWidth
                      label="Indicator Name"
                      placeholder="Enter Indicator Name"
                      value={indicator.indicatorName || ""}
                      onChange={(e) => {
                        const updatedIndicators = [...indicatorList];
                        updatedIndicators[index].indicatorName = e.target.value;
                        setIndicatorList(updatedIndicators);
                      }}
                      required
                      error={Boolean(errors?.[`indicatorList[${index}].indicatorName`])}
                      helperText={errors?.[`indicatorList[${index}].indicatorName`] || ""}
                      disabled={isViewing}
                    />
                  </Grid>
                  <Grid size={{ xs: 12, sm: 6 }}>
                    <Autocomplete
                      disabled={isViewing}
                      options={
                        allOomfMastersData?.measurementTypes?.map((item) => ({
                          id: item.id,
                          name: item.name,
                        })) || []
                      }
                      value={indicator.measurementType || null}
                      getOptionLabel={(option) => option?.name || ""}
                      isOptionEqualToValue={(option, value) => option.id === value.id}
                      onChange={(event, newValue) => {
                        const updatedIndicators = [...indicatorList];
                        updatedIndicators[index].measurementType = newValue || null;
                        if (newValue?.id === 1) {
                          const metricTonne =
                            allOomfMastersData?.units?.find((item) => item.id === 8) || {
                              id: 8,
                              name: "Metric Tonne",
                            };
                          updatedIndicators[index].unit = metricTonne;
                          updatedIndicators[index].scale = null;
                        } else {
                          updatedIndicators[index].unit = null;
                          updatedIndicators[index].scale = null;
                        }
                        setIndicatorList(updatedIndicators);
                      }}
                      renderInput={(params) => (
                        <TextField
                          {...params}
                          label="Measurement Type"
                          placeholder="Select Measurement Type"
                          required
                          error={Boolean(errors?.[`indicatorList[${index}].measurementType`])}
                          helperText={errors?.[`indicatorList[${index}].measurementType`] || ""}
                        />
                      )}
                    />
                  </Grid>
                  <Grid size={{ xs: 12, sm: 6 }}>
                    <Autocomplete
                      disabled={isViewing || indicator.measurementType?.id === 1}
                      options={
                        allOomfMastersData?.units?.map((item) => ({
                          id: item.id,
                          name: item.name,
                        })) || []
                      }
                      value={indicator.unit || null}
                      getOptionLabel={(option) => option?.name || ""}
                      isOptionEqualToValue={(option, value) => option.id === value.id}
                      onChange={(event, newValue) => {
                        const updatedIndicators = [...indicatorList];
                        updatedIndicators[index].unit = newValue || null;
                        setIndicatorList(updatedIndicators);
                      }}
                      renderInput={(params) => (
                        <TextField
                          {...params}
                          label="Unit"
                          placeholder="Select Unit"
                          required
                          error={Boolean(errors?.[`indicatorList[${index}].unit`])}
                          helperText={errors?.[`indicatorList[${index}].unit`] || ""}
                        />
                      )}
                    />
                  </Grid>
                  {indicator.measurementType?.id !== 1 && (
                    <Grid size={{ xs: 12, sm: 6 }}>
                      <Autocomplete
                        disabled={isViewing}
                        options={
                          allOomfMastersData?.scales?.map((item) => ({
                            id: item.id,
                            name: item.name,
                          })) || []
                        }
                        value={indicator.scale || null}
                        getOptionLabel={(option) => option?.name || ""}
                        isOptionEqualToValue={(option, value) => option.id === value.id}
                        onChange={(event, newValue) => {
                          const updatedIndicators = [...indicatorList];
                          updatedIndicators[index].scale = newValue || null;
                          setIndicatorList(updatedIndicators);
                        }}
                        renderInput={(params) => (
                          <TextField
                            {...params}
                            label="Scale"
                            placeholder="Select Scale"
                            required
                            error={Boolean(errors?.[`indicatorList[${index}].scale`])}
                            helperText={errors?.[`indicatorList[${index}].scale`] || ""}
                          />
                        )}
                      />
                    </Grid>
                  )}
                  <Grid size={{ xs: 12, sm: 6 }}>
                    <Autocomplete
                      disabled={isViewing}
                      options={
                        allOomfMastersData?.measurementAreas?.map((item) => ({
                          id: item.id,
                          name: item.name,
                        })) || []
                      }
                      value={indicator.measurementArea || null}
                      getOptionLabel={(option) => option?.name || ""}
                      isOptionEqualToValue={(option, value) => option.id === value.id}
                      onChange={(event, newValue) => {
                        const updatedIndicators = [...indicatorList];
                        updatedIndicators[index].measurementArea = newValue || null;
                        setIndicatorList(updatedIndicators);
                      }}
                      renderInput={(params) => (
                        <TextField
                          {...params}
                          label="Measurement Area"
                          placeholder="Select Measurement Area"
                          required
                          error={Boolean(errors?.[`indicatorList[${index}].measurementArea`])}
                          helperText={errors?.[`indicatorList[${index}].measurementArea`] || ""}
                        />
                      )}
                    />
                  </Grid>
                  <Grid size={{ xs: 12, sm: 6 }}>
                    <Autocomplete
                      disabled={isViewing}
                      options={
                        allOomfMastersData?.indicatorRises?.map((item) => ({
                          id: item.id,
                          name: item.name,
                        })) || []
                      }
                      value={indicator.indicatorRise || null}
                      getOptionLabel={(option) => option?.name || ""}
                      isOptionEqualToValue={(option, value) => option.id === value.id}
                      onChange={(event, newValue) => {
                        const updatedIndicators = [...indicatorList];
                        updatedIndicators[index].indicatorRise = newValue || null;
                        setIndicatorList(updatedIndicators);
                      }}
                      renderInput={(params) => (
                        <TextField
                          {...params}
                          label="Indicator Rise"
                          placeholder="Select Indicator Rise"
                          required
                          error={Boolean(errors?.[`indicatorList[${index}].indicatorRise`])}
                          helperText={errors?.[`indicatorList[${index}].indicatorRise`] || ""}
                        />
                      )}
                    />
                  </Grid>
                  <Grid size={{ xs: 12, sm: 6 }}>
                    <Autocomplete
                      disabled={isViewing}
                      options={
                        allOomfMastersData?.sdg?.map((item) => ({
                          id: item.id,
                          name: item.name,
                        })) || []
                      }
                      value={indicator.sdg || null}
                      getOptionLabel={(option) => option?.name || ""}
                      isOptionEqualToValue={(option, value) => option.id === value.id}
                      onChange={(event, newValue) => {
                        const updatedIndicators = [...indicatorList];
                        updatedIndicators[index].sdg = newValue || null;
                        setIndicatorList(updatedIndicators);
                      }}
                      renderInput={(params) => (
                        <TextField
                          {...params}
                          label="SDG"
                          placeholder="Select SDG"
                          error={Boolean(errors?.[`indicatorList[${index}].sdg`])}
                          helperText={errors?.[`indicatorList[${index}].sdg`] || ""}
                        />
                      )}
                    />
                  </Grid>
                  <Grid size={{ xs: 12, sm: 6 }}>
                    <Autocomplete
                      disabled={isViewing}
                      options={
                        allOomfMastersData?.categories?.map((item) => ({
                          id: item.id,
                          name: item.name,
                        })) || []
                      }
                      value={indicator.category || null}
                      getOptionLabel={(option) => option?.name || ""}
                      isOptionEqualToValue={(option, value) => option.id === value.id}
                      onChange={(event, newValue) => {
                        const updatedIndicators = [...indicatorList];
                        updatedIndicators[index].category = newValue || null;
                        setIndicatorList(updatedIndicators);
                      }}
                      renderInput={(params) => (
                        <TextField
                          {...params}
                          label="Category"
                          placeholder="Select Category"
                          error={Boolean(errors?.[`indicatorList[${index}].category`])}
                          helperText={errors?.[`indicatorList[${index}].category`] || ""}
                        />
                      )}
                    />
                  </Grid>
                  <Grid size={{ xs: 12, sm: 6 }}>
                    <Autocomplete
                      disabled={isViewing}
                      options={
                        allOomfMastersData?.periods?.map((item) => ({
                          id: item.id,
                          name: item.name,
                        })) || []
                      }
                      value={indicator.period || null}
                      getOptionLabel={(option) => option?.name || ""}
                      isOptionEqualToValue={(option, value) => option.id === value.id}
                      onChange={(event, newValue) => {
                        const updatedIndicators = [...indicatorList];
                        updatedIndicators[index].period = newValue || null;
                        setIndicatorList(updatedIndicators);
                      }}
                      renderInput={(params) => (
                        <TextField
                          {...params}
                          label="Period"
                          placeholder="Select Period"
                          required
                          error={Boolean(errors?.[`indicatorList[${index}].period`])}
                          helperText={errors?.[`indicatorList[${index}].period`] || ""}
                        />
                      )}
                    />
                  </Grid>
                  <Grid size={12} sx={{ display: 'flex', justifyContent: 'flex-end' }}>
                    <Button
                      variant="outlined"
                      color="error"
                      onClick={() => {
                        const updatedIndicators = indicatorList.filter((_, i) => i !== index);
                        setIndicatorList(updatedIndicators);
                      }}
                      disabled={isViewing || indicatorList.length === 1}
                    >
                      Remove Indicator
                    </Button>
                  </Grid>
                </Grid>
              </AccordionDetails>
            </Accordion>
          ))}
          <Button
            variant="contained"
            onClick={() => {
              setIndicatorList([
                ...indicatorList,
                {
                  indicatorType: "",
                  indicatorName: "",
                  measurementType: null,
                  unit: null,
                  scale: null,
                  measurementArea: null,
                  indicatorRise: null,
                  sdg: null,
                  category: null,
                  period: null,
                },
              ]);
            }}
            disabled={isViewing}
            sx={{ mt: 1 }}
          >
            Add Indicator
          </Button>
        </Grid>

        <FormControl component="fieldset" disabled={isViewing}>
          <FormLabel component="legend">Status</FormLabel>
          <FormControlLabel
            control={
              <Switch
                checked={newRow?.status}
                onChange={handleSwitchChange}
                color="primary"
              />
            }
            label={newRow?.status ? "Active" : "In Active"}
          />
        </FormControl>

      </Grid>
    </>
  );
};
export default Indicator;
