import React from "react";
import {
  Box,
  Typography,
  Paper,
  TableContainer,
  Table,
  TableHead,
  TableRow,
  TableCell,
  TableBody,
} from "@mui/material";
import InboxIcon from "@mui/icons-material/Inbox";

const processTargetDataEntries = (
  entries,
  isSubScheme = false,
  stateName = null,
  districtName = null
) => {
  const aggregatedRows = {};
  const financialYears = new Set();
  const currentYearBEYearWise = new Set();
  const currentYearAEYearWise = new Set();
  let cumulativeBE = 0;
  let cumulativeAE = 0;

  if (!entries || entries.length === 0) {
    return {
      rows: [],
      financialYears: [],
      cumulativeBE: 0,
      cumulativeAE: 0,
      currentYearBEYearWise: [],
      currentYearAEYearWise: [],
    };
  }

  entries.forEach((dataEntry) => {
    const financialYear = dataEntry.financialYear || "Unknown";
    financialYears.add(financialYear);
    const financialOutlay = dataEntry.financialOutlay || 0;
    const actualExpenditure = dataEntry?.actualExpenditure || 0;
    currentYearBEYearWise.add(
      JSON.stringify({
        [financialYear]: financialOutlay,
      })
    );
    currentYearAEYearWise.add(
      JSON.stringify({
        [financialYear]: actualExpenditure,
      })
    );
    cumulativeBE += financialOutlay;
    cumulativeAE += actualExpenditure;

    (dataEntry.indicatorData || []).forEach((indicatorTypeEntry) => {
      (indicatorTypeEntry.sections || []).forEach((section) => {
        (section.indicators || []).forEach((indicator) => {
          const frequency = indicator.frequency?.name || "Yearly";
          let targets = indicator.targets || {};
          let achievedTargets = indicator.achievedTargets || {};

          if (stateName) {
            if (Array.isArray(targets)) {
              const stateTarget = targets.find((t) => t.name === stateName);
              targets = stateTarget ? stateTarget.targets : {};
              // const stateAchieved = (achievedTargets || [])?.find(
              //   (t) => t.name === stateName
              // );
              const stateAchieved = Array.isArray(achievedTargets)
                ? achievedTargets.find((t) => t.name === stateName)
                : null;

              achievedTargets = stateAchieved
                ? stateAchieved.achievedTargets
                : {};
              if (districtName && stateTarget?.connectedDistricts) {
                const districtTarget = stateTarget.connectedDistricts.find(
                  (d) => d.name === districtName
                );
                targets = districtTarget ? districtTarget.targets : {};
                const districtAchieved =
                  stateAchieved?.connectedDistricts?.find(
                    (d) => d.name === districtName
                  );
                achievedTargets = districtAchieved
                  ? districtAchieved.achievedTargets
                  : {};
              }
            }
          }

          const subSchemeIdentifier = isSubScheme
            ? `${dataEntry.subSchemeId?.name || ""}-`
            : "";
          const rowKey = `${subSchemeIdentifier}${
            indicatorTypeEntry.indicatorType?.name || ""
          }-${section.name || ""}-${indicator.indicator?.name || ""}-${
            indicator.unit?.name || ""
          }-${indicator.period?.name || ""}-${frequency}`;

          if (!aggregatedRows[rowKey]) {
            aggregatedRows[rowKey] = {
              indicatorType: indicatorTypeEntry.indicatorType?.name || "",
              indicatorStatement: section.name || "",
              indicator: indicator.indicator?.name || "",
              unit: indicator.unit?.name || "",
              periodAttribute: indicator.period?.name || "",
              frequency: frequency,
              isSubSchemeRow: isSubScheme,
              subSchemeName: isSubScheme ? dataEntry.subSchemeId?.name : null,
              cumulativeTarget: 0,
              cumulativeProgress: 0,
            };
          }

          aggregatedRows[rowKey][`${financialYear}_data`] = {
            targets: {},
            achievedTargets: {},
            achievedFinalProgress: {},
            totalTarget: 0,
            totalAchieved: 0,
          };

          if (frequency === "Quarterly") {
            const quarters = [
              "First Quarter",
              "Second Quarter",
              "Third Quarter",
              "Fourth Quarter",
            ];
            quarters.forEach((q, index) => {
              const isRangeOrRatioUnit = [9, 10].includes(indicator?.unit?.id);
              const targetValue = isRangeOrRatioUnit
                ? targets[q] || "-"
                : !isNaN(parseFloat(targets[q]))
                ? parseFloat(targets[q])
                : indicator?.targetAmenable || "-";
              const achievedValue = isRangeOrRatioUnit
                ? achievedTargets[q] || "-"
                : !isNaN(parseFloat(achievedTargets[q]))
                ? parseFloat(achievedTargets[q])
                : achievedTargets[q] || "-";

              aggregatedRows[rowKey][`${financialYear}_data`].targets[
                `Q${index + 1}`
              ] = targetValue;
              aggregatedRows[rowKey][`${financialYear}_data`].achievedTargets[
                `Q${index + 1}`
              ] = achievedValue;
              aggregatedRows[rowKey][
                `${financialYear}_data`
              ].achievedFinalProgress[`Q${index + 1}`] =
                !isNaN(achievedValue) && !isNaN(targetValue)
                  ? (achievedValue / targetValue) * 100
                  : "N/A";
              if (typeof targetValue === "number") {
                aggregatedRows[rowKey][`${financialYear}_data`].totalTarget +=
                  targetValue;
              }
              if (typeof achievedValue === "number") {
                aggregatedRows[rowKey][`${financialYear}_data`].totalAchieved +=
                  achievedValue;
              }
            });

            if (
              indicator?.measurementType?.name !== "Qualitative" &&
              ![9, 10].includes(indicator?.unit?.id)
            ) {
              aggregatedRows[rowKey][`${financialYear}_data`].targets["Total"] =
                aggregatedRows[rowKey][`${financialYear}_data`].totalTarget ||
                "-";
              aggregatedRows[rowKey][`${financialYear}_data`].achievedTargets[
                "Total"
              ] =
                aggregatedRows[rowKey][`${financialYear}_data`].totalAchieved ||
                "-";
              const totalTargetValue =
                aggregatedRows[rowKey][`${financialYear}_data`].totalTarget;
              const totalAchievedValue =
                aggregatedRows[rowKey][`${financialYear}_data`].totalAchieved;
              if (!isNaN(totalTargetValue) && !isNaN(totalAchievedValue)) {
                aggregatedRows[rowKey][
                  `${financialYear}_data`
                ].achievedFinalProgress["Total"] =
                  (totalAchievedValue / totalTargetValue) * 100 || "-";
              }
            } else {
              aggregatedRows[rowKey][`${financialYear}_data`].targets["Total"] =
                "N/A";
              aggregatedRows[rowKey][`${financialYear}_data`].achievedTargets[
                "Total"
              ] = indicator?.achievedTargets === undefined ? "-" : "N/A";
              aggregatedRows[rowKey][
                `${financialYear}_data`
              ].achievedFinalProgress["Total"] = "N/A";
            }
          } else if (frequency === "Half-Yearly") {
            const halfYears = ["First Half", "Second Half"];
            halfYears.forEach((h, index) => {
              const isRangeOrRatioUnit = [9, 10].includes(indicator?.unit?.id);
              const targetValue = isRangeOrRatioUnit
                ? targets[h] || "-"
                : !isNaN(parseFloat(targets[h]))
                ? parseFloat(targets[h])
                : indicator?.targetAmenable || "-";
              const achievedValue = isRangeOrRatioUnit
                ? achievedTargets[h] || "-"
                : !isNaN(parseFloat(achievedTargets[h]))
                ? parseFloat(achievedTargets[h])
                : achievedTargets[h] || "-";
              aggregatedRows[rowKey][`${financialYear}_data`].targets[
                `HY${index + 1}`
              ] = targetValue || "-";
              aggregatedRows[rowKey][`${financialYear}_data`].achievedTargets[
                `HY${index + 1}`
              ] = achievedValue || "-";
              aggregatedRows[rowKey][
                `${financialYear}_data`
              ].achievedFinalProgress[`HY${index + 1}`] =
                !isNaN(achievedValue) && !isNaN(targetValue)
                  ? (achievedValue / targetValue) * 100
                  : "N/A";
              if (typeof targetValue === "number") {
                aggregatedRows[rowKey][`${financialYear}_data`].totalTarget +=
                  targetValue;
              }
              if (typeof achievedValue === "number") {
                aggregatedRows[rowKey][`${financialYear}_data`].totalAchieved +=
                  achievedValue;
              }
            });

            if (
              indicator?.measurementType?.name !== "Qualitative" &&
              ![9, 10].includes(indicator?.unit?.id)
            ) {
              aggregatedRows[rowKey][`${financialYear}_data`].targets["Total"] =
                aggregatedRows[rowKey][`${financialYear}_data`].totalTarget ||
                "-";
              aggregatedRows[rowKey][`${financialYear}_data`].achievedTargets[
                "Total"
              ] =
                aggregatedRows[rowKey][`${financialYear}_data`].totalAchieved ||
                "-";
              const totalTargetValue =
                aggregatedRows[rowKey][`${financialYear}_data`].totalTarget;
              const totalAchievedValue =
                aggregatedRows[rowKey][`${financialYear}_data`].totalAchieved;
              if (!isNaN(totalTargetValue) && !isNaN(totalAchievedValue)) {
                aggregatedRows[rowKey][
                  `${financialYear}_data`
                ].achievedFinalProgress["Total"] =
                  (totalAchievedValue / totalTargetValue) * 100 || "-";
              }
            } else {
              aggregatedRows[rowKey][`${financialYear}_data`].targets["Total"] =
                "N/A";
              aggregatedRows[rowKey][`${financialYear}_data`].achievedTargets[
                "Total"
              ] = indicator?.achievedTargets === undefined ? "-" : "N/A";
              aggregatedRows[rowKey][
                `${financialYear}_data`
              ].achievedFinalProgress["Total"] = "N/A";
            }
          } else {
            const isRangeOrRatio = [9, 10].includes(indicator?.unit?.id);
            let totalTarget = isRangeOrRatio
              ? indicator.preTarget || "-"
              : indicator?.targetAmenable !== undefined
              ? indicator?.targetAmenable
              : parseFloat(indicator.preTarget) ||
                Object.values(targets).reduce(
                  (sum, val) => sum + (parseFloat(val) || 0),
                  0
                );
            let totalAchieved = isRangeOrRatio
              ? achievedTargets["Yearly"] || "-"
              : Object.values(achievedTargets).reduce(
                  (sum, val) => sum + (parseFloat(val) || 0),
                  0
                );

            aggregatedRows[rowKey][`${financialYear}_data`].targets["Yearly"] =
              totalTarget !== undefined ? totalTarget : "N/A";
            aggregatedRows[rowKey][`${financialYear}_data`].achievedTargets[
              "Yearly"
            ] =
              totalAchieved !== undefined
                ? totalAchieved
                : indicator?.achievedTargets === undefined
                ? "-"
                : "N/A";
            aggregatedRows[rowKey][
              `${financialYear}_data`
            ].achievedFinalProgress["Yearly"] =
              !isNaN(totalAchieved) && !isNaN(totalTarget)
                ? (totalAchieved / totalTarget) * 100
                : "N/A";

            aggregatedRows[rowKey][`${financialYear}_data`].totalTarget =
              isRangeOrRatio ? "-" : totalTarget || 0;
            aggregatedRows[rowKey][`${financialYear}_data`].totalAchieved =
              isRangeOrRatio ? "-" : totalAchieved || 0;
          }

          const isQuantitative =
            indicator?.measurementType?.name !== "Qualitative";
          const isNumericUnit = ![9, 10].includes(indicator?.unit?.id);
          if (isQuantitative && isNumericUnit) {
            aggregatedRows[rowKey].cumulativeTarget +=
              parseFloat(indicator.preTarget) || 0;
            aggregatedRows[rowKey].cumulativeProgress +=
              aggregatedRows[rowKey][`${financialYear}_data`].totalAchieved;
            const totalTargetValue = aggregatedRows[rowKey].cumulativeTarget;
            const totalAchievedValue =
              aggregatedRows[rowKey].cumulativeProgress;
            if (!isNaN(totalTargetValue) && !isNaN(totalAchievedValue)) {
              aggregatedRows[rowKey].cumulativeAchievedFinalProgress =
                (totalAchievedValue / totalTargetValue) * 100 || "N/A";
            }
          } else {
            aggregatedRows[rowKey].cumulativeTarget = "N/A";
            aggregatedRows[rowKey].cumulativeProgress =
              indicator?.achievedTargets === undefined ? "-" : "N/A";
            aggregatedRows[rowKey].cumulativeAchievedFinalProgress = "N/A";
          }
        });
      });
    });
  });

  const sortedRows = Object.values(aggregatedRows).sort((a, b) => {
    const indicatorTypeCompare = (a.indicatorType || "").localeCompare(
      b.indicatorType || ""
    );
    if (indicatorTypeCompare !== 0) return indicatorTypeCompare;
    const indicatorStatementCompare = (
      a.indicatorStatement || ""
    ).localeCompare(b.indicatorStatement || "");
    if (indicatorStatementCompare !== 0) return indicatorStatementCompare;
    return (a.indicator || "").localeCompare(b.indicator || "");
  });

  return {
    rows: sortedRows,
    financialYears: Array.from(financialYears).sort(),
    currentYearBEYearWise: Array.from(currentYearBEYearWise).map((item) =>
      JSON.parse(item)
    ),
    currentYearAEYearWise: Array.from(currentYearAEYearWise).map((item) =>
      JSON.parse(item)
    ),
    cumulativeBE,
    cumulativeAE,
  };
};

const transformDataForTable = (rawData) => {
  const allTablesData = [];

  rawData?.data.forEach((area, areaIndex) => {
    const measurementArea = area.years[0]?.measurementArea?.name || "Unknown";
    area.years.forEach((year) => {
      if (measurementArea === "National") {
        const schemeGroup = {
          type: "scheme",
          measurementArea,
          schemeName: area.schemeName,
          parentTable: null,
          subSchemeTables: [],
          path: `${areaIndex + 1}`,
        };

        // Process parent scheme data
        const financialYears = [year.financialYear];
        const parentSchemeDataEntries = (
          year.measurementArea?.targetDataParent || []
        ).map((entry) => ({
          ...entry,
          financialYear: year.financialYear,
        }));
        const {
          rows,
          cumulativeBE,
          cumulativeAE,
          currentYearAEYearWise,
          currentYearBEYearWise,
        } = processTargetDataEntries(parentSchemeDataEntries, false);
        if (rows.length > 0) {
          schemeGroup.parentTable = {
            schemeName: area.schemeName,
            financialYears,
            rows,
            currentYearBEYearWise,
            currentYearAEYearWise,
            cumulativeBEForAllYears: cumulativeBE,
            cumulativeAEForAllYears: cumulativeAE,
          };
        }

        // Process sub-scheme data
        const subSchemeMap = new Map();
        (year.measurementArea?.targetDataSubScheme || []).forEach(
          (subSchemeData) => {
            const subSchemeId = subSchemeData.subSchemeId?.id || "unknown";
            if (!subSchemeMap.has(subSchemeId)) {
              subSchemeMap.set(subSchemeId, []);
            }
            subSchemeMap
              .get(subSchemeId)
              .push({ ...subSchemeData, financialYear: year.financialYear });
          }
        );

        subSchemeMap.forEach((subSchemeEntries, subSchemeId, map) => {
          const subIndex = Array.from(map.keys()).indexOf(subSchemeId) + 1;
          const {
            rows,
            cumulativeBE,
            cumulativeAE,
            currentYearAEYearWise,
            currentYearBEYearWise,
          } = processTargetDataEntries(subSchemeEntries, true);
          if (rows.length > 0) {
            const subSchemeName =
              subSchemeEntries[0].subSchemeId?.name ||
              `Sub-Scheme ${subSchemeId}`;
            schemeGroup.subSchemeTables.push({
              schemeName: subSchemeName,
              financialYears,
              rows,
              currentYearBEYearWise,
              currentYearAEYearWise,
              cumulativeBEForAllYears: cumulativeBE,
              cumulativeAEForAllYears: cumulativeAE,
              path: `${schemeGroup.path}.${subIndex}`,
            });
          }
        });

        // Include schemeGroup in allTablesData if either parentTable or subSchemeTables have data
        if (schemeGroup.parentTable || schemeGroup.subSchemeTables.length > 0) {
          allTablesData.push(schemeGroup);
        }
      } else if (measurementArea === "State") {
        (year.measurementArea.states || []).forEach((state, stateIndex) => {
          const stateGroup = {
            type: "state",
            measurementArea,
            stateName: state.name,
            schemes: [],
            path: `${areaIndex + 1}-${state.name}`,
          };

          // Process parent scheme data
          const financialYears = [year.financialYear];
          const parentSchemeDataEntries = (state.targetDataParent || []).map(
            (entry) => ({
              ...entry,
              financialYear: year.financialYear,
            })
          );
          const {
            rows,
            cumulativeBE,
            cumulativeAE,
            currentYearAEYearWise,
            currentYearBEYearWise,
          } = processTargetDataEntries(
            parentSchemeDataEntries,
            false,
            state.name
          );

          // Initialize scheme object
          const scheme = {
            type: "scheme",
            schemeName: area.schemeName,
            parentTable: null,
            subSchemeTables: [],
            path: `${stateGroup.path}.1`,
          };

          if (rows.length > 0) {
            scheme.parentTable = {
              schemeName: area.schemeName,
              financialYears,
              rows,
              currentYearBEYearWise,
              currentYearAEYearWise,
              cumulativeBEForAllYears: cumulativeBE,
              cumulativeAEForAllYears: cumulativeAE,
            };
          }

          // Process sub-scheme data
          const subSchemeMap = new Map();
          (state.targetDataSubScheme || []).forEach((subSchemeData) => {
            const subSchemeId = subSchemeData.subSchemeId?.id || "unknown";
            if (!subSchemeMap.has(subSchemeId)) {
              subSchemeMap.set(subSchemeId, []);
            }
            subSchemeMap
              .get(subSchemeId)
              .push({ ...subSchemeData, financialYear: year.financialYear });
          });

          subSchemeMap.forEach((subSchemeEntries, subSchemeId, map) => {
            const subIndex = Array.from(map.keys()).indexOf(subSchemeId) + 1;
            const {
              rows,
              cumulativeBE,
              cumulativeAE,
              currentYearAEYearWise,
              currentYearBEYearWise,
            } = processTargetDataEntries(subSchemeEntries, true, state.name);
            if (rows.length > 0) {
              const subSchemeName =
                subSchemeEntries[0].subSchemeId?.name ||
                `Sub-Scheme ${subSchemeId}`;
              scheme.subSchemeTables.push({
                schemeName: subSchemeName,
                financialYears,
                rows,
                currentYearBEYearWise,
                currentYearAEYearWise,
                cumulativeBEForAllYears: cumulativeBE,
                cumulativeAEForAllYears: cumulativeAE,
                path: `${stateGroup.path}.1.${subIndex}`,
              });
            }
          });

          // Include scheme in stateGroup.schemes if either parentTable or subSchemeTables have data
          if (scheme.parentTable || scheme.subSchemeTables.length > 0) {
            stateGroup.schemes.push(scheme);
          }

          // Include stateGroup in allTablesData if it has any schemes
          if (stateGroup.schemes.length > 0) {
            allTablesData.push(stateGroup);
          }
        });
      } else if (measurementArea === "District") {
        (year.measurementArea.states || []).forEach((state, stateIndex) => {
          const stateGroup = {
            type: "state",
            measurementArea,
            stateName: state.name,
            districts: [],
            path: `${areaIndex + 1}-${state.name}`,
          };

          (state.districts || []).forEach((district, districtIndex) => {
            const districtGroup = {
              type: "district",
              districtName: district.name,
              schemes: [],
              path: `${stateGroup.path}-${district.name}`,
            };

            // Process parent scheme data
            const financialYears = [year.financialYear];
            const parentSchemeDataEntries = (
              district.targetDataParent || []
            ).map((entry) => ({
              ...entry,
              financialYear: year.financialYear,
            }));
            const {
              rows,
              cumulativeBE,
              cumulativeAE,
              currentYearAEYearWise,
              currentYearBEYearWise,
            } = processTargetDataEntries(
              parentSchemeDataEntries,
              false,
              state.name,
              district.name
            );

            // Initialize scheme object
            const scheme = {
              type: "scheme",
              schemeName: area.schemeName,
              parentTable: null,
              subSchemeTables: [],
              path: `${districtGroup.path}.1`,
            };

            if (rows.length > 0) {
              scheme.parentTable = {
                schemeName: area.schemeName,
                financialYears,
                rows,
                currentYearBEYearWise,
                currentYearAEYearWise,
                cumulativeBEForAllYears: cumulativeBE,
                cumulativeAEForAllYears: cumulativeAE,
              };
            }

            // Process sub-scheme data
            const subSchemeMap = new Map();
            (district.targetDataSubScheme || []).forEach((subSchemeData) => {
              const subSchemeId = subSchemeData.subSchemeId?.id || "unknown";
              if (!subSchemeMap.has(subSchemeId)) {
                subSchemeMap.set(subSchemeId, []);
              }
              subSchemeMap
                .get(subSchemeId)
                .push({ ...subSchemeData, financialYear: year.financialYear });
            });

            subSchemeMap.forEach((subSchemeEntries, subSchemeId, map) => {
              const subIndex = Array.from(map.keys()).indexOf(subSchemeId) + 1;
              const {
                rows,
                cumulativeBE,
                cumulativeAE,
                currentYearAEYearWise,
                currentYearBEYearWise,
              } = processTargetDataEntries(
                subSchemeEntries,
                true,
                state.name,
                district.name
              );
              if (rows.length > 0) {
                const subSchemeName =
                  subSchemeEntries[0].subSchemeId?.name ||
                  `Sub-Scheme ${subSchemeId}`;
                scheme.subSchemeTables.push({
                  schemeName: subSchemeName,
                  financialYears,
                  rows,
                  currentYearBEYearWise,
                  currentYearAEYearWise,
                  cumulativeBEForAllYears: cumulativeBE,
                  cumulativeAEForAllYears: cumulativeAE,
                  path: `${districtGroup.path}.1.${subIndex}`,
                });
              }
            });

            // Include scheme in districtGroup.schemes if either parentTable or subSchemeTables have data
            if (scheme.parentTable || scheme.subSchemeTables.length > 0) {
              districtGroup.schemes.push(scheme);
            }
            // Include districtGroup in stateGroup.districts if it has any schemes
            if (districtGroup.schemes.length > 0) {
              stateGroup.districts.push(districtGroup);
            }
          });

          // Include stateGroup in allTablesData if it has any districts
          if (stateGroup.districts.length > 0) {
            allTablesData.push(stateGroup);
          }
        });
      }
    });
  });

  return allTablesData;
};

const RenderTable = ({
  title,
  financialYears,
  currentYearBEYearWise,
  currentYearAEYearWise,
  rows,
  cumulativeBEForAllYears,
  cumulativeAEForAllYears,
}) => {
  const fixedHeaderCells = [
    { label: "Indicator Type", rowSpan: 3 },
    { label: "Indicator Statement", rowSpan: 3 },
    { label: "Indicator", rowSpan: 3 },
    { label: "Unit", rowSpan: 3 },
    { label: "Period Attribute", rowSpan: 3 },
  ];

  const frequencies = [...new Set(rows.map((row) => row.frequency))];
  const isYearlyFrequency =
    frequencies.includes("Yearly") && frequencies.length === 1;

  let subColumns = ["Yearly"];
  if (frequencies.includes("Quarterly")) {
    subColumns = ["Q1", "Q2", "Q3", "Q4", "Total"];
  } else if (frequencies.includes("Half-Yearly")) {
    subColumns = ["HY1", "HY2", "Total"];
  }

  return (
    <Paper
      sx={{
        width: "100%",
        overflowX: "auto",
        boxShadow: "0 4px 20px rgba(0,0,0,0.05)",
        mb: 5,
      }}
    >
      <TableContainer sx={{ border: "1px solid #ddd" }}>
        <Table stickyHeader aria-label={`${title} data table`}>
          <TableHead>
            <TableRow sx={{ backgroundColor: "#45154F" }}>
              {fixedHeaderCells.map((cell, index) => (
                <TableCell
                  key={index}
                  rowSpan={isYearlyFrequency ? 2 : 3}
                  sx={{
                    fontWeight: "bold",
                    borderRight: "1px solid #c0d9e0",
                    borderBottom: "1px solid #c0d9e0",
                    textAlign: "center",
                    minWidth: "120px",
                    color: "#fff",
                    backgroundColor: "#45154F",
                    fontSize: "0.9rem",
                  }}
                >
                  {cell.label}
                </TableCell>
              ))}
              {financialYears.map((year, yearIndex) => {
                const value =
                  currentYearBEYearWise.find((item) => year in item)?.[year] ??
                  0;
                const AEvalue =
                  currentYearAEYearWise.find((item) => year in item)?.[year] ??
                  0;

                return (
                  <TableCell
                    key={yearIndex}
                    colSpan={isYearlyFrequency ? 3 : subColumns.length * 3}
                    align="center"
                    sx={{
                      fontWeight: "bold",
                      borderRight: "1px solid #c0d9e0",
                      borderBottom: "1px solid #c0d9e0",
                      minWidth: "180px",
                      backgroundColor: "#45154F",
                      color: "#fff",
                      fontSize: "0.9rem",
                    }}
                  >
                    {year}
                    <br />
                    <span
                      style={{
                        fontSize: "0.8em",
                        fontWeight: "normal",
                        color: "#fff",
                      }}
                    >
                      BE (In Rs. Crore): {value}, AE (In Rs. Crore): {AEvalue}
                    </span>
                  </TableCell>
                );
              })}
              {isYearlyFrequency && (
                <TableCell
                  colSpan={3}
                  align="center"
                  sx={{
                    fontWeight: "bold",
                    borderRight: "1px solid #c0d9e0",
                    borderBottom: "1px solid #c0d9e0",
                    minWidth: "180px",
                    backgroundColor: "#45154F",
                    color: "#fff",
                    fontSize: "0.9rem",
                  }}
                >
                  Cumulative
                  <br />
                  <span
                    style={{
                      fontSize: "0.8em",
                      fontWeight: "normal",
                      color: "#fff",
                    }}
                  >
                    BE (In Rs. Crore): {cumulativeBEForAllYears.toFixed(1)}
                  </span>
                  <span
                    style={{
                      fontSize: "0.8em",
                      fontWeight: "normal",
                      color: "#fff",
                    }}
                  >
                    , AE (In Rs. Crore): {cumulativeAEForAllYears.toFixed(1)}
                  </span>
                </TableCell>
              )}
            </TableRow>
            {!isYearlyFrequency && (
              <TableRow sx={{ backgroundColor: "#45154F" }}>
                {financialYears.map((year, yearIndex) => (
                  <React.Fragment key={yearIndex}>
                    <TableCell
                      colSpan={subColumns.length}
                      align="center"
                      sx={{
                        fontWeight: "bold",
                        borderRight: "1px solid #c0d9e0",
                        borderBottom: "1px solid #c0d9e0",
                        minWidth: "90px",
                        color: "#fff",
                        backgroundColor: "#45154F",
                        fontSize: "0.9rem",
                      }}
                    >
                      Target
                    </TableCell>
                    <TableCell
                      colSpan={subColumns.length}
                      align="center"
                      sx={{
                        fontWeight: "bold",
                        borderRight: "1px solid #c0d9e0",
                        borderBottom: "1px solid #c0d9e0",
                        minWidth: "90px",
                        color: "#fff",
                        backgroundColor: "#45154F",
                        fontSize: "0.9rem",
                      }}
                    >
                      Progress
                    </TableCell>
                    <TableCell
                      colSpan={subColumns.length}
                      align="center"
                      sx={{
                        fontWeight: "bold",
                        borderRight: "1px solid #c0d9e0",
                        borderBottom: "1px solid #c0d9e0",
                        minWidth: "90px",
                        color: "#fff",
                        backgroundColor: "#45154F",
                        fontSize: "0.9rem",
                      }}
                    >
                      Achieved
                    </TableCell>
                  </React.Fragment>
                ))}
              </TableRow>
            )}
            {!isYearlyFrequency && (
              <TableRow sx={{ backgroundColor: "#45154F" }}>
                {financialYears.map((year, yearIndex) => (
                  <React.Fragment key={yearIndex}>
                    {subColumns.map((subCol, subIndex) => (
                      <TableCell
                        key={`${yearIndex}-target-${subCol}`}
                        align="center"
                        sx={{
                          fontWeight: "bold",
                          borderRight: "1px solid #c0d9e0",
                          minWidth: "90px",
                          color: "#fff",
                          backgroundColor: "#45154F",
                          fontSize: "0.9rem",
                        }}
                      >
                        {subCol}
                      </TableCell>
                    ))}
                    {subColumns.map((subCol, subIndex) => (
                      <TableCell
                        key={`${yearIndex}-progress-${subCol}`}
                        align="center"
                        sx={{
                          fontWeight: "bold",
                          borderRight: "1px solid #c0d9e0",
                          minWidth: "90px",
                          color: "#fff",
                          backgroundColor: "#45154F",
                          fontSize: "0.9rem",
                        }}
                      >
                        {subCol}
                      </TableCell>
                    ))}
                    {subColumns.map((subCol, subIndex) => (
                      <TableCell
                        key={`${yearIndex}-final-progress-${subCol}`}
                        align="center"
                        sx={{
                          fontWeight: "bold",
                          borderRight: "1px solid #c0d9e0",
                          minWidth: "90px",
                          color: "#fff",
                          backgroundColor: "#45154F",
                          fontSize: "0.9rem",
                        }}
                      >
                        {subCol}
                      </TableCell>
                    ))}
                  </React.Fragment>
                ))}
                {frequencies.includes("Yearly") && (
                  <>
                    <TableCell
                      key="cumulative-target-subheader"
                      align="center"
                      sx={{
                        fontWeight: "bold",
                        borderRight: "1px solid #c0d9e0",
                        minWidth: "90px",
                        backgroundColor: "#45154F",
                        color: "#fff",
                        fontSize: "0.9rem",
                      }}
                    >
                      Target
                    </TableCell>
                    <TableCell
                      key="cumulative-progress-subheader"
                      align="center"
                      sx={{
                        fontWeight: "bold",
                        borderRight: "1px solid #c0d9e0",
                        minWidth: "90px",
                        color: "#fff",
                        backgroundColor: "#45154F",
                        fontSize: "0.9rem",
                      }}
                    >
                      Progress
                    </TableCell>
                    <TableCell
                      key="cumulative-final-progress-subheader"
                      align="center"
                      sx={{
                        fontWeight: "bold",
                        borderRight: "1px solid #c0d9e0",
                        minWidth: "90px",
                        color: "#fff",
                        backgroundColor: "#45154F",
                        fontSize: "0.9rem",
                      }}
                    >
                      Achieved
                    </TableCell>
                  </>
                )}
              </TableRow>
            )}
            {isYearlyFrequency && (
              <TableRow sx={{ backgroundColor: "#45154F" }}>
                {financialYears.map((year, yearIndex) => (
                  <React.Fragment key={yearIndex}>
                    <TableCell
                      align="center"
                      sx={{
                        fontWeight: "bold",
                        borderRight: "1px solid #c0d9e0",
                        minWidth: "90px",
                        color: "#fff",
                        backgroundColor: "#45154F",
                        fontSize: "0.9rem",
                      }}
                    >
                      Target
                    </TableCell>
                    <TableCell
                      align="center"
                      sx={{
                        fontWeight: "bold",
                        borderRight: "1px solid #c0d9e0",
                        minWidth: "90px",
                        color: "#fff",
                        backgroundColor: "#45154F",
                        fontSize: "0.9rem",
                      }}
                    >
                      Progress
                    </TableCell>
                    <TableCell
                      align="center"
                      sx={{
                        fontWeight: "bold",
                        borderRight: "1px solid #c0d9e0",
                        minWidth: "90px",
                        color: "#fff",
                        backgroundColor: "#45154F",
                        fontSize: "0.9rem",
                      }}
                    >
                      Achieved
                    </TableCell>
                  </React.Fragment>
                ))}
                <TableCell
                  align="center"
                  sx={{
                    fontWeight: "bold",
                    borderRight: "1px solid #c0d9e0",
                    minWidth: "90px",
                    color: "#fff",
                    backgroundColor: "#45154F",
                    fontSize: "0.9rem",
                  }}
                >
                  Target
                </TableCell>
                <TableCell
                  align="center"
                  sx={{
                    fontWeight: "bold",
                    borderRight: "1px solid #c0d9e0",
                    minWidth: "90px",
                    color: "#fff",
                    backgroundColor: "#45154F",
                    fontSize: "0.9rem",
                  }}
                >
                  Progress
                </TableCell>
                <TableCell
                  align="center"
                  sx={{
                    fontWeight: "bold",
                    borderRight: "1px solid #c0d9e0",
                    minWidth: "90px",
                    color: "#fff",
                    backgroundColor: "#45154F",
                    fontSize: "0.9rem",
                  }}
                >
                  Achieved
                </TableCell>
              </TableRow>
            )}
          </TableHead>
          <TableBody>
            {rows.map((row, index) => (
              <TableRow
                key={index}
                sx={{
                  "&:nth-of-type(odd)": { backgroundColor: "#f9f9f9" },
                }}
              >
                <TableCell sx={{ borderRight: "1px solid #eee" }}>
                  {row.indicatorType}
                </TableCell>
                <TableCell sx={{ borderRight: "1px solid #eee" }}>
                  {row.indicatorStatement}
                </TableCell>
                <TableCell sx={{ borderRight: "1px solid #eee" }}>
                  {row.indicator}
                </TableCell>
                <TableCell sx={{ borderRight: "1px solid #eee" }}>
                  {row.unit}
                </TableCell>
                <TableCell sx={{ borderRight: "1px solid #eee" }}>
                  {row.periodAttribute}
                </TableCell>
                {financialYears.map((year, yearIndex) => {
                  const data = row[`${year}_data`] || {
                    targets: {},
                    achievedTargets: {},
                    achievedFinalProgress: {},
                    totalTarget: 0,
                    totalAchieved: 0,
                  };
                  const rowSubColumns =
                    row.frequency === "Quarterly"
                      ? ["Q1", "Q2", "Q3", "Q4", "Total"]
                      : row.frequency === "Half-Yearly"
                      ? ["HY1", "HY2", "Total"]
                      : ["Yearly"];
                  return (
                    <React.Fragment key={yearIndex}>
                      {isYearlyFrequency ? (
                        <>
                          <TableCell
                            align="right"
                            sx={{ borderRight: "1px solid #eee" }}
                          >
                            {data.targets["Yearly"] || "-"}
                          </TableCell>
                          <TableCell
                            align="right"
                            sx={{ borderRight: "1px solid #eee" }}
                          >
                            {data.achievedTargets["Yearly"] || "-"}
                          </TableCell>
                          <TableCell
                            align="right"
                            sx={{
                              borderRight: "1px solid #eee",
                              backgroundColor: (() => {
                                const value =
                                  data.achievedFinalProgress["Yearly"];
                                const numericValue = Number(value);
                                if (Number.isFinite(numericValue)) {
                                  if (numericValue > 80) return "lightgreen";
                                  if (numericValue >= 50 && numericValue <= 80)
                                    return "lightyellow";
                                  if (numericValue < 50) return "lightcoral";
                                }
                                return "transparent";
                              })(),
                              fontWeight: (() => {
                                const numericValue = Number(
                                  data.achievedFinalProgress["Yearly"]
                                );
                                return Number.isFinite(numericValue)
                                  ? "bold"
                                  : "normal";
                              })(),
                            }}
                          >
                            {(() => {
                              const value =
                                data.achievedFinalProgress["Yearly"];
                              const numericValue = Number(value);
                              return Number.isFinite(numericValue)
                                ? numericValue % 1 === 0
                                  ? numericValue
                                  : numericValue.toFixed(2)
                                : value || "-";
                            })()}
                          </TableCell>
                        </>
                      ) : (
                        <>
                          {subColumns.map((subCol, subIndex) => (
                            <TableCell
                              key={`${yearIndex}-target-${subCol}`}
                              align="right"
                              sx={{ borderRight: "1px solid #eee" }}
                            >
                              {rowSubColumns.includes(subCol)
                                ? data.targets[subCol] || "-"
                                : "-"}
                            </TableCell>
                          ))}
                          {subColumns.map((subCol, subIndex) => (
                            <TableCell
                              key={`${yearIndex}-progress-${subCol}`}
                              align="right"
                              sx={{ borderRight: "1px solid #eee" }}
                            >
                              {rowSubColumns.includes(subCol)
                                ? data.achievedTargets[subCol] || "-"
                                : "-"}
                            </TableCell>
                          ))}
                          {subColumns.map((subCol, subIndex) => {
                            const value = rowSubColumns.includes(subCol)
                              ? data.achievedFinalProgress[subCol]
                              : "-";
                            const numericValue = Number(value);
                            const displayValue = Number.isFinite(numericValue)
                              ? numericValue % 1 === 0
                                ? numericValue
                                : numericValue.toFixed(2)
                              : value || "-";
                            let bgColor = "transparent";
                            if (subCol === "Total") {
                              if (Number.isFinite(numericValue)) {
                                if (numericValue > 80) {
                                  bgColor = "lightgreen";
                                } else if (
                                  numericValue >= 50 &&
                                  numericValue <= 80
                                ) {
                                  bgColor = "lightyellow";
                                } else if (numericValue < 50) {
                                  bgColor = "lightcoral";
                                }
                              }
                            }
                            return (
                              <TableCell
                                key={`${yearIndex}-final-progress-${subCol}`}
                                align="right"
                                sx={{
                                  borderRight: "1px solid #eee",
                                  backgroundColor: bgColor,
                                  fontWeight: Number.isFinite(numericValue)
                                    ? "bold"
                                    : "normal",
                                }}
                              >
                                {displayValue}
                              </TableCell>
                            );
                          })}
                        </>
                      )}
                    </React.Fragment>
                  );
                })}
                {(isYearlyFrequency || frequencies.includes("Yearly")) && (
                  <>
                    <TableCell
                      align="right"
                      sx={{ borderRight: "1px solid #eee" }}
                    >
                      {row.cumulativeTarget || "-"}
                    </TableCell>
                    <TableCell align="right">
                      {row.cumulativeProgress || "-"}
                    </TableCell>
                    <TableCell
                      align="right"
                      sx={{
                        borderRight: "1px solid #eee",
                        backgroundColor: (() => {
                          const value = row.cumulativeAchievedFinalProgress;
                          const numericValue = Number(value);
                          if (Number.isFinite(numericValue)) {
                            if (numericValue > 80) return "lightgreen";
                            if (numericValue >= 50 && numericValue <= 80)
                              return "lightyellow";
                            if (numericValue < 50) return "lightcoral";
                          }
                          return "transparent";
                        })(),
                        fontWeight: (() => {
                          const numericValue = Number(
                            row.cumulativeAchievedFinalProgress
                          );
                          return Number.isFinite(numericValue)
                            ? "bold"
                            : "normal";
                        })(),
                      }}
                    >
                      {(() => {
                        const value = row.cumulativeAchievedFinalProgress;
                        const numericValue = Number(value);
                        return Number.isFinite(numericValue)
                          ? numericValue % 1 === 0
                            ? numericValue
                            : numericValue.toFixed(2)
                          : value || "-";
                      })()}
                    </TableCell>
                  </>
                )}
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </TableContainer>
    </Paper>
  );
};

function ProgressTable({ data }) {
  if (!data?.data || data.data.length === 0) {
    return (
      <Box
        sx={{
          textAlign: "center",
          mt: 8,
          color: "#6c757d",
          display: "flex",
          flexDirection: "column",
          alignItems: "center",
        }}
      >
        <InboxIcon sx={{ fontSize: 60, mb: 1, color: "#adb5bd" }} />
        <Typography variant="h6" gutterBottom>
          No data available
        </Typography>
        <Typography variant="body2">
          No data available for the selected filters.
        </Typography>
      </Box>
    );
  }

  const allTablesData = React.useMemo(
    () => transformDataForTable(data),
    [data]
  );
  const groupedByMeasurementArea = allTablesData.reduce((acc, group) => {
    const area = group.measurementArea;
    if (!acc[area]) {
      acc[area] = [];
    }
    acc[area].push(group);
    return acc;
  }, {});

  return (
    <Box sx={{ p: 3, minHeight: "100vh", fontFamily: "Inter, sans-serif" }}>
      {/* <Typography
        variant="h4"
        sx={{ mb: 4, color: "#45154F", fontWeight: "bold" }}
        aria-label="Progress Report Overview"
      >
        Progress Report Overview
      </Typography> */}

      {Object.entries(groupedByMeasurementArea).map(
        ([measurementArea, groups]) => (
          <React.Fragment key={measurementArea}>
            <Typography
              variant="h5"
              sx={{ p: 2, color: "#45154F", fontWeight: "bold", mt: 4 }}
              aria-label={`${measurementArea} Level Section`}
            >
              {`${
                measurementArea === "National"
                  ? "National Level"
                  : measurementArea === "State"
                  ? "State Level"
                  : "District Level"
              }`}
            </Typography>

            {groups.map((group, groupIndex) => {
              if (measurementArea === "National") {
                return (
                  <React.Fragment key={`${measurementArea}-${group.path}`}>
                    <Typography
                      variant="h6"
                      sx={{ p: 2, color: "#45154F", fontWeight: "bold", mt: 2 }}
                    >
                      {`${groupIndex + 1}.) ${group.schemeName}`}
                    </Typography>
                    {group.parentTable && group.parentTable.rows.length > 0 ? (
                      <RenderTable
                        title={group.parentTable.schemeName}
                        financialYears={group.parentTable.financialYears}
                        currentYearBEYearWise={
                          group.parentTable.currentYearBEYearWise
                        }
                        currentYearAEYearWise={
                          group.parentTable.currentYearAEYearWise
                        }
                        rows={group.parentTable.rows}
                        cumulativeBEForAllYears={
                          group.parentTable.cumulativeBEForAllYears
                        }
                        cumulativeAEForAllYears={
                          group.parentTable.cumulativeAEForAllYears
                        }
                      />
                    ) : (
                      <Typography
                        variant="body2"
                        sx={{ p: 2, color: "#6c757d", ml: 2 }}
                      >
                        No data available for this scheme.
                      </Typography>
                    )}
                    {group.subSchemeTables.map((subTable, idx) => (
                      <React.Fragment key={subTable.path}>
                        <Typography
                          variant="h6"
                          sx={{
                            p: 2,
                            color: "#45154F",
                            fontWeight: "bold",
                            mt: 2,
                            ml: 2,
                          }}
                        >
                          {`${groupIndex + 1}.${idx + 1}) ${
                            subTable.schemeName
                          }`}
                        </Typography>
                        {subTable.rows.length > 0 ? (
                          <RenderTable
                            title={subTable.schemeName}
                            financialYears={subTable.financialYears}
                            currentYearBEYearWise={
                              subTable.currentYearBEYearWise
                            }
                            currentYearAEYearWise={
                              subTable.currentYearAEYearWise
                            }
                            rows={subTable.rows}
                            cumulativeBEForAllYears={
                              subTable.cumulativeBEForAllYears
                            }
                            cumulativeAEForAllYears={
                              subTable.cumulativeAEForAllYears
                            }
                          />
                        ) : (
                          <Typography
                            variant="body2"
                            sx={{ p: 2, color: "#6c757d", ml: 4 }}
                          >
                            No data available for this sub-scheme.
                          </Typography>
                        )}
                      </React.Fragment>
                    ))}
                  </React.Fragment>
                );
              } else if (measurementArea === "State") {
                return (
                  <React.Fragment key={`${measurementArea}-${group.path}`}>
                    <Typography
                      variant="h6"
                      sx={{ p: 2, color: "#45154F", fontWeight: "bold", mt: 2 }}
                    >
                      {`${groupIndex + 1}.) ${group.stateName}`}
                    </Typography>
                    {group.schemes.map((schemeGroup, schemeIdx) => (
                      <React.Fragment key={schemeGroup.path}>
                        <Typography
                          variant="h6"
                          sx={{
                            p: 2,
                            color: "#45154F",
                            fontWeight: "bold",
                            mt: 2,
                            ml: 2,
                          }}
                        >
                          {`${groupIndex + 1}.${schemeIdx + 1}) ${
                            schemeGroup.schemeName
                          }`}
                        </Typography>
                        {schemeGroup.parentTable &&
                        schemeGroup.parentTable.rows.length > 0 ? (
                          <RenderTable
                            title={schemeGroup.parentTable.schemeName}
                            financialYears={
                              schemeGroup.parentTable.financialYears
                            }
                            currentYearBEYearWise={
                              schemeGroup.parentTable.currentYearBEYearWise
                            }
                            currentYearAEYearWise={
                              schemeGroup.parentTable.currentYearAEYearWise
                            }
                            rows={schemeGroup.parentTable.rows}
                            cumulativeBEForAllYears={
                              schemeGroup.parentTable.cumulativeBEForAllYears
                            }
                            cumulativeAEForAllYears={
                              schemeGroup.parentTable.cumulativeAEForAllYears
                            }
                          />
                        ) : (
                          <Typography
                            variant="body2"
                            sx={{ p: 2, color: "#6c757d", ml: 4 }}
                          >
                            No data available for this scheme.
                          </Typography>
                        )}
                        {schemeGroup.subSchemeTables.map((subTable, subIdx) => (
                          <React.Fragment key={subTable.path}>
                            <Typography
                              variant="h6"
                              sx={{
                                p: 2,
                                color: "#45154F",
                                fontWeight: "bold",
                                mt: 2,
                                ml: 4,
                              }}
                            >
                              {`${groupIndex + 1}.${schemeIdx + 1}.${
                                subIdx + 1
                              }) ${subTable.schemeName}`}
                            </Typography>
                            {subTable.rows.length > 0 ? (
                              <RenderTable
                                title={subTable.schemeName}
                                financialYears={subTable.financialYears}
                                currentYearBEYearWise={
                                  subTable.currentYearBEYearWise
                                }
                                currentYearAEYearWise={
                                  subTable.currentYearAEYearWise
                                }
                                rows={subTable.rows}
                                cumulativeBEForAllYears={
                                  subTable.cumulativeBEForAllYears
                                }
                                cumulativeAEForAllYears={
                                  subTable.cumulativeAEForAllYears
                                }
                              />
                            ) : (
                              <Typography
                                variant="body2"
                                sx={{ p: 2, color: "#6c757d", ml: 6 }}
                              >
                                No data available for this sub-scheme.
                              </Typography>
                            )}
                          </React.Fragment>
                        ))}
                      </React.Fragment>
                    ))}
                  </React.Fragment>
                );
              } else if (measurementArea === "District") {
                return (
                  <React.Fragment key={`${measurementArea}-${group.path}`}>
                    <Typography
                      variant="h6"
                      sx={{ p: 2, color: "#45154F", fontWeight: "bold", mt: 2 }}
                    >
                      {`${groupIndex + 1}.) ${group.stateName}`}
                    </Typography>
                    {group.districts.map((districtGroup, districtIdx) => (
                      <React.Fragment key={districtGroup.path}>
                        <Typography
                          variant="h6"
                          sx={{
                            p: 2,
                            color: "#45154F",
                            fontWeight: "bold",
                            mt: 2,
                            ml: 2,
                          }}
                        >
                          {`${groupIndex + 1}.${districtIdx + 1}.) ${
                            districtGroup.districtName
                          }`}
                        </Typography>
                        {districtGroup.schemes.map((schemeGroup, schemeIdx) => (
                          <React.Fragment key={schemeGroup.path}>
                            <Typography
                              variant="h6"
                              sx={{
                                p: 2,
                                color: "#45154F",
                                fontWeight: "bold",
                                mt: 2,
                                ml: 4,
                              }}
                            >
                              {`${groupIndex + 1}.${districtIdx + 1}.${
                                schemeIdx + 1
                              }.) ${schemeGroup.schemeName}`}
                            </Typography>
                            {schemeGroup.parentTable &&
                            schemeGroup.parentTable.rows.length > 0 ? (
                              <RenderTable
                                title={schemeGroup.parentTable.schemeName}
                                financialYears={
                                  schemeGroup.parentTable.financialYears
                                }
                                currentYearBEYearWise={
                                  schemeGroup.parentTable.currentYearBEYearWise
                                }
                                currentYearAEYearWise={
                                  schemeGroup.parentTable.currentYearAEYearWise
                                }
                                rows={schemeGroup.parentTable.rows}
                                cumulativeBEForAllYears={
                                  schemeGroup.parentTable
                                    .cumulativeBEForAllYears
                                }
                                cumulativeAEForAllYears={
                                  schemeGroup.parentTable
                                    .cumulativeAEForAllYears
                                }
                              />
                            ) : (
                              <Typography
                                variant="body2"
                                sx={{ p: 2, color: "#6c757d", ml: 6 }}
                              >
                                No data available for this scheme.
                              </Typography>
                            )}
                            {schemeGroup.subSchemeTables.map(
                              (subTable, subIdx) => (
                                <React.Fragment key={subTable.path}>
                                  <Typography
                                    variant="h6"
                                    sx={{
                                      p: 2,
                                      color: "#45154F",
                                      fontWeight: "bold",
                                      mt: 2,
                                      ml: 6,
                                    }}
                                  >
                                    {`${groupIndex + 1}.${districtIdx + 1}.${
                                      schemeIdx + 1
                                    }.${subIdx + 1}.) ${subTable.schemeName}`}
                                  </Typography>
                                  {subTable.rows.length > 0 ? (
                                    <RenderTable
                                      title={subTable.schemeName}
                                      financialYears={subTable.financialYears}
                                      currentYearBEYearWise={
                                        subTable.currentYearBEYearWise
                                      }
                                      currentYearAEYearWise={
                                        subTable.currentYearAEYearWise
                                      }
                                      rows={subTable.rows}
                                      cumulativeBEForAllYears={
                                        subTable.cumulativeBEForAllYears
                                      }
                                      cumulativeAEForAllYears={
                                        subTable.cumulativeAEForAllYears
                                      }
                                    />
                                  ) : (
                                    <Typography
                                      variant="body2"
                                      sx={{ p: 2, color: "#6c757d", ml: 8 }}
                                    >
                                      No data available for this sub-scheme.
                                    </Typography>
                                  )}
                                </React.Fragment>
                              )
                            )}
                          </React.Fragment>
                        ))}
                      </React.Fragment>
                    ))}
                  </React.Fragment>
                );
              }
              return null;
            })}
          </React.Fragment>
        )
      )}
    </Box>
  );
}

export default ProgressTable;
