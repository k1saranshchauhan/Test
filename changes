      formik.setFieldValue("ministry", []);
      formik.setFieldValue("department", []);
      formik.setFieldValue("recepients", []);
      formik.setFieldValue("orgTypes", []);
    }
  }, [formik?.values?.specificCondition]);

  const fetchOrgTypes = async () => {
    const res = await apiClient.get("api/master/fetch-all-organization");
