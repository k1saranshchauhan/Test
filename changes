  // ─────────────────────────────────────────────────────────────
  // Helpers (put once, near your handler file)
  // ─────────────────────────────────────────────────────────────

  // NATIONAL (measurementArea === 2) — targets is an object: { "First Quarter": "10", ... }
  function sumNationalTargetsForFrequency(ind) {
    if (!ind || !ind.targets || Array.isArray(ind.targets)) return 0;
    const keys = frequencyKeysMap[ind.frequency] || [];
    if (!keys.length) return 0;
    return keys.reduce((s, k) => s + toInt(ind.targets[k]), 0);
  }

  // STATE (measurementArea === 3) — targets is an array of states: [{ targets: { ... }}, ...]
  function sumStateTargetsForFrequency(ind) {
    if (!ind || !Array.isArray(ind.targets)) return 0;
    const keys = frequencyKeysMap[ind.frequency] || [];
    if (!keys.length) return 0;

    let total = 0;
    for (const state of ind.targets) {
      const t = state?.targets || {};
      for (const k of keys) total += toInt(t[k]);
    }
    return total;
  }

  // DISTRICT (measurementArea === 1) — targets is an array of states, each with connectedDistricts
  function sumDistrictTargetsForFrequency(ind) {
    if (!ind || !Array.isArray(ind.targets)) return 0;
    const keys = frequencyKeysMap[ind.frequency] || [];
    if (!keys.length) return 0;

    let total = 0;
    for (const state of ind.targets) {
      for (const dist of state?.connectedDistricts || []) {
        const t = dist?.targets || {};
        for (const k of keys) total += toInt(t[k]);
      }
    }
    return total;
  }

  const hasNonEmpty = (val) => {
    if (val === null || val === undefined) return false;
    if (typeof val === "number") return Number.isFinite(val);
    if (typeof val === "string") return val.trim() !== "";
    // For safety, stringify other primitives
    return String(val).trim() !== "";
  };

  function buildTargetLimitErrorMessage(
    targetLimitError,
    sectionsByType,
    inputRefs,
  ) {
    const firstKey = Object.keys(targetLimitError)[0];
    if (!firstKey) return "Target totals do not match the required value.";

    // Parse "Output_0_0_Year" -> type="Output", sIdx=0, iIdx=0, labelKey="Year"
    const [type, sIdxStr, iIdxStr, ...rest] = firstKey.split("_");
    const sIdx = Number(sIdxStr);
    const iIdx = Number(iIdxStr);
    const labelKey = rest.join("_");

    const sectionList = sectionsByType[type] || [];
    const section = sectionList[sIdx];

    const sectionName = section?.name ?? `Section ${sIdx + 1}`;
    const indicator = section?.indicators?.[iIdx];

    // Focus the first offending input (type-aware key)
    const refKey = `${type}_${sIdx}_${iIdx}_targets_${labelKey}`;
    const el = inputRefs?.current?.[refKey];
    if (el && typeof el.focus === "function") setTimeout(() => el.focus(), 0);

    const indicatorTitle =
      typeof indicator?.indicator === "string"
        ? indicator.indicator
        : (indicator?.indicator?.label ?? `Indicator ${iIdx + 1}`);

    const preTarget = toInt(indicator?.preTarget);
    const freq = indicator?.frequency;
    const freqKeys = frequencyKeysMap[freq] || [];
    const freqName =
      freq === 2
        ? "Yearly"
        : freq === 3
          ? "Quarterly"
          : freq === 4
            ? "Half-Yearly"
            : "Selected frequency";
    const keysList = freqKeys.length
      ? ` [${freqKeys.join(", ")}]`
      : ` (${labelKey})`;

    // Compute grand total depending on measurementArea
    let total = 0;
    const isNumeric =
      indicator?.measurementType === 2 && ![9, 10].includes(indicator?.unit);
    if (isNumeric) {
      if (
        indicator?.measurementArea === 2 &&
        !Array.isArray(indicator?.targets)
      ) {
        total = sumNationalTargetsForFrequency(indicator);
      } else if (
        indicator?.measurementArea === 3 &&
        Array.isArray(indicator?.targets)
      ) {
        total = sumStateTargetsForFrequency(indicator);
      } else if (
        indicator?.measurementArea === 1 &&
        Array.isArray(indicator?.targets)
      ) {
        total = sumDistrictTargetsForFrequency(indicator);
      }
    } else {
      // Fallback single value (for completeness)
      total = Array.isArray(indicator?.targets)
        ? 0
        : toInt(indicator?.targets?.[labelKey]);
    }

    if (Number.isFinite(preTarget)) {
      return `For "${type}" → "${sectionName}" → "${indicatorTitle}" • ${freqName}${keysList}, the sum of targets is ${total} but must equal ${preTarget}. Please adjust the values.`;
    }
    return `For "${type}" → "${sectionName}" → "${indicatorTitle}" • ${freqName}${keysList}, the sum of targets must equal the required value. Please adjust the values.`;
  }

  function validateStateCoverage(ind) {
    if (ind?.measurementArea !== 3) return { valid: true };
    const allowed = frequencyKeysMap[ind.frequency] || [];
    console.log(allowed, "coverage");
    if (!Array.isArray(ind.targets) || allowed.length === 0)
      return { valid: true };

    const coverage = new Set();
    const allowedSet = new Set(allowed);

    for (const state of ind.targets) {
      const t = state?.targets || {};
      for (const [key, raw] of Object.entries(t)) {
        if (allowedSet.has(key) && hasNonEmpty(raw)) coverage.add(key);
      }
    }

    if (
      (ind.frequency === 3 || ind.frequency === 4) &&
      coverage.size < allowed.length
    ) {
      const missing = allowed.filter((k) => !coverage.has(k));
      const fqName = ind.frequency === 3 ? "Quarterly" : "Half-Yearly";
      return {
        valid: false,
        message: `For ${fqName} frequency, there must be at least one STATE entry for: ${missing.join(", ")}`,
      };
    }
    return { valid: true };
  }

  function validateDistrictCoverage(ind) {
    if (ind?.measurementArea !== 1) return { valid: true };
    const allowed = frequencyKeysMap[ind.frequency] || [];
    if (!Array.isArray(ind.targets) || allowed.length === 0)
      return { valid: true };

    const coverage = new Set();
    const allowedSet = new Set(allowed);

    for (const state of ind.targets) {
      for (const dist of state?.connectedDistricts || []) {
        const t = dist?.targets || {};
        for (const [key, raw] of Object.entries(t)) {
          if (allowedSet.has(key) && hasNonEmpty(raw)) coverage.add(key);
        }
      }
    }

    if (
      (ind.frequency === 3 || ind.frequency === 4) &&
      coverage.size < allowed.length
    ) {
      const missing = allowed.filter((k) => !coverage.has(k));
      const fqName = ind.frequency === 3 ? "Quarterly" : "Half-Yearly";
      return {
        valid: false,
        message: `For ${fqName} frequency, there must be at least one DISTRICT entry for: ${missing.join(", ")}`,
      };
    }
    return { valid: true };
  }

  // State-level validator (quantitative, non-special units) + coverage for Q/H
  function validateStateTargetsSum(ind) {
    if (!ind || ind.measurementArea !== 3) {
      return { valid: true, total: 0, preTarget: toInt(ind?.preTarget) };
    }
    const isNumeric = ind.measurementType === 2 && ![9, 10].includes(ind.unit);
    if (!isNumeric)
      return { valid: true, total: 0, preTarget: toInt(ind?.preTarget) };

    const allowed = frequencyKeysMap[ind.frequency] || [];
    const allowedSet = new Set(allowed);
    const preTarget = toInt(ind.preTarget);
    if (!Number.isFinite(preTarget)) {
      return {
        valid: false,
        total: 0,
        preTarget,
        message: "preTarget must be a number for quantitative state indicators",
      };
    }
    if (!Array.isArray(ind.targets) || allowed.length === 0) {
      return { valid: true, total: 0, preTarget };
    }

    let total = 0;
    const invalidKeys = new Set();
    const coverage = new Set(); // <- track which periods have at least one entry

    for (const state of ind.targets) {
      const t = state?.targets || {};
      for (const [key, raw] of Object.entries(t)) {
        const s = (raw ?? "").toString().trim();
        if (!allowedSet.has(key)) {
          if (s !== "") invalidKeys.add(key);
          continue;
        }
        if (hasNonEmpty(raw)) coverage.add(key);
        total += toInt(s);
      }
    }

    if (invalidKeys.size > 0) {
      return {
        valid: false,
        total,
        preTarget,
        invalidKeys: [...invalidKeys],
        message: `Found keys not allowed for selected frequency: ${[...invalidKeys].join(", ")}`,
      };
    }

    // Enforce per-period coverage for Quarterly / Half-Yearly
    if (
      (ind.frequency === 3 || ind.frequency === 4) &&
      coverage.size < allowed.length
    ) {
      const missing = allowed.filter((k) => !coverage.has(k));
      const fqName = ind.frequency === 3 ? "Quarterly" : "Half-Yearly";
      return {
        valid: false,
        total,
        preTarget,
        message: `For ${fqName} frequency, there must be at least one STATE entry for: ${missing.join(", ")}`,
      };
    }

    if (total !== preTarget) {
      return {
        valid: false,
        total,
        preTarget,
        message: `Sum of all state targets (${total}) must equal preTarget (${preTarget}).`,
      };
    }
    return { valid: true, total, preTarget };
  }

  // District-level validator (quantitative, non-special units) + coverage for Q/H
  function validateDistrictTargetsSum(ind) {
    if (!ind || ind.measurementArea !== 1) {
      return { valid: true, total: 0, preTarget: toInt(ind?.preTarget) };
    }
    const isNumeric = ind.measurementType === 2 && ![9, 10].includes(ind.unit);
    if (!isNumeric)
      return { valid: true, total: 0, preTarget: toInt(ind?.preTarget) };

    const allowed = frequencyKeysMap[ind.frequency] || [];
    const allowedSet = new Set(allowed);
    const preTarget = toInt(ind.preTarget);
    if (!Number.isFinite(preTarget)) {
      return {
        valid: false,
        total: 0,
        preTarget,
        message:
          "preTarget must be a number for quantitative district indicators",
      };
    }
    if (!Array.isArray(ind.targets) || allowed.length === 0) {
      return { valid: true, total: 0, preTarget };
    }

    let total = 0;
    const invalidKeys = new Set();
    const coverage = new Set(); // <- track which periods have at least one entry

    for (const state of ind.targets) {
      for (const dist of state?.connectedDistricts || []) {
        const t = dist?.targets || {};
        for (const [key, raw] of Object.entries(t)) {
          const s = (raw ?? "").toString().trim();
          if (!allowedSet.has(key)) {
            if (s !== "") invalidKeys.add(key);
            continue;
          }
          if (hasNonEmpty(raw)) coverage.add(key);
          total += toInt(s);
        }
      }
    }

    if (invalidKeys.size > 0) {
      return {
        valid: false,
        total,
        preTarget,
        invalidKeys: [...invalidKeys],
        message: `Found keys not allowed for selected frequency: ${[...invalidKeys].join(", ")}`,
      };
    }

    // Enforce per-period coverage for Quarterly / Half-Yearly
    if (
      (ind.frequency === 3 || ind.frequency === 4) &&
      coverage.size < allowed.length
    ) {
      const missing = allowed.filter((k) => !coverage.has(k));
      const fqName = ind.frequency === 3 ? "Quarterly" : "Half-Yearly";
      return {
        valid: false,
        total,
        preTarget,
        message: `For ${fqName} frequency, there must be at least one DISTRICT entry for: ${missing.join(", ")}`,
      };
    }

    if (total !== preTarget) {
      return {
        valid: false,
        total,
        preTarget,
        message: `Sum of all district targets (${total}) must equal preTarget (${preTarget}).`,
      };
    }
    return { valid: true, total, preTarget };
  }
  function sumTargetsForFrequency(ind) {
    if (!ind || !ind.targets) return 0;
    const keys = frequencyKeysMap[ind.frequency] || [];
    if (!keys.length) return 0;
    if (Array.isArray(ind.targets)) {
      // If you ever need State/District sums here, aggregate nested lists.
      // For now, we assume the sum-equality rule applies to National only.
      return 0;
    }
    return keys.reduce((s, k) => s + toInt(ind.targets[k]), 0);
  }
  // Submit handler with mapping to only id/name objects
  const handleSubmit = async () => {
    if (!userData) return;

    // BEFORE checking outputs / outcomes
    if (targetLimitError && Object.keys(targetLimitError).length > 0) {
      const msg = buildTargetLimitErrorMessage(
        targetLimitError,
        sectionsByType,
        inputRefs,
      );
      dispatch(setError(msg));
      return;
    }

    const outputs = sectionsByType["Output"] || [];
    const outcomes = sectionsByType["Outcome"] || [];

    // --- Must have at least one Output & Outcome with indicators ---
    if (!outputs.length || !outputs.some((s) => s.indicators?.length > 0)) {
      dispatch(
        setError("At least one Output section with one indicator is required."),
      );
      return;
    }

    if (!outcomes.length || !outcomes.some((s) => s.indicators?.length > 0)) {
      dispatch(
        setError(
          "At least one Outcome section with one indicator is required.",
        ),
      );
      return;
    }

    // --- Validate targets ---
    // const validateTargets = (ind) => {
    //   if (type !== "addFrequency")
    //     return {
    //       valid: true,
    //       message: "Completed",
    //     };

    //   if (
    //     !ind.targets ||
    //     (Array.isArray(ind.targets) && ind.targets.length === 0)
    //   ) {
    //     const msg =
    //       ind.measurementArea === 2
    //         ? "National targets missing"
    //         : ind.measurementArea === 3
    //           ? "State targets missing"
    //           : "District targets missing";
    //     return { valid: false, message: msg };
    //   }

    //   const frequencyKeysMap = {
    //     2: ["Year"], // Yearly
    //     3: [
    //       "First Quarter",
    //       "Second Quarter",
    //       "Third Quarter",
    //       "Fourth Quarter",
    //     ], // Quarterly
    //     4: ["First Half", "Second Half"], // Half-Yearly
    //   };

    //   const requiredKeys = frequencyKeysMap[ind.frequency] || [];

    //   const checkValue = (val) => {
    //     if (val === undefined || val === null) return false;
    //     if (typeof val === "string") val = val.trim();
    //     if (val === "") return false;

    //     if (ind.unit === 10) return /^\d+:\d+$/.test(val); // ratio
    //     if (ind.unit === 9) return /^\d+-\d+$/.test(val); // range
    //     if (![8, 9, 10].includes(ind.unit)) return !isNaN(Number(val)); // numeric
    //     return true; // descriptive/other
    //   };

    //   const missingKeys = [];

    //   switch (ind.measurementArea) {
    //     case 2: // National
    //       requiredKeys.forEach((key) => {
    //         if (!checkValue(ind.targets[key])) missingKeys.push(key);
    //       });
    //       break;

    //     case 3: // State
    //       requiredKeys.forEach((key) => {
    //         const filled = ind.targets.some(
    //           (state) => state.targets && checkValue(state.targets[key]),
    //         );
    //         if (!filled) missingKeys.push(key);
    //       });
    //       break;

    //     case 1: // District
    //       requiredKeys.forEach((key) => {
    //         const filled = ind.targets.some(
    //           (state) =>
    //             Array.isArray(state.connectedDistricts) &&
    //             state.connectedDistricts.some((dist) =>
    //               checkValue(dist.targets[key]),
    //             ),
    //         );
    //         if (!filled) missingKeys.push(key);
    //       });
    //       break;

    //     default:
    //       break;
    //   }

    //   if (missingKeys.length) {
    //     return {
    //       valid: false,
    //       message: `Missing/invalid targets for: ${missingKeys.join("; ")}`,
    //     };
    //   }

    //   return { valid: true };
    // };

    // --- Validate targets ---
    const validateTargets = (ind) => {
      // If we're not in addFrequency flow, skip strict target validation
      if (type !== "addFrequency") {
        return { valid: true, message: "Completed" };
      }

      // --- Basic presence check (same as your earlier logic) ---
      const hasTargets =
        ind.targets &&
        (Array.isArray(ind.targets)
          ? ind.targets.length > 0
          : Object.keys(ind.targets).length > 0);

      if (!hasTargets) {
        const msg =
          ind.measurementArea === 2
            ? "National targets missing"
            : ind.measurementArea === 3
              ? "State targets missing"
              : "District targets missing";
        return { valid: false, message: msg };
      }

      // Quantitative and non-special units (skip sum-equality for ratio=10 / range=9 / descriptive=8)
      const isNumericNonSpecial =
        ind.measurementType === 2 && ![9, 10].includes(ind.unit);

      // --- National (measurementArea === 2) ---
      if (isNumericNonSpecial && ind.measurementArea === 2) {
        const requiredKeys = frequencyKeysMap[ind.frequency] || [];
        if (requiredKeys.length) {
          const preTarget = toInt(ind.preTarget);
          const total = sumTargetsForFrequency(ind); // sums only the relevant freq keys for National

          if (!Number.isFinite(preTarget) || preTarget < 0) {
            return {
              valid: false,
              message:
                "Target (preTarget) must be a non-negative number for quantitative National indicators",
            };
          }

          if (total !== preTarget) {
            const fqName =
              ind.frequency === 2
                ? "Yearly"
                : ind.frequency === 3
                  ? "Quarterly"
                  : ind.frequency === 4
                    ? "Half-Yearly"
                    : "Selected frequency";
            return {
              valid: false,
              message: `${fqName} totals (${requiredKeys.join(
                ", ",
              )}) must sum to ${preTarget}, but current sum is ${total}`,
            };
          }
        }

        // if no required keys (unknown frequency), treat as valid
        return { valid: true };
      }

      // --- State (measurementArea === 3) ---
      if (isNumericNonSpecial && ind.measurementArea === 3) {
        const result = validateStateTargetsSum(ind); // uses allowed keys per frequency + coverage
        if (!result.valid) {
          return {
            valid: false,
            message: result.message || "State targets sum mismatch",
          };
        }
        return { valid: true };
      }

      // For NON-numeric state indicators, still enforce coverage for Q/H
      if (!isNumericNonSpecial && ind.measurementArea === 3) {
        const result = validateStateCoverage(ind);
        if (!result.valid) return { valid: false, message: result.message };
        return { valid: true };
      }

      // --- District (measurementArea === 1) ---
      if (isNumericNonSpecial && ind.measurementArea === 1) {
        const result = validateDistrictTargetsSum(ind); // uses allowed keys per frequency + coverage
        if (!result.valid) {
          return {
            valid: false,
            message: result.message || "District targets sum mismatch",
          };
        }
        return { valid: true };
      }

      // For NON-numeric district indicators, still enforce coverage for Q/H
      if (!isNumericNonSpecial && ind.measurementArea === 1) {
        const result = validateDistrictCoverage(ind);
        if (!result.valid) return { valid: false, message: result.message };
        return { valid: true };
      }

      // For qualitative/descriptive/range/ratio, sum-equality is not enforced here
      return { valid: true };
    };
    // --- Validate individual indicator ---
    const isIndicatorComplete = (ind) => {
      const requiredFields = [
        "indicator",
        "measurementType",
        "unit",
        "measurementArea",
        "indicatorRise",
        "period",
      ];

      for (const field of requiredFields) {
        if (
          ind[field] === undefined ||
          ind[field] === null ||
          ind[field] === ""
        ) {
          return { valid: false, message: `Missing field ${field}` };
        }
      }

      if (!ind.frequency && type === "addFrequency")
        return {
          valid: false,
          message: "Frequency is required for all indicators",
        };

      if (ind.measurementType === 1 && !ind.targetAmenable) {
        return {
          valid: false,
          message: "Target amenable required for qualitative indicator",
        };
      }

      if (ind.measurementType === 2) {
        if (ind.unit === 8 && !ind.targetAmenable) {
          return {
            valid: false,
            message: "Target amenable required for descriptive unit",
          };
        } else if (ind.unit !== 8 && !ind.preTarget) {
          return {
            valid: false,
            // message: "Pre-target required for quantitative unit",
            message: "Target required for quantitative unit",
          };
        }
        if (!ind.scale)
          return {
            valid: false,
            message: "Scale required for quantitative indicator",
          };
      }

      return validateTargets(ind);
    };

    // --- Validate section ---
    const isSectionValid = (section, sectionTypeName) => {
      if (!section.name || section.name.trim() === "") {
        return {
          valid: false,
          message: `${sectionTypeName} Section name is required`,
        };
      }

      if (!section.indicators || section.indicators.length === 0) {
        return {
          valid: false,
          message: `Section "${section.name}" must have at least one indicator`,
        };
      }

      for (const ind of section.indicators) {
        const result = isIndicatorComplete(ind);
        if (!result.valid) {
          return {
            valid: false,
            message: `Indicator in section "${section.name}" error: ${result.message}`,
          };
        }
      }

      return { valid: true };
    };

    // Validate outputs
    for (const section of outputs) {
      const check = isSectionValid(section, "Output");
      if (!check.valid) {
        dispatch(setError(check.message));
        return; // STOP submission
      }
    }

    // Validate outcomes
    for (const section of outcomes) {
      const check = isSectionValid(section, "Outcome");
      if (!check.valid) {
        dispatch(setError(check.message));
        return; // STOP submission
      }
    }

    // --- Create payload & call API ---
    dispatch(startLoader());
    try {
      const ministry = dummyMinistries.find(
        (m) => m.id === selectedMinistry?.id,
      );

      const department = dummyDepartments.find(
        (d) => d.id === selectedDepartment?.id,
      );
      const schemeType = dummySchemeTypes.find(
        (st) => st.id === selectedSchemeType?.id,
      );
      const scheme = dummySchemes.find((s) => s.id === selectedScheme?.id);

      const subScheme = dummySubSchemes.find(
        (s) => s.id === selectedSubScheme?.id,
      );

      const payload = {
        financialYear,
        ministryId: ministry && { id: ministry.id, name: ministry.name },
        departmentId: department && {
          id: department.id,
          name: department.name,
        },
        schemeTypeId: schemeType && {
          id: schemeType.id,
          name: schemeType.name,
        },
        schemeId: scheme && { id: scheme.id, name: scheme.name },
        subSchemeId: subScheme && { id: subScheme.id, name: subScheme.name },
        financialOutlay,
        indicatorData: Object.entries(sectionsByType).map(([type, secs]) => ({
          indicatorType: dummyIndicatorTypes.find((it) => it.name === type) && {
            id: dummyIndicatorTypes.find((it) => it.name === type).id,
            name: dummyIndicatorTypes.find((it) => it.name === type).name,
            footNote: footnoteIndicatorType[type?.toLowerCase()],
          },
          sections: secs.map((section) => ({
            ...section,
            indicators: section.indicators.map((ind) => {
              const measurementAreaObj =
                ind.measurementArea &&
                (() => {
                  const u = dummyMeasurementArea.find(
                    (x) => x.id === ind.measurementArea,
                  );
                  return u && { id: u.id, name: u.name };
                })();

              const hasTargets =
                ind.targets &&
                (Array.isArray(ind.targets)
                  ? ind.targets.length > 0
                  : Object.keys(ind.targets).length > 0);

              // Conditional targets logic
              const targetsValue = hasTargets
                ? ind.targets
                : ind.measurementArea === 1 || ind.measurementArea === 3
                  ? []
                  : ind.measurementArea === 2
                    ? {}
                    : [];

              return {
                name: ind.name,
                footNoteIndicatorName: ind?.footNoteIndicatorName,
                footNoteIndicatorTarget: ind?.footNoteIndicatorTarget,
                active: ind.active,
                targets: targetsValue,
                preTarget: ind.preTarget,
                prePreTarget: ind?.prePreTarget,
                targetAmenable: ind.targetAmenable,
                measurementType:
                  ind.measurementType &&
                  (() => {
                    const mt = dummyMeasurementTypes.find(
                      (m) => m.id === ind.measurementType,
                    );
                    return mt && { id: mt.id, name: mt.name };
                  })(),
                unit:
                  ind.unit &&
                  (() => {
                    const u = dummyUnits.find((x) => x.id === ind.unit);
                    return u && { id: u.id, name: u.name };
                  })(),
                scale:
                  ind.scale &&
                  (() => {
                    const u = dummyScales.find((x) => x.id === ind.scale);
                    return u && { id: u.id, name: u.name };
                  })(),
                measurementArea: measurementAreaObj,
                indicatorRise:
                  ind.indicatorRise &&
                  (() => {
                    const u = dummyIndicatorRise.find(
                      (x) => x.id === ind.indicatorRise,
                    );
                    return u && { id: u.id, name: u.name };
                  })(),
                sdg:
                  ind.sdg &&
                  (() => {
                    const u = dummySdg.find((x) => x.id === ind.sdg);
                    return u && { id: u.id, name: u.name };
                  })(),
                period:
                  ind.period &&
                  (() => {
                    const u = dummyPeriod.find((x) => x.id === ind.period);
                    return u && { id: u.id, name: u.name };
                  })(),
                applicableCategory:
                  ind.applicableCategory &&
                  (() => {
                    const u = dummyCategoty.find(
                      (x) => x.id === ind.applicableCategory,
                    );
                    return u && { id: u.id, name: u.name };
                  })(),
                frequency:
                  ind.frequency &&
                  (() => {
                    const f = dummyFrequencies.find(
                      (x) => x.id === ind.frequency,
                    );
                    return f && { id: f.id, name: f.name };
                  })(),
                indicator: (() => {
                  if (typeof ind.indicator === "number") {
                    const f = originalDummyIndicator.find(
                      (x) => x.id === ind.indicator,
                    );

                    return f && { id: f.id, name: f.name };
                  } else if (typeof ind.indicator === "string") {
                    return { id: null, name: ind.indicator.trim() };
                  }
                  return null;
                })(),
              };
            }),
          })),
        })),
      };

      const validate = validateIndicatorSections(payload);
      if (!validate.valid) {
        dispatch(setError(validate.messages[0]));
        return;
      }

      const reqData = {
        user_id: userData.id,
        scheme: true,
        data: payload,
        submission_id: moto === "draft" ? null : id,
        isSubScheme: isSubScheme,

        draftId: draftId,
        schemeId: selectedScheme?.id,
        subSchemeId: selectedSubScheme?.id,
      };

      const response = await apiClient.post(
        "api/oomf/submissions/submit-scheme",
        reqData,
      );
      const { message } = response.data;
      // if (type !== "addFrequency") {
      router.push("/niti/oomf/oomfDashboard/oomfDashboard");
      // }
      dispatch(setSuccess(message));
    } catch (error) {
      dispatch(setError(error.message));
    } finally {
      dispatch(stopLoader());
    }
  };

  const [hoveredCancelIdx, setHoveredCancelIdx] = useState(null);
  const [hoveredSectionIdx, setHoveredSectionIdx] = useState(null);

  const initialTargetsMap = useMemo(() => {
    const map = {};
    sectionsByType[currentType].forEach((sec, sIdx) => {
      sec?.indicators?.forEach((ind, iIdx) => {
        map[`${sIdx}_${iIdx}`] = buildTargetsByMeasurementArea(ind);
      });
    });
    return map;
  }, [sectionsByType[currentType]]);

  const onOpenFrequencyModal = ({ sectionIndex, indicatorIndex, label }) => {
    setFootnoteContext({
      sectionIndex,
      indicatorIndex,
    });
    setCurrentField(label);
    setOpenRemarkModal(true);
  };

  const onAddSection = () => {
    handleAddSection();
    dispatch(setSuccess(`${currentType} section added successfully`));
  };

  const draftShowCondition =
    subRoleIds?.includes(1) &&
    [10, 11, 1, 9].includes(userData?.orgType_id) &&
    ((moto === "draft" && !!draftId) || // draft requires draftId
      (moto !== "draft" && !id));

  return (
    <Box>
      <SubmissionDialog
        open={alertDialogOpen}
        onClose={() => setAlertDialogOpen(false)}
        onUpdate={() => {
          setAlertDialogOpen(false);
          if (previousSubmissionId)
            router.push({
              pathname: router.pathname,
              query: { ...router.query, id: previousSubmissionId },
            });
        }}
      />

      {isSubScheme ? (
        <OomfFormSubSchemeHeader
          id={id}
          moto={moto}
          financialYear={financialYear}
          setFinancialYear={setFinancialYear}
          selectedMinistry={selectedMinistry}
          setSelectedMinistry={setSelectedMinistry}
          selectedDepartment={selectedDepartment}
          setSelectedDepartment={setSelectedDepartment}
          dummyMinistries={dummyMinistries}
          dummyDepartments={dummyDepartments}
          selectedSchemeType={selectedSchemeType}
          setSelectedSchemeType={setSelectedSchemeType}
          dummySchemeTypes={dummySchemeTypes}
          selectedScheme={selectedScheme}
          setSelectedScheme={setSelectedScheme}
          dummySchemes={dummySchemes}
          selectedSubScheme={selectedSubScheme}
          setSelectedSubScheme={setSelectedSubScheme}
          setDummySubSchemes={setDummySubSchemes}
          financialOutlay={financialOutlay}
          setFinancialOutlay={setFinancialOutlay}
          changeSubSchemeHandler={(e) => {
            if (e === true) {
              router.push("/niti/create-sub-scheme-op-oc");
            } else {
              router.push("/niti/create-output-outcomes");
            }
          }}
          setFiltersCompleted={setFiltersCompleted}
          initialDraft={initialDraft}
          handleSubmissionCheck={handleSubmissionCheck}
          hasChecked={hasChecked}
          setHasChecked={setHasChecked}
        />
      ) : (
        <OomfFormHeader
          financialYear={financialYear}
          selectedMinistry={selectedMinistry}
          setSelectedMinistry={setSelectedMinistry}
          dummyMinistries={dummyMinistries}
          selectedDepartment={selectedDepartment}
          setSelectedDepartment={setSelectedDepartment}
          dummyDepartments={dummyDepartments}
          selectedSchemeType={selectedSchemeType}
          setSelectedSchemeType={setSelectedSchemeType}
          dummySchemeTypes={dummySchemeTypes}
          selectedScheme={selectedScheme}
          setSelectedScheme={setSelectedScheme}
          dummySchemes={dummySchemes}
          financialOutlay={financialOutlay}
          setFinancialOutlay={setFinancialOutlay}
          changeSubSchemeHandler={(e) => {
            if (e === true) {
              router.push("/niti/create-sub-scheme-op-oc");
            } else {
              router.push("/niti/create-output-outcomes");
            }
          }}
          setFiltersCompleted={setFiltersCompleted}
          initialDraft={initialDraft}
          handleSubmissionCheck={handleSubmissionCheck}
          hasChecked={hasChecked}
          setHasChecked={setHasChecked}
        />
      )}

      {filtersComplete && (
        <>
          <Box m={3}>
            <IndicatorTypeSelector
              indicatorData={dummyIndicatorTypes}
              currentType={currentType}
              setCurrentType={setCurrentType}
            />
          </Box>

          {/* {!isReadOnly ? (
            <Box mt={4} alignItems="center">
              <Divider textAlign="left">
                Add {currentType} & Indicator Details{" "}
                <IconButton onClick={handleAddSection} sx={{ ml: 1 }}>
                  <Add color="primary" />
                </IconButton>
              </Divider>
            </Box>
          ) : null} */}
          {!isReadOnly && (
            <Box mt={5} display="flex" justifyContent="flex-end">
              <Box
                sx={{
                  display: "flex",
                  alignItems: "center",
                  gap: 2,
                  px: 3.5,
                  py: 1.5,
                  borderRadius: 50,
                  bgcolor: "rgba(69,21,79,0.06)",
                  backdropFilter: "blur(6px)",
                  border: "1px solid rgba(69,21,79,0.2)",
                  boxShadow: "0 4px 15px rgba(0,0,0,0.08)",
                  transition: "0.25s ease",
                  "&:hover": {
                    boxShadow: "0 6px 22px rgba(0,0,0,0.14)",
                    borderColor: "rgba(69,21,79,0.4)",
                  },
                }}
              >
                <Typography
                  sx={{
                    fontSize: 15,
                    fontWeight: 600,
                    letterSpacing: 0.3,
                    color: "#45154F",
                    textTransform: "capitalize",
                    userSelect: "none",
                  }}
                >
                  Add {currentType} & Indicator Details
                </Typography>

                <Tooltip title="Add new section">
                  <IconButton
                    onClick={onAddSection}
                    sx={{
                      bgcolor: "#45154F",
                      color: "#fff",
                      width: 36,
                      height: 36,
                      borderRadius: "50%",
                      boxShadow: "0 3px 10px rgba(69,21,79,0.3)",
                      transition: "0.25s ease",
                      "&:hover": {
                        bgcolor: "#5C1C69",
                        transform: "translateY(-2px)",
                        boxShadow: "0 6px 16px rgba(69,21,79,0.35)",
                      },
                    }}
                  >
                    <Add fontSize="small" />
                  </IconButton>
                </Tooltip>
              </Box>
            </Box>
          )}

          {sectionsByType[currentType].map((sec, sIdx) => (
            <SectionCard
              key={sIdx}
              moto={moto}
              section={sec}
              sectionIndex={sIdx}
              currentType={currentType}
              isReadOnly={isReadOnly}
              type={type}
              isPostBudget={isPostBudget}
              outputResponse={outputResponse}
              outcomeResponse={outcomeResponse}
              sectionsByType={sectionsByType}
              prefillData={prefillData}
              dummyIndicator={dummyIndicator}
              dummyMeasurementTypes={dummyMeasurementTypes}
              dummyUnits={dummyUnits}
              dummyScales={dummyScales}
              dummyMeasurementArea={dummyMeasurementArea}
              dummyIndicatorRise={dummyIndicatorRise}
              dummyPeriod={dummyPeriod}
              dummyCategoty={dummyCategoty}
              dummySdg={dummySdg}
              dummyFrequencies={dummyFrequencies}
              fieldErrors={fieldErrors}
              inputRefs={inputRefs}
              handleSectionChange={handleSectionChange}
              handleIndicatorChange={handleIndicatorChange}
              handleChange={handleChange}
              handleDialogOpen={handleDialogOpen}
              handleAddIndicator={handleAddIndicator}
              handleRemoveIndicator={handleRemoveIndicator}
              handleMoveUp={handleMoveUp}
              handleMoveDown={handleMoveDown}
              handleMoveSectionUp={handleMoveSectionUp}
              handleMoveSectionDown={handleMoveSectionDown}
              handleRemoveSection={handleRemoveSection}
              hoveredSectionIdx={hoveredSectionIdx}
              hoveredCancelIdx={hoveredCancelIdx}
              setHoveredSectionIdx={setHoveredSectionIdx}
              setHoveredCancelIdx={setHoveredCancelIdx}
              initialTargetsMap={initialTargetsMap}
              buildTargetsByMeasurementArea={buildTargetsByMeasurementArea}
              computeTotals={computeTotals}
              dummyDistrict={dummyDistrict}
              dummyStates={dummyStates}
              onOpenFrequencyModal={onOpenFrequencyModal}
            />
          ))}

          <FootnoteDialog
            open={dialogOpen}
            onClose={handleDialogClose}
            onSave={handleFootnoteSave}
            value={footnoteValue}
            onChange={(e) => setFootnoteValue(e.target.value)}
            isReadOnly={isReadOnly}
          />

          <Dialog
            open={openRemarkModal}
            onClose={(event, reason) => {
              if (
                reason &&
                (reason === "backdropClick" || reason === "escapeKeyDown")
              ) {
                return;
              }
              setOpenRemarkModal(false);
            }}
            maxWidth="md"
            fullWidth
          >
            <DialogTitle sx={{ color: "#fff", backgroundColor: "#45154f" }}>
              Add Frequency
            </DialogTitle>
            <DialogContent>
              {footnoteContext.sectionIndex !== undefined &&
                footnoteContext.indicatorIndex !== undefined && (
                  <AddRemarkFrequency
                    measurementType={
                      sectionsByType[currentType][footnoteContext.sectionIndex]
                        ?.indicators[footnoteContext.indicatorIndex]
                        ?.measurementType
                    }
                    measurementAreaType={
                      sectionsByType[currentType][footnoteContext.sectionIndex]
                        ?.indicators[footnoteContext.indicatorIndex]
                        ?.measurementArea === 3
                        ? "state"
                        : sectionsByType[currentType][
                              footnoteContext.sectionIndex
                            ]?.indicators[footnoteContext.indicatorIndex]
                              ?.measurementArea === 1
                          ? "district"
                          : sectionsByType[currentType][
                                footnoteContext.sectionIndex
                              ]?.indicators[footnoteContext.indicatorIndex]
                                ?.measurementArea === 2
                            ? "national"
                            : ""
                    }
                    label={currentField}
                    unitType={
                      sectionsByType[currentType][footnoteContext.sectionIndex]
                        ?.indicators[footnoteContext.indicatorIndex]?.unit
                    }
                    targetTypeField="targets"
                    initialData={
                      sectionsByType[currentType][footnoteContext.sectionIndex]
                        ?.indicators[footnoteContext.indicatorIndex]?.targets ||
                      []
                    }
                    onRecordsChange={(recordsFromAddRemark) => {
                      setSectionsByType((prev) => {
                        const updated = { ...prev };
                        updated[currentType][
                          footnoteContext.sectionIndex
                        ].indicators[footnoteContext.indicatorIndex].targets =
                          JSON.parse(JSON.stringify(recordsFromAddRemark));
                        return updated;
                      });
                    }}
                    preTarget={
                      sectionsByType[currentType][footnoteContext.sectionIndex]
                        ?.indicators[footnoteContext.indicatorIndex]?.preTarget
                    }
                    frequency={
                      sectionsByType[currentType][footnoteContext.sectionIndex]
                        ?.indicators[footnoteContext.indicatorIndex]?.frequency
                    }
                    // strictOnSave={true}
                    statesList={dummyStates}
                    districtsList={dummyDistrict}
                  />
                )}
            </DialogContent>
            <DialogActions>
              <Button
                onClick={() => setOpenRemarkModal(false)}
                variant="contained"
                color="primary"
              >
                Close
              </Button>
            </DialogActions>
          </Dialog>

          {!isReadOnly || (isReadOnly && type === "addFrequency") ? (
            <Box
              mt={4}
              sx={{
                textAlign: "center",
                display: "flex",
                justifyContent: "center",
                gap: 2,
              }}
            >
              <Button
                variant="contained"
                size="large"
                sx={{
                  backgroundColor: "gray",
                  color: "#fff",
                  display: draftShowCondition ? "" : "none",
                }}
                onClick={handleSaveDraft}
                startIcon={<BookmarkAddedIcon />}
              >
                {"Save as Draft"}
              </Button>
              <Button
                variant="contained"
                size="large"
                sx={{
                  backgroundColor: id
                    ? moto === "draft"
                      ? "#388E3C"
                      : "#F57C00"
                    : "#388E3C",
                  color: "#fff",
                }}
                onClick={handleSubmit}
                startIcon={id ? <PublishedWithChangesIcon /> : <BeenhereIcon />}
              >
                {id
                  ? moto === "draft"
                    ? "Submit Details"
                    : "Update Details"
                  : "Submit Details"}
              </Button>
              {/* {type === "addFrequency" && (
                <Button
                  variant="contained"
                  color="success"
                  onClick={() => setOpenForwardDialog(true)}
                  endIcon={<ArrowForwardIosIcon />}
                >
                  Click to Forward
                </Button>
              )} */}
            </Box>
          ) : null}
        </>
      )}
      <ForwardDialog
        open={openForwardDialog}
        onClose={() => setOpenForwardDialog(false)}
        mode={mode}
        submissionId={id}
        type={type}
      />
    </Box>
  );
}
