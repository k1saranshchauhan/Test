const generateLegacyProgressReportPDF = async (reportData, res) => {
  // A4 Landscape is better for wide tables
  const doc = new PDFDocument({ margin: 30, layout: "landscape", size: "A4" });

  // Stream directly to the response
  doc.pipe(res);

  const years = Object.keys(reportData).sort();

  for (const year of years) {
    doc.fontSize(18).fillColor("#45154F").text(`Progress Report: FY ${year}-${parseInt(year) + 1}`, { align: 'center' });
    doc.moveDown();

    for (const schemeEntry of reportData[year]) {
      // Scheme Headers
      doc.fontSize(12).fillColor("#1a237e").text(`Ministry: ${schemeEntry.ministryId.name}`);
      doc.text(`Department: ${schemeEntry.departmentId.name}`);
      doc.fontSize(14).fillColor("#45154F").text(`Scheme: ${schemeEntry.schemeId.name}`, { underline: true });
      doc.moveDown(0.5);

      const tableRows = [];

      // Logic to flatten nested indicator data
      schemeEntry.indicatorData.forEach((typeGroup) => {
        typeGroup.sections.forEach((section) => {
          section.indicators.forEach((ind) => {
            
            // Helper to format Target/Progress/Achieved cells (handles Q1, HY1, etc.)
            const formatCell = (val) => {
              if (typeof val === "object" && val !== null) {
                return Object.entries(val)
                  .map(([key, value]) => `${key}: ${value}`)
                  .join("\n");
              }
              return String(val ?? "-");
            };

            tableRows.push([
              typeGroup.indicatorType.name,
              section.name,
              ind.indicator.name,
              ind.unit.name,
              formatCell(ind.target),
              formatCell(ind.progress),
              formatCell(ind.achieved) + (typeof ind.achieved === 'number' ? '%' : '')
            ]);
          });
        });
      });

      const table = {
        headers: [
          { label: "Type", property: "type", width: 60 },
          { label: "Statement", property: "statement", width: 120 },
          { label: "Indicator", property: "indicator", width: 120 },
          { label: "Unit", property: "unit", width: 50 },
          { label: "Target", property: "target", width: 80 },
          { label: "Progress", property: "progress", width: 80 },
          { label: "Achieved", property: "achieved", width: 80 },
        ],
        rows: tableRows,
      };

      await doc.table(table, {
        prepareHeader: () => doc.font("Helvetica-Bold").fontSize(9),
        prepareRow: (row, indexColumn, indexRow, rectRow, rectCell) => {
          doc.font("Helvetica").fontSize(8);
          // Optional: Add borders/colors here
        },
      });

      doc.addPage(); // New scheme, new page
    }
  }

  doc.end();
};
