import * as React from "react";
import { DataGrid, GridToolbar, GridRowIdGetter } from "@mui/x-data-grid";
import {
  Typography,
  Box,
  Link,
  Card,
  CardContent,
  Button,
  Tooltip,
  IconButton,
  Grid,
  TextField,
  InputAdornment,
} from "@mui/material";
import {
  GridToolbarContainer,
  GridToolbarColumnsButton,
  GridToolbarFilterButton,
  GridToolbarExport,
  GridToolbarDensitySelector,
} from "@mui/x-data-grid";
import SwapHorizIcon from "@mui/icons-material/SwapHoriz";
import FileDownloadIcon from "@mui/icons-material/FileDownload";
import { useState } from "react";
import { SearchIcon } from "lucide-react";
import ExportCsvButton from "./superadmin/ExportCSV";
import { useMemo } from "react";
import { useEffect } from "react";
import dayjs from "dayjs";
import { genericSortComparator } from "@/utils/customSortingFunc";
export default function DataTable({
  columns,
  data,
  isCheckbox,
  isHideDensity,
  isHideExport = false,
  isHideFilter,
  isHideColumn,
  isHidePaging,
  isHideReordercolumn = false,
  name,
  columnVisibilityModel, // added
  onColumnVisibilityModelChange,
  handleOpenReorder,
  fileName = "Data_Table",
  maxHeight = 600,
  marginTop = 3,
}) {
  const flag = isCheckbox;
  const [filteredData, setFilteredData] = useState([]);
  const flagDen = isHideDensity;
  const flagExp = isHideExport;
  const flagFilter = isHideFilter;
  const flagColumn = isHideColumn;
  const [searchText, setSearchText] = useState("");

  useEffect(() => {
    if (data.length > 0) setFilteredData(data);
  }, [data]);

  const formatDisplayDate = (dateString) => {
    const d = dayjs(dateString);
    return d.isValid() ? d.format("DD-MMM-YYYY hh:mm A").toLowerCase() : "";
  };

  useEffect(() => {
    const trimmedSearch = (searchText || "").trim().toLowerCase();

    if (!trimmedSearch) {
      setFilteredData(data);
      return;
    }

    const ignoredKeys = ["id", "uuid", "raw"];

    const searchObject = (obj) => {
      if (!obj || typeof obj !== "object") return false;

      // 🧩 Shallow search
      const shallowMatch = Object.entries(obj).some(([key, val]) => {
        if (ignoredKeys.includes(key.toLowerCase()) || val == null)
          return false;

        // ✅ Handle boolean is_active
        if (key === "is_active" && typeof val === "boolean") {
          const statusText = val ? "active" : "inactive";
          return statusText.startsWith(trimmedSearch);
        }

        // ✅ Handle ISO date strings like 2025-11-01T07:37:06.863Z
        if (typeof val === "string" && /^\d{4}-\d{2}-\d{2}T/.test(val)) {
          const formattedDate = formatDisplayDate(val);
          const dateOnly = dayjs(val).format("DD-MMM-YYYY").toLowerCase();
          return (
            formattedDate.includes(trimmedSearch) ||
            dateOnly.includes(trimmedSearch)
          );
        }

        // ✅ Regular string or number
        if (typeof val === "string" || typeof val === "number") {
          return val.toString().toLowerCase().includes(trimmedSearch);
        }

        return false;
      });

      if (shallowMatch) return true;

      // 🔍 Deep recursive search
      return Object.entries(obj).some(([key, val]) => {
        if (ignoredKeys.includes(key.toLowerCase()) || val == null)
          return false;

        if (typeof val === "object") {
          if (Array.isArray(val)) {
            return val.some((item) => searchObject(item));
          } else {
            return searchObject(val);
          }
        }

        return false;
      });
    };

    const filtered = data.filter((item) => searchObject(item));
    setFilteredData(filtered);
  }, [searchText, data]);

  function CustomToolbar() {
    return (
      <GridToolbarContainer>
        {flagColumn ? <GridToolbarColumnsButton /> : null}
        {flagFilter ? <GridToolbarFilterButton /> : null}
        {flagDen ? <GridToolbarDensitySelector /> : null}
        {flagExp ? <GridToolbarExport /> : null}
      </GridToolbarContainer>
    );
  }

  return (
    <Box sx={{ overflow: "auto" }}>
      <Grid container spacing={2} sx={{ mb: 2, mt: marginTop }}>
        <Grid size={4}>
          <TextField
            variant="outlined"
            size="small"
            fullWidth
            placeholder="Search using keywords"
            onChange={(e) => setSearchText(e.target.value)}
            slotProps={{
              input: {
                startAdornment: (
                  <InputAdornment position="start">
                    <SearchIcon sx={{ color: "#5f6368", mr: 1 }} />
                  </InputAdornment>
                ),
              },
            }}
          />
        </Grid>
        <Grid size={4}>
          {/* <Button variant="contained" color="primary">
            <FileDownloadIcon /> Export CSV
          </Button> */}

          {!isHideFilter && (
            <>
              <ExportCsvButton
                modal="DataTable"
                columns={columns.filter(
                  (col) => !["action", "attachments"].includes(col.field)
                )}
                rows={filteredData}
                fileName={fileName}
                columnVisibilityModel={columnVisibilityModel}
              />
            </>
          )}
        </Grid>
        <Grid size={2}></Grid>
        <Grid size={2}>
          <Box
            sx={{
              display: "block",
              float: "right",
            }}
          >
            <Tooltip title="Reorder Columns">
              {!isHideReordercolumn && (
                <>
                  <IconButton
                    onClick={handleOpenReorder}
                    size="medium"
                    color="primary"
                  >
                    <SwapHorizIcon fontSize="large" />
                  </IconButton>
                </>
              )}
            </Tooltip>
          </Box>
        </Grid>
      </Grid>

      <Box>
        <DataGrid
          rows={filteredData}
          sortingOrder={["asc", "desc"]}
          columns={columns.map((col) =>
            col.sortable !== false
              ? { ...col, sortComparator: genericSortComparator }
              : col
          )}
          getRowId={(rows) => rows?.id}
          hideFooter={isHidePaging}
          disableColumnFilter
          autoHeight={false} // 🔥 MUST DISABLE autoHeight
          sx={{
            width: "100%",
            maxHeight: "100%", // 🔥 height on DataGrid, not wrapper
            "& .super-app-theme--header": {
              fontFamily: "Franklin Gothic Medium",
              fontSize: "15px",
              color: "#fff",
              backgroundColor: "#45154F",
            },
          }}
          pageSizeOptions={[10, 20, 30, 40, 50, 100]}
          initialState={{
            pagination: {
              paginationModel: { pageSize: 10, page: 0 },
            },
          }}
          disableRowSelectionOnClick
          checkboxSelection={flag}
          columnVisibilityModel={columnVisibilityModel}
          onColumnVisibilityModelChange={onColumnVisibilityModelChange}
          localeText={{
            columnMenuSortAsc: "Sort as A to Z",
            columnMenuSortDesc: "Sort as Z to A",
          }}
        />
      </Box>
    </Box>
  );
}
