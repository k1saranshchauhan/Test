import React, { useState, useEffect } from "react";
import {
  Autocomplete,
  TextField,
  FormControl,
  Box,
  Button,
  CircularProgress,
  Tooltip,
  Paper,
  Divider,
  Dialog,
  DialogTitle,
  DialogContent,
  DialogActions,
} from "@mui/material";
import DownloadIcon from "@mui/icons-material/FileDownload";
import VisibilityIcon from "@mui/icons-material/Visibility";
import apiClient from "@/utils/apiClient";
import MainFormHeader from "@/src/components/DashboardUI/MainFormHeader";
import * as Mammoth from "mammoth";
import { jsPDF } from "jspdf";

const ReportComponent = () => {
  const getCurrentFinancialYear = () => {
    const today = new Date();
    const year = today.getFullYear();
    const month = today.getMonth() + 1;
    return month >= 4 ? `${year}-${year + 1}` : `${year - 1}-${year}`;
  };

  const [financialYear, setFinancialYear] = useState(getCurrentFinancialYear());
  const [financialYearList, setFinancialYearList] = useState([]);
  const [loadingYears, setLoadingYears] = useState(false);
  const [exportLoading, setExportLoading] = useState(false);

  const [previewOpen, setPreviewOpen] = useState(false);
  const [pdfUrl, setPdfUrl] = useState("");
  const [previewLoading, setPreviewLoading] = useState(false);

  // Fetch financial years and filter future ones
  const fetchFinancialYearList = async () => {
    setLoadingYears(true);
    try {
      const response = await apiClient.post(
        "api/oomf/submissions/get-scheme-filters",
        { isSubScheme: false }
      );

      const { filters } = response?.data || {};
      const formattedData = filters?.financialYears?.map((item, index) => ({
        id: index + 1,
        name: item?.name,
      })) || [];

      const currentFY = getCurrentFinancialYear();
      const filteredData = formattedData.filter(fy => {
        const fyStartYear = parseInt(fy.name.split("-")[0], 10);
        const currentStartYear = parseInt(currentFY.split("-")[0], 10);
        return fyStartYear <= currentStartYear;
      });

      setFinancialYearList(filteredData);

      if (filteredData.find(fy => fy.name === currentFY)) {
        setFinancialYear(currentFY);
      } else if (filteredData.length > 0) {
        setFinancialYear(filteredData[0].name);
      } else {
        setFinancialYear("");
      }
    } catch (error) {
      console.error("Failed to fetch financialYear list:", error);
      setFinancialYearList([]);
      setFinancialYear("");
    } finally {
      setLoadingYears(false);
    }
  };

  useEffect(() => {
    fetchFinancialYearList();
  }, []);

  // Export Word document
  const handleExport = async () => {
    if (!financialYear) return;
    setExportLoading(true);

    try {
      const response = await apiClient.post(
        "api/oomf/report/oomf-workflow-financial-document",
        { financialYear: [financialYear] },
        { responseType: "blob", headers: { "Content-Type": "application/json" } }
      );

      const blob = new Blob([response.data], {
        type: "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
      });

      const url = window.URL.createObjectURL(blob);
      const link = document.createElement("a");

      let filename = "OOMF_Report_" + financialYear + ".docx";
      const contentDisposition = response.headers["content-disposition"];
      if (contentDisposition) {
        const filenameStarMatch = contentDisposition.match(/filename\*\s*=\s*UTF-8''(.+?)(?:;|$)/i);
        if (filenameStarMatch && filenameStarMatch[1]) {
          filename = decodeURIComponent(filenameStarMatch[1].trim());
        } else {
          const filenameMatch = contentDisposition.match(/filename="?([^";]+)"?/i);
          if (filenameMatch && filenameMatch[1]) filename = filenameMatch[1].trim();
        }
        filename = filename.replace(/_+$/, "");
      }

      link.href = url;
      link.setAttribute("download", filename);
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      window.URL.revokeObjectURL(url);
    } catch (err) {
      console.error("Export failed:", err);
      alert("Failed to download report. Please try again.");
    } finally {
      setExportLoading(false);
    }
  };

  // Preview Word document as PDF in modal
  const handlePreview = async () => {
    if (!financialYear) return;
    setPreviewLoading(true);

    try {
      const response = await apiClient.post(
        "api/oomf/report/oomf-workflow-financial-document",
        { financialYear: [financialYear] },
        { responseType: "arraybuffer" }
      );

      // Convert Word -> text using Mammoth
      const arrayBuffer = response.data;
      const { value: textContent } = await Mammoth.extractRawText({ arrayBuffer });

      // Create PDF using jsPDF
      const pdf = new jsPDF("p", "pt", "a4");
      const lines = textContent.split("\n");
      let y = 40;
      const lineHeight = 14;

      lines.forEach(line => {
        pdf.text(line, 40, y);
        y += lineHeight;
        if (y > 800) { // page break
          pdf.addPage();
          y = 40;
        }
      });

      const blob = pdf.output("blob");
      const url = URL.createObjectURL(blob);
      setPdfUrl(url);
      setPreviewOpen(true);
    } catch (err) {
      console.error("Preview failed:", err);
      alert("Failed to preview report. Please try again.");
    } finally {
      setPreviewLoading(false);
    }
  };

  return (
    <Box sx={{ mt: 4, mx: "auto", px: 2 }}>
      <MainFormHeader title="Outcome Budget Report" />
      <Divider sx={{ my: 2 }} />

      <Paper
        elevation={3}
        sx={{
          p: 3,
          display: "flex",
          alignItems: "center",
          justifyContent: "space-between",
          mb: 4,
          flexWrap: "wrap",
          gap: 2,
        }}
      >
        {/* Financial Year Selector */}
        <FormControl sx={{ minWidth: 250, flex: 1 }}>
          <Autocomplete
            options={financialYearList}
            getOptionLabel={(option) => option.name || ""}
            value={financialYearList.find((fy) => fy.name === financialYear) || null}
            onChange={(event, newValue) => setFinancialYear(newValue ? newValue.name : "")}
            renderInput={(params) => (
              <TextField
                {...params}
                label="Financial Year"
                variant="outlined"
                disabled={loadingYears}
              />
            )}
            disableClearable
          />
        </FormControl>

        {/* Buttons */}
        <Box sx={{ display: "flex", gap: 2, flexWrap: "wrap" }}>
          <Tooltip title={financialYear ? "Preview report" : "Select a financial year first"}>
            <span>
              <Button
                variant="outlined"
                color="secondary"
                startIcon={<VisibilityIcon />}
                onClick={handlePreview}
                disabled={!financialYear || previewLoading || exportLoading}
                sx={{ height: 56 }}
              >
                {previewLoading ? <CircularProgress size={20} /> : "Preview"}
              </Button>
            </span>
          </Tooltip>

          <Tooltip title={financialYear ? "Export report" : "Select a financial year first"}>
            <span>
              <Button
                variant="contained"
                color="primary"
                startIcon={
                  exportLoading ? <CircularProgress size={20} color="inherit" /> : <DownloadIcon />
                }
                onClick={handleExport}
                disabled={!financialYear || exportLoading || previewLoading}
                sx={{ height: 56 }}
              >
                {exportLoading ? "Processing..." : "Export as Word"}
              </Button>
            </span>
          </Tooltip>
        </Box>
      </Paper>

      {/* PDF Preview Modal */}
      <Dialog
        open={previewOpen}
        onClose={() => setPreviewOpen(false)}
        maxWidth="lg"
        fullWidth
      >
        <DialogTitle>Preview Outcome Budget Report</DialogTitle>
        <DialogContent dividers sx={{ height: "80vh" }}>
          {pdfUrl ? (
            <iframe src={pdfUrl} style={{ width: "100%", height: "100%" }} />
          ) : (
            <Box sx={{ textAlign: "center", mt: 4 }}>Loading preview...</Box>
          )}
        </DialogContent>
        <DialogActions>
          <Button onClick={() => setPreviewOpen(false)}>Close</Button>
        </DialogActions>
      </Dialog>
    </Box>
  );
};

export default ReportComponent;
