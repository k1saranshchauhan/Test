    mappedPrivileges: stripMappedPrivileges,
    hasAddAccess: stripHasAddAccess,
    hasEditAccess: stripHasEditAccess,
    hasViewAccess: stripHasViewAccess,
    refresh: stripPrivilegeRefresh,
