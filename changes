import {
  getTargetLabels,
  getNextFinancialYear,
  createNewIndicator,
  createNewSection,
  buildTargetsByMeasurementArea,
  computeTotals,
  validateIndicatorSections,
} from "./utils/helpers";
import SubmissionDialog from "./SubmissionDialog";
