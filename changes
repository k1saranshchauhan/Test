import React, { useState, useCallback } from "react";
import {
  Box,
  Button,
  Typography,
  IconButton,
  List,
  ListItem,
  TextField,
  Stack,
  Divider,
  Tooltip,
  Card,
  CardContent,
  Alert,
  Fade,
  LinearProgress,
  Paper,
} from "@mui/material";
import DeleteIcon from "@mui/icons-material/Delete";
import UploadFileIcon from "@mui/icons-material/UploadFile";
import CloudUploadIcon from "@mui/icons-material/CloudUpload";
import DescriptionIcon from "@mui/icons-material/Description";
import CheckCircleIcon from "@mui/icons-material/CheckCircle";

const MAX_FILE_COUNT = 5;
const MAX_FILE_SIZE_MB = 10;
const MAX_FILE_SIZE_BYTES = MAX_FILE_SIZE_MB * 1024 * 1024;

const ProfessionalFileRepeater = ({ onUploadComplete, uploadMultipleFiles }) => {
  const [selectedFiles, setSelectedFiles] = useState([]);
  const [titles, setTitles] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  const validateAndAddFiles = (files) => {
    setError("");
    
    // Check Count
    if (selectedFiles.length + files.length > MAX_FILE_COUNT) {
      setError(`Limit exceeded. You can only have ${MAX_FILE_COUNT} files total.`);
      return;
    }

    // Check Size
    const oversizedFiles = files.filter(f => f.size > MAX_FILE_SIZE_BYTES);
    if (oversizedFiles.length > 0) {
      setError(`One or more files exceed the ${MAX_FILE_SIZE_MB}MB limit.`);
      return;
    }

    const newFiles = [...selectedFiles, ...files];
    const newTitles = [
      ...titles,
      ...files.map((f) => f.name.replace(/\.[^/.]+$/, "")),
    ];

    setSelectedFiles(newFiles);
    setTitles(newTitles);
  };

  const handleFileChange = (e) => {
    const files = Array.from(e.target.files);
    validateAndAddFiles(files);
    e.target.value = ""; // Reset input
  };

  const handleRemove = (index) => {
    setSelectedFiles(prev => prev.filter((_, i) => i !== index));
    setTitles(prev => prev.filter((_, i) => i !== index));
    setError("");
  };

  const handleUpload = async () => {
    setLoading(true);
    try {
      await uploadMultipleFiles(selectedFiles, titles, "System Upload");
      if (onUploadComplete) onUploadComplete();
      setSelectedFiles([]);
      setTitles([]);
    } catch (err) {
      setError("Server error during upload. Please try again.");
    } finally {
      setLoading(false);
    }
  };

  return (
    <Card sx={{ maxWidth: 700, mx: "auto", borderRadius: 3, boxShadow: "0 8px 24px rgba(0,0,0,0.1)" }}>
      <CardContent sx={{ p: 4 }}>
        <Stack spacing={3}>
          {/* Header */}
          <Box display="flex" justifyContent="space-between" alignItems="center">
            <Box>
              <Typography variant="h5" fontWeight={700} color="text.primary">
                Supporting Documents
              </Typography>
              <Typography variant="body2" color="text.secondary">
                {selectedFiles.length} of {MAX_FILE_COUNT} files added
              </Typography>
            </Box>
            {selectedFiles.length === MAX_FILE_COUNT && (
              <CheckCircleIcon color="success" />
            )}
          </Box>

          {/* Upload Zone */}
          <Paper
            variant="outlined"
            sx={{
              p: 4,
              borderRadius: 2,
              border: "2px dashed",
              borderColor: error ? "error.light" : "primary.light",
              bgcolor: "grey.50",
              textAlign: "center",
              cursor: selectedFiles.length >= MAX_FILE_COUNT ? "not-allowed" : "pointer",
              "&:hover": { bgcolor: "action.hover" },
            }}
            component="label"
          >
            <input 
              type="file" 
              hidden 
              multiple 
              onChange={handleFileChange} 
              disabled={selectedFiles.length >= MAX_FILE_COUNT}
            />
            <UploadFileIcon sx={{ fontSize: 40, color: "primary.main", mb: 1 }} />
            <Typography variant="subtitle1" fontWeight={600}>
              Click to browse or drag and drop
            </Typography>
            <Typography variant="caption" color="text.secondary">
              PDF, PNG, JPG (Max {MAX_FILE_SIZE_MB}MB per file)
            </Typography>
          </Paper>

          {/* Error Feedback */}
          {error && (
            <Fade in={!!error}>
              <Alert severity="error" variant="filled" sx={{ borderRadius: 2 }}>
                {error}
              </Alert>
            </Fade>
          )}

          {/* File List */}
          <List disablePadding>
            {selectedFiles.map((file, index) => (
              <Paper
                key={index}
                variant="outlined"
                sx={{ mb: 2, p: 2, borderRadius: 2, position: "relative", borderLeft: "4px solid", borderLeftColor: "primary.main" }}
              >
                <Box display="flex" alignItems="flex-start" gap={2}>
                  <DescriptionIcon color="action" />
                  <Box flex={1}>
                    <Typography variant="body2" fontWeight={600} noWrap sx={{ maxWidth: 400 }}>
                      {file.name}
                    </Typography>
                    <Typography variant="caption" color="text.secondary" display="block" sx={{ mb: 1 }}>
                      {(file.size / 1024 / 1024).toFixed(2)} MB
                    </Typography>
                    
                    <TextField
                      fullWidth
                      size="small"
                      placeholder="Give this document a title..."
                      value={titles[index] || ""}
                      onChange={(e) => {
                        const newTitles = [...titles];
                        newTitles[index] = e.target.value;
                        setTitles(newTitles);
                      }}
                      sx={{ "& .MuiInputBase-root": { fontSize: "0.875rem" } }}
                    />
                  </Box>
                  <IconButton onClick={() => handleRemove(index)} size="small" sx={{ color: "error.main" }}>
                    <DeleteIcon />
                  </IconButton>
                </Box>
              </Paper>
            ))}
          </List>

          {/* Footer Actions */}
          {selectedFiles.length > 0 && (
            <Box pt={2}>
              {loading && <LinearProgress sx={{ mb: 2, borderRadius: 2 }} />}
              <Stack direction="row" spacing={2} justifyContent="flex-end">
                <Button 
                  variant="text" 
                  color="inherit" 
                  onClick={() => {setSelectedFiles([]); setTitles([]);}}
                >
                  Discard All
                </Button>
                <Button
                  variant="contained"
                  startIcon={<CloudUploadIcon />}
                  onClick={handleUpload}
                  disabled={loading}
                  sx={{ 
                    borderRadius: 2, 
                    px: 4, 
                    textTransform: "none",
                    fontWeight: 600,
                    boxShadow: "0 4px 12px rgba(25, 118, 210, 0.3)"
                  }}
                >
                  {loading ? "Uploading..." : "Confirm & Upload"}
                </Button>
              </Stack>
            </Box>
          )}
        </Stack>
      </CardContent>
    </Card>
  );
};

export default ProfessionalFileRepeater;
