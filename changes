import React, { useMemo } from "react";
import {
  Box,
  Typography,
  Paper,
  TableContainer,
  Table,
  TableHead,
  TableRow,
  TableCell,
  TableBody,
} from "@mui/material";

const ProgressTable = ({ data }) => {
  const formatDecimal = (value) => {
    if (value === null || value === undefined || value === "-") return "-";
    const num = Number(value);
    return !isNaN(num) ? num.toFixed(2) : value;
  };

  const getBackgroundColor = (value) => {
    const num = Number(value);
    if (isNaN(num) || value === "-" || value === null) return "transparent";
    if (num > 80) return "#90ee90"; // lightgreen
    if (num >= 50) return "#fff9c4"; // lightyellow
    return "#f8bbd0"; // lightcoral
  };

  if (!data?.data) return null;

  const reportData = data.data;
  const years = Object.keys(reportData).sort();

  const hierarchy = useMemo(() => {
    const tree = {};
    years.forEach((year) => {
      reportData[year].forEach((schemeEntry) => {
        const minName = schemeEntry.ministryId?.name || "Unknown Ministry";
        const deptName = schemeEntry.departmentId?.name || "Unknown Department";
        const schemeName = schemeEntry.schemeId?.name || "Unknown Scheme";

        if (!tree[minName]) tree[minName] = {};
        if (!tree[minName][deptName]) tree[minName][deptName] = {};
        if (!tree[minName][deptName][schemeName]) {
          tree[minName][deptName][schemeName] = { indicatorRows: {} };
        }

        schemeEntry.indicatorData.forEach((typeGroup) => {
          typeGroup.sections.forEach((section) => {
            section.indicators.forEach((ind) => {
              const rowKey = `${typeGroup.indicatorType.name}-${section.name}-${ind.indicator.name}`;
              if (!tree[minName][deptName][schemeName].indicatorRows[rowKey]) {
                tree[minName][deptName][schemeName].indicatorRows[rowKey] = {
                  type: typeGroup.indicatorType.name,
                  statement: section.name,
                  indicatorName: ind.indicator.name,
                  unit: ind.unit?.name || "nos.",
                  frequency: ind.frequency?.name || "Yearly",
                  yearlyValues: {},
                };
              }
              tree[minName][deptName][schemeName].indicatorRows[rowKey].yearlyValues[year] = {
                target: ind.target,
                progress: ind.progress,
              };
            });
          });
        });
      });
    });
    return tree;
  }, [reportData, years]);

  const getSubKeys = (frequency) => {
    if (frequency === "Quarterly") return ["Q1", "Q2", "Q3", "Q4"];
    if (frequency === "Half-Yearly") return ["HY1", "HY2"];
    return ["Yearly"];
  };

  return (
    <Box sx={{ p: 2, backgroundColor: "#fdfdfd" }}>
      {Object.entries(hierarchy).map(([minName, departments], minIdx) => (
        <Box key={minName} sx={{ mb: 6 }}>
          <Typography variant="h4" sx={{ color: "#1a237e", fontWeight: "bold", mb: 2, fontSize: "22px" }}>
            {minIdx + 1}) {minName}
          </Typography>

          {Object.entries(departments).map(([deptName, schemes], deptIdx) => (
            <Box key={deptName} sx={{ ml: 2, mb: 4 }}>
              <Typography variant="h5" sx={{ color: "black", fontWeight: "600", mb: 2, fontSize: "20px" }}>
                {minIdx + 1}.{deptIdx + 1}) {deptName}
              </Typography>

              {Object.entries(schemes).map(([schemeName, schemeContent], schemeIdx) => {
                const firstRow = Object.values(schemeContent.indicatorRows)[0];
                const frequency = firstRow?.frequency || "Yearly";
                const subKeys = getSubKeys(frequency);

                return (
                  <Box key={schemeName} sx={{ ml: 2, mb: 6 }}>
                    <Typography variant="h6" sx={{ color: "#45154F", fontWeight: "bold", mb: 2, fontSize: "18px" }}>
                      {minIdx + 1}.{deptIdx + 1}.{schemeIdx + 1}) {schemeName}
                    </Typography>

                    <TableContainer component={Paper} sx={{ borderRadius: "8px", overflowX: "auto" }}>
                      <Table size="small" sx={{ border: "1px solid #ccc", minWidth: 1200 }}>
                        <TableHead>
                          <TableRow sx={{ backgroundColor: "#45154F" }}>
                            <TableCell rowSpan={3} sx={{ color: "#fff", fontWeight: "bold", border: "1px solid #632a6d", textAlign: "center" }}>Indicator</TableCell>
                            <TableCell rowSpan={3} sx={{ color: "#fff", fontWeight: "bold", border: "1px solid #632a6d", textAlign: "center" }}>Unit</TableCell>
                            {years.map((year) => (
                              <TableCell key={year} colSpan={subKeys.length * 3 + 3} align="center" sx={{ color: "#fff", fontWeight: "bold", border: "1px solid #632a6d" }}>
                                {year}-{parseInt(year) + 1}
                              </TableCell>
                            ))}
                          </TableRow>
                          <TableRow sx={{ backgroundColor: "#45154F" }}>
                            {years.map((year) => (
                              <React.Fragment key={year}>
                                <TableCell colSpan={subKeys.length + 1} align="center" sx={{ color: "#fff", border: "1px solid #632a6d", fontSize: "0.75rem" }}>Target</TableCell>
                                <TableCell colSpan={subKeys.length + 1} align="center" sx={{ color: "#fff", border: "1px solid #632a6d", fontSize: "0.75rem" }}>Progress</TableCell>
                                <TableCell colSpan={subKeys.length + 1} align="center" sx={{ color: "#fff", border: "1px solid #632a6d", fontSize: "0.75rem" }}>Achieved</TableCell>
                              </React.Fragment>
                            ))}
                          </TableRow>
                          <TableRow sx={{ backgroundColor: "#45154F" }}>
                            {years.map((year) => (
                              <React.Fragment key={year}>
                                {subKeys.map(sk => <TableCell key={`th-t-${sk}`} sx={{ color: "#fff", border: "1px solid #632a6d", fontSize: "0.65rem" }}>{sk}</TableCell>)}
                                <TableCell sx={{ color: "#fff", border: "1px solid #632a6d", fontWeight: "bold", fontSize: "0.65rem" }}>Total</TableCell>
                                {subKeys.map(sk => <TableCell key={`th-p-${sk}`} sx={{ color: "#fff", border: "1px solid #632a6d", fontSize: "0.65rem" }}>{sk}</TableCell>)}
                                <TableCell sx={{ color: "#fff", border: "1px solid #632a6d", fontWeight: "bold", fontSize: "0.65rem" }}>Total</TableCell>
                                {subKeys.map(sk => <TableCell key={`th-a-${sk}`} sx={{ color: "#fff", border: "1px solid #632a6d", fontSize: "0.65rem" }}>{sk}</TableCell>)}
                                <TableCell sx={{ color: "#fff", border: "1px solid #632a6d", fontWeight: "bold", fontSize: "0.65rem", backgroundColor: "#2e0e35" }}>Total %</TableCell>
                              </React.Fragment>
                            ))}
                          </TableRow>
                        </TableHead>

                        <TableBody>
                          {Object.values(schemeContent.indicatorRows).map((row, rIdx) => (
                            <TableRow key={rIdx}>
                              <TableCell sx={{ border: "1px solid #ddd" }}>{row.indicatorName}</TableCell>
                              <TableCell sx={{ border: "1px solid #ddd", textAlign: "center" }}>{row.unit}</TableCell>
                              {years.map((year) => {
                                const val = row.yearlyValues[year] || {};
                                
                                // Calculation logic
                                let sumTarget = 0, sumProgress = 0, isValid = true;
                                subKeys.forEach(sk => {
                                  const t = frequency === "Yearly" ? val.target : val.target?.[sk];
                                  const p = frequency === "Yearly" ? val.progress : val.progress?.[sk];
                                  if (typeof t === 'number' && typeof p === 'number') {
                                    sumTarget += t; sumProgress += p;
                                  } else { isValid = false; }
                                });

                                const totalPct = (isValid && sumTarget > 0) ? (sumProgress / sumTarget) * 100 : "N/A";

                                return (
                                  <React.Fragment key={year}>
                                    {/* Target Columns */}
                                    {subKeys.map(sk => <TableCell key={`t-${sk}`} align="right" sx={{ border: "1px solid #ddd" }}>{formatDecimal(frequency === "Yearly" ? val.target : val.target?.[sk])}</TableCell>)}
                                    <TableCell align="right" sx={{ border: "1px solid #ddd", fontWeight: "bold" }}>{isValid ? formatDecimal(sumTarget) : "N/A"}</TableCell>
                                    
                                    {/* Progress Columns */}
                                    {subKeys.map(sk => <TableCell key={`p-${sk}`} align="right" sx={{ border: "1px solid #ddd" }}>{formatDecimal(frequency === "Yearly" ? val.progress : val.progress?.[sk])}</TableCell>)}
                                    <TableCell align="right" sx={{ border: "1px solid #ddd", fontWeight: "bold" }}>{isValid ? formatDecimal(sumProgress) : "N/A"}</TableCell>
                                    
                                    {/* Achieved Columns (Raw value/Indicator, no calculation) */}
                                    {subKeys.map(sk => <TableCell key={`a-${sk}`} align="right" sx={{ border: "1px solid #ddd" }}>-</TableCell>)}
                                    
                                    {/* Total Achieved % Column (CALCULATED & COLORED) */}
                                    <TableCell align="right" sx={{ border: "1px solid #ddd", fontWeight: "bold", backgroundColor: getBackgroundColor(totalPct) }}>
                                      {isValid && typeof totalPct === 'number' ? `${totalPct.toFixed(2)}%` : "N/A"}
                                    </TableCell>
                                  </React.Fragment>
                                );
                              })}
                            </TableRow>
                          ))}
                        </TableBody>
                      </Table>
                    </TableContainer>
                  </Box>
                );
              })}
            </Box>
          ))}
        </Box>
      ))}
    </Box>
  );
};

export default ProgressTable;
