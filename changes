import {
  Paper,
  Grid,
  Box,
  FormLabel,
  Autocomplete,
  TextField,
  InputAdornment,
  Tooltip,
  IconButton,
  Typography,
  Switch,
  Accordion,
  AccordionSummary,
  AccordionDetails,
} from "@mui/material";
import {
  ArrowUpward as ArrowUpwardIcon,
  ArrowDownward as ArrowDownwardIcon,
  ExpandMore as ExpandMoreIcon,
} from "@mui/icons-material";
import DescriptionIcon from "@mui/icons-material/Description";
import IndicatorForm from "./IndicatorForm";
import DeleteOutlinedIcon from "@mui/icons-material/DeleteOutlined";
import { useMediaQuery } from "@mui/material";

export default function SectionCard({
  section,
  moto,
  sectionIndex,
  currentType,
  isReadOnly,
  type,
  isPostBudget,
  outputResponse,
  outcomeResponse,
  sectionsByType,
  prefillData,
  dummyIndicator,
  dummyMeasurementTypes,
  dummyUnits,
  dummyScales,
  dummyMeasurementArea,
  dummyIndicatorRise,
  dummyPeriod,
  dummyCategoty,
  dummySdg,
  dummyFrequencies,
  fieldErrors,
  inputRefs,
  handleSectionChange,
  handleIndicatorChange,
  handleChange,
  handleDialogOpen,
  handleAddIndicator,
  handleRemoveIndicator,
  handleMoveUp,
  handleMoveDown,
  handleMoveSectionUp,
  handleMoveSectionDown,
  handleRemoveSection,
  hoveredSectionIdx,
  hoveredCancelIdx,
  setHoveredSectionIdx,
  setHoveredCancelIdx,
  initialTargetsMap,
  buildTargetsByMeasurementArea,
  computeTotals,
  dummyDistrict,
  dummyStates,
  onOpenFrequencyModal,
  selectedMinistry,
  selectedDepartment,
  selectedSchemeType,
  selectedScheme,
  selectedSubScheme,
}) {
  const primaryColor = "#45154F";
  const secondaryColor = "#F5F5F5";
  const borderColor = "#E0E0E0";
  const errorColor = "#D32F2F";

  const totalSections = sectionsByType[currentType]?.length || 0;
  const isOnlySection = totalSections === 1;
  const isSmall = useMediaQuery("(max-width:600px)");

  return (
    <Accordion
      key={sectionIndex}
      defaultExpanded={true}
      sx={{
        mt: 4,
        py: 4,
        borderRadius: 2,
        border:
          hoveredSectionIdx === sectionIndex
            ? `2px solid ${errorColor}`
            : `1px solid ${borderColor}`,
        transition: "border 0.3s ease-in-out, box-shadow 0.3s ease-in-out",
        boxShadow:
          hoveredSectionIdx === sectionIndex
            ? `0 4px 12px rgba(211, 47, 47, 0.15)`
            : `0 2px 8px rgba(0, 0, 0, 0.08)`,
        position: "relative",
        backgroundColor: "#f7f1fa",
        "&:before": {
          display: "none",
        },
      }}
    >
      {/* Header */}
      <AccordionSummary
        expandIcon={!isReadOnly ? <ExpandMoreIcon /> : null}
        sx={{
          px: 4,
          minHeight: 56,
          "& .MuiAccordionSummary-content": {
            my: 0,
          },
        }}
      >
        <Box
          sx={{
            width: "100%",
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            pb: 2,
            borderBottom: `1px solid ${borderColor}`,
          }}
        >
          <Box
            sx={{
              display: isSmall ? "none" : "flex",
              alignItems: "center",
              gap: 2,
            }}
          >
            <Box
              sx={{
                display: isSmall ? "none" : "flex",
                alignItems: "center",
                gap: 2,
              }}
            >
              <Box
                sx={{
                  background: primaryColor,
                  padding: "8px 24px",
                  borderRadius: "24px",
                  minWidth: "fit-content",
                }}
              >
                <FormLabel
                  sx={{
                    color: "#fff",
                    fontSize: "0.875rem",
                    fontWeight: 600,
                  }}
                >
                  {`${currentType} ${sectionIndex + 1}`}
                </FormLabel>
              </Box>

              <Tooltip
                title={section.name || `Untitled ${currentType}`}
                placement="top"
              >
                <Typography
                  variant="h6"
                  sx={{
                    color: primaryColor,
                    fontWeight: 600,
                    maxWidth: {
                      xs: "14rem",
                      sm: "20rem",
                      md: "40rem",
                    },
                    whiteSpace: "nowrap",
                    overflow: "hidden",
                    textOverflow: "ellipsis",
                    display: "block",
                    cursor: "pointer",
                  }}
                >
                  {section.name || `Untitled ${currentType}`}
                </Typography>
              </Tooltip>
            </Box>

            <Box sx={{ display: "flex", alignItems: "center", gap: 1 }}>
              {!isReadOnly && totalSections > 1 && (
                <>
                  <Tooltip title="Move Up">
                    <IconButton
                      onClick={(e) => {
                        e.stopPropagation();
                        handleMoveSectionUp(sectionIndex);
                      }}
                      disabled={sectionIndex === 0}
                      sx={{
                        color:
                          sectionIndex === 0 ? "action.disabled" : primaryColor,
                        "&:hover": {
                          backgroundColor:
                            sectionIndex === 0
                              ? "transparent"
                              : `${primaryColor}10`,
                        },
                      }}
                      size="small"
                    >
                      <ArrowUpwardIcon fontSize="small" />
                    </IconButton>
                  </Tooltip>

                  <Tooltip title="Move Down">
                    <IconButton
                      onClick={(e) => {
                        e.stopPropagation();
                        handleMoveSectionDown(sectionIndex);
                      }}
                      disabled={sectionIndex === totalSections - 1}
                      sx={{
                        color:
                          sectionIndex === totalSections - 1
                            ? "action.disabled"
                            : primaryColor,
                        "&:hover": {
                          backgroundColor:
                            sectionIndex === totalSections - 1
                              ? "transparent"
                              : `${primaryColor}10`,
                        },
                      }}
                      size="small"
                    >
                      <ArrowDownwardIcon fontSize="small" />
                    </IconButton>
                  </Tooltip>
                </>
              )}
              <Button variant="outlined">
                Manage {currentType === "Output" ? "Output" : "Outcome"} Indicators
              </Button>
              
              {/* Active Switch */}
              <Box sx={{ display: "flex", alignItems: "center", gap: 1 }}>
                <Typography
                  variant="body2"
                  sx={{
                    color: "text.secondary",
                    fontWeight: 500,
                    cursor: "default",
                  }}
                  onClick={(e) => e.stopPropagation()}
                >
                  Active
                </Typography>

                {/* <Switch
                  disabled={isReadOnly}
                  checked={section.active}
                  onClick={(e) => e.stopPropagation()}
                  onChange={(e) =>
                    handleSectionChange(
                      sectionIndex,
                      "active",
                      e.target.checked
                    )
                  }
                  size="small"
                /> */}

                {isOnlySection ? (
                  <Tooltip
                    title={
                      isReadOnly
                        ? ""
                        : "At least two sections are required to enable activation or deactivation. This section cannot be deactivated as it is the only available one."
                    }
                  >
                    <Box onClick={(e) => e.stopPropagation()}>
                      <Switch
                        checked
                        disabled
                        size="small"
                        sx={{
                          opacity: 0.5,
                          cursor: "not-allowed",
                        }}
                      />
                    </Box>
                  </Tooltip>
                ) : (
                  <Switch
                    checked={section.active}
                    disabled={isReadOnly}
                    onClick={(e) => e.stopPropagation()}
                    onChange={(e) =>
                      handleSectionChange(
                        sectionIndex,
                        "active",
                        e.target.checked,
                      )
                    }
                    size="small"
                  />
                )}
              </Box>

              {/* Delete Button */}
              {!isReadOnly && totalSections > 1 && (
                <Tooltip title={`Delete this ${currentType}`}>
                  <IconButton
                    onClick={(e) => {
                      e.stopPropagation();
                      setHoveredSectionIdx(null);
                      handleRemoveSection(sectionIndex);
                    }}
                    onMouseEnter={() => setHoveredSectionIdx(sectionIndex)}
                    onMouseLeave={() => setHoveredSectionIdx(null)}
                    sx={{
                      color: errorColor,
                      "&:hover": { backgroundColor: `${errorColor}10` },
                    }}
                    size="small"
                  >
                    <DeleteOutlinedIcon fontSize="small" />
                  </IconButton>
                </Tooltip>
              )}
            </Box>
          </Box>
        </Box>
      </AccordionSummary>

      <AccordionDetails sx={{ px: 4, py: 0 }}>
        {/* Section Name Selection */}
        <Grid
          container
          spacing={3}
          alignItems="flex-end"
          mb={4}
          sx={{ backgroundColor: "#fff" }}
        >
          <Grid size={{ xs: 12, md: 12 }}>
            <Autocomplete
              disableClearable
              disabled={isReadOnly}
              fullWidth
              options={(
                (currentType === "Output"
                  ? outputResponse?.outputList
                  : outcomeResponse?.outcomeList) || []
              ).filter(
                (option) =>
                  !sectionsByType[currentType]
                    .filter((_, i) => i !== sectionIndex)
                    .some((sec) => sec.name === option.name),
              )}
              value={
                section.name
                  ? {
                      id:
                        outputResponse?.outputList?.find(
                          (x) => x.name === section.name,
                        )?.id ||
                        outcomeResponse?.outcomeList?.find(
                          (x) => x.name === section.name,
                        )?.id,
                      name: section.name,
                    }
                  : null
              }
              onChange={(event, newValue) => {
                handleSectionChange(
                  sectionIndex,
                  "name",
                  newValue ? newValue.name : "",
                );
                handleSectionChange(
                  sectionIndex,
                  "id",
                  newValue ? newValue.id : "",
                );
                handleSectionChange(sectionIndex, "footNote", "");
              }}
              getOptionLabel={(option) => option?.name || ""}
              isOptionEqualToValue={(option, value) => option.id === value.id}
              renderInput={(params) => (
                <TextField
                  {...params}
                  variant="outlined"
                  label={
                    <>
                      Select {currentType} Name{" "}
                      <span
                        style={{
                          color: "red",
                          display: moto === "draft" ? "none" : "inline",
                        }}
                      >
                        *
                      </span>
                    </>
                  }
                  sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
                  InputProps={{
                    ...params.InputProps,
                    endAdornment: (
                      <>
                        <InputAdornment position="end">
                          <Tooltip
                            title={
                              isReadOnly
                                ? `View Footnote`
                                : `Add a footnote for this ${currentType}`
                            }
                          >
                            <IconButton
                              onClick={() => {
                                const matchingIndicator =
                                  prefillData?.indicatorData?.find(
                                    (item) =>
                                      item.indicatorType?.name.toLowerCase() ===
                                      currentType.toLowerCase(),
                                  );

                                handleDialogOpen({
                                  field: currentType,
                                  sectionIndex,
                                  defaultValue:
                                    sectionsByType[currentType]?.[sectionIndex]
                                      ?.footNote ??
                                    matchingIndicator?.indicatorType
                                      ?.footNote ??
                                    "",
                                });
                              }}
                            >
                              <DescriptionIcon sx={{ color: primaryColor }} />
                            </IconButton>
                          </Tooltip>
                        </InputAdornment>

                        {params.InputProps.endAdornment}
                      </>
                    ),
                  }}
                />
              )}
            />
          </Grid>
        </Grid>

        {/* Indicators */}
        {section?.indicators?.map((indicator, indicatorIndex) => (
          <IndicatorForm
            key={indicatorIndex}
            moto={moto}
            indicator={indicator}
            sectionIndex={sectionIndex}
            indicatorIndex={indicatorIndex}
            section={section}
            currentType={currentType}
            isReadOnly={isReadOnly}
            type={type}
            isPostBudget={isPostBudget}
            dummyIndicator={dummyIndicator}
            dummyMeasurementTypes={dummyMeasurementTypes}
            dummyUnits={dummyUnits}
            dummyScales={dummyScales}
            dummyMeasurementArea={dummyMeasurementArea}
            dummyIndicatorRise={dummyIndicatorRise}
            dummyPeriod={dummyPeriod}
            dummyCategoty={dummyCategoty}
            dummySdg={dummySdg}
            dummyFrequencies={dummyFrequencies}
            fieldErrors={fieldErrors}
            inputRefs={inputRefs}
            handleIndicatorChange={handleIndicatorChange}
            handleChange={handleChange}
            handleDialogOpen={handleDialogOpen}
            handleAddIndicator={handleAddIndicator}
            handleRemoveIndicator={handleRemoveIndicator}
            handleMoveUp={handleMoveUp}
            handleMoveDown={handleMoveDown}
            hoveredCancelIdx={hoveredCancelIdx}
            setHoveredCancelIdx={setHoveredCancelIdx}
            totals={{}}
            dummyDistrict={dummyDistrict}
            dummyStates={dummyStates}
            onOpenFrequencyModal={onOpenFrequencyModal}
            initialTargetsMap={initialTargetsMap}
            buildTargetsByMeasurementArea={buildTargetsByMeasurementArea}
            computeTotals={computeTotals}
          />
        ))}
      </AccordionDetails>
    </Accordion>
  );
}
