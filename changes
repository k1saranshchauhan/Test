          : alertTypes[0];

      formik.setFieldValue("alertType", typeAlert);
      formik.setFieldValue("targetModule", editAlertContent?.targetModule);

      if (editAlertContent?.alertType?.label === "Email Alert") {
        formik.setFieldValue("ministry", editAlertContent?.ministry);
        formik.setFieldValue("department", editAlertContent?.department);
        formik.setFieldValue("orgTypes", editAlertContent?.orgTypes);
        formik.setFieldValue("recepients", editAlertContent?.recepients); // ✅ recipients populated here
        formik.setFieldValue(
          "subject",
          editAlertContent?.content?.subject || "",
        );
        formik.setFieldValue("body", editAlertContent?.content?.body || "");
        formik.setFieldValue(
          "specificCondition",
          editAlertContent?.specificCondition,
        );
        setAlertFrequency(editAlertContent?.frequencyPattern);
      } else {
        setStartDate(dayjs(editAlertContent?.startDate).format("YYYY-MM-DD"));
        setEndDate(dayjs(editAlertContent?.endDate).format("YYYY-MM-DD"));
        setStripContent(editAlertContent?.content?.content);
      }
    };

    fetchData();
