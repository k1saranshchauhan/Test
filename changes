  const formik = useFormik({
    initialValues: {
      alertType: "",
      targetModule: "",
      specificCondition: "",
      ministry: [],
      department: [],
      orgTypes: [],
      recepients: [],
      subject: "",
      body: "",
    },
    validate: (values) => {
      try {
        const schema = getValidationSchema(values?.alertType?.label);

        // If schema doesn't exist, skip validation safely
        if (schema) {
          schema.validateSync(values, { abortEarly: false });
        }
      } catch (err) {
        const errors = {};

        // Safely handle only Yup validation errors
        if (err.inner && Array.isArray(err.inner)) {
          err.inner.forEach((e) => {
            errors[e.path] = e.message;
          });
        } else {
          // fallback for non-Yup errors
          errors.general = err.message;
        }

        return errors;
      }
    },

    enableReinitialize: true,
    onSubmit: (values) => {},
  });

  useEffect(() => {
    if (router.query?.editId === undefined) {
      formik.resetForm();
    }
  }, [router.query]);

  const handleSubmit = async ({ isCancelled = false } = {}) => {
    setHandleSubmitClicked(true);
    const isValid = await formik?.validateForm();
    if (Object.keys(isValid).length > 0) {
      // 🔹 Filter out 'body' field from validation handling
      const filteredErrors = Object.keys(isValid).filter(
        (key) => key !== "body",
      );

      if (filteredErrors.length > 0) {
        formik.setTouched(
          filteredErrors.reduce((acc, key) => ({ ...acc, [key]: true }), {}),
        );
        console.warn("Form has validation errors:", isValid);
        dispatch(setError("Required fields missing"));
        return;
      }
    }

    if (
      formik?.values?.alertType?.label === "Email Alert" &&
      !isFrequencyValid
    ) {
      dispatch(
        setError("Please complete all required fields before submitting!"),
      );
      return;
    }
    const isEmptyHtml = (html) => {
      if (!html) return true;
      const text = html.replace(/<[^>]*>/g, "").trim(); // remove HTML tags and spaces
      return text.length === 0;
    };

    if (formik?.values?.alertType?.label === "Email Alert") {
      if (isEmptyHtml(formik.values.body)) {
        dispatch(setError("Body is required!"));
        return;
      }
    }
    if (formik?.values?.alertType?.label === "Strip Alert") {
      if (stripContent === "" || stripContent === undefined) {
        dispatch(setError("Alert content is required"));
        return;
      }
