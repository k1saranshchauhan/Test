import { getGridStringOperators } from "@mui/x-data-grid";

/**
 * 🔹 Extract searchable string from any type
 */
export const getTargetValue = (val) => {
  if (val === null || val === undefined) return "";

  if (typeof val === "object") {
    if (Array.isArray(val)) {
      return val.map(getTargetValue).join(" ");
    }

    if (val.name) return String(val.name).toLowerCase();
    if (val.label) return String(val.label).toLowerCase();

    return Object.values(val)
      .map(getTargetValue)
      .join(" ");
  }

  return String(val).toLowerCase();
};

/**
 * 🔹 Custom filter operators (GLOBAL)
 */
export const getCustomFilterOperators = () =>
  getGridStringOperators().map((operator) => {
    const originalGetApplyFilterFn = operator.getApplyFilterFn;

    return {
      ...operator,
      getApplyFilterFn: (filterItem) => {
        if (
          !filterItem.value &&
          operator.value !== "isEmpty" &&
          operator.value !== "isNotEmpty"
        ) {
          return null;
        }

        const filterValue = Array.isArray(filterItem.value)
          ? filterItem.value.map((v) => String(v).toLowerCase())
          : String(filterItem.value).toLowerCase();

        const innerFilterFn = originalGetApplyFilterFn(filterItem);

        return (params) => {
          const cellValue = getTargetValue(params.value); // ✅ FIXED

          switch (operator.value) {
            case "contains":
              return cellValue.includes(filterValue);

            case "doesNotContain":
              return !cellValue.includes(filterValue);

            case "equals":
              return cellValue === filterValue;

            case "doesNotEqual":
              return cellValue !== filterValue;

            case "startsWith":
              return cellValue.startsWith(filterValue);

            case "endsWith":
              return cellValue.endsWith(filterValue);

            case "isEmpty":
              return cellValue.trim() === "";

            case "isNotEmpty":
              return cellValue.trim() !== "";

            case "isAnyOf":
              return Array.isArray(filterValue)
                ? filterValue.some((val) => cellValue.includes(val))
                : false;

            default:
              return innerFilterFn
                ? innerFilterFn({ ...params, value: cellValue })
                : true;
          }
        };
      },
    };
  });

/**
 * 🔹 Apply filter logic to columns
 */
export const applyCustomFilterOperators = (columns) => {
  const operators = getCustomFilterOperators();

  return columns.map((col) => ({
    ...col,
    filterOperators: col.filterOperators || operators, // allow override
  }));
};
