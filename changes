  const handleIndicatorChange = (sIdx, iIdx, key, value, extra = {}) => {
    return setSectionsByType((prev) => {
      const sections = prev[currentType];
      const originalSection = sections[sIdx];

      if (
        key === "active" &&
        value === true &&
        originalSection.active === false
      ) {
        return prev;
      }

      const list = [...sections];
      const section = { ...originalSection };
      list[sIdx] = section;

      const indicators = [...section.indicators];
      section.indicators = indicators;

      const indicator = { ...indicators[iIdx] };
      indicators[iIdx] = indicator;

      if (key === "targetsReset") {
        indicator.targets = value; // {} or []
        setFieldErrors((prev) => {
          const next = { ...prev };
          Object.keys(next).forEach((k) => {
            if (k.startsWith(`${currentType}_${sIdx}_${iIdx}_targets_`)) {
              delete next[k];
            }
          });
          return next;
        });
        return { ...prev, [currentType]: list };
      }

      if (key === "targets") {
        const { targetKey, newValue, strict = false } = extra;
        const unitType = indicator.unit;
        const isSpecialUnit = unitType === 9 || unitType === 10; // 9=range, 10=ratio

        const nextTargets = {
          ...(indicator.targets || {}),
          [targetKey]: newValue,
        };
        if (
          indicator.measurementType === 2 &&
          !isSpecialUnit &&
          !isSpecialUnit
        ) {
          const freq = indicator.frequency;
          const freqKeys = frequencyKeysMap[freq] || [];
          const keysToSum = freqKeys.length
            ? freqKeys
            : Object.keys(nextTargets);
          const isNational = indicator.measurementArea === 2;

          if (isNational) {
            const total = keysToSum.reduce(
              (sum, k) => sum + toInt(nextTargets[k]),
              0,
            );
            const maxLimit = toInt(indicator.preTarget);

            const allFilled = keysToSum.every((k) => {
              const v = nextTargets[k];
              if (v === undefined || v === null) return false;
              return String(v).trim() !== "";
            });

            const isValidDuringTyping = total <= maxLimit;
            const isValidOnBlur = allFilled && total === maxLimit;
            const isValid = strict ? isValidOnBlur : isValidDuringTyping;

            // 🔑 include currentType to disambiguate keys
            setTargetLimitError((prevErr) => {
              const updated = { ...prevErr };
              keysToSum.forEach(
                (k) => delete updated[`${currentType}_${sIdx}_${iIdx}_${k}`],
              );
              if (!isValid) {
                keysToSum.forEach((k) => {
                  updated[`${currentType}_${sIdx}_${iIdx}_${k}`] = true;
                });
              }
              return updated;
            });

            // (Optional) inline helper text in fieldErrors (also type-aware)
            // setFieldErrors((prev) => {
            //   const next = { ...prev };
            //   const msg = !isValid
            //     ? `Sum ${total} must ${strict ? "equal" : "not exceed"} ${maxLimit}`
            //     : undefined;
            //   keysToSum.forEach((k) => {
            //     const key = `${currentType}_${sIdx}_${iIdx}_targets_${k}`;
            //     if (msg) next[key] = msg; else delete next[key];
            //   });
            //   return next;
            // });
          }
        }

        indicator.targets = nextTargets;
      } else {
        indicator[key] = value;

        if (key === "measurementType") {
          indicator.unit = value === 1 ? 8 : "";
        }

        if (key === "preTarget" && indicator.id === undefined) {
          indicator["prePreTarget"] = value;
        }
      }

      return { ...prev, [currentType]: list };
    });
  };
  const handleSaveDraft = async () => {
