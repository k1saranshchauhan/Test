import { useState, useCallback } from "react";

/**
 * Custom hook to manage individual bulk forward records.
 */
export const useBulkForwardManager = (initialRecords = []) => {
  // Records state: [{ submissionId, documents: {Revised, Hindi, Snippet}, remarks, isValid }]
  const [records, setRecords] = useState(
    initialRecords.map((r) => ({ ...r, isValid: false }))
  );

  /**
   * Save/Update a single record
   * recordData = { submissionId, documents: {...}, remarks }
   */
  const saveRecord = useCallback((recordData) => {
    setRecords((prev) =>
      prev.map((r) =>
        r.submissionId === recordData.submissionId
          ? { ...recordData, isValid: validateRecord(recordData) }
          : r
      )
    );
  }, []);

  /**
   * Validate a record
   */
  const validateRecord = (recordData) => {
    const { documents = {}, remarks = "" } = recordData;

    // Check mandatory documents
    const hasRevised = documents.revised?.length > 0;
    const hasHindi = documents.hindi?.length > 0;
    const hasSnippet = documents.snippet?.length > 0;

    // Check remarks
    const hasRemarks = remarks?.trim().length > 0;

    return hasRevised && hasHindi && hasSnippet && hasRemarks;
  };

  /**
   * Check if all records are valid
   */
  const areAllRecordsValid = records.every((r) => r.isValid);

  /**
   * Prepare payload for bulk forward
   * returns { submissionId: recordData }
   */
  const prepareBulkForwardPayload = () => {
    const payload = {};
    records.forEach((r) => {
      if (r.isValid) {
        payload[r.submissionId] = {
          documents: r.documents,
          remarks: r.remarks,
        };
      }
    });
    return payload;
  };

  return {
    records,
    saveRecord,
    areAllRecordsValid,
    prepareBulkForwardPayload,
  };
};
