import React, { useState, useEffect, useRef } from "react";
import {
  Box,
  Typography,
  TextField,
  Button,
  CircularProgress,
  Grid,
  Divider,
  Card,
  Paper,
  Stack,
} from "@mui/material";
import AddIcon from "@mui/icons-material/Add";
import SearchIcon from "@mui/icons-material/Search";
import RestartAltIcon from "@mui/icons-material/RestartAlt";
import { DataGrid, useGridApiRef } from "@mui/x-data-grid";
import apiClient from "@/utils/apiClient";
import ExportCsvButton from "../ExportCSV";
import Ministry from "../ModalsFields/Ministry";
import AddRecordDialog from "./AddRecordDialog";
import { getMasterColumns } from "../UnifiedMastersDataGridTables";
import { deepSearch, generateRowsForColumns } from "@/utils/unifiedHelpers";
import { getMasterExampleRow } from "../UnifiedMastersDataGridRows";
import { ColumnReorderManager } from "@/utils/columnReorderManager";
import { useDispatch, useSelector } from "react-redux";
import {
  validateDepartmentFields,
  validateIndicatorFields,
} from "../ModalsFields/Validation";
import { setError, setSuccess } from "@/store/slices/errorSlice";
import Department from "../ModalsFields/Department";
import { CustomAutoCompleteWithoutFormik } from "../CustomAutoCompleteWithoutFormik";
import MainFormHeader from "../../DashboardUI/MainFormHeader";
import Indicator from "../ModalsFields/Indicator";
import CommonViewMasterDialog from "../commonViewProfileDialog";
import { usePrivileges } from "@/src/context/privilegeContextProvider";
import { SECTION_KEY } from "@/src/constants/privilegesSectionKeys/sectionKeys";
import AuditDataGrid from "../../AuditDetailsDialog";
import { AuditTrailDialog } from "../../audit";
import axios from "axios";
import { applyCustomLogic } from "@/utils/niti/datagridUtils";

const IndicatorMaster = ({ masterState }) => {
  const {
    newRow,
    handleNewChange,
    isViewing,
    isEditing,
    setIsEditing,
    setIsViewing,
    editId,
    setEditId,
    setNewRow,
    handleEdit,
    setSchemeData,
    urlModal,
    handleSwitchChange,
    setParentRows,
    selected,
    jsonData,
    sdgNames,
    setErrors,
    associatedFrameworks,
    targetGroups,
    showAccordion,
    setShowAccordion,
    handleJsonDataChange,
    initialUploadDocuments,
    uploadMultipleFiles,
    errors,
    statementFilters,
  } = masterState;

  const dispatch = useDispatch();
  const [ministries, setMinistries] = useState([]);
  const [departments, setDepartments] = useState([]);
  const [schemes, setSchemes] = useState([]);
  const [isSubSchemes, setIsSubSchemes] = useState([
    { id: 1, name: "Yes" },
    { id: 2, name: "No" },
  ]);
  const [statementTypes, setStatementTypes] = useState([
    { id: 1, name: "Output" },
    { id: 2, name: "Outcome" },
  ]);
  const [selectedMinistries, setSelectedMinistries] = useState([]);
  const [selectedDepartments, setSelectedDepartments] = useState([]);
  const [selectedSchemes, setSelectedSchemes] = useState([]);
  const [selectedIsSubScheme, setSelectedIsSubScheme] = useState(null);
  const [selectedStatement, setSelectedStatement] = useState();
  const [indicators, setIndicators] = useState([]);
  const [filteredIndicators, setFilteredIndicators] = useState([]);
  const [indicatorList, setIndicatorList] = useState([
    {
      indicatorType: "",
      indicatorName: "",
      measurementType: null,
      unit: null,
      scale: null,
      measurementArea: null,
      indicatorRise: null,
      sdg: null,
      category: null,
      period: null,
    },
  ]);
  const [loading, setLoading] = useState(true);
  const [auditParams, setAuditParams] = useState({});
  const [search, setSearch] = useState("");
  const [auditDialogOpen, setAuditDialogOpen] = useState(false);
  const apiRef = useGridApiRef();
  const [allOomfMastersData, setAllOomfMastersData] = useState({});
  const [indicatorMasterflag, setIndicatorMasterflag] = useState(false);
  const [paginationModel, setPaginationModel] = useState({
    page: 0, // MUI is 0-based
    pageSize: 10, // number of rows per page
  });
  const [totalRows, setTotalRows] = useState(0);
  const abortRef = useRef(null);
  const inFlightRef = useRef(false);
  const firstLoadRef = useRef(true);
  const filterSyncRef = useRef(false); // Track if we've synced filters from parent
  const {
    mappedPrivileges,
    hasAddAccess,
    hasEditAccess,
    hasViewAccess,
    hasAuditTrailViewAccess,
    refresh,
  } = usePrivileges(SECTION_KEY.INDICATORS);
  const userData = useSelector((state) => state.config.userData);
  const handleViewAuditTrail = async (row) => {
    if (!row?.id || !mappedPrivileges?.sectionId) return;

    setAuditParams({
      auditableId: String(row.id),
      sectionId: mappedPrivileges.sectionId,
    });
    setAuditDialogOpen(true);
  };
  const actionsConfig = React.useMemo(
    () => ({
      hasAddAccess,
      hasEditAccess,
      hasViewAccess,
      hasAuditTrailViewAccess,
      handleEdit,
      handleViewAuditTrail,
      setIsViewing,
      urlModal,
      setSchemeData,
    }),
    [
      hasAddAccess,
      hasEditAccess,
      hasViewAccess,
      handleEdit,
      hasAuditTrailViewAccess,
      setIsViewing,
      urlModal,
      setSchemeData,
    ],
  );

  const userMinistryIds = userData?.userRelationships[0]?.ministryIds;
  const userDepartmentIds = userData?.userRelationships[0]?.departmentIds;
  const userSchemeIds = userData?.userRelationships[0]?.schemeIds;
  const toggleSeqRef = useRef(0);
       useEffect(() => {
         console.log("indic::", indicatorList);
       }, []);

  // Sync filters from parent OutputOutcomeMaster when in indicator view
  // useEffect(() => {
  //   if (statementFilters && statementFilters.isIndicatorView && !filterSyncRef.current) {
  //     filterSyncRef.current = true;
      
  //     if (statementFilters.selectedMinistries?.length > 0) {
  //       setSelectedMinistries(statementFilters.selectedMinistries);
  //     }
  //     if (statementFilters.selectedDepartments?.length > 0) {
  //       setSelectedDepartments(statementFilters.selectedDepartments);
  //     }
  //     if (statementFilters.selectedSchemes?.length > 0) {
  //       setSelectedSchemes(statementFilters.selectedSchemes);
  //     }
  //     if (statementFilters.selectedIsSubScheme) {
  //       setSelectedIsSubScheme(statementFilters.selectedIsSubScheme);
  //     }
  //     if (statementFilters.selectedStatement) {
  //       setSelectedStatement(statementFilters.selectedStatement);
  //     }
  //   }
  // }, [statementFilters?.isIndicatorView]);
useEffect(() => {
  if (statementFilters && statementFilters.isIndicatorView && !filterSyncRef.current) {
    
    if (statementFilters.selectedMinistries?.length > 0) {
      setSelectedMinistries(statementFilters.selectedMinistries);
    }
    if (statementFilters.selectedDepartments?.length > 0) {
      setSelectedDepartments(statementFilters.selectedDepartments);
    }
    if (statementFilters.selectedSchemes?.length > 0) {
      setSelectedSchemes(statementFilters.selectedSchemes);
    }
    if (statementFilters.selectedIsSubScheme) {
      setSelectedIsSubScheme(statementFilters.selectedIsSubScheme);
    }
    if (statementFilters.selectedStatement) {
      setSelectedStatement(statementFilters.selectedStatement);
    }

    // ✅ Delay marking sync complete
    setTimeout(() => {
      filterSyncRef.current = true;
    }, 0);
  }
}, [statementFilters?.isIndicatorView]);
  useEffect(() => {
    // 🔥 Skip FIRST RUN
    if (firstLoadRef.current) {
      firstLoadRef.current = false;
      return;
    }

    const handle = setTimeout(() => {
      if (!search?.trim() || search.trim().length >= 3)
        fetchIndicators({
          page: paginationModel.page,
          pageSize: paginationModel.pageSize,
        });
    }, 400); // debounce 400ms

    return () => {
      clearTimeout(handle);
    };
  }, [search]);
  //helper
  const pickIdName = (obj) => {
    if (!obj) return null;
    return { id: obj.id, name: obj.name };
  };

  // 🔹 Fetch Sectors
  const fetchMinistries = async () => {
    try {
      const response = await apiClient.post("api/dynamic-model-details/data", {
        modelName: "ministry",
        filters: userData?.userRelationships?.[0]?.ministryIds?.length
          ? {
              where: {
                id: {
                  in: userData?.userRelationships?.[0]?.ministryIds || [],
                },
                status: true,
              },
            } // ✅ filter by userData
          : {}, // ✅ else fetch all
      });

      const { data } = response.data || {};
      const formattedData = data?.map((item) => ({
        id: item?.id,
        name: item?.name,
        associatedFramework: item?.jsonData?.associatedFramework,
      }));
      setMinistries(formattedData || []);
    } catch (error) {
      console.error("Error fetching ministries:", error);
      setMinistries([]);
    }
  };
  const fetchDepartments = async (selectedMinistryIds = []) => {
    setLoading(true);
    try {
      const response = await apiClient.post(
        "api/master/get-departments-for-ministry",
        { ministryIds: selectedMinistryIds || [] },
      );

      const filteredRes = response?.data?.data || [];
      const res = filteredRes?.map((item) => ({
        id: item?.id,
        name: item?.name,
        associatedFramework: item?.jsonData?.associatedFramework,
      }));

      // ✅ Step 1: Extract user-allowed department IDs
      const allowedDeptIds =
        userData?.userRelationships?.[0]?.departmentIds || [];

      // ✅ Step 2: Apply filtering if user has department restrictions
      const filteredDepartments =
        allowedDeptIds.length > 0
          ? res.filter((dept) => allowedDeptIds.includes(dept.id))
          : res;
      setDepartments(filteredDepartments);

      // ✅ Step 3: Auto-select if there’s only one allowed department
      if (filteredDepartments.length === 1) {
        const onlyDept = filteredDepartments;
        setSelectedDepartments(onlyDept);
      }
    } catch (err) {
      console.error("Error fetching departments:", err);
      setDepartments([]);
    } finally {
      setLoading(false);
    }
  };

  const fetchSchemes = async (selectedDepartmentIds = []) => {
    setLoading(true);
    try {
      const response = await apiClient.post(
        "api/master/get-schemes-for-departments",
        { departmentIds: selectedDepartmentIds || [] },
      );

      const filteredRes = response?.data?.data || [];
      const res = filteredRes?.map((item) => ({
        id: item?.id,
        name: item?.name,
        associatedFramework: item?.jsonData?.associatedFramework,
      }));

      // ✅ Step 1: Extract user-allowed department IDs
      const allowedSchemeIds =
        userData?.userRelationships?.[0]?.schemeIds || [];

      // ✅ Step 2: Apply filtering if user has department restrictions
      const filteredSchemes =
        allowedSchemeIds.length > 0
          ? res.filter((scheme) => allowedSchemeIds.includes(scheme.id))
          : res;
      setSchemes(filteredSchemes);

      // ✅ Step 3: Auto-select if there’s only one allowed department
      if (filteredSchemes.length === 1) {
        const onlyScheme = filteredSchemes;
        setSelectedSchemes(onlyScheme);
      }
    } catch (err) {
      console.error("Error fetching schemes:", err);
      setSchemes([]);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    const selectedMinistryIds =
      selectedMinistries?.map((item) => item?.id) || [];
    setSelectedDepartments([]);

    // Fetch departments for selected ministries
    fetchDepartments(selectedMinistryIds);
  }, [selectedMinistries]);

  useEffect(() => {
    const selectedDepartmentIds =
      selectedDepartments?.map((item) => item?.id) || [];
    setSelectedSchemes([]);

    // Fetch departments for selected ministries
    fetchSchemes(selectedDepartmentIds);
  }, [selectedDepartments]);
  const fetchAllMastersData = async () => {
    try {
      const response = await apiClient.get(`api/master/all-oomf-masters`);
      setAllOomfMastersData(response?.data?.data);
    } catch (error) {
      console.error("Failed to fetch master data:", error);
    }
  };

  const fetchIndicators = async ({
    page = paginationModel.page,
    pageSize = paginationModel.pageSize,
    isReset = false,
  } = {}) => {
    setLoading(true);
    // 💥 SAFE & CORRECT ABORT
    if (
      inFlightRef.current &&
      abortRef.current &&
      !abortRef.current.signal.aborted
    ) {
      abortRef.current.abort();
    }

    abortRef.current = new AbortController();
    const signal = abortRef.current.signal;
    inFlightRef.current = true;

    const apiPage = page + 1; // backend needs 1-based

    const selectedMinistryIds = isReset
      ? userMinistryIds
      : selectedMinistries?.map((item) => item?.id);

    const selectedDepartmentIds = isReset
      ? userDepartmentIds
      : selectedDepartments?.map((item) => item?.id);

    const selectedSchemeIds = isReset
      ? userSchemeIds
      : selectedSchemes?.map((item) => item?.id);

    const isSubScheme = isReset
      ? null
      : !selectedIsSubScheme?.name
        ? null
        : selectedIsSubScheme.name.trim() === "Yes";

    const statementType = isReset
      ? null
      : selectedStatement?.name?.trim() || "";
    const payload = {
      ministryIds: selectedMinistryIds,
      departmentIds: selectedDepartmentIds,
      schemeIds: selectedSchemeIds,
      isSubScheme,
      indicatorType: statementType?.toLowerCase().trim(),
      page: apiPage,
      limit: pageSize,
      searchQuery: search.trim(),
      searchParams: [],
    };

    try {
      const response = await apiClient.post(
        "api/master/get-all-indicators",
        payload,
        { signal, throwIfAborted: false },
      );
      const { data: rows, total } = response?.data?.data || {};
      setTotalRows(total ?? 0);

      if (!rows?.length) {
        setIndicators([]);
        setFilteredIndicators([]);
        return;
      }

      // Global Serial Number (correct)
      const offset = page * pageSize;
      const rowsWithSerial = rows.map((row, index) => ({
        ...row,
        serial: offset + index + 1,
      }));

      // Transform rows to match DataGrid columns
      const masterRow = getMasterExampleRow(urlModal) || {};
      const finalRows = generateRowsForColumns(
        rowsWithSerial,
        gridColumns,
        masterRow,
      );

      setIndicators(finalRows);
      setFilteredIndicators(finalRows);
    } catch (err) {
      if (axios.isCancel(err) || err.code === "ERR_CANCELED") {
        // 🔇 Silent — do not log, do not show error
        return;
      }

      console.error("Error fetching indicators:", err);
    } finally {
      inFlightRef.current = false; // 💥 finished
      setLoading(false);
    }
  };

  async function handleIndicatorSubmit() {
    if (urlModal === "indicator") {
      // Validate common fields
      const validationErrors = validateIndicatorFields(newRow, jsonData || {});
      // Validate indicators array
      const indicatorErrors = {};
      indicatorList.forEach((indicator, index) => {
        if (!indicator.indicatorType) {
          indicatorErrors[`indicatorList[${index}].indicatorType`] = "Indicator Type is required";
        }
        if (!indicator.indicatorName) {
          indicatorErrors[`indicatorList[${index}].indicatorName`] = "Indicator Name is required";
        }
        if (!indicator.measurementType) {
          indicatorErrors[`indicatorList[${index}].measurementType`] = "Measurement Type is required";
        }
        if (!indicator.unit) {
          indicatorErrors[`indicatorList[${index}].unit`] = "Unit is required";
        }
        if (indicator.measurementType?.id !== 1 && !indicator.scale) {
          indicatorErrors[`indicatorList[${index}].scale`] = "Scale is required";
        }
        if (!indicator.measurementArea) {
          indicatorErrors[`indicatorList[${index}].measurementArea`] = "Measurement Area is required";
        }
        if (!indicator.indicatorRise) {
          indicatorErrors[`indicatorList[${index}].indicatorRise`] = "Indicator Rise is required";
        }
        if (!indicator.period) {
          indicatorErrors[`indicatorList[${index}].period`] = "Period is required";
        }
      });
      const allErrors = { ...validationErrors, ...indicatorErrors };
      setErrors(allErrors);

      if (Object.keys(allErrors).length > 0) {
        dispatch(setError("Please fill required fields before submitting."));
        return;
      }
      try {
        const cleanedJsonData = {
          ...jsonData,
          ministry: pickIdName(jsonData?.ministry),
          department: pickIdName(jsonData?.department),
          scheme: pickIdName(jsonData?.scheme),
          subScheme: pickIdName(jsonData?.subScheme),
        };
        let payload;

        if(editId){
          payload = {
            name: indicatorList[0]?.indicatorName?.trim(),
            parentId: newRow?.parentId || null,
            status: newRow?.status,
            parentScheme: newRow?.parentScheme,
            jsonData: {
              ...cleanedJsonData,
              indicatorType:indicatorList[0]?.indicatorType,
              category: indicatorList[0]?.category,
              indicatorRise: indicatorList[0]?.indicatorRise,
              measurementArea: indicatorList[0]?.measurementArea,
              measurementType: indicatorList[0]?.measurementType,
              period: indicatorList[0]?.period,
              scale: indicatorList[0]?.scale,
              unit: indicatorList[0]?.unit,
              sdg: indicatorList[0]?.sdg,
            },
            createdBy: userData?.id,
          };
        }else{
          payload = {
          jsonData: cleanedJsonData,
          indicators: indicatorList,
          createdBy: userData?.id,
        };
        }

        if (editId) {
          payload.id = editId;
          payload.updatedBy = userData?.id;
        }

        const response = await apiClient.post(
          `api/master/create-or-update-indicator`,
          payload,
        );
        const result = response?.data;

        if (!result?.success) {
          dispatch(setError(result?.message || "Failed to save Indicator"));
          return;
        }

        dispatch(setSuccess(result?.message));
        setShowAccordion(false);
        setNewRow({
          status: true,
        });
        setIndicatorList([{ indicatorType: "", indicatorName: "", measurementType: "", unit: "", scale: "", measurementArea: "", indicatorRise: "", sdg: "", category: "", period: "" }]);
        setEditId(null);
        setErrors({});

        fetchIndicators();
      } catch (error) {
        console.error("Failed to add/update Indicator:", error);
        dispatch(setError("Server error while saving Indicator"));
      }
    }
  }

  useEffect(() => {
    fetchMinistries();
    fetchAllMastersData();
    fetchIndicators();
  }, []);

  const gridColumns = React.useMemo(() => {
    return getMasterColumns(urlModal, actionsConfig);
  }, [urlModal, actionsConfig]);

  // // 🔹 Search Filter
  // useEffect(() => {
  //   const trimmedSearch = (search || "").trim().toLowerCase();
  //   if (!trimmedSearch) {
  //     setFilteredIndicators(indicators || []);
  //     return;
  //   }
  //   const filtered = (indicators || []).filter((item) =>
  //     deepSearch(item, trimmedSearch),
  //   );
  //   setFilteredIndicators(filtered);
  // }, [search, indicators]);

  // 🔹 Column Management

  const handleSearch = () => {
    fetchIndicators();
  };
  const [columns, setColumns] = useState([]);
  const [columnVisibilityModel, setColumnVisibilityModel] = useState({});

  useEffect(() => {
    setColumns(gridColumns);

    const visibilityModel = {};
    gridColumns.forEach((col) => {
      visibilityModel[col.field] = true;
    });

    setColumnVisibilityModel(visibilityModel);
  }, [gridColumns]);

  const modalState = {
    newRow,
    isViewing,
    errors,
    handleNewChange,
    ministryNames: ministries,
    allOomfMastersData,
    handleSwitchChange,
    jsonData: newRow.jsonData,
    initialUploadDocuments: newRow?.jsonData?.supportingDocuments,
    uploadMultipleFiles,
    handleJsonDataChange,
    indicatorList,
    setIndicatorList,
  };

  useEffect(() => {
  if (
    !statementFilters?.selectedMinistries?.length ||
    ministries.length === 0
  )
    return;

  const matched = ministries.filter(opt =>
    statementFilters.selectedMinistries.some(sel => sel.id === opt.id)
  );

  if (matched.length) {
    setSelectedMinistries(matched);
  }
}, [ministries]);

useEffect(() => {
  if (
    !statementFilters?.selectedDepartments?.length ||
    departments.length === 0
  )
    return;

  const matched = departments.filter(opt =>
    statementFilters.selectedDepartments.some(sel => sel.id === opt.id)
  );

  if (matched.length) {
    setSelectedDepartments(matched);
  }
}, [departments]);

useEffect(() => {
  if (
    !statementFilters?.selectedSchemes?.length ||
    schemes.length === 0
  )
    return;

  const matched = schemes.filter(opt =>
    statementFilters.selectedSchemes.some(sel => sel.id === opt.id)
  );

  if (matched.length) {
    setSelectedSchemes(matched);
  }
}, [schemes]);

useEffect(() => {
  if (
    !statementFilters?.indicatorToggleSeq ||
    statementFilters.indicatorToggleSeq === toggleSeqRef.current
  ) {
    return;
  }

  toggleSeqRef.current = statementFilters.indicatorToggleSeq;

  // ✅ Apply filters
  setSelectedMinistries(statementFilters.selectedMinistries || []);
  setSelectedDepartments(statementFilters.selectedDepartments || []);
  setSelectedSchemes(statementFilters.selectedSchemes || []);
  setSelectedIsSubScheme(statementFilters.selectedIsSubScheme || null);
  setSelectedStatement(statementFilters.selectedStatement || null);

  // ✅ AUTO SEARCH (after state flush)
  setTimeout(() => {
    fetchIndicators({
      page: 0,
      pageSize: paginationModel.pageSize,
    });
  }, 0);
}, [statementFilters?.indicatorToggleSeq]);

useEffect(() => {
  // ❌ Skip first load (already handled elsewhere)
  if (firstLoadRef.current) return;

  // ❌ Avoid firing while filters are being synced initially
  if (!filterSyncRef.current) return;

  const timeout = setTimeout(() => {
    fetchIndicators({
      page: 0,
      pageSize: paginationModel.pageSize,
    });
  }, 300); // small debounce

  return () => clearTimeout(timeout);
}, [
  selectedMinistries,
  selectedDepartments,
  selectedSchemes,
  selectedIsSubScheme,
  selectedStatement,
]);

  return (
    <Box>
      <Card
        elevation={3}
        sx={{
          p: 3,
          mb: 4,
          borderRadius: 3,
        }}
      >
        <MainFormHeader title="Filter Indicators by Ministries and Departments" />
        <Divider sx={{ my: 2 }} />

        <Grid container spacing={2} alignItems="center">
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="ministries"
              multiple
              selectAll
              label="Choose Ministries"
              options={ministries}
              value={selectedMinistries ?? []}
              fullWidth
              onChange={(event, newValue) =>
                setSelectedMinistries(newValue || [])
              }
            />
          </Grid>
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="departments"
              multiple
              selectAll
              label="Choose Departments"
              options={departments}
              value={selectedDepartments ?? []}
              fullWidth
              onChange={(event, newValue) =>
                setSelectedDepartments(newValue || [])
              }
            />
          </Grid>
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="schemes"
              multiple
              selectAll
              label="Choose Schemes"
              options={schemes}
              value={selectedSchemes ?? []}
              fullWidth
              onChange={(event, newValue) => setSelectedSchemes(newValue || [])}
            />
          </Grid>
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="isSubScheme"
              multiple={false}
              selectAll={false}
              label="Choose Is Sub Scheme"
              options={isSubSchemes}
              value={selectedIsSubScheme ?? null}
              fullWidth
              onChange={(event, newValue) =>
                setSelectedIsSubScheme(newValue || null)
              }
            />
          </Grid>
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="statementType"
              label="Choose Indicator Type"
              selectAll={false}
              multiple={false}
              options={statementTypes}
              value={selectedStatement ?? {}}
              fullWidth
              onChange={(event, newValue) =>
                setSelectedStatement(newValue || {})
              }
            />
          </Grid>

          <Grid size={{ xs: 12 }}>
            <Stack
              direction="row"
              spacing={2}
              justifyContent="center"
              sx={{ mt: 2 }}
            >
              <Button
                variant="contained"
                color="primary"
                startIcon={<SearchIcon />}
                onClick={handleSearch}
                sx={{ minWidth: 150 }}
              >
                Search
              </Button>
              <Button
                variant="outlined"
                sx={{ color: "#45154F" }}
                startIcon={<RestartAltIcon />}
                onClick={() => {
                  setSelectedMinistries([]);
                  setSelectedDepartments([]);
                  setSelectedSchemes([]);
                  setSelectedIsSubScheme(null);
                  setSelectedStatement({});
                  fetchIndicators({ isReset: true });
                }}
              >
                Reset
              </Button>
            </Stack>
          </Grid>
        </Grid>
      </Card>
      {/* Add/Edit Dialog */}
      <AddRecordDialog
        open={!isViewing ? showAccordion : false}
        onClose={() => {
          setShowAccordion(false);
          setNewRow({
            status: true, // Ensure Active by default
            // other fields...
          });
          setIndicatorList([
            {
              indicatorType: "",
              indicatorName: "",
              measurementType: null,
              unit: null,
              scale: null,
              measurementArea: null,
              indicatorRise: null,
              sdg: null,
              category: null,
              period: null,
            },
          ]);
          setEditId(null);
          setErrors({});
        }}
        onSubmit={handleIndicatorSubmit}
        urlModal={urlModal}
        isViewing={isViewing}
        isEditing={isEditing}
        selected={selected}
      >
        <Indicator modalState={modalState} />
      </AddRecordDialog>

      {isViewing && (
        <CommonViewMasterDialog
          open={showAccordion}
          handleClose={() => {
            setShowAccordion(false);
            setNewRow({
              status: true, // Ensure Active by default
              // other fields...
            });
            setEditId(null);
            setErrors({});
          }}
          title="Indicator Details"
          data={{
            ...selected,
            subScheme: selected?.subScheme?.name,
            indicatorType: selected?.indicatorType
              ? selected.indicatorType.charAt(0).toUpperCase() +
                selected.indicatorType.slice(1)
              : selected?.indicatorType,
          }}
          exampleRow={gridColumns}
        />
      )}
      <Paper
        elevation={3}
        sx={{ p: 2, borderRadius: 3, backgroundColor: "#ffffff" }}
      >
        {/* Header */}
        <Box
          sx={{
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            mb: 2,
            mt: 2,
            flexWrap: "wrap",
            gap: 2,
          }}
        >
          {/* Left: Search + Export */}
          <Box
            sx={{
              display: "flex",
              gap: 2,
              flexDirection: { xs: "column", sm: "row" },
            }}
          >
            <Box display="flex" alignItems="center">
              <SearchIcon sx={{ mr: 1 }} />
              <TextField
                size="small"
                placeholder="Search..."
                value={search}
                disabled={loading ? true : false}
                onChange={(e) => setSearch(e.target.value)}
                error={search.trim().length > 0 && search.trim().length < 3}
                helperText={
                  search.trim().length > 0 && search.trim().length < 3
                    ? "Enter at least 3 characters to search"
                    : ""
                }
                sx={{ width: { xs: "100%", sm: "auto" } }}
              />
            </Box>

            <ExportCsvButton
              apiRef={apiRef}
              modal={urlModal}
              columns={columns}
              // rows={filteredIndicators}
              rows={filteredIndicators.map((row) => ({
                ...row,
                subScheme: row?.subScheme?.label || "",
              }))}
              columnVisibilityModel={columnVisibilityModel}
              fileName={urlModal}
            />
          </Box>

          {/* Right: Add Record Button */}
          {hasAddAccess && (
            <>
              {/*
              <Button
                variant="outlined"
                onClick={() => {
                  setIsEditing(false);
                  setIsViewing(false);
                  setShowAccordion(true);
                }}
                disabled={!selected}
                startIcon={<AddIcon />}
                sx={{ whiteSpace: "nowrap" }}
              >
                Add Record in{" "}
                {`${urlModal
                  ?.replace(/([a-z])([A-Z])/g, "$1 $2")
                  ?.replace(/\b\w/g, (char) => char.toUpperCase())} Master`}
              </Button>
              */}
            </>
          )}
        </Box>
        <Box
          sx={{
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            mb: 2,
            mt: 2,
            flexWrap: "wrap", // responsive wrapping
            gap: 2,
          }}
        >
          {auditParams?.auditableId && auditParams?.sectionId && (
            // <AuditDataGrid
            //   {...auditParams}
            //   auditDialogOpen={auditDialogOpen}
            //   setAuditDialogOpen={setAuditDialogOpen}
            // />
            <AuditTrailDialog
              auditDialogOpen={auditDialogOpen}
              setAuditDialogOpen={setAuditDialogOpen}
              auditableId={auditParams.auditableId}
              sectionId={auditParams.sectionId}
            />
          )}
        </Box>

        <Box
          sx={{
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            mb: 2,
          }}
        >
          <MainFormHeader title="Indicators List" />
          <Divider sx={{ my: 2 }} />
          <ColumnReorderManager
            gridColumns={gridColumns}
            columns={columns}
            setColumns={setColumns}
            columnVisibilityModel={columnVisibilityModel}
            setColumnVisibilityModel={setColumnVisibilityModel}
          />
        </Box>

        {/* DataGrid */}
        {loading ? (
          <Box
            display="flex"
            justifyContent="center"
            alignItems="center"
            minHeight="300px"
          >
            <CircularProgress />
          </Box>
        ) : (
          <div style={{ height: 450, width: "100%" }}>
            {/* <DataGrid
              sortingOrder={["asc", "desc"]}
              rows={filteredIndicators}
              columns={columns}
              pageSizeOptions={[10, 20, 30, 40, 50, 100]} // ✅ replaces rowsPerPageOptions
              initialState={{
                pagination: {
                  paginationModel: { pageSize: 10, page: 0 }, // ✅ replaces pageSize
                },
              }}
              pagination
              disableSelectionOnClick
              //disableColumnFilter
              columnVisibilityModel={columnVisibilityModel}
              onColumnVisibilityModelChange={(newModel) =>
                setColumnVisibilityModel(newModel)
              }
            /> */}
            <DataGrid
              apiRef={apiRef}
              rows={filteredIndicators}
              columns={applyCustomLogic(columns)}
              rowCount={totalRows} // 🔥 total rows from backend
              paginationMode="server" // 🔥 important
              paginationModel={paginationModel}
              onPaginationModelChange={(model) => {
                setPaginationModel(model);
                fetchIndicators({ page: model.page, pageSize: model.pageSize }); // <— pass fresh values
              }}
              pageSizeOptions={[10, 20, 30, 40, 50, 100]}
              sortingOrder={["asc", "desc"]}
              disableSelectionOnClick
              columnVisibilityModel={columnVisibilityModel}
              onColumnVisibilityModelChange={(newValue) =>
                setColumnVisibilityModel(newValue)
              }
              localeText={{
                columnMenuSortAsc: "Sort as A to Z",
                columnMenuSortDesc: "Sort as Z to A",
              }}
            />
          </div>
        )}
      </Paper>
    </Box>
  );
};

export default IndicatorMaster;
