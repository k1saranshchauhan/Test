/**
 * Extracts the searchable string from a cell value.
 * Handles strings, numbers, and JSON objects (prioritizing 'name').
 */
const getTargetValue = (val) => {
  if (val === null || val === undefined) return "";

  // If it's an object (like your Organization or Framework objects)
  if (typeof val === "object" && !Array.isArray(val)) {
    if ("name" in val) {
      return String(val.name).toLowerCase();
    }
    // Fallback for objects without a 'name' key
    return Object.values(val)
      .map((v) => String(v))
      .join(" ")
      .toLowerCase();
  }

  // If it's an array (useful for "is any of" or multi-select data)
  if (Array.isArray(val)) {
    return val.map((item) => getTargetValue(item)).join(" ");
  }

  return String(val).toLowerCase();
};

export const dataGridFilterOperators = getGridStringOperators().map(
  (operator) => {
    const originalGetApplyFilterFn = operator.getApplyFilterFn;
    return {
      ...operator,
      getApplyFilterFn: (filterItem) => {
        // 1. Standard MUI check for empty filter values
        if (
          !filterItem.value &&
          operator.value !== "isEmpty" &&
          operator.value !== "isNotEmpty"
        ) {
          return null;
        }

        const filterValue = Array.isArray(filterItem.value)
          ? filterItem.value.map((v) => String(v).toLowerCase())
          : String(filterItem.value).toLowerCase();

        const innerFilterFn = originalGetApplyFilterFn(filterItem);

        return (params) => {
          // IMPORTANT: Pass params.value, not the whole params object
          const cellValue = getTargetValue(params);

          // Map logic for ALL common operators
          switch (operator.value) {
            case "contains":
              return cellValue.includes(filterValue);
            case "doesNotContain":
              return !cellValue.includes(filterValue);
            case "equals":
              return cellValue === filterValue;
            case "doesNotEqual":
              return cellValue !== filterValue;
            case "startsWith":
              return cellValue.startsWith(filterValue);
            case "endsWith":
              return cellValue.endsWith(filterValue);
            case "isEmpty":
              return cellValue.trim() === "";
            case "isNotEmpty":
              return cellValue.trim() !== "";
            case "isAnyOf":
              return (
                Array.isArray(filterValue) && filterValue.includes(cellValue)
              );
            default:
              /** * For any other operator, we pass our extracted string
               * into a mock params object to use MUI's internal logic.
               */
              return innerFilterFn
                ? innerFilterFn({ ...params, value: cellValue })
                : true;
          }
        };
      },
    };
  },
);

// 🔹 Common reusable renderer for object / array values
/**
 * 🔹 Universal render function for object/array/string values
 */
const getFileIcon = (filename) => {
  const ext = filename?.split(".").pop()?.toLowerCase();
  if (!ext) return <InsertDriveFileIcon sx={{ color: "gray" }} />;

  switch (ext) {
    case "pdf":
      return <PictureAsPdfIcon sx={{ color: "#D32F2F" }} />;
    case "xls":
    case "xlsx":
    case "csv":
      return <TableChartIcon sx={{ color: "#2E7D32" }} />;
    case "doc":
    case "docx":
    case "rtf":
      return <ArticleIcon sx={{ color: "#1565C0" }} />;
    case "ppt":
    case "pptx":
      return <SlideshowIcon sx={{ color: "#D44726" }} />; // Distinct color for PowerPoint
    case "png":
    case "jpg":
    case "jpeg":
    case "gif":
    case "bmp":
    case "tiff":
    case "webp":
      return <ImageIcon sx={{ color: "#FBC02D" }} />;
    case "txt":
    case "log":
      return <DescriptionIcon sx={{ color: "#6A1B9A" }} />;
    case "json":
    case "xml":
    case "html":
    case "css":
    case "js":
      return <CodeIcon sx={{ color: "#4A148C" }} />; // Icon for code/structured text
    case "mp3":
    case "wav":
    case "mp4":
    case "mpeg":
      return <FilePresentIcon sx={{ color: "#00838F" }} />; // Generic media icon
    case "zip":
    case "rar":
    case "7z":
      return <CompressedFileIcon sx={{ color: "#BF360C" }} />; // Icon for compressed files
    default:
      return <FilePresentIcon sx={{ color: "#78909C" }} />;
  }
};
const FILE_SERVER_URL = `${process.env.NEXT_PUBLIC_API_BASE_URL}api/public/download-file/`;
export const renderCellValue = (params) => {
  const val = params?.value ?? params?.row?.[params?.field];

  if (val === null || val === undefined) return "-";

  // 🔸 Handle arrays
  if (Array.isArray(val)) {
    if (val.length === 0) return "-";
    return val
      .map((v) => {
        if (typeof v === "object")
          return v?.name || v?.label || v?.frameworkName || "-";
        return v;
      })
      .join(", ");
  }

  // 🔸 Handle single objects
  if (typeof val === "object") {
    return val?.name || val?.label || "-";
  }

  // 🔸 Default (string, number, etc.)
  return val.toString();
};

