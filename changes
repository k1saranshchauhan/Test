const getOomfWorkflowSubmissionDocumentDownload = async (req, res) => {
  try {
    const requestedData = req.body;

    // Get buffer from your service
    const documentBuffer = await workflowService.getOomfWorkflowSubmissionDocument(requestedData);

    // Base filename
    const baseName = "oomf_workflow_document";
    const filename = `${baseName}.docx`;
    const encodedFilename = encodeURIComponent(filename); // encode for filename*

    // Set content type for Word document
    res.setHeader(
      "Content-Type",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
    );

    // Set safe Content-Disposition
    res.setHeader(
      "Content-Disposition",
      `attachment; filename="${filename}"; filename*=UTF-8''${encodedFilename}`
    );

    // Set content length
    res.setHeader("Content-Length", Buffer.byteLength(documentBuffer));

    // Send the file
    res.end(documentBuffer);
  } catch (error) {
    console.error("Error downloading OOMF workflow document:", error);
    res.status(500).json({
      status: 500,
      success: false,
      message: "Failed to download OOMF workflow document",
      data: null,
    });
  }
};
