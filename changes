"use client";

import React, { useState, useEffect, useMemo } from "react";
import {
  Box,
  TextField,
  Paper,
  InputAdornment,
  IconButton,
  Typography,
  Stack,
} from "@mui/material";
import { DataGrid, GridToolbarContainer, GridToolbarExport } from "@mui/x-data-grid";
import { Search, Clear, DragIndicator, Sort } from "@mui/icons-material";
import { DragDropContext, Droppable, Draggable } from "@hello-pangea/dnd";

const AdvancedDataGrid = ({
  data = [],
  columns = [],
  rowIdField = "id",
  enableReorder = true,
  searchPlaceholder = "Search and reorder...",
  onSelectionChange,
  checkboxSelection = true,
}) => {
  const [searchText, setSearchText] = useState("");
  const [rows, setRows] = useState(data);

  useEffect(() => {
    setRows(data);
  }, [data]);

  // 1. Better Search Engine (Handles nested data & dates)
  const filteredRows = useMemo(() => {
    const term = searchText.toLowerCase().trim();
    if (!term) return rows;
    return rows.filter((row) =>
      Object.values(row).some((val) => 
        val !== null && String(val).toLowerCase().includes(term)
      )
    );
  }, [rows, searchText]);

  // 2. Drag & Drop Logic
  const onDragEnd = (result) => {
    if (!result.destination) return;
    const items = Array.from(rows);
    const [reorderedItem] = items.splice(result.source.index, 1);
    items.splice(result.destination.index, 0, reorderedItem);
    setRows(items);
  };

  // 3. Columns with Drag Handle
  const finalColumns = useMemo(() => {
    const dragCol = {
      field: "drag_handle",
      headerName: "",
      width: 50,
      sortable: false,
      renderCell: () => (
        <DragIndicator sx={{ color: "action.disabled", cursor: "grab" }} />
      ),
    };
    return enableReorder ? [dragCol, ...columns] : columns;
  }, [columns, enableReorder]);

  // 4. Custom Draggable Row Component
  const DraggableRow = (props) => {
    const { row, index } = props;
    return (
      <Draggable draggableId={String(row[rowIdField])} index={index}>
        {(provided, snapshot) => (
          <div
            ref={provided.innerRef}
            {...provided.draggableProps}
            {...provided.dragHandleProps}
            style={{
              ...provided.draggableProps.style,
              backgroundColor: snapshot.isDragging ? "#f5f5f5" : "transparent",
              display: "contents", // Keeps DataGrid layout intact
            }}
          >
            {/* The actual DataGrid Row is rendered by the parent via the 'slots' prop */}
            {props.children}
          </div>
        )}
      </Draggable>
    );
  };

  return (
    <Paper elevation={2} sx={{ borderRadius: 2, overflow: "hidden", border: "1px solid #eee" }}>
      {/* Header Area */}
      <Box sx={{ p: 2, bgcolor: "white" }}>
        <Stack direction="row" justifyContent="space-between" alignItems="center">
          <Typography variant="subtitle1" fontWeight="bold" sx={{ display: 'flex', alignItems: 'center', gap: 1 }}>
            <Sort fontSize="small" /> Data Explorer
          </Typography>
          <TextField
            size="small"
            placeholder={searchPlaceholder}
            value={searchText}
            onChange={(e) => setSearchText(e.target.value)}
            sx={{ width: 300 }}
            InputProps={{
              startAdornment: <InputAdornment position="start"><Search fontSize="small" /></InputAdornment>,
              endAdornment: searchText && (
                <IconButton size="small" onClick={() => setSearchText("")}><Clear fontSize="small" /></IconButton>
              ),
            }}
          />
        </Stack>
      </Box>

      {/* Drag Context wrapping the Grid */}
      <DragDropContext onDragEnd={onDragEnd}>
        <Droppable droppableId="grid-droppable">
          {(provided) => (
            <Box ref={provided.innerRef} {...provided.droppableProps} sx={{ height: 500 }}>
              <DataGrid
                rows={filteredRows}
                columns={finalColumns}
                getRowId={(row) => row[rowIdField]}
                checkboxSelection={checkboxSelection}
                onRowSelectionModelChange={(ids) => onSelectionChange?.(ids)}
                disableRowSelectionOnClick
                hideFooterSelectedRowCount={false}
                slots={{
                  toolbar: () => (
                    <GridToolbarContainer sx={{ p: 1, borderBottom: '1px solid #eee' }}>
                      <GridToolbarExport />
                    </GridToolbarContainer>
                  ),
                }}
                sx={{
                  border: "none",
                  "& .MuiDataGrid-row:hover": { bgcolor: "#f9f9f9" },
                  "& .MuiDataGrid-columnHeaders": { bgcolor: "#fafafa", borderBottom: "2px solid #eee" },
                }}
              />
              {provided.placeholder}
            </Box>
          )}
        </Droppable>
      </DragDropContext>
    </Paper>
  );
};

export default AdvancedDataGrid;
