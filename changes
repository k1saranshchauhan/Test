import React, { useMemo } from "react";
import { Box, Typography, Table, TableHead, TableRow, TableCell, TableBody } from "@mui/material";

// Simplified RenderTable component for this example
const RenderTable = ({ title, financialYears, rows }) => {
  return (
    <Box sx={{ ml: 4, mt: 2 }}>
      <Typography variant="subtitle2" sx={{ fontWeight: "bold", mb: 1 }}>
        {title}
      </Typography>
      <Table size="small">
        <TableHead>
          <TableRow>
            <TableCell>Indicator</TableCell>
            <TableCell>Unit</TableCell>
            <TableCell>Scale</TableCell>
            <TableCell>Frequency</TableCell>
            {financialYears.map((year) => (
              <TableCell key={year}>{year} BE</TableCell>
            ))}
            {financialYears.map((year) => (
              <TableCell key={year}>{year} AE</TableCell>
            ))}
          </TableRow>
        </TableHead>
        <TableBody>
          {rows.map((row, idx) => (
            <TableRow key={idx}>
              <TableCell>{row.indicatorName}</TableCell>
              <TableCell>{row.unitName}</TableCell>
              <TableCell>{row.scaleName}</TableCell>
              <TableCell>{row.frequencyName}</TableCell>
              {financialYears.map((year) => (
                <TableCell key={year}>0</TableCell>
              ))}
              {financialYears.map((year) => (
                <TableCell key={year}>0</TableCell>
              ))}
            </TableRow>
          ))}
        </TableBody>
      </Table>
    </Box>
  );
};

const ProgressTable = ({ data }) => {
  const groupedByMinistry = useMemo(() => {
    const grouped = {};
    // Convert data object into array of schemes with year info
    Object.entries(data || {}).forEach(([year, schemes]) => {
      if (!Array.isArray(schemes)) return;
      schemes.forEach((scheme) => {
        const ministry = scheme.ministryId?.name || "Unknown Ministry";
        if (!grouped[ministry]) grouped[ministry] = [];
        grouped[ministry].push({ ...scheme, year });
      });
    });
    return grouped;
  }, [data]);

  return (
    <Box sx={{ p: 3, minHeight: "100vh", fontFamily: "Inter, sans-serif" }}>
      {Object.entries(groupedByMinistry).map(([ministry, groups]) => (
        <Box key={ministry}>
          <Typography
            variant="h5"
            sx={{ p: 2, color: "#45154F", fontWeight: "bold", mt: 4 }}
          >
            {ministry}
          </Typography>

          {/* Group by Department */}
          {Object.entries(
            groups.reduce((deptAcc, group) => {
              const dept = group.departmentId?.name || "Unknown Department";
              if (!deptAcc[dept]) deptAcc[dept] = [];
              deptAcc[dept].push(group);
              return deptAcc;
            }, {})
          ).map(([department, deptGroups]) => (
            <Box key={department}>
              <Typography
                variant="h6"
                sx={{ p: 2, color: "#45154F", fontWeight: "bold", mt: 2 }}
              >
                {department}
              </Typography>

              {/* Schemes under department */}
              {deptGroups.map((scheme, idx) => {
                // Flatten indicators for table rows
                const rows = [];
                scheme.indicatorData?.forEach((indData) => {
                  indData.sections?.forEach((section) => {
                    section.indicators?.forEach((ind) => {
                      rows.push({
                        indicatorName: ind.indicator?.name || "Unknown",
                        unitName: ind.unit?.name || "-",
                        scaleName: ind.scale?.name || "-",
                        frequencyName: ind.frequency?.name || "-",
                      });
                    });
                  });
                });

                // Use year keys for financialYears
                const financialYears = [scheme.year];

                return (
                  <RenderTable
                    key={scheme.schemeId?.id || idx}
                    title={scheme.schemeId?.name || scheme.name || "Unnamed Scheme"}
                    financialYears={financialYears}
                    rows={rows}
                  />
                );
              })}
            </Box>
          ))}
        </Box>
      ))}
    </Box>
  );
};

export default ProgressTable;
