const getOomfWorkflowSubmissionDocumentDownload = async (req, res) => {
  try {
    const requestedData = req.body;
 
    // Get buffer from your service
    const documentBuffer =
      await workflowService.getOomfWorkflowSubmissionDocument(requestedData);
 
    // Make sure the filename is clean (no trailing spaces or odd chars)
    const baseName = "oomf_workflow_document";
    const filename = `${baseName}.docx`;
 
    // Set safe headers
    res.setHeader(
      "Content-Type",
      "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
    );
 
    // Provide both filename and filename* for wide browser compatibility
    // RFC 5987: filename*=UTF-8''<url-encoded>
    const encoded = encodeURIComponent(filename);
    res.setHeader(
      "Content-Disposition",
      `attachment; filename="${filename}"; filename*=UTF-8''${encoded}`
    );
 
    // Ensure correct content length (Buffer.byteLength is safest)
    res.setHeader("Content-Length", Buffer.byteLength(documentBuffer));
 
    // Send the buffer as-is
    res.end(documentBuffer);
  } catch (error) {
    console.error("Error downloading OOMF workflow document:", error);
    res.status(500).json({
      status: 500,
      success: false,
      message: "Failed to download OOMF workflow document",
      data: null,
    });
  }
};
 
