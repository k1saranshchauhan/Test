"use client";

import React, { useState, useEffect, useMemo, useCallback } from "react";
import {
  Box,
  TextField,
  Paper,
  InputAdornment,
  IconButton,
  Typography,
  Stack,
  Divider,
} from "@mui/material";
import { DataGrid, GridToolbarContainer, GridToolbarExport } from "@mui/x-data-grid";
import { Search, Clear, DragIndicator, TableView } from "@mui/icons-material";
import { DragDropContext, Droppable, Draggable } from "@hello-pangea/dnd";

// 1. Move Slot components OUTSIDE the main component to prevent infinite loops
const CustomToolbar = () => (
  <GridToolbarContainer sx={{ p: 1, borderBottom: '1px solid', borderColor: 'divider' }}>
    <GridToolbarExport />
  </GridToolbarContainer>
);

const AdvancedDataGrid = ({
  data = [],
  columns = [],
  rowIdField = "id",
  enableReorder = true,
  searchPlaceholder = "Search and reorder...",
  onSelectionChange,
  checkboxSelection = true,
}) => {
  const [searchText, setSearchText] = useState("");
  const [rows, setRows] = useState(data);

  // Sync internal state when props change, but only if data actually changed
  useEffect(() => {
    setRows(data);
  }, [data]);

  // 2. Memoized Search (Prevents lag while typing)
  const filteredRows = useMemo(() => {
    const term = searchText.toLowerCase().trim();
    if (!term) return rows;
    
    return rows.filter((row) =>
      Object.values(row).some((val) => 
        val !== null && String(val).toLowerCase().includes(term)
      )
    );
  }, [rows, searchText]);

  // 3. Optimized Drag End Handler
  const onDragEnd = useCallback((result) => {
    if (!result.destination) return;
    
    const newItems = Array.from(rows);
    const [reorderedItem] = newItems.splice(result.source.index, 1);
    newItems.splice(result.destination.index, 0, reorderedItem);
    
    setRows(newItems);
  }, [rows]);

  // 4. Columns Definition
  const finalColumns = useMemo(() => {
    const baseCols = [
      {
        field: "drag_handle",
        headerName: "",
        width: 50,
        sortable: false,
        renderCell: () => (
          <DragIndicator sx={{ color: "action.disabled", cursor: "grab", mt: 1.5 }} />
        ),
      },
      ...columns.map(col => ({ ...col, flex: col.flex || 1 }))
    ];
    return enableReorder ? baseCols : columns;
  }, [columns, enableReorder]);

  return (
    <Paper 
      elevation={0} 
      variant="outlined" 
      sx={{ borderRadius: 2, overflow: "hidden", borderColor: "divider" }}
    >
      {/* Header / Search Bar */}
      <Box sx={{ p: 2, bgcolor: "background.paper" }}>
        <Stack direction="row" spacing={2} alignItems="center">
          <Box sx={{ display: 'flex', alignItems: 'center', gap: 1, flexGrow: 1 }}>
            <TableView color="primary" />
            <Typography variant="h6" fontWeight="600">Data Manager</Typography>
          </Box>
          
          <TextField
            size="small"
            placeholder={searchPlaceholder}
            value={searchText}
            onChange={(e) => setSearchText(e.target.value)}
            sx={{ width: 350 }}
            InputProps={{
              startAdornment: (
                <InputAdornment position="start">
                  <Search fontSize="small" />
                </InputAdornment>
              ),
              endAdornment: searchText && (
                <IconButton size="small" onClick={() => setSearchText("")}>
                  <Clear fontSize="small" />
                </IconButton>
              ),
            }}
          />
        </Stack>
      </Box>
      <Divider />

      {/* Drag & Drop logic wrapping the DataGrid */}
      <DragDropContext onDragEnd={onDragEnd}>
        <Droppable droppableId="grid-items">
          {(provided) => (
            <Box 
              ref={provided.innerRef} 
              {...provided.droppableProps} 
              sx={{ height: 600, width: "100%" }}
            >
              <DataGrid
                rows={filteredRows}
                columns={finalColumns}
                getRowId={(row) => row[rowIdField]}
                checkboxSelection={checkboxSelection}
                onRowSelectionModelChange={(ids) => onSelectionChange?.(ids)}
                disableRowSelectionOnClick
                // Use the memoized/static component here
                slots={{ toolbar: CustomToolbar }}
                sx={{
                  border: "none",
                  "& .MuiDataGrid-columnHeaders": {
                    bgcolor: "grey.50",
                    borderBottom: "1px solid",
                    borderColor: "divider",
                  },
                  "& .MuiDataGrid-cell:focus": { outline: "none" },
                }}
              />
              {provided.placeholder}
            </Box>
          )}
        </Droppable>
      </DragDropContext>
    </Paper>
  );
};

export default AdvancedDataGrid;
