const alertTypes = [
  { id: 1, label: "Strip Alert" },
  { id: 2, label: "Email Alert" },
];

const getValidationSchema = (alertTypeLabel) => {
  const base = {
    alertType: Yup.object().required("Alert type is required"),

    targetModule: Yup.object().required("Target Module is required"),
  };

  if (alertTypeLabel === "Email Alert") {
    return Yup.object({
      ...base,
      ministry: Yup.array()
        .min(1, "At least one ministry is required")
        .required(),
      department: Yup.array()
        .min(1, "At least one department is required")
        .required(),
      recepients: Yup.array()
        .min(1, "At least one recipient is required")
        .required(),
      subject: Yup.string().required("Subject is required"),
      body: Yup.string().required("Body is required"),
    });
  }

  if (alertTypeLabel === "Strip Alert") {
    return Yup.object(base);
  }

  return Yup.object(base);
};

const alertParent = () => {
  const dispatch = useDispatch();
  const router = useRouter();
  const { editId, status } = router.query;
  const [ministryNames, setMinistryNames] = useState([]);
  const [departmentNames, setDepartmentNames] = useState([]);
  const [stripContent, setStripContent] = useState("");
  const [showPreview, setShowPreview] = useState(false);
  const [editAlertContent, setEditAlertContent] = useState({});
  const [isFrequencyValid, setIsFrequencyValid] = useState(false);

  const [startDate, setStartDate] = useState(dayjs().format("YYYY-MM-DD"));
  const [endDate, setEndDate] = useState(dayjs().format("YYYY-MM-DD"));
  const [dateError, setDateError] = useState(false);
  const [associatedFramework, setAssociatedFramework] = useState([]);
  const [isSpecificRecordsFound, setIsSpecificRecordsFound] = useState(false);
  const [handleSubmitClicked, setHandleSubmitClicked] = useState(false);
  const [isAlertCancelled, setIsAlertCancelled] = useState(false);

  const [orgTypesList, setOrgTypesList] = useState([]);
  const {
    mappedPrivileges,
    hasAddAccess,
    hasEditAccess,
    hasViewAccess,
    refresh,
  } = usePrivileges(SECTION_KEY.CREATE_ALERT);
