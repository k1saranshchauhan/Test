function generateMDThemeChartColumns(sortedThemes) {
  return [
    {
      field: "ministryName",
      headerName: "Ministry",
      flex: 1,
      minWidth: 200,
    },
    {
      field: "departmentName",
      headerName: "Department",
      flex: 1,
      minWidth: 220,
    },
    ...sortedThemes.map((theme) => ({
      field: theme.theme_name,
      headerName: theme.theme_name,
      flex: 1,
      minWidth: 180,
      type: "number",
    })),
  ];
}
