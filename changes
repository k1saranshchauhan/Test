import React, { useState, useMemo } from "react";
import {
  Box,
  Button,
  Typography,
  IconButton,
  List,
  ListItem,
  ListItemText,
  ListItemSecondaryAction,
  TextField,
  Stack,
  Divider,
  Tooltip,
  Card,
  CardContent,
  Alert,
  Fade,
  LinearProgress,
} from "@mui/material";
import DeleteIcon from "@mui/icons-material/Delete";
import UploadFileIcon from "@mui/icons-material/UploadFile";
import CloudUploadIcon from "@mui/icons-material/CloudUpload";
import ErrorOutlineIcon from "@mui/icons-material/ErrorOutline";

const MAX_FILE_COUNT = 5;

const EnhancedSupportingDocumentsRepeater = ({
  onUploadComplete,
  uploadMultipleFiles,
}) => {
  const [selectedFiles, setSelectedFiles] = useState([]);
  const [titles, setTitles] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  // Logic to determine if we can add more files
  const isLimitReached = selectedFiles.length >= MAX_FILE_COUNT;
  const remainingSlots = MAX_FILE_COUNT - selectedFiles.length;

  const handleFileChange = (e) => {
    setError("");
    const files = Array.from(e.target.files);

    if (selectedFiles.length + files.length > MAX_FILE_COUNT) {
      setError(`You can only upload a maximum of ${MAX_FILE_COUNT} files.`);
      return;
    }

    const newFiles = [...selectedFiles, ...files];
    const newTitles = [
      ...titles,
      ...files.map((file) => file.name.replace(/\.[^/.]+$/, "")),
    ];

    setSelectedFiles(newFiles);
    setTitles(newTitles);
  };

  const handleRemove = (index) => {
    setSelectedFiles(prev => prev.filter((_, i) => i !== index));
    setTitles(prev => prev.filter((_, i) => i !== index));
    if (selectedFiles.length <= MAX_FILE_COUNT) setError("");
  };

  const handleTitleChange = (index, value) => {
    const updated = [...titles];
    updated[index] = value;
    setTitles(updated);
  };

  const handleUpload = async () => {
    if (selectedFiles.length === 0) return;
    setLoading(true);
    try {
      const uploaded = await uploadMultipleFiles(
        selectedFiles,
        titles,
        "Uploaded via enhanced component"
      );
      if (onUploadComplete) onUploadComplete(uploaded);
      setSelectedFiles([]);
      setTitles([]);
    } catch (err) {
      setError("Upload failed. Please try again.");
    } finally {
      setLoading(false);
    }
  };

  return (
    <Card variant="outlined" sx={{ borderRadius: 2, boxShadow: 1 }}>
      <CardContent>
        <Stack spacing={3}>
          <Box>
            <Typography variant="h6" fontWeight="bold">
              Supporting Documents
            </Typography>
            <Typography variant="body2" color="text.secondary">
              Upload up to {MAX_FILE_COUNT} files. {remainingSlots} slots remaining.
            </Typography>
          </Box>

          {/* File Picker / Dropzone Style */}
          <Box
            sx={{
              border: "2px dashed",
              borderColor: isLimitReached ? "action.disabled" : "primary.main",
              borderRadius: 2,
              p: 3,
              textAlign: "center",
              bgcolor: isLimitReached ? "action.hover" : "primary.lighter",
              transition: "0.3s",
            }}
          >
            <Button
              variant="contained"
              component="label"
              disabled={isLimitReached || loading}
              startIcon={<UploadFileIcon />}
              sx={{ px: 4 }}
            >
              {isLimitReached ? "Limit Reached" : "Select Files"}
              <input type="file" hidden multiple onChange={handleFileChange} />
            </Button>
            <Typography variant="caption" display="block" sx={{ mt: 1, color: "text.secondary" }}>
              PDF, JPG, or PNG (Max 10MB per file)
            </Typography>
          </Box>

          {/* Error Message */}
          {error && (
            <Fade in={!!error}>
              <Alert severity="error" icon={<ErrorOutlineIcon />}>
                {error}
              </Alert>
            </Fade>
          )}

          {/* Selected Files List */}
          {selectedFiles.length > 0 && (
            <Box>
              <Divider sx={{ mb: 2 }} />
              <List spacing={2}>
                {selectedFiles.map((file, index) => (
                  <ListItem
                    key={`${file.name}-${index}`}
                    sx={{
                      border: "1px solid",
                      borderColor: "divider",
                      borderRadius: 1,
                      mb: 1,
                      flexDirection: "column",
                      alignItems: "stretch",
                      bgcolor: "background.paper",
                    }}
                  >
                    <Box display="flex" alignItems="center" width="100%">
                      <ListItemText
                        primary={file.name}
                        primaryTypographyProps={{ fontWeight: "medium", noWrap: true }}
                        secondary={`${(file.size / 1024).toFixed(1)} KB`}
                      />
                      <ListItemSecondaryAction>
                        <Tooltip title="Remove file">
                          <IconButton edge="end" onClick={() => handleRemove(index)} disabled={loading}>
                            <DeleteIcon color="error" />
                          </IconButton>
                        </Tooltip>
                      </ListItemSecondaryAction>
                    </Box>

                    <TextField
                      size="small"
                      fullWidth
                      label="Custom Document Title"
                      placeholder="e.g. Identity Proof"
                      value={titles[index] || ""}
                      onChange={(e) => handleTitleChange(index, e.target.value)}
                      disabled={loading}
                      sx={{ mt: 1, mb: 1 }}
                    />
                  </ListItem>
                ))}
              </List>

              {/* Progress & Upload */}
              <Box sx={{ mt: 3 }}>
                {loading && <LinearProgress sx={{ mb: 2, borderRadius: 1 }} />}
                <Box display="flex" justifyContent="space-between" alignItems="center">
                  <Button 
                    color="inherit" 
                    onClick={() => {setSelectedFiles([]); setTitles([]); setError("");}}
                    disabled={loading}
                  >
                    Clear All
                  </Button>
                  <Button
                    variant="contained"
                    color="primary"
                    size="large"
                    startIcon={<CloudUploadIcon />}
                    disabled={loading}
                    onClick={handleUpload}
                    sx={{ minWidth: 150 }}
                  >
                    {loading ? "Uploading..." : "Finish & Upload"}
                  </Button>
                </Box>
              </Box>
            </Box>
          )}
        </Stack>
      </CardContent>
    </Card>
  );
};

export default EnhancedSupportingDocumentsRepeater;
