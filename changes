import React, { useEffect, useState } from "react";
import { DataGrid } from "@mui/x-data-grid";
import { CustomAutoCompleteWithoutFormik } from "../../superadmin/CustomAutoCompleteWithoutFormik";
import {
  filterByFramework,
  filterSchemesByFramework,
} from "@/utils/niti/filterByFramework";
import { oomfFrameworkId } from "@/src/constants/unified/frameworkConstants";

const SchemeAcrossMd = ({
  financialYearSchemeList,
  selectedYearSchemeAcrossMd,
  setSelectedYearSchemeAcrossMd,
  schemeAcrossMd,
  ministryList,
  setMinistryList,
  selectedMinistrySchemeAcrossMd,
  setSelectedMinistrySchemeAcrossMd,
  departmentListAcrossMd,
  setDepartmentListAcrossMd,
  selectedDepartmentAcrossMd,
  setSelectedDepartmentAcrossMd,
}) => {
  const [rows, setRows] = useState([]);
  const [columns, setColumns] = useState([]);

  // Transform API data for DataGrid (Ministry → Department → Years)
  const transformSchemeData = (data) => {
    const result = [];
    const allYearsSet = new Set();

    data.forEach((ministryEntry) => {
      const ministryName =
        ministryEntry.ministry?.name?.trim() || "Unknown Ministry";

      (ministryEntry.departments || []).forEach((dept) => {
        const departmentName =
          dept.department?.name?.trim() || "Unknown Department";
        const row = {
          "Ministry Name": ministryName,
          "Department Name": departmentName,
        };

        const yearsData = dept.yearsData || {};
        Object.entries(yearsData).forEach(([year, yearInfo]) => {
          row[year] = yearInfo?.totalSchemes ?? 0;
          allYearsSet.add(year);
        });

        result.push(row);
      });
    });

    // Sort years like 2021-2022 → ascending order
    const allYears = Array.from(allYearsSet).sort((a, b) => {
      const numA = parseInt(a.split("-")[0]) || 0;
      const numB = parseInt(b.split("-")[0]) || 0;
      return numA - numB;
    });

    // Ensure every row has all year columns
    result.forEach((row) => {
      allYears.forEach((year) => {
        if (!(year in row)) row[year] = "-";
      });
    });

    return { rows: result, years: allYears };
  };

  // Auto-select Ministry + Department when only 1 option exists
useEffect(() => {
  // ---- Auto-select Ministry ----
  const filteredMinistries = filterByFramework(ministryList, oomfFrameworkId) || [];
  if (
    filteredMinistries?.length === 1 &&
    selectedMinistrySchemeAcrossMd?.length === 0
  ) {
    const onlyMinistryId = filteredMinistries[0]?.id;
    setSelectedMinistrySchemeAcrossMd([onlyMinistryId]);

    // reset department selection
    setSelectedDepartmentAcrossMd([]);
  }

  // ---- Auto-select Department ----
  const filteredDepartments =
    filterByFramework(departmentListAcrossMd, oomfFrameworkId) || [];

  if (
    filteredDepartments?.length === 1 &&
    selectedDepartmentAcrossMd?.length === 0
  ) {
    const onlyDepartmentId = filteredDepartments[0]?.id;
    setSelectedDepartmentAcrossMd([onlyDepartmentId]);
  }
}, [
  ministryList,
  departmentListAcrossMd,
  selectedMinistrySchemeAcrossMd,
  selectedDepartmentAcrossMd,
]);


  useEffect(() => {
    if (schemeAcrossMd && schemeAcrossMd.length > 0) {
      const { rows: transformedData, years: sortedYears } =
        transformSchemeData(schemeAcrossMd);

      // Add S.No
      const rowsWithIndex = transformedData.map((item, index) => ({
        id: index + 1,
        "S.No": index + 1,
        ...item,
      }));

      // Columns: S.No → Ministry → Department → Years
      const dynamicColumns = [
        {
          field: "S.No",
          headerName: "S.No",
          flex: 0.6,
          headerAlign: "center",
          align: "center",
        },
        {
          field: "Ministry Name",
          headerName: "Ministry Name",
          flex: 1.5,
          headerAlign: "left",
          align: "left",
        },
        {
          field: "Department Name",
          headerName: "Department Name",
          flex: 1.5,
          headerAlign: "left",
          align: "left",
        },
        ...sortedYears.map((year) => ({
          field: year,
          headerName: year,
          flex: 1,
          headerAlign: "center",
          align: "center",
        })),
      ];

      setColumns(dynamicColumns);
      setRows(rowsWithIndex);
    } else {
      setColumns([]);
      setRows([]);
    }
  }, [
    selectedMinistrySchemeAcrossMd,
    selectedDepartmentAcrossMd,
    selectedYearSchemeAcrossMd,
    schemeAcrossMd,
  ]);

  return (
    <div >
      <div
        className="col-md-12 mb-4"
        style={{
          border: "1px solid lightgray",
          borderRadius: "6px",
          padding: "20px",
          backgroundColor:"#fff",
        }}
      >
        <div className="row">
          <div className="col-md-12">
            <h5 className="card-title text-dark mt-2 fw-bold">
              Total Number of Scheme across all M/D
            </h5>
          </div>
          <div className="row px-0 mx-0 my-3">
      
            {/* <div className="col-md-4">
              <CustomAutoCompleteWithoutFormik
                label="Ministry"
                multiple
                selectAll
                options={filterByFramework(ministryList, oomfFrameworkId) || []}
                getOptionLabel={(option) => option?.name || "Unknown"}
                value={
                  ministryList?.filter((item) =>
                    (selectedMinistrySchemeAcrossMd || []).includes(item.id)
                  ) || []
                }
                onChange={(event, newValue) => {
                  setSelectedMinistrySchemeAcrossMd(
                    newValue.map((item) => item.id)
                  );
                  setSelectedDepartmentAcrossMd([]);
                  setDepartmentListAcrossMd([]);
                }}
                isOptionEqualToValue={(option, value) => option.id === value.id}
                renderOption={(props, option) => (
                  <li {...props} key={option.id}>
                    {option.name}
                  </li>
                )}
                fullWidth
              />
            </div>
            <div className="col-md-4">
              <CustomAutoCompleteWithoutFormik
                label="Department"
                multiple
                selectAll
                options={
                  filterByFramework(departmentListAcrossMd, oomfFrameworkId) || []
                }
                getOptionLabel={(option) => option?.name || "Unknown Part"}
                value={
                  departmentListAcrossMd?.filter((item) =>
                    (selectedDepartmentAcrossMd || []).includes(item.id)
                  ) || []
                }
                onChange={(event, newValue) =>
                  setSelectedDepartmentAcrossMd(newValue.map((item) => item.id))
                }
                isOptionEqualToValue={(option, value) => option.id === value.id}
                renderOption={(props, option) => (
                  <li {...props} key={option.id}>
                    {option.name}
                  </li>
                )}
                fullWidth
              />
            </div> */}

            {/* Year Filter */}
            <div className="col-md-6">
              <CustomAutoCompleteWithoutFormik
                label="Financial Year"
                multiple
                selectAll
                options={financialYearSchemeList || []}
                getOptionLabel={(option) => option?.name || "Unknown"}
                value={
                  financialYearSchemeList?.filter((item) =>
                    (selectedYearSchemeAcrossMd || []).includes(item.id)
                  ) || []
                }
                onChange={(event, newValue) => {
                  setSelectedYearSchemeAcrossMd(
                    newValue.map((item) => item.id)
                  );
                }}
                isOptionEqualToValue={(option, value) => option.id === value.id}
                renderOption={(props, option) => (
                  <li {...props} key={option.id}>
                    {option.name}
                  </li>
                )}
                fullWidth
              />
            </div>
          </div>
        </div>

        {/* DataGrid */}
        <div
          style={{
            height: 400,
            width: "100%",
            marginTop: "15px",
            padding: "0px",
          }}
        >
          <DataGrid
            rows={rows}
            columns={columns}
            pageSize={5}
            rowsPerPageOptions={[5, 10, 20]}
            getRowId={(row) =>
              `${row["Ministry Name"]}-${row["Department Name"]}`
            }
            localeText={{
              columnMenuSortAsc: "Sort as A to Z",
              columnMenuSortDesc: "Sort as Z to A",
            }}
            disableColumnFilter
          />
        </div>
      </div>
    </div>
  );
};

export default SchemeAcrossMd;

