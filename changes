export const isNonEmptyText = (value = "") => {
  return typeof value === "string" && value.trim() !== "";
};

export const hasDocuments = (docs = []) => {
  return (
    Array.isArray(docs) &&
    docs.some(
      (doc) =>
        doc &&
        (doc.uploadedFile || doc.id || doc.filePath || doc.fileName || doc.name),
    )
  );
};

/* -------------------------------
   Draft validation
-------------------------------- */
export const validateCreatorDraft = ({ uploadedFiles = [], remarks = "" }) => {
  const errors = [];

  if (!hasDocuments(uploadedFiles)) {
    errors.push("Framework attachment is required.");
  }

  if (!isNonEmptyText(remarks)) {
    errors.push("Remarks are required.");
  }

  return {
    isValid: errors.length === 0,
    errors,
  };
};

export const validateNonCreatorDraft = ({
  revisedFrameworkFiles = [],
  hindiFiles = [],
  snippetFiles = [],
  remarks = "",
  uniqueFlag = "No",
}) => {
  const errors = [];

  if (!hasDocuments(revisedFrameworkFiles)) {
    errors.push("Revised Framework is required.");
  }

  if (uniqueFlag === "No") {
    if (!hasDocuments(hindiFiles)) {
      errors.push("Hindi Document is required.");
    }

    if (!hasDocuments(snippetFiles)) {
      errors.push("Snippet of e file is required.");
    }

    if (!isNonEmptyText(remarks)) {
      errors.push("Remarks are required.");
    }
  }

  return {
    isValid: errors.length === 0,
    errors,
  };
};

/* -------------------------------
   Row-level validation
   (state draft OR backend row data)
-------------------------------- */
export const validateRowForBulkForward = (row, reviewedDrafts = {}) => {
  const submissionId = row?.submissionId;
  const draft = reviewedDrafts?.[submissionId];

  // 1. If reviewed draft exists, validate from state draft
  if (draft) {
    if (draft?.isCreator) {
      return validateCreatorDraft({
        uploadedFiles: draft?.documents || [],
        remarks: draft?.remarks || "",
      });
    }

    const docs = draft?.documents || [];

    return validateNonCreatorDraft({
      revisedFrameworkFiles: docs.filter(
        (doc) => doc?.name === "Revised framework" || doc?.name === "Framework",
      ),
      hindiFiles: docs.filter((doc) => doc?.name === "Hindi Document"),
      snippetFiles: docs.filter((doc) => doc?.name === "Snippet of e file "),
      remarks: draft?.remarks || "",
      uniqueFlag: row?.uniqueFlag || "No",
    });
  }

  // 2. Otherwise validate from backend/prepopulated row data
  const docs = row?.documents || [];
  const remarks = row?.remarks || row?.fromRemarks || "";
  const isCreator = Number(row?.permission?.orderIndex) === 1;

  if (isCreator) {
    return validateCreatorDraft({
      uploadedFiles: docs.filter(
        (doc) => doc?.name === "Framework" || doc?.name === "Revised framework",
      ),
      remarks,
    });
  }

  return validateNonCreatorDraft({
    revisedFrameworkFiles: docs.filter(
      (doc) => doc?.name === "Revised framework" || doc?.name === "Framework",
    ),
    hindiFiles: docs.filter((doc) => doc?.name === "Hindi Document"),
    snippetFiles: docs.filter((doc) => doc?.name === "Snippet of e file "),
    remarks,
    uniqueFlag: row?.uniqueFlag || "No",
  });
};

/* -------------------------------
   Bulk-level validation
-------------------------------- */
export const areAllSelectedRecordsValidated = (
  rows = [],
  reviewedDrafts = {},
) => {
  if (!rows?.length) return false;

  return rows.every((row) => validateRowForBulkForward(row, reviewedDrafts).isValid);
};

export const getValidationSummaryForRows = (rows = [], reviewedDrafts = {}) => {
  return rows.map((row) => {
    const validation = validateRowForBulkForward(row, reviewedDrafts);

    return {
      submissionId: row?.submissionId,
      isValid: validation.isValid,
      errors: validation.errors,
    };
  });
};

/* -------------------------------
   Final payload
-------------------------------- */
export const buildBulkForwardIndividualPayload = ({
  selectedRows = [],
  orgTypeId,
  subRoleId,
  createdBy,
  reviewedDrafts = {},
}) => {
  const validSubmissionIds = [];
  const fromDocumentIds = {};
  const fromRemarks = {};

  selectedRows?.forEach((row) => {
    const id = row?.submissionId;
    const draft = reviewedDrafts?.[id];

    // If user has reviewed and saved draft, use that
    if (draft?.payload) {
      validSubmissionIds.push(Number(id));
      fromDocumentIds[id] = draft?.payload?.fromDocumentIds || [];
      fromRemarks[id] = draft?.payload?.fromRemarks || "";
      return;
    }

    // Otherwise fallback to backend/prepopulated row data
    const docs = row?.documents || [];
    const remarks = row?.remarks || row?.fromRemarks || "";

    validSubmissionIds.push(Number(id));
    fromDocumentIds[id] = docs;
    fromRemarks[id] = remarks;
  });

  return {
    submissionIds: validSubmissionIds,
    orgTypeId,
    subRoleId,
    fromRemarks,
    fromDocumentIds,
    createdBy,
  };
};
