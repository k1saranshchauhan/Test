import React, { useState, useCallback } from "react";
import {
  Box,
  Button,
  Typography,
  IconButton,
  List,
  TextField,
  Stack,
  Card,
  CardContent,
  Alert,
  Fade,
  LinearProgress,
  Paper,
  alpha
} from "@mui/material";
import DeleteIcon from "@mui/icons-material/Delete";
import UploadFileIcon from "@mui/icons-material/UploadFile";
import CloudUploadIcon from "@mui/icons-material/CloudUpload";
import DescriptionIcon from "@mui/icons-material/Description";

const MAX_FILE_COUNT = 5;
const MAX_FILE_SIZE_MB = 10;
const MAX_FILE_SIZE_BYTES = MAX_FILE_SIZE_MB * 1024 * 1024;

const ProfessionalFileRepeater = ({ onUploadComplete, uploadMultipleFiles }) => {
  const [selectedFiles, setSelectedFiles] = useState([]);
  const [titles, setTitles] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");
  const [isDragging, setIsDragging] = useState(false); // Track drag state

  const validateAndAddFiles = useCallback((files) => {
    setError("");
    
    if (selectedFiles.length + files.length > MAX_FILE_COUNT) {
      setError(`Limit exceeded. Max ${MAX_FILE_COUNT} files allowed.`);
      return;
    }

    const oversizedFiles = files.filter(f => f.size > MAX_FILE_SIZE_BYTES);
    if (oversizedFiles.length > 0) {
      setError(`Files must be under ${MAX_FILE_SIZE_MB}MB.`);
      return;
    }

    setSelectedFiles(prev => [...prev, ...files]);
    setTitles(prev => [
      ...prev,
      ...files.map((f) => f.name.replace(/\.[^/.]+$/, ""))
    ]);
  }, [selectedFiles]);

  // --- Drag & Drop Handlers ---
  const handleDrag = (e) => {
    e.preventDefault();
    e.stopPropagation();
    if (e.type === "dragenter" || e.type === "dragover") {
      setIsDragging(true);
    } else if (e.type === "dragleave") {
      setIsDragging(false);
    }
  };

  const handleDrop = (e) => {
    e.preventDefault();
    e.stopPropagation();
    setIsDragging(false);

    if (e.dataTransfer.files && e.dataTransfer.files.length > 0) {
      const files = Array.from(e.dataTransfer.files);
      validateAndAddFiles(files);
    }
  };

  const handleFileChange = (e) => {
    const files = Array.from(e.target.files);
    validateAndAddFiles(files);
    e.target.value = ""; 
  };

  const handleRemove = (index) => {
    setSelectedFiles(prev => prev.filter((_, i) => i !== index));
    setTitles(prev => prev.filter((_, i) => i !== index));
  };

  const handleUpload = async () => {
    setLoading(true);
    try {
      await uploadMultipleFiles(selectedFiles, titles);
      if (onUploadComplete) onUploadComplete();
      setSelectedFiles([]);
      setTitles([]);
    } catch (err) {
      setError("Upload failed. Please try again.");
    } finally {
      setLoading(false);
    }
  };

  return (
    <Card sx={{ maxWidth: 700, mx: "auto", borderRadius: 4, boxShadow: "0 10px 30px rgba(0,0,0,0.08)" }}>
      <CardContent sx={{ p: 4 }}>
        <Stack spacing={3}>
          <Box>
            <Typography variant="h5" fontWeight={800} gutterBottom>
              Document Manager
            </Typography>
            <Typography variant="body2" color="text.secondary">
              Upload supporting evidence (Max {MAX_FILE_COUNT} files).
            </Typography>
          </Box>

          {/* DRAG & DROP ZONE */}
          <Paper
            variant="outlined"
            onDragEnter={handleDrag}
            onDragLeave={handleDrag}
            onDragOver={handleDrag}
            onDrop={handleDrop}
            sx={{
              p: 5,
              borderRadius: 3,
              border: "2px dashed",
              borderColor: isDragging ? "primary.main" : "divider",
              bgcolor: isDragging ? alpha("#1976d2", 0.05) : "grey.50",
              textAlign: "center",
              transition: "all 0.2s ease-in-out",
              cursor: selectedFiles.length >= MAX_FILE_COUNT ? "not-allowed" : "pointer",
              position: "relative"
            }}
          >
            <input 
              type="file" 
              multiple 
              hidden 
              id="file-input"
              onChange={handleFileChange} 
              disabled={selectedFiles.length >= MAX_FILE_COUNT}
            />
            <label htmlFor="file-input" style={{ cursor: 'inherit', width: '100%', display: 'block' }}>
              <UploadFileIcon sx={{ fontSize: 48, color: isDragging ? "primary.main" : "text.disabled", mb: 2 }} />
              <Typography variant="h6" fontWeight={600} color={isDragging ? "primary.main" : "text.primary"}>
                {isDragging ? "Drop files here" : "Drag & drop or click to upload"}
              </Typography>
              <Typography variant="caption" color="text.secondary">
                Limit: {MAX_FILE_SIZE_MB}MB per file
              </Typography>
            </label>
          </Paper>

          {error && (
            <Fade in={!!error}>
              <Alert severity="error" variant="outlined" sx={{ borderRadius: 2 }}>
                {error}
              </Alert>
            </Fade>
          )}

          {/* FILE LIST */}
          <List disablePadding>
            {selectedFiles.map((file, index) => (
              <Paper
                key={index}
                elevation={0}
                sx={{ 
                  mb: 2, p: 2, borderRadius: 2, 
                  bgcolor: "background.paper", 
                  border: "1px solid",
                  borderColor: "divider",
                  display: "flex", gap: 2, alignItems: "center" 
                }}
              >
                <Box sx={{ bgcolor: "primary.lighter", p: 1, borderRadius: 1.5, display: "flex" }}>
                  <DescriptionIcon color="primary" />
                </Box>
                
                <Box flex={1} minWidth={0}>
                  <Typography variant="body2" fontWeight={700} noWrap>
                    {file.name}
                  </Typography>
                  <Typography variant="caption" color="text.secondary">
                    {(file.size / (1024 * 1024)).toFixed(2)} MB
                  </Typography>
                  <TextField
                    fullWidth
                    size="small"
                    placeholder="Document Label"
                    value={titles[index] || ""}
                    onChange={(e) => {
                      const newTitles = [...titles];
                      newTitles[index] = e.target.value;
                      setTitles(newTitles);
                    }}
                    sx={{ mt: 1, "& .MuiInputBase-input": { py: 0.5 } }}
                  />
                </Box>

                <IconButton onClick={() => handleRemove(index)} size="small" color="error">
                  <DeleteIcon fontSize="small" />
                </IconButton>
              </Paper>
            ))}
          </List>

          {selectedFiles.length > 0 && (
            <Stack direction="row" spacing={2} justifyContent="flex-end" sx={{ pt: 2 }}>
              <Button variant="text" color="inherit" onClick={() => {setSelectedFiles([]); setTitles([]);}}>
                Clear
              </Button>
              <Button
                variant="contained"
                startIcon={<CloudUploadIcon />}
                onClick={handleUpload}
                disabled={loading}
                sx={{ borderRadius: 2, px: 4, fontWeight: 700 }}
              >
                {loading ? "Processing..." : "Upload Selection"}
              </Button>
            </Stack>
          )}
        </Stack>
      </CardContent>
      {loading && <LinearProgress />}
    </Card>
  );
};

export default ProfessionalFileRepeater;
