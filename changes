const STORAGE_KEY = "individual_bulk_forward_drafts";

export const getIndividualBulkForwardDrafts = () => {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    return raw ? JSON.parse(raw) : {};
  } catch (err) {
    console.error("Failed to parse individual bulk forward drafts", err);
    return {};
  }
};

export const saveIndividualBulkForwardDraft = (submissionId, data) => {
  try {
    const drafts = getIndividualBulkForwardDrafts();
    drafts[submissionId] = {
      ...(drafts[submissionId] || {}),
      ...data,
    };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(drafts));
    return drafts;
  } catch (err) {
    console.error("Failed to save individual bulk forward draft", err);
    return {};
  }
};

export const getIndividualBulkForwardDraftById = (submissionId) => {
  const drafts = getIndividualBulkForwardDrafts();
  return drafts?.[submissionId] || null;
};

export const removeIndividualBulkForwardDraft = (submissionId) => {
  try {
    const drafts = getIndividualBulkForwardDrafts();
    delete drafts[submissionId];
    localStorage.setItem(STORAGE_KEY, JSON.stringify(drafts));
    return drafts;
  } catch (err) {
    console.error("Failed to remove draft", err);
    return {};
  }
};

export const clearIndividualBulkForwardDrafts = () => {
  localStorage.removeItem(STORAGE_KEY);
};

export const validateCreatorDraft = ({ uploadedFiles = [], remarks = "" }) => {
  const errors = [];

  if (!uploadedFiles?.[0]?.uploadedFile) {
    errors.push("Framework attachment is required.");
  }

  if (!remarks?.trim()) {
    errors.push("Remarks are required.");
  }

  return {
    isValid: errors.length === 0,
    errors,
  };
};

export const validateNonCreatorDraft = ({
  revisedFrameworkFiles = [],
  hindiFiles = [],
  snippetFiles = [],
  remarks = "",
  uniqueFlag = "No",
}) => {
  const errors = [];

  if (!revisedFrameworkFiles?.[0]?.uploadedFile) {
    errors.push("Revised Framework is required.");
  }

  if (uniqueFlag === "No") {
    if (!hindiFiles?.[0]?.uploadedFile) {
      errors.push("Hindi Document is required.");
    }

    if (!snippetFiles?.[0]?.uploadedFile) {
      errors.push("Snippet of e file is required.");
    }

    if (!remarks?.trim()) {
      errors.push("Remarks are required.");
    }
  }

  return {
    isValid: errors.length === 0,
    errors,
  };
};

export const areAllSelectedRecordsValidated = (selectedSubmissionIds = []) => {
  const drafts = getIndividualBulkForwardDrafts();

  if (!selectedSubmissionIds?.length) {
    return false;
  }

  return selectedSubmissionIds.every((id) => drafts?.[id]?.isValid === true);
};

export const getValidationSummaryForRows = (selectedSubmissionIds = []) => {
  const drafts = getIndividualBulkForwardDrafts();

  return selectedSubmissionIds.map((id) => ({
    submissionId: id,
    isValid: drafts?.[id]?.isValid === true,
    errors: drafts?.[id]?.errors || [],
    payload: drafts?.[id]?.payload || null,
  }));
};
//final payload
export const buildBulkForwardIndividualPayload = ({
  selectedSubmissionIds = [],
  orgTypeId,
  subRoleId,
  createdBy,
}) => {
  console.log({selectedSubmissionIds,
  orgTypeId,
  subRoleId,
  createdBy})
  const drafts = getIndividualBulkForwardDrafts();

  const validSubmissionIds = [];
  const fromDocumentIds = {};
  const fromRemarks = {};

  selectedSubmissionIds.forEach((id) => {
    const draft = drafts?.[id];

    if (draft?.isValid && draft?.payload) {
      validSubmissionIds.push(Number(id));

      fromDocumentIds[id] = draft?.payload?.fromDocumentIds || [];
      fromRemarks[id] = draft?.payload?.fromRemarks || "";
    }
  });

  return {
    submissionIds: validSubmissionIds,
    orgTypeId,
    subRoleId,
    fromRemarks, // recommended object-based remarks
    fromDocumentIds,
    createdBy,
  };
};
