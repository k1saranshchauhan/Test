"use client";

import React, { useState, useEffect, useMemo } from "react";
import {
  Box,
  TextField,
  Paper,
  InputAdornment,
  IconButton,
  Typography,
  Stack,
} from "@mui/material";
import { DataGrid, GridToolbarContainer, GridToolbarExport, GridRow } from "@mui/x-data-grid";
import { Search, Clear, DragIndicator, Sort } from "@mui/icons-material";
import { DragDropContext, Droppable, Draggable } from "@hello-pangea/dnd";

// --- Draggable Row Component ---
const DraggableRow = (props) => {
  const { id, index, style } = props;

  if (id === undefined) return <GridRow {...props} />;

  return (
    <Draggable draggableId={String(id)} index={index}>
      {(provided, snapshot) => (
        <div
          ref={provided.innerRef}
          {...provided.draggableProps}
          {...provided.dragHandleProps}
          style={{
            ...style,
            ...provided.draggableProps.style,
            backgroundColor: snapshot.isDragging ? "#f5f5f5" : "inherit",
            cursor: "grab",
          }}
        >
          <GridRow {...props} />
        </div>
      )}
    </Draggable>
  );
};

const AdvancedDataGrid = ({
  data = [],
  columns = [],
  rowIdField = "id",
  enableReorder = true,
  searchPlaceholder = "Search and reorder...",
  onSelectionChange,
  checkboxSelection = true,
  height = 500,
}) => {
  const [searchText, setSearchText] = useState("");
  const [rows, setRows] = useState(data);

  // Sync internal rows when external data changes
  useEffect(() => {
    setRows(data);
  }, [data]);

  // --- 1. Filter rows by search text ---
  const filteredRows = useMemo(() => {
    const term = searchText.toLowerCase().trim();
    if (!term) return rows;
    return rows.filter((row) =>
      Object.values(row).some(
        (val) => val !== null && String(val).toLowerCase().includes(term)
      )
    );
  }, [rows, searchText]);

  // --- 2. Drag & Drop Handler ---
  const onDragEnd = (result) => {
    if (!result.destination) return;

    // Use filtered rows to get the visible order
    const newItems = Array.from(filteredRows);
    const [reorderedItem] = newItems.splice(result.source.index, 1);
    newItems.splice(result.destination.index, 0, reorderedItem);

    // Update the original rows array to preserve order
    const newRows = [...rows];
    newItems.forEach((item, idx) => {
      const originalIndex = newRows.findIndex((r) => r[rowIdField] === item[rowIdField]);
      newRows.splice(originalIndex, 1); // remove
      newRows.splice(idx, 0, item); // insert at new position
    });

    setRows(newRows);
  };

  // --- 3. Add Drag Handle Column ---
  const finalColumns = useMemo(() => {
    if (!enableReorder) return columns;

    const dragCol = {
      field: "drag_handle",
      headerName: "",
      width: 50,
      sortable: false,
      filterable: false,
      disableColumnMenu: true,
      renderCell: () => <DragIndicator sx={{ color: "action.disabled" }} />,
    };

    return [dragCol, ...columns];
  }, [columns, enableReorder]);

  return (
    <Paper elevation={2} sx={{ borderRadius: 2, overflow: "hidden", border: "1px solid #eee" }}>
      {/* Header / Search Bar */}
      <Box sx={{ p: 2, bgcolor: "white" }}>
        <Stack direction="row" justifyContent="space-between" alignItems="center">
          <Typography
            variant="subtitle1"
            fontWeight="bold"
            sx={{ display: "flex", alignItems: "center", gap: 1 }}
          >
            <Sort fontSize="small" /> Data Explorer
          </Typography>

          <TextField
            size="small"
            placeholder={searchPlaceholder}
            value={searchText}
            onChange={(e) => setSearchText(e.target.value)}
            sx={{ width: 300 }}
            InputProps={{
              startAdornment: (
                <InputAdornment position="start">
                  <Search fontSize="small" />
                </InputAdornment>
              ),
              endAdornment: searchText && (
                <IconButton size="small" onClick={() => setSearchText("")}>
                  <Clear fontSize="small" />
                </IconButton>
              ),
            }}
          />
        </Stack>
      </Box>

      {/* DragDropContext */}
      <DragDropContext onDragEnd={onDragEnd}>
        <Droppable droppableId="grid-droppable">
          {(provided) => (
            <Box
              ref={provided.innerRef}
              {...provided.droppableProps}
              sx={{ height, width: "100%" }}
            >
              <DataGrid
                rows={filteredRows}
                columns={finalColumns}
                getRowId={(row) => row[rowIdField]}
                checkboxSelection={checkboxSelection}
                onRowSelectionModelChange={(ids) => onSelectionChange?.(ids)}
                disableRowSelectionOnClick
                disableVirtualization={true} // ✅ required for drag-and-drop
                slots={{
                  row: enableReorder ? DraggableRow : GridRow,
                  toolbar: () => (
                    <GridToolbarContainer sx={{ p: 1, borderBottom: "1px solid #eee" }}>
                      <GridToolbarExport />
                    </GridToolbarContainer>
                  ),
                }}
                sx={{
                  border: "none",
                  "& .MuiDataGrid-row:hover": { bgcolor: "#f9f9f9" },
                  "& .MuiDataGrid-columnHeaders": { bgcolor: "#fafafa", borderBottom: "2px solid #eee" },
                }}
              />
              {provided.placeholder}
            </Box>
          )}
        </Droppable>
      </DragDropContext>
    </Paper>
  );
};

export default AdvancedDataGrid;
