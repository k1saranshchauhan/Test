      Object.assign(payload, {
        ministry_ids: JSON.stringify(ministry),
        dept_ids: JSON.stringify(department),
        user_ids: JSON.stringify(recepients?.map((r) => r?.id) || []),
        content: JSON.stringify({ subject: subject, body: body }),
        frequency: (alertFrequency?.frequencyType).toUpperCase(),
        frequencyPattern: JSON.stringify({ frequencyPattern: alertFrequency }),
        specificCondition: JSON.stringify(specificCondition),
      });
    }

    if (alertType?.label === "Strip Alert") {
      Object.assign(payload, {
        content: JSON.stringify({ content: stripContent }),
      });
