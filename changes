              : [selectedModules.id ?? selectedModules];
            filteredData = filteredData.filter((ministry) => {
              const frameworks = ministry?.jsonData?.associatedFramework || [];

              const frameworkIds = frameworks.map((fw) => fw?.id);

              // match if any id intersection exists
              return selectedModuleIds.some((moduleId) =>
                frameworkIds.includes(moduleId),
