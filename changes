            filteredData = filteredData.filter((department) => {
              const frameworks =
                department?.jsonData?.associatedFramework || [];

              const frameworkIds = frameworks.map((fw) => fw?.id);

              // check if any selected module exists in framework list
              return selectedModuleIds.some((moduleId) =>
                frameworkIds.includes(moduleId),
