import React, { useState, useEffect, useRef } from "react";
import {
  Box,
  Typography,
  TextField,
  Button,
  CircularProgress,
  Card,
  Divider,
  Grid,
  Stack,
  Paper,
} from "@mui/material";
import AddIcon from "@mui/icons-material/Add";
import SearchIcon from "@mui/icons-material/Search";
import RestartAltIcon from "@mui/icons-material/RestartAlt";
import { DataGrid } from "@mui/x-data-grid";
import apiClient from "@/utils/apiClient";
import ExportCsvButton from "../ExportCSV";
import Ministry from "../ModalsFields/Ministry";
import AddRecordDialog from "./AddRecordDialog";
import { getMasterColumns } from "../UnifiedMastersDataGridTables";
import { deepSearch, generateRowsForColumns } from "@/utils/unifiedHelpers";
import { getMasterExampleRow } from "../UnifiedMastersDataGridRows";
import { ColumnReorderManager } from "@/utils/columnReorderManager";
import { useDispatch, useSelector } from "react-redux";
import { setError, setSuccess } from "@/store/slices/errorSlice";
import {
  validateDistrictFields,
  validateOutputOutcomeFields,
  validateUnitsFields,
} from "../ModalsFields/Validation";
import District from "../ModalsFields/District";
import MainFormHeader from "../../DashboardUI/MainFormHeader";
import { CustomAutoCompleteWithoutFormik } from "../CustomAutoCompleteWithoutFormik";
import Units from "../ModalsFields/Units";
import OutputOutcome from "../ModalsFields/OutputOutcome";
import CommonViewMasterDialog from "../commonViewProfileDialog";
import { usePrivileges } from "@/src/context/privilegeContextProvider";
import { SECTION_KEY } from "@/src/constants/privilegesSectionKeys/sectionKeys";
import AuditDataGrid from "../../AuditDetailsDialog";
import { AuditTrailDialog } from "../../audit";
import axios from "axios";
import { applyCustomLogic } from "@/utils/niti/datagridUtils";

const OutputOutcomeMaster = ({ masterState }) => {
  const {
    newRow,
    handleNewChange,
    isViewing,
    isEditing,
    setIsEditing,
    setIsViewing,
    editId,
    setEditId,
    setNewRow,
    handleEdit,
    setSchemeData,
    urlModal,
    handleSwitchChange,
    selected,
    jsonData,
    setErrors,
    showAccordion,
    setShowAccordion,
    handleJsonDataChange,
    uploadMultipleFiles,
    errors,
  } = masterState;

  const dispatch = useDispatch();
  const [ministryNames, SetMinistryNames] = useState([]);
  const [departments, setDepartments] = useState([]);
  const [schemes, setSchemes] = useState([]);
  const [isSubSchemes, setIsSubSchemes] = useState([
    { id: 1, name: "Yes" },
    { id: 2, name: "No" },
  ]);
  const [statementTypes, setStatementTypes] = useState([
    { id: 1, name: "Output" },
    { id: 2, name: "Outcome" },
  ]);
  const [selectedMinistries, setSelectedMinistries] = useState([]);
  const [selectedDepartments, setSelectedDepartments] = useState([]);
  const [selectedSchemes, setSelectedSchemes] = useState([]);
  const [selectedIsSubScheme, setSelectedIsSubScheme] = useState(null);
  const [selectedStatement, setSelectedStatement] = useState();
  const [outputOutcomes, setOutputOutcomes] = useState([]);
  const [filteredOutputOutcomes, setFilteredOutputOutcomes] = useState([]);
  const [loading, setLoading] = useState(true);
  const [auditParams, setAuditParams] = useState({});
  const [search, setSearch] = useState("");
  const [auditDialogOpen, setAuditDialogOpen] = useState(false);
  const [paginationModel, setPaginationModel] = useState({
    page: 0, // MUI is 0-based
    pageSize: 10, // number of rows per page
  });
  const [totalRows, setTotalRows] = useState(0);
  const {
    mappedPrivileges,
    hasAddAccess,
    hasEditAccess,
    hasViewAccess,
    hasAuditTrailViewAccess,
    refresh,
  } = usePrivileges(SECTION_KEY.OUTPUT_OUTCOME_STATEMENT);
  const abortRef = useRef(null);
  const inFlightRef = useRef(false);
  const firstLoadRef = useRef(true);
  const userData = useSelector((state) => state.config.userData);
  const handleViewAuditTrail = async (row) => {
    if (!row?.id || !mappedPrivileges?.sectionId) return;

    setAuditParams({
      auditableId: String(row.id),
      sectionId: mappedPrivileges.sectionId,
    });
    setAuditDialogOpen(true);
  };
  const actionsConfig = React.useMemo(
    () => ({
      hasAddAccess,
      hasEditAccess,
      hasViewAccess,
      hasAuditTrailViewAccess,
      handleEdit,
      handleViewAuditTrail,
      setIsViewing,
      urlModal,
      setSchemeData,
    }),
    [
      hasAddAccess,
      hasEditAccess,
      hasViewAccess,
      handleEdit,
      hasAuditTrailViewAccess,
      setIsViewing,
      urlModal,
      setSchemeData,
    ],
  );

  const userMinistryIds = userData?.userRelationships[0]?.ministryIds;
  const userDepartmentIds = userData?.userRelationships[0]?.departmentIds;
  const userSchemeIds = userData?.userRelationships[0]?.schemeIds;

  //helper
  const pickIdName = (obj) => {
    if (!obj) return null;
    return {
      id: obj.id,
      name: obj.name,
    };
  };

  useEffect(() => {
    // 🔥 Skip FIRST RUN
    if (firstLoadRef.current) {
      firstLoadRef.current = false;
      return;
    }

    const handle = setTimeout(() => {
      if (!search?.trim() || search.trim().length >= 3)
        fetchOutputOutcomes({
          page: paginationModel.page,
          pageSize: paginationModel.pageSize,
        });
    }, 400); // debounce 400ms

    return () => {
      clearTimeout(handle);
    };
  }, [search]);

  const fetchMinistries = async () => {
    try {
      const response = await apiClient.get(
        "api/master/fetch-ministries-dropdown",
      );
      const res = response?.data?.result || [];
      const formattedRes = res?.map((item) => ({
        id: item?.id,
        name: item?.name,
        associatedFramework: item?.jsonData?.associatedFramework,
      }));
      SetMinistryNames(formattedRes);
    } catch (err) {
      console.error("Error fetching ministries:", err);
    }
  };

  const fetchDepartments = async (selectedMinistryIds = []) => {
    setLoading(true);
    try {
      const response = await apiClient.post(
        "api/master/get-departments-for-ministry",
        { ministryIds: selectedMinistryIds || [] },
      );

      const filteredRes = response?.data?.data || [];
      const res = filteredRes?.map((item) => ({
        id: item?.id,
        name: item?.name,
        associatedFramework: item?.jsonData?.associatedFramework,
      }));

      // ✅ Step 1: Extract user-allowed department IDs
      const allowedDeptIds =
        userData?.userRelationships?.[0]?.departmentIds || [];

      // ✅ Step 2: Apply filtering if user has department restrictions
      const filteredDepartments =
        allowedDeptIds.length > 0
          ? res.filter((dept) => allowedDeptIds.includes(dept.id))
          : res;
      setDepartments(filteredDepartments);

      // ✅ Step 3: Auto-select if there’s only one allowed department
      if (filteredDepartments.length === 1) {
        const onlyDept = filteredDepartments;
        setSelectedDepartments(onlyDept);
      }
    } catch (err) {
      console.error("Error fetching departments:", err);
      setDepartments([]);
    } finally {
      setLoading(false);
    }
  };

  const fetchSchemes = async (selectedDepartmentIds = []) => {
    setLoading(true);
    try {
      const response = await apiClient.post(
        "api/master/get-schemes-for-departments",
        { departmentIds: selectedDepartmentIds || [] },
      );

      const filteredRes = response?.data?.data || [];
      const res = filteredRes?.map((item) => ({
        id: item?.id,
        name: item?.name,
        associatedFramework: item?.jsonData?.associatedFramework,
      }));

      // ✅ Step 1: Extract user-allowed department IDs
      const allowedSchemeIds =
        userData?.userRelationships?.[0]?.schemeIds || [];

      // ✅ Step 2: Apply filtering if user has department restrictions
      const filteredSchemes =
        allowedSchemeIds.length > 0
          ? res.filter((scheme) => allowedSchemeIds.includes(scheme.id))
          : res;
      setSchemes(filteredSchemes);

      // ✅ Step 3: Auto-select if there’s only one allowed department
      if (filteredSchemes.length === 1) {
        const onlyScheme = filteredSchemes;
        setSelectedSchemes(onlyScheme);
      }
    } catch (err) {
      console.error("Error fetching schemes:", err);
      setSchemes([]);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    const selectedMinistryIds =
      selectedMinistries?.map((item) => item?.id) || [];
    setSelectedDepartments([]);

    // Fetch departments for selected ministries
    fetchDepartments(selectedMinistryIds);
  }, [selectedMinistries]);

  useEffect(() => {
    const selectedDepartmentIds =
      selectedDepartments?.map((item) => item?.id) || [];
    setSelectedSchemes([]);

    // Fetch departments for selected ministries
    fetchSchemes(selectedDepartmentIds);
  }, [selectedDepartments]);

  const fetchOutputOutcomes = async ({
    page = paginationModel.page,
    pageSize = paginationModel.pageSize,
    isReset = false,
  } = {}) => {
    setLoading(true);

    // 💥 SAFE & CORRECT ABORT
    if (
      inFlightRef.current &&
      abortRef.current &&
      !abortRef.current.signal.aborted
    ) {
      abortRef.current.abort();
    }

    abortRef.current = new AbortController();
    const signal = abortRef.current.signal;
    inFlightRef.current = true;
    const apiPage = page + 1;
    const selectedMinistryIds = isReset
      ? userMinistryIds
      : selectedMinistries?.map((item) => item?.id);

    const selectedDepartmentIds = isReset
      ? userDepartmentIds
      : selectedDepartments?.map((item) => item?.id);

    const selectedSchemeIds = isReset
      ? userSchemeIds
      : selectedSchemes?.map((item) => item?.id);

    const isSubScheme = isReset
      ? null
      : !selectedIsSubScheme?.name
        ? null
        : selectedIsSubScheme.name.trim() === "Yes";

    const statementType = isReset
      ? null
      : selectedStatement?.name?.trim() || "";

    const payload = {
      ministryIds: selectedMinistryIds,
      departmentIds: selectedDepartmentIds,
      schemeIds: selectedSchemeIds,
      isSubScheme,
      statementType: statementType?.toLowerCase().trim(),
      page: apiPage,
      limit: pageSize,
      searchQuery: search.trim(),
      searchParams: [],
    };

    try {
      const response = await apiClient.post(
        "/api/master/get-all-output-outcomes",
        payload,
        { signal, throwIfAborted: false },
      );

      const { data: rows, total } = response?.data?.data || {};
      setTotalRows(total ?? 0);

      if (!rows?.length) {
        setOutputOutcomes([]);
        setFilteredOutputOutcomes([]);
        return;
      }

      const offset = page * pageSize;
      const withSerial = rows.map((row, index) => ({
        ...row,
        serial: offset + index + 1,
      }));

      const masterRow = getMasterExampleRow(urlModal) || {};
      const finalRows = generateRowsForColumns(
        withSerial,
        gridColumns,
        masterRow,
      );

      setOutputOutcomes(finalRows);
      setFilteredOutputOutcomes(finalRows);
    } catch (err) {
      if (axios.isCancel(err) || err.code === "ERR_CANCELED") {
        // 🔇 Silent — do not log, do not show error
        return;
      }

      console.error("Error fetching indicators:", err);
    } finally {
      inFlightRef.current = false; // 💥 finished
      setLoading(false);
    }
  };

  async function handleOutputOutcomeSubmit() {
    if (urlModal === "outputOutcome") {
      const validationErrors = validateOutputOutcomeFields(
        newRow,
        jsonData || {},
      );
      setErrors(validationErrors);

      if (Object.keys(validationErrors).length > 0) {
        dispatch(setError("Please fill required fields before submitting."));
        // ❌ Invalid → show errors, don’t submit
        return;
      }

      try {
        const cleanedJsonData = {
          ...jsonData,
          ministry: pickIdName(jsonData?.ministry),
          department: pickIdName(jsonData?.department),
          scheme: pickIdName(jsonData?.scheme),
          subScheme: pickIdName(jsonData?.subScheme),
        };

        const payload = {
          name: newRow?.name?.trim(),
          description: newRow?.description?.trim() || null,
          status: newRow?.status,
          parentScheme: newRow?.parentScheme,
          jsonData: cleanedJsonData,
          createdBy: userData?.id,
        };

        if (editId) {
          payload.id = editId;
          payload.updatedBy = userData?.id;
        }

        const response = await apiClient.post(
          `api/master/create-or-update-output-outcome`,
          payload,
        );

        const result = response?.data;

        // ✅ Handle backend validation / duplicate errors
        if (!result?.success) {
          dispatch(
            setError(result?.message || "Failed to save Output outcome"),
          );
          return;
        }

        dispatch(setSuccess(result?.message));
        setShowAccordion(false);
        setNewRow({
          status: true, // Ensure Active by default
          // other fields...
        });
        setEditId(null);
        setErrors({});
        // Refresh associated framework data
        fetchOutputOutcomes();
      } catch (error) {
        console.error("Failed to add Output outcome:", error);
        dispatch(setError("Server error while saving Output outcome"));
      }
    }
  }

  useEffect(() => {
    fetchMinistries();
    fetchOutputOutcomes();
  }, []);

  const gridColumns = React.useMemo(() => {
    return getMasterColumns(urlModal, actionsConfig);
  }, [urlModal, actionsConfig]);

  // // 🔹 Search Filter
  // useEffect(() => {
  //   const trimmedSearch = (search || "").trim().toLowerCase();
  //   if (!trimmedSearch) {
  //     setFilteredOutputOutcomes(outputOutcomes || []);
  //     return;
  //   }
  //   const filtered = (outputOutcomes || []).filter((item) =>
  //     deepSearch(item, trimmedSearch),
  //   );
  //   setFilteredOutputOutcomes(filtered);
  // }, [search, outputOutcomes]);

  // 🔹 Column Management

  const handleSearch = () => {
    fetchOutputOutcomes();
  };
  const [columns, setColumns] = useState([]);
  const [columnVisibilityModel, setColumnVisibilityModel] = useState({});

  useEffect(() => {
    setColumns(gridColumns);

    const visibilityModel = {};
    gridColumns.forEach((col) => {
      visibilityModel[col.field] = true;
    });

    setColumnVisibilityModel(visibilityModel);
  }, [gridColumns]);

  const modalState = {
    newRow,
    isViewing,
    errors,
    handleNewChange,
    handleSwitchChange,
    ministryNames,
    jsonData: newRow.jsonData,
    initialUploadDocuments: newRow?.jsonData?.supportingDocuments,
    uploadMultipleFiles,
    handleJsonDataChange,
  };

  return (
    <Box>
      <Card
        elevation={3}
        sx={{
          p: 3,
          mb: 4,
          borderRadius: 3,
        }}
      >
        <MainFormHeader title="Filter Statements by Ministries and Departments" />
        <Divider sx={{ my: 2 }} />

        <Grid container spacing={2} alignItems="center">
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="ministries"
              multiple
              selectAll
              label="Choose Ministries"
              options={ministryNames}
              value={selectedMinistries ?? []}
              fullWidth
              onChange={(event, newValue) =>
                setSelectedMinistries(newValue || [])
              }
            />
          </Grid>
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="departments"
              multiple
              selectAll
              label="Choose Departments"
              options={departments}
              value={selectedDepartments ?? []}
              fullWidth
              onChange={(event, newValue) =>
                setSelectedDepartments(newValue || [])
              }
            />
          </Grid>
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="schemes"
              multiple
              selectAll
              label="Choose Schemes"
              options={schemes}
              value={selectedSchemes ?? []}
              fullWidth
              onChange={(event, newValue) => setSelectedSchemes(newValue || [])}
            />
          </Grid>
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="isSubScheme"
              multiple={false}
              selectAll={false}
              label="Choose Is Sub Scheme"
              options={isSubSchemes}
              value={selectedIsSubScheme ?? null}
              fullWidth
              onChange={(event, newValue) =>
                setSelectedIsSubScheme(newValue || null)
              }
            />
          </Grid>
          <Grid size={{ xs: 12, md: 6 }}>
            <CustomAutoCompleteWithoutFormik
              name="statementType"
              label="Choose Statement Type"
              selectAll={false}
              multiple={false}
              options={statementTypes}
              value={selectedStatement ?? {}}
              fullWidth
              onChange={(event, newValue) =>
                setSelectedStatement(newValue || {})
              }
            />
          </Grid>

          <Grid size={{ xs: 12 }}>
            <Stack
              direction="row"
              spacing={2}
              justifyContent="center"
              sx={{ mt: 2 }}
            >
              <Button
                variant="contained"
                color="primary"
                startIcon={<SearchIcon />}
                onClick={handleSearch}
                sx={{ minWidth: 150 }}
              >
                Search
              </Button>
              <Button
                variant="outlined"
                sx={{ color: "#45154F" }}
                startIcon={<RestartAltIcon />}
                onClick={() => {
                  setSelectedMinistries([]);
                  setSelectedDepartments([]);
                  setSelectedSchemes([]);
                  setSelectedIsSubScheme(null);
                  setSelectedStatement({});
                  fetchOutputOutcomes({ isReset: true });
                }}
              >
                Reset
              </Button>
            </Stack>
          </Grid>
        </Grid>
      </Card>
      {/* Add/Edit Dialog */}
      <AddRecordDialog
        open={!isViewing ? showAccordion : false}
        onClose={() => {
          setShowAccordion(false);
          setNewRow({
            status: true, // Ensure Active by default
            // other fields...
          });
          setEditId(null);
          setErrors({});
        }}
        onSubmit={handleOutputOutcomeSubmit}
        isViewing={isViewing}
        isEditing={isEditing}
        urlModal={urlModal}
        selected={selected}
      >
        <OutputOutcome modalState={modalState} />
      </AddRecordDialog>
      {isViewing && (
        <CommonViewMasterDialog
          open={showAccordion}
          handleClose={() => {
            setShowAccordion(false);
            setNewRow({
              status: true, // Ensure Active by default
              // other fields...
            });
            setEditId(null);
            setErrors({});
          }}
          title="Output Outcome Details"
          data={{
            ...selected,
            subScheme: selected?.subScheme?.name,
            statementType: selected?.statementType
              ? selected.statementType.charAt(0).toUpperCase() +
                selected.statementType.slice(1)
              : selected?.statementType,
          }}
          exampleRow={gridColumns}
        />
      )}

      <Paper
        elevation={3}
        sx={{ p: 2, borderRadius: 3, backgroundColor: "#ffffff" }}
      >
        {/* Header */}
        <Box
          sx={{
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            mb: 2,
            mt: 2,
            flexWrap: "wrap",
            gap: 2,
          }}
        >
          {/* Left: Search + Export */}
          <Box
            sx={{
              display: "flex",
              gap: 2,
              flexDirection: { xs: "column", sm: "row" },
            }}
          >
            <Box display="flex" alignItems="center">
              <SearchIcon sx={{ mr: 1 }} />
              <TextField
                size="small"
                placeholder="Search..."
                value={search}
                disabled={loading ? true : false}
                onChange={(e) => setSearch(e.target.value)}
                error={search.trim().length > 0 && search.trim().length < 3}
                helperText={
                  search.trim().length > 0 && search.trim().length < 3
                    ? "Enter at least 3 characters to search"
                    : ""
                }
                sx={{ width: { xs: "100%", sm: "auto" } }}
              />
            </Box>
            <ExportCsvButton
              modal={urlModal}
              columns={columns}
              // rows={filteredOutputOutcomes}
              rows={filteredOutputOutcomes.map((row) => ({
                ...row,
                subScheme: row?.subScheme?.label || "",
              }))}
              columnVisibilityModel={columnVisibilityModel}
              fileName={urlModal}
            />
          </Box>

          {/* Right: Add Record Button */}
          {hasAddAccess && (
            <Button
              variant="outlined"
              onClick={() => {
                setIsEditing(false);
                setIsViewing(false);
                setShowAccordion(true);
              }}
              disabled={!selected}
              startIcon={<AddIcon />}
              sx={{ whiteSpace: "nowrap" }}
            >
              Add Record in{" "}
              {`${urlModal
                ?.replace(/([a-z])([A-Z])/g, "$1 $2")
                ?.replace(/\b\w/g, (char) => char.toUpperCase())} Master`}
            </Button>
          )}
        </Box>

        <Box
          sx={{
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            mb: 2,
            mt: 2,
            flexWrap: "wrap", // responsive wrapping
            gap: 2,
          }}
        >
          {auditParams?.auditableId && auditParams?.sectionId && (
            // <AuditDataGrid
            //   {...auditParams}
            //   auditDialogOpen={auditDialogOpen}
            //   setAuditDialogOpen={setAuditDialogOpen}
            // />
            <AuditTrailDialog
              auditDialogOpen={auditDialogOpen}
              setAuditDialogOpen={setAuditDialogOpen}
              auditableId={auditParams.auditableId}
              sectionId={auditParams.sectionId}
            />
          )}
        </Box>
        <Box
          sx={{
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            mb: 2,
          }}
        >
          <MainFormHeader title="Output Outcome List" />
          <Divider sx={{ my: 2 }} />
          <ColumnReorderManager
            gridColumns={gridColumns}
            columns={columns}
            setColumns={setColumns}
            columnVisibilityModel={columnVisibilityModel}
            setColumnVisibilityModel={setColumnVisibilityModel}
          />
        </Box>

        {/* DataGrid */}
        {loading ? (
          <Box
            display="flex"
            justifyContent="center"
            alignItems="center"
            minHeight="300px"
          >
            <CircularProgress />
          </Box>
        ) : (
          <div style={{ height: 450, width: "100%" }}>
            <DataGrid
              sortingOrder={["asc", "desc"]}
              rows={filteredOutputOutcomes}
              columns={applyCustomLogic(columns)}
              rowCount={totalRows} // 🔥 total rows from backend
              paginationMode="server" // 🔥 important
              paginationModel={paginationModel}
              onPaginationModelChange={(model) => {
                setPaginationModel(model);
                fetchOutputOutcomes({
                  page: model.page,
                  pageSize: model.pageSize,
                }); // <— pass fresh values
              }}
              pageSizeOptions={[10, 20, 30, 40, 50, 100]}
              disableSelectionOnClick
              columnVisibilityModel={columnVisibilityModel}
              onColumnVisibilityModelChange={(newModel) =>
                setColumnVisibilityModel(newModel)
              }
              localeText={{
                columnMenuSortAsc: "Sort as A to Z",
                columnMenuSortDesc: "Sort as Z to A",
              }}
            />
          </div>
        )}
      </Paper>
    </Box>
  );
};

export default OutputOutcomeMaster;
