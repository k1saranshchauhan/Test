  useEffect(() => {
    const fetchSpecificConditionAlert = async () => {
      try {
        dispatch(setLoader(true));
        const response = await apiClient.post(
          `api/alert/create-condition-alert`,
          {
            orgTypeIds: formik?.values?.specificCondition?.orgTypeIds,
            subRoleId: formik?.values?.specificCondition?.subRoleId,
            checkId: formik?.values?.specificCondition?.checkId,
          },
