import {
  Box,
  Grid,
  FormControl,
  InputLabel,
  Select,
  MenuItem,
  TextField,
  Autocomplete,
  Tooltip,
  IconButton,
  InputAdornment,
  FormLabel,
  RadioGroup,
  FormControlLabel,
  Radio,
  Paper,
  Button,
  Switch,
  Typography,
  Accordion,
  AccordionSummary,
  AccordionDetails,
} from "@mui/material";
import {
  Add as AddIcon,
  ArrowUpward as ArrowUpwardIcon,
  ArrowDownward as ArrowDownwardIcon,
  ExpandMore as ExpandMoreIcon,
} from "@mui/icons-material";
import DeleteOutlinedIcon from "@mui/icons-material/DeleteOutlined";
import DescriptionIcon from "@mui/icons-material/Description";
import apiClient from "@/utils/apiClient";
import TargetInputs from "./TargetInputs";
import { getTargetLabels } from "./utils/helpers";
import { useMediaQuery } from "@mui/material";
import { useEffect } from "react";
import { useDispatch, useSelector } from "react-redux";
import { startLoader, stopLoader } from "@/store/slices/errorSlice";

export default function IndicatorForm({
  indicator,
  moto,
  sectionIndex,
  indicatorIndex,
  section,
  currentType,
  isReadOnly,
  type,
  isPostBudget,
  dummyIndicator,
  dummyMeasurementTypes,
  dummyUnits,
  dummyScales,
  dummyMeasurementArea,
  dummyIndicatorRise,
  dummyPeriod,
  dummyCategoty,
  dummySdg,
  dummyFrequencies,
  fieldErrors,
  inputRefs,
  handleIndicatorChange,
  handleChange,
  handleDialogOpen,
  handleAddIndicator,
  handleRemoveIndicator,
  handleMoveUp,
  handleMoveDown,
  hoveredCancelIdx,
  setHoveredCancelIdx,
  totals,
  dummyDistrict,
  dummyStates,
  onOpenFrequencyModal,
  initialTargetsMap,
  buildTargetsByMeasurementArea,
  computeTotals,
}) {
  const dispatch = useDispatch();
  const isSmall = useMediaQuery("(max-width:900px)");
  const labels = getTargetLabels(indicator.frequency);
  const rows =
    indicator.frequency === 1
      ? [labels.slice(0, 6), labels.slice(6, 12)]
      : [labels];

  const totalsForIndicator =
    type === "addFrequency" || isPostBudget === true
      ? computeTotals([indicator], indicator.measurementArea)
      : {};

  const selectedIndicatorName =
    dummyIndicator?.find((i) => i.id === indicator.indicator)?.name ||
    "Select Indicator";

  const primaryColor = "#45154F";
  const secondaryColor = "#F5F5F5";
  const borderColor = "#E0E0E0";
  const errorColor = "#D32F2F";

  useEffect(() => {
    if (moto !== "edit") return;
    if (!indicator?.indicator) return;

    const fetchIndicatorDetails = async () => {
      try {
        const res = await apiClient.post("/api/oomf/master/indicator/details", {
          indicatorId: indicator.indicator,
        });

        const indicatorDetail = res?.data?.data?.jsonData;

        handleIndicatorChange(sectionIndex, indicatorIndex, "options", {
          measurementTypes: [indicatorDetail?.measurementType],
          units: [indicatorDetail?.unit],
          scales: [indicatorDetail?.scale],
          measurementAreas: [indicatorDetail?.measurementArea],
          indicatorRises: [indicatorDetail?.indicatorRise],
          sdg: [indicatorDetail?.sdg],
          periods: [indicatorDetail?.period],
          categories: [indicatorDetail?.category],
        });

        handleIndicatorChange(
          sectionIndex,
          indicatorIndex,
          "measurementType",
          indicatorDetail?.measurementType?.id,
        );
        handleIndicatorChange(
          sectionIndex,
          indicatorIndex,
          "unit",
          indicatorDetail?.unit?.id,
        );
        handleIndicatorChange(
          sectionIndex,
          indicatorIndex,
          "scale",
          indicatorDetail?.scale?.id,
        );
        handleIndicatorChange(
          sectionIndex,
          indicatorIndex,
          "measurementArea",
          indicatorDetail?.measurementArea?.id,
        );
        handleIndicatorChange(
          sectionIndex,
          indicatorIndex,
          "indicatorRise",
          indicatorDetail?.indicatorRise?.id,
        );
        handleIndicatorChange(
          sectionIndex,
          indicatorIndex,
          "sdg",
          indicatorDetail?.sdg?.id,
        );
        handleIndicatorChange(
          sectionIndex,
          indicatorIndex,
          "period",
          indicatorDetail?.period?.id,
        );
        handleIndicatorChange(
          sectionIndex,
          indicatorIndex,
          "applicableCategory",
          indicatorDetail?.category?.id,
        );
      } catch (err) {
        console.error("Error fetching indicator details:", err);
      }
    };

    fetchIndicatorDetails();
  }, [indicator?.indicator]);

  return (
    <Accordion
      key={indicatorIndex}
      defaultExpanded={true}
      sx={{
        mt: 4,
        py: 4,
        borderRadius: 2,
        border:
          hoveredCancelIdx?.iIdx === indicatorIndex &&
          hoveredCancelIdx?.sIdx === sectionIndex
            ? `2px solid ${errorColor}`
            : `1px solid ${borderColor}`,
        transition: "border 0.3s ease-in-out, box-shadow 0.3s ease-in-out",
        boxShadow:
          hoveredCancelIdx?.iIdx === indicatorIndex &&
          hoveredCancelIdx?.sIdx === sectionIndex
            ? `0 4px 12px rgba(211, 47, 47, 0.15)`
            : `0 2px 8px rgba(0, 0, 0, 0.08)`,
        position: "relative",
        backgroundColor: "#fff",
        "&:before": {
          display: "none",
        },
      }}
      elevation={2}
      variant="outlined"
    >
      <AccordionSummary
        expandIcon={!isReadOnly ? <ExpandMoreIcon /> : null}
        sx={{
          px: 3,
          minHeight: 56,
          "& .MuiAccordionSummary-content": {
            my: 0,
          },
        }}
      >
        <Box
          sx={{
            width: "100%",
            display: "flex",
            justifyContent: "space-between",
            alignItems: "center",
            pb: 2,
            borderBottom: `1px solid ${borderColor}`,
          }}
        >
          <Box
            sx={{
              display: isSmall ? "none" : "flex",
              alignItems: "center",
              gap: 2,
            }}
          >
            <Box
              sx={{
                background: primaryColor,
                padding: "8px 24px",
                borderRadius: "24px",
                minWidth: "fit-content",
              }}
            >
              <FormLabel
                sx={{
                  color: "#fff",
                  fontSize: "0.875rem",
                  fontWeight: 600,
                }}
              >
                Indicator {indicatorIndex + 1}
              </FormLabel>
            </Box>

            <Tooltip title={selectedIndicatorName} placement="top">
              <Typography
                variant="h6"
                sx={{
                  color: primaryColor,
                  fontWeight: 600,
                  maxWidth: {
                    xs: "14rem",
                    sm: "20rem",
                    md: "40rem",
                  },
                  whiteSpace: "nowrap",
                  overflow: "hidden",
                  textOverflow: "ellipsis",
                  display: "block",
                  cursor: "pointer",
                }}
              >
                {selectedIndicatorName}
              </Typography>
            </Tooltip>
          </Box>

          {!isReadOnly && (
            <Box
              sx={{
                display: "flex",
                justifyContent: "space-between",
                alignItems: "center",
                width: "auto",
              }}
            >
              <Box
                sx={{
                  display: "flex",
                  flexDirection: isSmall ? "column" : "row",
                  gap: 2,
                  alignItems: "center",
                }}
              >
                <Button
                  variant="contained"
                  startIcon={!isSmall && <AddIcon />}
                  onClick={(e) => {
                    e.stopPropagation();
                    handleAddIndicator(sectionIndex);
                  }}
                  size="small"
                  sx={{
                    backgroundColor: primaryColor,
                    "&:hover": { backgroundColor: `${primaryColor}E6` },
                  }}
                >
                  <Typography sx={{ fontSize: isSmall ? "8px" : "14px" }}>
                    Add Indicator
                  </Typography>
                </Button>
                <Box sx={{ display: "flex", alignItems: "center", gap: 1 }}>
                  {/* <Typography
                    sx={{
                      fontWeight: 500,
                      color: "text.secondary",
                      fontSize: isSmall ? "12px" : "16px",
                      cursor: "default",
                    }}
                    onClick={(e) => e.stopPropagation()} 
                  >
                    Active
                  </Typography> */}
                  {/* <Switch
                    onClick={(e)=>{e.stopPropagation();}}
                    checked={indicator.active}
                    onChange={(e) =>
                      handleIndicatorChange(
                        sectionIndex,
                        indicatorIndex,
                        "active",
                        e.target.checked
                      )
                    }
                    size="small"
                    sx={{
                      "& .MuiSwitch-switchBase.Mui-checked": {
                        color: primaryColor,
                      },
                      "& .MuiSwitch-track": { backgroundColor: primaryColor },
                    }}
                  /> */}
                  {section.indicators.length > 1 && (
                    <>
                      <Typography
                        sx={{
                          fontWeight: 500,
                          color: "text.secondary",
                          fontSize: isSmall ? "12px" : "16px",
                          cursor: "default",
                        }}
                        onClick={(e) => e.stopPropagation()}
                      >
                        Active
                      </Typography>

                      <Tooltip
                        title={!section.active ? "Activate section first" : ""}
                      >
                        <span>
                          <Switch
                            disabled={!section.active}
                            onClick={(e) => e.stopPropagation()}
                            checked={indicator.active}
                            onChange={(e) =>
                              handleIndicatorChange(
                                sectionIndex,
                                indicatorIndex,
                                "active",
                                e.target.checked,
                              )
                            }
                            size="small"
                            sx={{
                              "& .MuiSwitch-switchBase.Mui-checked": {
                                color: primaryColor,
                              },
                              "& .MuiSwitch-track": {
                                backgroundColor: primaryColor,
                              },
                            }}
                          />
                        </span>
                      </Tooltip>
                    </>
                  )}
                </Box>
              </Box>

              {section?.indicators?.length > 1 && (
                <Box sx={{ display: "flex", gap: 1 }}>
                  <Tooltip title="Move Up">
                    <IconButton
                      size="small"
                      onClick={(e) => {
                        e.stopPropagation();
                        handleMoveUp(sectionIndex, indicatorIndex);
                      }}
                      disabled={indicatorIndex === 0}
                      sx={{
                        color:
                          indicatorIndex === 0
                            ? "action.disabled"
                            : primaryColor,
                        "&:hover": {
                          backgroundColor:
                            indicatorIndex === 0
                              ? "transparent"
                              : `${primaryColor}10`,
                        },
                      }}
                    >
                      <ArrowUpwardIcon fontSize="small" />
                    </IconButton>
                  </Tooltip>
                  <Tooltip title="Move Down">
                    <IconButton
                      size="small"
                      onClick={(e) => {
                        e.stopPropagation();
                        handleMoveDown(sectionIndex, indicatorIndex);
                      }}
                      disabled={
                        indicatorIndex === section.indicators.length - 1
                      }
                      sx={{
                        color:
                          indicatorIndex === section.indicators.length - 1
                            ? "action.disabled"
                            : primaryColor,
                        "&:hover": {
                          backgroundColor:
                            indicatorIndex === section.indicators.length - 1
                              ? "transparent"
                              : `${primaryColor}10`,
                        },
                      }}
                    >
                      <ArrowDownwardIcon fontSize="small" />
                    </IconButton>
                  </Tooltip>
                  <Tooltip title="Delete Indicator">
                    <IconButton
                      color="error"
                      size="small"
                      onClick={(e) => {
                        e.stopPropagation();
                        setHoveredCancelIdx(null);
                        handleRemoveIndicator(sectionIndex, indicatorIndex);
                      }}
                      onMouseEnter={() =>
                        setHoveredCancelIdx({
                          sIdx: sectionIndex,
                          iIdx: indicatorIndex,
                        })
                      }
                      onMouseLeave={() => setHoveredCancelIdx(null)}
                      sx={{
                        bgcolor: "error.lighter",
                        "&:hover": {
                          bgcolor: "error.main",
                          color: "#fff",
                        },
                      }}
                    >
                      <DeleteOutlinedIcon fontSize="small" />
                    </IconButton>
                  </Tooltip>
                </Box>
              )}
            </Box>
          )}
        </Box>
      </AccordionSummary>

      <AccordionDetails sx={{ px: 3, py: 0, mt: 4 }}>
        <Grid container spacing={3} alignItems="flex-start">
          <Grid size={{ md: 4, sm: 6, xs: 12 }}>
            <Autocomplete
              disableClearable
              fullWidth
              options={(dummyIndicator || []).filter(
                (option) =>
                  !section.indicators
                    .filter((_, index) => index !== indicatorIndex)
                    .some((ind) => ind.indicator === option.id),
              )}
              getOptionLabel={(option) => option?.name || ""}
              isOptionEqualToValue={(option, value) => option?.id === value?.id}
              value={
                dummyIndicator?.length
                  ? dummyIndicator.find((i) => i.id === indicator.indicator) ||
                    null
                  : null
              }
              disabled={!section?.name || isReadOnly}
              onChange={async (event, newValue) => {
                if (newValue) {
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "indicator",
                    newValue.id,
                  );
                  // Reset footnotes
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "footNoteIndicatorName",
                    "",
                  );
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "footNoteIndicatorTarget",
                    "",
                  );
                  // Reset Target Value
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "preTarget",
                    "",
                  );
                  // Reset Target dropdown
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "targetAmenable",
                    "",
                  );
                  dispatch(startLoader());
                  try {
                    const res = await apiClient.post(
                      `/api/oomf/master/indicator/details`,
                      { indicatorId: newValue.id },
                    );
                    const indicatorDetail = res?.data?.data?.jsonData;
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "options",
                      {
                        measurementTypes: [indicatorDetail?.measurementType],
                        units: [indicatorDetail?.unit],
                        scales: [indicatorDetail?.scale],
                        measurementAreas: [indicatorDetail?.measurementArea],
                        indicatorRises: [indicatorDetail?.indicatorRise],
                        sdg: [indicatorDetail?.sdg],
                        periods: [indicatorDetail?.period],
                        categories: [indicatorDetail?.category],
                      },
                    );
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "measurementType",
                      indicatorDetail?.measurementType?.id,
                    );
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "unit",
                      indicatorDetail?.unit?.id,
                    );
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "scale",
                      indicatorDetail?.scale?.id,
                    );
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "measurementArea",
                      indicatorDetail?.measurementArea?.id,
                    );
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "indicatorRise",
                      indicatorDetail?.indicatorRise?.id,
                    );
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "sdg",
                      indicatorDetail?.sdg?.id,
                    );
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "period",
                      indicatorDetail?.period?.id,
                    );
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "applicableCategory",
                      indicatorDetail?.category?.id,
                    );
                  } catch (error) {
                    console.error("Error fetching indicator details:", error);
                  } finally {
                    dispatch(stopLoader());
                  }
                } else {
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "indicator",
                    null,
                  );
                  // Reset footnotes if indicator is cleared
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "footNoteIndicatorName",
                    "",
                  );
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "footNoteIndicatorTarget",
                    "",
                  );
                  // Reset Target Value
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "preTarget",
                    "",
                  );
                  // Reset Target dropdown
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "targetAmenable",
                    "",
                  );
                }
              }}
              renderInput={(params) => (
                <Tooltip
                  title={
                    !section?.name
                      ? `Please select an ${currentType} first to enable Indicator`
                      : ""
                  }
                  arrow
                >
                  <TextField
                    {...params}
                    label={
                      <>
                        Indicator{" "}
                        <span
                          style={{
                            color: "red",
                            display: moto === "draft" ? "none" : "inline",
                          }}
                        >
                          *
                        </span>
                      </>
                    }
                    sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
                    InputProps={{
                      ...params.InputProps,
                      endAdornment: (
                        <>
                          <Tooltip
                            title={
                              isReadOnly
                                ? "View Footnote"
                                : "Add a footnote for this Indicator"
                            }
                          >
                            <IconButton
                              onClick={() =>
                                handleDialogOpen({
                                  field: "indicatorName",
                                  sectionIndex,
                                  indicatorIndex,
                                  defaultValue:
                                    section.indicators[indicatorIndex]
                                      ?.footNoteIndicatorName || "",
                                })
                              }
                            >
                              <DescriptionIcon sx={{ color: primaryColor }} />
                            </IconButton>
                          </Tooltip>
                          {params.InputProps.endAdornment}
                        </>
                      ),
                    }}
                  />
                </Tooltip>
              )}
            />
          </Grid>

          <Grid size={{ md: 4, sm: 6, xs: 12 }}>
            <FormControl fullWidth disabled>
              <InputLabel
                id={`measurement-label-${sectionIndex}-${indicatorIndex}`}
              >
                Measurement Type
              </InputLabel>
              <Select
                labelId={`measurement-label-${sectionIndex}-${indicatorIndex}`}
                label="Measurement Type"
                value={indicator.measurementType ?? ""}
                onChange={(e) =>
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "measurementType",
                    e.target.value,
                  )
                }
                IconComponent={() => null}
                sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
              >
                {dummyMeasurementTypes.map((mt) => (
                  <MenuItem key={mt.id} value={mt.id}>
                    {mt.name}
                  </MenuItem>
                ))}
              </Select>
            </FormControl>
          </Grid>

          <Grid size={{ md: 4, sm: 12, xs: 12 }}>
            <FormControl fullWidth disabled>
              <InputLabel id={`unit-label-${sectionIndex}-${indicatorIndex}`}>
                Unit
              </InputLabel>
              <Select
                labelId={`unit-label-${sectionIndex}-${indicatorIndex}`}
                label="Unit"
                value={indicator.unit ?? ""}
                onChange={(e) =>
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "unit",
                    e.target.value,
                  )
                }
                IconComponent={() => null}
                sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
              >
                {dummyUnits.map((u) => (
                  <MenuItem key={u.id} value={u.id}>
                    {u.name}
                  </MenuItem>
                ))}
              </Select>
            </FormControl>
          </Grid>

          <Grid
            size={{ md: 4, sm: 12, xs: 12 }}
            sx={{ display: indicator.measurementType === 1 && "none" }}
          >
            <FormControl fullWidth disabled>
              <InputLabel id={`scale-label-${sectionIndex}-${indicatorIndex}`}>
                Scale
              </InputLabel>
              <Select
                labelId={`scale-label-${sectionIndex}-${indicatorIndex}`}
                label="Scale"
                value={indicator.scale ?? ""}
                onChange={(e) =>
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "scale",
                    e.target.value,
                  )
                }
                IconComponent={() => null}
                sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
              >
                {dummyScales
                  ?.filter((u) => indicator.measurementType === 1 || u.id !== 8)
                  .map((u) => (
                    <MenuItem key={u.id} value={u.id}>
                      {u.name}
                    </MenuItem>
                  ))}
              </Select>
            </FormControl>
          </Grid>

          <Grid size={{ md: 4, sm: 12, xs: 12 }}>
            <FormControl fullWidth disabled>
              <InputLabel
                id={`measurementArea-label-${sectionIndex}-${indicatorIndex}`}
              >
                Measurement Area
              </InputLabel>
              <Select
                labelId={`measurementArea-label-${sectionIndex}-${indicatorIndex}`}
                label="Measurement Area"
                value={indicator.measurementArea ?? ""}
                onChange={(e) =>
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "measurementArea",
                    e.target.value,
                  )
                }
                IconComponent={() => null}
                sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
              >
                {dummyMeasurementArea
                  ?.filter((u) => indicator.measurementType === 1 || u.id !== 8)
                  .map((u) => (
                    <MenuItem key={u.id} value={u.id}>
                      {u.name}
                    </MenuItem>
                  ))}
              </Select>
            </FormControl>
          </Grid>

          <Grid size={{ md: 4, sm: 12, xs: 12 }}>
            <FormControl fullWidth disabled>
              <InputLabel
                id={`indicatorRise-label-${sectionIndex}-${indicatorIndex}`}
              >
                Indicator Rise
              </InputLabel>
              <Select
                labelId={`indicatorRise-label-${sectionIndex}-${indicatorIndex}`}
                label="Indicator Rise"
                value={indicator.indicatorRise ?? ""}
                onChange={(e) =>
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "indicatorRise",
                    e.target.value,
                  )
                }
                IconComponent={() => null}
                sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
              >
                {dummyIndicatorRise
                  ?.filter((u) => indicator.measurementType === 1 || u.id !== 8)
                  .map((u) => (
                    <MenuItem key={u.id} value={u.id}>
                      {u.name}
                    </MenuItem>
                  ))}
              </Select>
            </FormControl>
          </Grid>

          <Grid size={{ md: 4, sm: 12, xs: 12 }}>
            <FormControl fullWidth disabled>
              <InputLabel id={`period-label-${sectionIndex}-${indicatorIndex}`}>
                Period
              </InputLabel>
              <Select
                labelId={`period-label-${sectionIndex}-${indicatorIndex}`}
                label="Period"
                value={indicator.period ?? ""}
                onChange={(e) =>
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "period",
                    e.target.value,
                  )
                }
                IconComponent={() => null}
                sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
              >
                {dummyPeriod.map((mt) => (
                  <MenuItem key={mt.id} value={mt.id}>
                    {mt.name}
                  </MenuItem>
                ))}
              </Select>
            </FormControl>
          </Grid>

          {indicator.applicableCategory && (
            <Grid size={{ md: 4, sm: 12, xs: 12 }}>
              <FormControl fullWidth disabled>
                <InputLabel
                  id={`applicable-category-${sectionIndex}-${indicatorIndex}`}
                >
                  Applicable Category
                </InputLabel>
                <Select
                  labelId={`applicable-category-${sectionIndex}-${indicatorIndex}`}
                  label="Applicable Category"
                  value={indicator.applicableCategory ?? ""}
                  onChange={(e) =>
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "applicableCategory",
                      e.target.value,
                    )
                  }
                  IconComponent={() => null}
                  sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
                >
                  {dummyCategoty.map((mt) => (
                    <MenuItem key={mt.id} value={mt.id}>
                      {mt.name}
                    </MenuItem>
                  ))}
                </Select>
              </FormControl>
            </Grid>
          )}

          {indicator.sdg && (
            <Grid size={{ md: 4, sm: 12, xs: 12 }}>
              <FormControl fullWidth disabled>
                <InputLabel id={`sdg-label-${sectionIndex}-${indicatorIndex}`}>
                  SDG
                </InputLabel>
                <Select
                  labelId={`sdg-label-${sectionIndex}-${indicatorIndex}`}
                  label="SDG"
                  value={indicator.sdg ?? ""}
                  onChange={(e) =>
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "sdg",
                      e.target.value,
                    )
                  }
                  IconComponent={() => null}
                  sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
                >
                  {dummySdg.map((mt) => (
                    <MenuItem key={mt.id} value={mt.id}>
                      {mt.name}
                    </MenuItem>
                  ))}
                </Select>
              </FormControl>
            </Grid>
          )}

          <Grid
            size={{ md: 4, sm: 12, xs: 12 }}
            sx={{
              display:
                indicator?.measurementType === 1 ||
                (indicator.measurementType === 2 && indicator?.unit === 8)
                  ? "block"
                  : "none",
            }}
          >
            <FormControl fullWidth disabled={isReadOnly}>
              <TextField
                disabled={isReadOnly}
                select
                label={
                  <>
                    Target
                    <span
                      style={{
                        color: "red",
                        display: moto === "draft" ? "none" : "inline",
                      }}
                    >
                      *
                    </span>
                  </>
                }
                value={indicator.targetAmenable ?? ""}
                onChange={(e) =>
                  handleIndicatorChange(
                    sectionIndex,
                    indicatorIndex,
                    "targetAmenable",
                    e.target.value,
                    { labels: getTargetLabels(indicator.frequency) },
                  )
                }
                sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
                InputProps={{
                  endAdornment: (
                    <InputAdornment position="end">
                      <Tooltip
                        title={
                          isReadOnly
                            ? "View Footnote"
                            : "Add a footnote for this Target"
                        }
                      >
                        <IconButton
                          onClick={() =>
                            handleDialogOpen({
                              field: "indicatorTarget",
                              sectionIndex,
                              indicatorIndex,
                              defaultValue:
                                section.indicators[indicatorIndex]
                                  ?.footNoteIndicatorTarget || "",
                            })
                          }
                        >
                          <DescriptionIcon
                            sx={{ mr: 2, color: primaryColor }}
                          />
                        </IconButton>
                      </Tooltip>
                    </InputAdornment>
                  ),
                }}
              >
                <MenuItem key={1} value="Target not amenable">
                  Target not amenable
                </MenuItem>

                {!(
                  indicator?.measurementType === 2 && indicator?.unit === 8
                ) && [
                  <MenuItem key={2} value="Yes">
                    Yes
                  </MenuItem>,
                  <MenuItem key={3} value="No">
                    No
                  </MenuItem>,
                ]}
              </TextField>
            </FormControl>
          </Grid>

          <Grid
            size={{ md: 4, sm: 12, xs: 12 }}
            sx={{
              display:
                indicator.measurementType === 1 ||
                (indicator?.measurementType === 2 && indicator?.unit === 8)
                  ? "none"
                  : "",
            }}
          >
            <TextField
              disabled={isReadOnly}
              onWheel={(e)=>e.target.blur()}
              inputRef={(el) => {
                if (el)
                  inputRefs.current[
                    `${sectionIndex}_${indicatorIndex}_preTarget`
                  ] = el;
              }}
              fullWidth
              label={
                <>
                  Target Value{" "}
                  <span
                    style={{
                      color: "red",
                      display: moto === "draft" ? "none" : "inline",
                    }}
                  >
                    *
                  </span>
                </>
              }
              type={
                indicator?.unit === 10 || indicator?.unit === 9
                  ? "text"
                  : "number"
              }
              value={indicator.preTarget ?? ""}
              onChange={(e) =>
                handleChange(
                  e,
                  sectionIndex,
                  indicatorIndex,
                  indicator?.unit,
                  "preTarget",
                )
              }
              error={
                !!fieldErrors[`${sectionIndex}_${indicatorIndex}_preTarget`]
              }
              helperText={
                fieldErrors[`${sectionIndex}_${indicatorIndex}_preTarget`]
              }
              sx={{ "& .MuiOutlinedInput-root": { borderRadius: 2 } }}
              InputProps={{
                endAdornment: (
                  <>
                    <InputAdornment position="end">
                      <Tooltip
                        title={
                          isReadOnly
                            ? "View Footnote"
                            : "Add a footnote for this Target"
                        }
                      >
                        <IconButton
                          onClick={() =>
                            handleDialogOpen({
                              field: "indicatorTarget",
                              sectionIndex,
                              indicatorIndex,
                              defaultValue:
                                section.indicators[indicatorIndex]
                                  ?.footNoteIndicatorTarget || "",
                            })
                          }
                        >
                          <DescriptionIcon sx={{ color: primaryColor }} />
                        </IconButton>
                      </Tooltip>
                    </InputAdornment>
                  </>
                ),
              }}
            />
          </Grid>
        </Grid>

        {(type === "addFrequency" || isPostBudget === true) && (
          <Box sx={{ mt: 4, pt: 3, borderTop: `1px solid ${borderColor}` }}>
            <Grid size={{ xs: 12, md: 12 }}>
              <FormControl
                component="fieldset"
                disabled={isReadOnly && type !== "addFrequency"}
                sx={{ mb: 3 }}
              >
                <FormLabel
                  component="legend"
                  sx={{ fontWeight: 600, color: "text.primary" }}
                >
                  Frequency
                </FormLabel>
                <RadioGroup
                  row
                  value={indicator?.frequency}
                  onChange={(e) => {
                    const newFrequency = parseInt(e.target.value, 10);

                    // 1️⃣ Update frequency
                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "frequency",
                      newFrequency,
                    );

                    // 2️⃣ Reset targets based on measurement area
                    let resetTargets;
                    switch (indicator?.measurementArea) {
                      case 2: // National
                        resetTargets = {};
                        break;
                      case 1: // District
                      case 3: // State
                      default:
                        resetTargets = [];
                    }

                    handleIndicatorChange(
                      sectionIndex,
                      indicatorIndex,
                      "targetsReset",
                      resetTargets,
                    );
                  }}
                >
                  {dummyFrequencies.map((f) => (
                    <FormControlLabel
                      key={f.id}
                      value={f.id}
                      control={<Radio />}
                      label={f.name}
                      sx={{ ml: 2 }}
                    />
                  ))}
                </RadioGroup>
              </FormControl>
              <TargetInputs
                rows={rows}
                indicator={indicator}
                currentType={currentType}
                sectionIndex={sectionIndex}
                indicatorIndex={indicatorIndex}
                isReadOnly={isReadOnly}
                type={type}
                fieldErrors={fieldErrors}
                inputRefs={inputRefs}
                handleChange={handleChange}
                totals={totalsForIndicator}
                dummyDistrict={dummyDistrict}
                dummyStates={dummyStates}
                onOpenFrequencyModal={onOpenFrequencyModal}
              />
            </Grid>
          </Box>
        )}
      </AccordionDetails>
    </Accordion>
  );
}
