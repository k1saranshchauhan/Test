    const orgTypeIds = orgTypes?.map((item) => item?.id) || [];

    const payload = {
      type: alertType?.label === "Email Alert" ? "EMAIL" : "STRIP",
      targetModule: JSON.stringify(targetModule),
      startDate: startDate,
      endDate: endDate,
      createdBy: userData?.id,
      orgTypeIds,
      moduleId: mappedPrivileges?.sectionId,
      status: isCancelled ? 0 : 1,
    };

