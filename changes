import React from "react";
import {
  Box,
  Typography,
  Paper,
  TableContainer,
  Table,
  TableHead,
  TableRow,
  TableCell,
  TableBody,
} from "@mui/material";

const ProgressTable = ({ data }) => {
  if (!data?.data) return null;

  const reportData = data.data;
  const years = Object.keys(reportData).sort(); // e.g., ["2018"]

  // Helper to get all unique indicators across all years for a scheme
  // This ensures that if an indicator exists in 2018 but not 2019, the row still aligns
  const getUniqueRows = (schemeName) => {
    const rowsMap = {};
    years.forEach((year) => {
      const scheme = reportData[year].find((s) => s.schemeId.name === schemeName);
      if (scheme) {
        scheme.indicatorData.forEach((typeGroup) => {
          typeGroup.sections.forEach((section) => {
            section.indicators.forEach((ind) => {
              const key = `${typeGroup.indicatorType.name}-${section.name}-${ind.indicator.name}`;
              if (!rowsMap[key]) {
                rowsMap[key] = {
                  type: typeGroup.indicatorType.name,
                  statement: section.name,
                  indicatorName: ind.indicator.name,
                  unit: ind.unit?.name || "nos.",
                  period: ind.period?.name || "Duration",
                  yearlyData: {}, // Map to store { "2018": { target, progress } }
                };
              }
              rowsMap[key].yearlyData[year] = {
                target: ind.target,
                progress: ind.progress,
              };
            });
          });
        });
      }
    });
    return Object.values(rowsMap);
  };

  // Assuming we process one main scheme at a time or the first available scheme name
  const firstYear = years[0];
  const schemeNames = reportData[firstYear].map((s) => s.schemeId.name);

  return (
    <Box sx={{ p: 3 }}>
      {schemeNames.map((schemeName) => {
        const rows = getUniqueRows(schemeName);

        return (
          <Paper key={schemeName} sx={{ mb: 6, overflowX: "auto" }}>
            <TableContainer>
              <Table size="small" sx={{ minWidth: 1000, border: "1px solid #ccc" }}>
                <TableHead>
                  {/* First Header Row: Year Names */}
                  <TableRow sx={{ backgroundColor: "#f5f5f5" }}>
                    <TableCell rowSpan={2} sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>Indicator Type</TableCell>
                    <TableCell rowSpan={2} sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>Indicator Statement</TableCell>
                    <TableCell rowSpan={2} sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>Indicator</TableCell>
                    <TableCell rowSpan={2} sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>Unit</TableCell>
                    <TableCell rowSpan={2} sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>Period Attribute</TableCell>
                    
                    {years.map((year) => (
                      <TableCell key={year} colSpan={2} align="center" sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>
                        {year}
                        {/* Note: Financial values like BE/AE can be extracted here if present in JSON */}
                      </TableCell>
                    ))}
                    <TableCell colSpan={2} align="center" sx={{ fontWeight: "bold", border: "1px solid #ccc", backgroundColor: "#e0e0e0" }}>
                      Cumulative
                    </TableCell>
                  </TableRow>

                  {/* Second Header Row: Target/Progress labels */}
                  <TableRow sx={{ backgroundColor: "#f5f5f5" }}>
                    {years.map((year) => (
                      <React.Fragment key={year}>
                        <TableCell align="center" sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>Target</TableCell>
                        <TableCell align="center" sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>Progress</TableCell>
                      </React.Fragment>
                    ))}
                    <TableCell align="center" sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>Target</TableCell>
                    <TableCell align="center" sx={{ fontWeight: "bold", border: "1px solid #ccc" }}>Progress</TableCell>
                  </TableRow>
                </TableHead>

                <TableBody>
                  {rows.map((row, idx) => {
                    let cumulativeTarget = 0;
                    let cumulativeProgress = 0;

                    return (
                      <TableRow key={idx}>
                        <TableCell sx={{ border: "1px solid #eee" }}>{row.type}</TableCell>
                        <TableCell sx={{ border: "1px solid #eee" }}>{row.statement}</TableCell>
                        <TableCell sx={{ border: "1px solid #eee" }}>{row.indicatorName}</TableCell>
                        <TableCell sx={{ border: "1px solid #eee" }}>{row.unit}</TableCell>
                        <TableCell sx={{ border: "1px solid #eee" }}>{row.period}</TableCell>
                        
                        {/* Year-wise Data Cells */}
                        {years.map((year) => {
                          const yearVal = row.yearlyData[year] || { target: "N/A", progress: "N/A" };
                          if (typeof yearVal.target === 'number') cumulativeTarget += yearVal.target;
                          if (typeof yearVal.progress === 'number') cumulativeProgress += yearVal.progress;

                          return (
                            <React.Fragment key={year}>
                              <TableCell align="center" sx={{ border: "1px solid #eee" }}>{yearVal.target}</TableCell>
                              <TableCell align="center" sx={{ border: "1px solid #eee" }}>{yearVal.progress}</TableCell>
                            </React.Fragment>
                          );
                        })}

                        {/* Cumulative Cells */}
                        <TableCell align="center" sx={{ border: "1px solid #eee", backgroundColor: "#fafafa", fontWeight: "bold" }}>
                          {cumulativeTarget || "-"}
                        </TableCell>
                        <TableCell align="center" sx={{ border: "1px solid #eee", backgroundColor: "#fafafa", fontWeight: "bold" }}>
                          {cumulativeProgress || "-"}
                        </TableCell>
                      </TableRow>
                    );
                  })}
                </TableBody>
              </Table>
            </TableContainer>
          </Paper>
        );
      })}
    </Box>
  );
};

export default ProgressTable;
